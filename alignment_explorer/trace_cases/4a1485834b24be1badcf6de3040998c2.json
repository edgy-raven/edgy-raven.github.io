[0.047291,0.085146,0.089334,0.092112,0.095356,0.1034,0.095066,0.093024,0.086233,0.082291,0.071537,0.059212],"unified_progress":[0.093363,0.11983,0.10128,0.092696,0.088428,0.088364,0.080704,0.085104,0.07456,0.067611,0.059153,0.048902]},{"section":14,"text":"The symptoms described\u2014lip smacking, grimacing, tongue movements\u2014are classic for tardive dyskinesia.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.056212,0.095689,0.091419,0.089506,0.090346,0.093012,0.090652,0.092583,0.084393,0.079077,0.070324,0.066787],"unified_progress":[0.072606,0.08954,0.096736,0.094761,0.092968,0.09684,0.089008,0.088986,0.082148,0.074873,0.065462,0.056072]},{"section":15,"text":"Other possibilities?","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.035176,0.074769,0.096028,0.1015,0.10017,0.093634,0.092184,0.088633,0.086298,0.088401,0.075054,0.068152],"unified_progress":[0.040113,0.076782,0.087913,0.10279,0.1003,0.095386,0.096072,0.091296,0.086956,0.091825,0.07342,0.057145]},{"section":16,"text":"Acute dystonia can happen soon after starting meds, but he's been on it for months.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.037309,0.074196,0.083156,0.089694,0.095041,0.098917,0.09928,0.09774,0.092183,0.089617,0.079304,0.063564],"unified_progress":[0.055196,0.081784,0.086203,0.08825,0.093409,0.095817,0.094334,0.096448,0.090801,0.08816,0.074197,0.055399]},{"section":17,"text":"Tardive dyskinesia is a late-onset side effect.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034392,0.067825,0.079588,0.090731,0.098226,0.10076,0.10197,0.096925,0.089465,0.089998,0.077308,0.072823],"unified_progress":[0.043284,0.062095,0.082576,0.089182,0.094346,0.10311,0.099762,0.09804,0.093046,0.089156,0.078255,0.067145]},{"section":18,"text":"Also, tardive means \"late,\" so that's a clue.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.040782,0.072505,0.081607,0.089063,0.093908,0.095078,0.095989,0.093747,0.089682,0.08981,0.079774,0.078057],"unified_progress":[0.054557,0.064909,0.077318,0.087071,0.091255,0.094811,0.094562,0.095509,0.092084,0.091052,0.082578,0.074293]},{"section":19,"text":"The symptoms are involuntary, which matches.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.038608,0.074628,0.084123,0.08847,0.091141,0.092,0.093962,0.093424,0.09173,0.090903,0.084766,0.076244],"unified_progress":[0.04814,0.068758,0.077603,0.085462,0.090533,0.093997,0.094508,0.096166,0.094944,0.095544,0.085228,0.069119]},{"section":20,"text":"Another thought: drug-induced movement disorder.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.032998,0.069164,0.08478,0.092044,0.095881,0.094822,0.096256,0.095473,0.092617,0.092861,0.082414,0.07069],"unified_progress":[0.038394,0.068035,0.083331,0.094714,0.096567,0.09698,0.099606,0.096774,0.09352,0.092037,0.078637,0.061405]},{"section":21,"text":"But the timing and the type of movements point more to tardive dyskinesia.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.036199,0.070055,0.082319,0.088436,0.090623,0.090111,0.092091,0.091297,0.090406,0.092367,0.086413,0.089684],"unified_progress":[0.042555,0.05945,0.071653,0.082954,0.08719,0.091521,0.093631,0.094981,0.095319,0.097507,0.094044,0.089194]},{"section":22,"text":"Tardive dyskinesia is caused by long-term dopamine receptor blockade.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.038822,0.068824,0.077664,0.088773,0.096982,0.099172,0.10063,0.095913,0.089264,0.089667,0.078446,0.075841],"unified_progress":[0.049828,0.05714,0.07463,0.083973,0.091801,0.10161,0.099469,0.099847,0.095988,0.092074,0.081793,0.071848]},{"section":23,"text":"The patient's symptoms are focal, affecting the mouth and face.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.039841,0.076018,0.081069,0.085975,0.091215,0.095558,0.097383,0.095994,0.094029,0.088092,0.082668,0.072159],"unified_progress":[0.07373,0.073092,0.079406,0.084676,0.09044,0.094371,0.092353,0.094123,0.091411,0.085534,0.076819,0.064044]},{"section":24,"text":"The fact that he's in a locked unit might mean he's not as mobile, but the key factor is the antipsychotic use.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.042987,0.078895,0.082789,0.086613,0.091502,0.099749,0.095743,0.095578,0.091698,0.088893,0.079194,0.066359],"unified_progress":[0.085135,0.10975,0.095733,0.088514,0.086768,0.088343,0.083579,0.088627,0.079482,0.074413,0.065803,0.053857]},{"section":25,"text":"There's no mention of other meds that could cause this, so haloperidol is the main suspect.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.038409,0.075838,0.087842,0.092844,0.094125,0.097172,0.094081,0.092021,0.088622,0.08884,0.078842,0.071363],"unified_progress":[0.069307,0.099929,0.09425,0.096078,0.091621,0.090587,0.086572,0.086851,0.079303,0.077307,0.068942,0.059254]},{"section":26,"text":"Could it be another condition?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.025973,0.059763,0.077956,0.087919,0.096897,0.098021,0.10099,0.10243,0.099193,0.098553,0.087195,0.065115],"unified_progress":[0.037976,0.075879,0.093646,0.10797,0.10265,0.097822,0.10052,0.094935,0.088686,0.085329,0.06782,0.046765]},{"section":27,"text":"Like Huntington's or Tourette's?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.024429,0.057505,0.073031,0.083992,0.095134,0.10054,0.1045,0.10604,0.1022,0.098866,0.0878,0.065968],"unified_progress":[0.034791,0.069521,0.087253,0.097402,0.10118,0.10163,0.10306,0.10074,0.094438,0.090119,0.071186,0.048675]},{"section":28,"text":"But he's 61, which is less likely for Huntington's, and Tourette's usually starts in childhood.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027076,0.059522,0.072216,0.082004,0.091188,0.099503,0.10342,0.10521,0.10202,0.099898,0.090394,0.067557],"unified_progress":[0.05401,0.081744,0.085042,0.086356,0.092919,0.094411,0.094559,0.099016,0.093674,0.093049,0.074921,0.050301]},{"section":29,"text":"Plus, the context of antipsychotic use makes tardive dyskinesia the most likely.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.030079,0.060657,0.072272,0.08028,0.085676,0.089891,0.094121,0.095091,0.095653,0.097688,0.094737,0.10386],"unified_progress":[0.043275,0.061146,0.069766,0.077645,0.082379,0.087112,0.090245,0.092517,0.092849,0.096851,0.10036,0.10585]},{"section":30,"text":"So, putting it all together: chronic antipsychotic use leading to tardive dyskinesia with orofacial-buccolingual-lingual movements.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.042738,0.07051,0.072511,0.0782,0.083517,0.087679,0.090872,0.09154,0.09243,0.092363,0.09091,0.10673],"unified_progress":[0.054129,0.05556,0.065571,0.073556,0.079103,0.086367,0.087034,0.091869,0.094434,0.094651,0.10252,0.11521]},{"section":31,"text":"The answer should be tardive dyskinesia.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.021874,0.041398,0.049727,0.05688,0.06547,0.073292,0.082047,0.088351,0.099279,0.10356,0.12193,0.1962],"unified_progress":[0.020238,0.028899,0.036716,0.045722,0.050206,0.063181,0.067897,0.083045,0.09829,0.11031,0.16142,0.23407]}]}}