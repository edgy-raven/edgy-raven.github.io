0.09796,0.094581,0.090686,0.086081,0.072124,0.051773]},{"section":10,"text":"Looking at her electrolytes, renal function, and calcium levels, all are normal.","dimension":7,"group":7,"is_degenerate":false,"model_progress":[0.039657,0.077299,0.10089,0.11227,0.11674,0.11304,0.11147,0.088629,0.075821,0.064474,0.055629,0.044071],"unified_progress":[0.043417,0.080173,0.094821,0.10257,0.10677,0.10098,0.10353,0.090585,0.087131,0.075793,0.064844,0.049388]},{"section":11,"text":"That's interesting because one of the complications of multiple myeloma is kidney issues, as the cancer can affect the kidneys.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.047216,0.064858,0.083676,0.094635,0.10304,0.10528,0.10589,0.098915,0.091392,0.08177,0.067944,0.055383],"unified_progress":[0.046541,0.0708,0.086564,0.095853,0.10036,0.10578,0.10224,0.096692,0.089906,0.083704,0.069309,0.052251]},{"section":12,"text":"If her renal function was off, that would be a big clue.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.040627,0.058805,0.079382,0.088602,0.095805,0.09988,0.10182,0.10087,0.097994,0.092654,0.083461,0.060108],"unified_progress":[0.041272,0.064095,0.078533,0.086628,0.096337,0.097765,0.09991,0.10134,0.098263,0.099297,0.080674,0.055887]},{"section":13,"text":"Similarly, calcium levels can drop because the cancer can cause bone breakdown, but here, her calcium is normal, which might mean the disease is in an early stage or perhaps not causing those effects yet.","dimension":7,"group":7,"is_degenerate":false,"model_progress":[0.047842,0.058621,0.081089,0.091515,0.10031,0.10315,0.10314,0.09838,0.093939,0.086876,0.076613,0.058522],"unified_progress":[0.050107,0.069936,0.082859,0.089741,0.096991,0.098269,0.099442,0.097783,0.093895,0.090375,0.076395,0.054207]},{"section":14,"text":"The skeletal survey didn't show any osteolytic lesions.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.028096,0.060509,0.087822,0.10725,0.1151,0.11848,0.11