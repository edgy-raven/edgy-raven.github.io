,0.10077,0.10578,0.1066,0.10086,0.097651,0.086718,0.085052,0.067347,0.056534,0.043849]},{"section":6,"text":"Hmm, the key here is to differentiate between different plasma cell dyscrasias.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.07869,0.1087,0.1084,0.10585,0.096639,0.084307,0.080494,0.075902,0.067437,0.074311,0.058672,0.060601],"unified_progress":[0.10104,0.074694,0.081694,0.09119,0.092534,0.089873,0.090524,0.088541,0.081117,0.082862,0.068619,0.057317]},{"section":7,"text":"The main ones are monoclonal gammopathy of undetermined significance (MGUS), smoldering multiple myeloma, and maybe Waldenstr\u00f6m macroglobulinemia, but that's less likely here.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.044049,0.080275,0.09293,0.10188,0.10549,0.10155,0.098388,0.089608,0.079788,0.079448,0.064974,0.061607],"unified_progress":[0.043133,0.064289,0.089291,0.094023,0.098786,0.10549,0.10057,0.096955,0.091285,0.086445,0.070786,0.058943]},{"section":8,"text":"First, in MGUS, the criteria are: plasma cells in bone marrow less than 10%, no end-organ damage (like hypercalcemia, renal failure, anemia, or bone lesions), and no evidence of light chain deposition.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.041917,0.081391,0.089955,0.095657,0.099003,0.099585,0.098927,0.093287,0.085137,0.083608,0.070376,0.061155],"unified_progress":[0.042185,0.070855,0.085978,0.094072,0.099262,0.10308,0.10025,0.097765,0.092477,0.085914,0.07201,0.056154]},{"section":9,"text":"The monoclonal protein is present but not causing problems.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.041124,0.08168,0.091848,0.095714,0.096716,0.095962,0.096176,0.09229,0.086309,0.083571,0.074144,0.064466],"unified_progress":[0.050764,0.073657,0.085037,0.091999,0.097008,0.098576,0.098322,0.094605,0.090061,0.085742,0.074639,0.059589]},{"section":10,"text":"The bone marrow here is 5%, which is under 10%, so that fits.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.044502,0.085316,0.09665,0.099366,0.097051,0.093421,0.092737,0.08838,0.0845,0.08021,0.072478,0.065388],"unified_progress":[0.051602,0.076893,0.088561,0.096071,0.10004,0.096922,0.09933,0.090518,0.086358,0.080437,0.072321,0.060943]},{"section":11,"text":"Also, the skeletal survey is negative, so no lytic lesions.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.04017,0.081453,0.09083,0.094557,0.094321,0.09509,0.094441,0.091033,0.092365,0.082914,0.075909,0.066918],"unified_progress":[0.042156,0.074065,0.087483,0.096596,0.10105,0.099365,0.099505,0.093767,0.092416,0.08273,0.072027,0.058835]},{"section":12,"text":"Her labs are all normal, so no evidence of organ damage.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.038914,0.079458,0.091448,0.09502,0.094851,0.0937,0.095338,0.092489,0.088909,0.084474,0.078638,0.066761],"unified_progress":[0.040415,0.073858,0.086891,0.09285,0.099718,0.096783,0.10076,0.094281,0.090577,0.086132,0.077066,0.060666]},{"section":13,"text":"Smoldering multiple myeloma would have more plasma cells (10% or more) or a higher M-protein level, but without symptoms.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037444,0.073752,0.084804,0.0932,0.09794,0.098819,0.099684,0.095042,0.088378,0.087333,0.076045,0.067559],"unified_progress":[0.041405,0.065507,0.082226,0.091454,0.097775,0.10479,0.10297,0.098462,0.092691,0.087689,0.075215,0.059811]},{"section":14,"text":"Since her plasma cells are only 5%, that's under the threshold for smoldering.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.039683,0.07728,0.087805,0.092283,0.093812,0.094134,0.095056,0.092367,0.089053,0.084965,0.079202,0.074358],"unified_progress":[0.054788,0.073013,0.082605,0.089031,0.093955,0.094022,0.094957,0.091955,0.088547,0.084098,0.07988,0.073148]},{"section":15,"text":"Multiple myeloma itself would have evidence of organ damage (CRAB features: hypercalcemia, renal failure, anemia, bone lesions), which she doesn't have.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.0319,0.066539,0.078619,0.088019,0.094895,0.098367,0.10113,0.098059,0.093212,0.092427,0.083342,0.073494],"unified_progress":[0.036435,0.062112,0.079329,0.086983,0.094428,0.10214,0.10064,0.09969,0.096517,0.094099,0.082091,0.065531]},{"section":16,"text":"So putting it all together, the most likely diagnosis is MGUS.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.029387,0.055903,0.066893,0.073214,0.077078,0.079187,0.084062,0.086854,0.091802,0.097097,0.10415,0.15437],"unified_progress":[0.029794,0.040518,0.049366,0.060344,0.064709,0.075266,0.078128,0.089093,0.096156,0.10464,0.13539,0.1766]},{"section":17,"text":"The patient is asymptomatic, meets the plasma cell percentage, and has no organ damage.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.032066,0.061983,0.069256,0.074592,0.080461,0.086274,0.09097,0.094449,0.098048,0.10125,0.1039,0.10676],"unified_progress":[0.034404,0.050676,0.059319,0.066991,0.075251,0.084607,0.088228,0.096562,0.10403,0.1106,0.11601,0.11332]},{"section":18,"text":"The monoclonal peak is present but not causing issues.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.032837,0.064848,0.073985,0.080006,0.085086,0.089406,0.094011,0.095441,0.097035,0.096898,0.096071,0.094376],"unified_progress":[0.041258,0.057932,0.067694,0.07535,0.082633,0.088119,0.092242,0.095524,0.099065,0.10097,0.10189,0.097332]},{"section":19,"text":"So yeah, MGUS fits here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.027475,0.052798,0.063575,0.070286,0.076026,0.080059,0.085695,0.08974,0.095726,0.10012,0.10766,0.15084],"unified_progress":[0.028786,0.038729,0.04669,0.056303,0.061128,0.070681,0.075688,0.087464,0.09844,0.10882,0.14112,0.18614]}]}}