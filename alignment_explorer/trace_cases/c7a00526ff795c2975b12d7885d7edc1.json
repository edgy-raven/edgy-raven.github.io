129,0.092617,0.084842,0.087385,0.067878,0.08212,0.053739,0.0473,0.039044,0.030846]},{"section":4,"text":"The radial styloid is lower than the ulnar styloid.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.085354,0.14666,0.13488,0.11128,0.093552,0.087797,0.076175,0.070748,0.064075,0.050634,0.042628,0.036226],"unified_progress":[0.077407,0.10854,0.11148,0.11043,0.10407,0.096878,0.086578,0.08139,0.077851,0.058397,0.047923,0.039052]},{"section":5,"text":"Hmm, that might indicate some displacement.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.060849,0.10387,0.11188,0.10908,0.10148,0.092885,0.086351,0.080177,0.074782,0.069644,0.057667,0.051336],"unified_progress":[0.071242,0.088743,0.096101,0.10498,0.10252,0.09475,0.092446,0.08638,0.080291,0.076307,0.059188,0.047059]},{"section":6,"text":"The tenderness in the anatomical snuff box is a key point because that's where the scaphoid bone is located.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.05853,0.10345,0.10516,0.10376,0.097825,0.0941,0.08833,0.082791,0.079638,0.070599,0.0602,0.055623],"unified_progress":[0.061312,0.083894,0.095861,0.10664,0.10354,0.099332,0.094182,0.088749,0.084092,0.071892,0.059513,0.05099]},{"section":7,"text":"Wait, the anatomical snuff box is the area between the tendons on the thumb side of the wrist.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.063787,0.099986,0.096971,0.097056,0.095084,0.093568,0.089915,0.085646,0.082538,0.073372,0.063845,0.058233],"unified_progress":[0.079014,0.079588,0.0902,0.09783,0.10027,0.09835,0.09396,0.089864,0.085079,0.073946,0.061029,0.050868]},{"section":8,"text":"The scaphoid is the most commonly fractured carpal bone in such falls.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.051573,0.085823,0.090964,0.097108,0.099284,0.097792,0.096114,0.089783,0.083029,0.079369,0.066597,0.062564],"unified_progress":[0.061664,0.06895,0.088204,0.095128,0.0981,0.10599,0.097993,0.093555,0.087581,0.079709,0.066486,0.056635]},{"section":9,"text":"The mechanism of injury\u2014fall on outstretched hand (FOOSH)\u2014is classic for scaphoid fractures.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.054108,0.09113,0.091374,0.093322,0.094825,0.095634,0.093022,0.089776,0.082348,0.080994,0.068963,0.064505],"unified_progress":[0.064603,0.075158,0.085523,0.091566,0.094422,0.09902,0.094798,0.093837,0.087957,0.082295,0.070735,0.060086]},{"section":10,"text":"The tenderness there is a big clue.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.04556,0.088134,0.10253,0.10354,0.097314,0.089391,0.087069,0.082873,0.07945,0.083691,0.070885,0.069559],"unified_progress":[0.046274,0.073804,0.083179,0.094267,0.095582,0.094413,0.094113,0.092328,0.089717,0.091565,0.078621,0.066138]},{"section":11,"text":"The radial styloid being lower...","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.32823,0.053813,0.053417,0.061868,0.062224,0.06422,0.060462,0.067819,0.068543,0.064,0.066783,0.048626],"unified_progress":[0.21024,0.08244,0.066157,0.064364,0.074506,0.074356,0.090685,0.081373,0.078183,0.063373,0.058634,0.055693]},{"section":12,"text":"Maybe it's a Colles fracture?","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.067562,0.13975,0.062602,0.10091,0.095911,0.09667,0.08703,0.081681,0.076405,0.070635,0.064249,0.056594],"unified_progress":[0.074807,0.094625,0.069991,0.10108,0.099904,0.10472,0.091548,0.088411,0.081374,0.074841,0.065722,0.052975]},{"section":13,"text":"But Colles typically has a dinner fork deformity with the wrist dorsiflexed and the radial styloid displaced posteriorly.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.050144,0.09208,0.09428,0.095156,0.097552,0.097793,0.095917,0.09089,0.083859,0.076914,0.06707,0.058343],"unified_progress":[0.063687,0.07787,0.090868,0.095682,0.09848,0.10211,0.096066,0.093231,0.086243,0.077628,0.064999,0.053134]},{"section":14,"text":"But th