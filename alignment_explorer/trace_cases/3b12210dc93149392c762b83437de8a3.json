48,0.092198,0.090103,0.087255,0.088389,0.07728,0.072434],"unified_progress":[0.034207,0.07014,0.083733,0.098326,0.097099,0.094844,0.096142,0.0951,0.091637,0.093975,0.080345,0.064452]},{"section":16,"text":"Maybe Waldenstr\u00f6m's macroglobulinemia, but that usually presents with hyperviscosity and different symptoms.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.02601,0.061793,0.079567,0.094727,0.10494,0.10725,0.10779,0.10022,0.090835,0.090282,0.07426,0.062324],"unified_progress":[0.028287,0.057647,0.079046,0.090444,0.10142,0.11354,0.10687,0.10492,0.098547,0.09254,0.072829,0.053906]},{"section":17,"text":"Or solitary plasmacytoma, but that's usually a single bone lesion.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026796,0.06232,0.077639,0.090582,0.098975,0.1037,0.10578,0.10058,0.096205,0.094768,0.077639,0.065023],"unified_progress":[0.03198,0.060461,0.079519,0.092875,0.10012,0.10554,0.10487,0.10358,0.099716,0.093108,0.073406,0.054827]},{"section":18,"text":"Leukemia?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.027485,0.063128,0.078504,0.088296,0.095487,0.099004,0.10252,0.10179,0.098617,0.095104,0.084382,0.065685],"unified_progress":[0.033078,0.066487,0.083683,0.094265,0.10001,0.1016,0.10248,0.10103,0.096952,0.092521,0.074828,0.053065]},{"section":19,"text":"But WBC is normal.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.028767,0.065771,0.081921,0.089403,0.093311,0.095038,0.10143,0.10124,0.098714,0.09369,0.087595,0.063129],"unified_progress":[0.042218,0.069547,0.084794,0.090994,0.10042,0.097832,0.10103,0.099478,0.09515,0.093583,0.076061,0.048898]},{"section":20,"text":"Maybe metastatic cancer, but the lytic lesions and M-protein point more to myeloma.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.026661,0.062821,0.07815,0.087475,0.091986,0.095953,0.099336,0.098434,0.1017,0.094676,0.08724,0.075564],"unified_progress":[0.033668,0.064939,0.080171,0.090209,0.096807,0.09846,0.09966,0.098441,0.098808,0.092932,0.081349,0.064556]},{"section":21,"text":"The combination of all these factors\u2014M-protein, lytic bones, renal issues (though not mentioned here), and cytopenias\u2014strongly suggest multiple myeloma.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.027745,0.061406,0.076333,0.084322,0.089054,0.091576,0.095283,0.095221,0.096654,0.098196,0.094985,0.089224],"unified_progress":[0.032741,0.058371,0.072409,0.082463,0.089986,0.095047,0.098042,0.098653,0.099509,0.099751,0.093404,0.079625]},{"section":22,"text":"The recurrent infections also fit with the immune dysfunction seen in myeloma.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.024568,0.055922,0.070236,0.080945,0.089716,0.095685,0.1007,0.10014,0.099055,0.098779,0.094795,0.089469],"unified_progress":[0.031809,0.050144,0.062265,0.071001,0.081875,0.092391,0.095666,0.10124,0.10535,0.10831,0.10654,0.093413]},{"section":23,"text":"So I think the diagnosis is multiple myeloma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.023896,0.047578,0.057848,0.064819,0.071195,0.076544,0.083406,0.088522,0.096175,0.10165,0.11387,0.17449],"unified_progress":[0.022548,0.033018,0.041225,0.050405,0.056322,0.071555,0.075336,0.091829,0.10419,0.11209,0.14711,0.19437]}]}}