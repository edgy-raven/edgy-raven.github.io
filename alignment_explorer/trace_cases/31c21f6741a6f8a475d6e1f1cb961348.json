0.054941,0.043405]},{"section":6,"text":"The most common ones are aphthous ulcers.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.056443,0.098288,0.1147,0.11637,0.10811,0.094122,0.087536,0.077868,0.068891,0.070258,0.055256,0.05216],"unified_progress":[0.052749,0.076686,0.094172,0.10211,0.10068,0.10017,0.095651,0.090348,0.084185,0.08312,0.066135,0.053994]},{"section":7,"text":"Since she's a teenager, that's a common age.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.054842,0.094856,0.10265,0.10413,0.10083,0.098222,0.0896,0.084424,0.076659,0.076021,0.063162,0.054606],"unified_progress":[0.086511,0.10507,0.0964,0.093967,0.091348,0.088844,0.085079,0.086726,0.077565,0.074945,0.06306,0.050481]},{"section":8,"text":"Aphthous stomatitis often presents with round or oval ulcers, white or gray center, red border.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.05025,0.088778,0.092381,0.097498,0.1005,0.099924,0.097082,0.091542,0.080638,0.07793,0.064501,0.058975],"unified_progress":[0.058093,0.075855,0.096571,0.095314,0.097851,0.10495,0.096398,0.09353,0.085792,0.079052,0.06442,0.052171]},{"section":9,"text":"They can be painful, which matches her symptoms.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.048228,0.091224,0.096101,0.09597,0.095038,0.093895,0.092661,0.090304,0.082938,0.081884,0.070773,0.060984],"unified_progress":[0.057535,0.078972,0.084577,0.09008,0.093422,0.095702,0.093456,0.094694,0.089781,0.089876,0.074813,0.057092]},{"section":10,"text":"The fact that it's on the lateral border of the tongue is a typical location for minor aphthous ulcers.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.053923,0.096981,0.099382,0.098741,0.095118,0.093253,0.089533,0.085393,0.082949,0.076852,0.066037,0.061837],"unified_progress":[0.058657,0.079597,0.089375,0.097398,0.097844,0.097644,0.094734,0.091399,0.088873,0.08,0.067792,0.056687]},{"section":11,"text":"She doesn't use tobacco or alcohol, so that rules out some other causes like smoking-related ulcers or alcohol irritation.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.042587,0.083242,0.092588,0.095856,0.096868,0.09893,0.094803,0.092174,0.086367,0.085214,0.07251,0.05886],"unified_progress":[0.059192,0.090831,0.091935,0.094009,0.094591,0.094615,0.092267,0.092976,0.086298,0.08339,0.068487,0.051407]},{"section":12,"text":"Also, no fever suggests it's not an infection like herpetic stomatitis, which would have multiple ulcers and possibly fever.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028853,0.064772,0.07785,0.086961,0.093662,0.098122,0.10375,0.10292,0.09846,0.095269,0.085992,0.063381],"unified_progress":[0.034365,0.063118,0.078689,0.085437,0.096116,0.099674,0.10094,0.10367,0.1009,0.10119,0.082015,0.053883]},{"section":13,"text":"Herpes simplex virus ulcers are usually more vesicular and might come in clusters.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026241,0.060635,0.074676,0.086569,0.095136,0.10031,0.10592,0.10453,0.099346,0.097251,0.084662,0.064722],"unified_progress":[0.030127,0.058142,0.076596,0.087076,0.096175,0.10394,0.10403,0.10661,0.10292,0.10195,0.080589,0.051849]},{"section":14,"text":"The duration is two weeks, which is about right for aphthous ulcers.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.04152,0.078496,0.085579,0.089517,0.091702,0.092808,0.093846,0.0927,0.089034,0.089345,0.080605,0.074849],"unified_progress":[0.04947,0.069601,0.078715,0.086805,0.091495,0.095056,0.096505,0.095952,0.093191,0.091943,0.082322,0.068946]},{"section":15,"text":"They typically heal in 7-10 days, but maybe up to two weeks.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.047511,0.086468,0.087281,0.088064,0.091101,0.094422,0.093976,0.093801,0.087294,0.084407,0.076394,0.069282],"unified_progress":[0.058594,0.077935,0.083117,0.086805,0.090196,0.094139,0.092857,0.094227,0.08943,0.088038,0.078321,0.066339]},{"section":16,"text":"Since no treatment was given and it resolved on its own, that's another point for aphthous.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.048733,0.088266,0.091895,0.090958,0.089835,0.090553,0.089082,0.08892,0.084505,0.08395,0.076904,0.076398],"unified_progress":[0.053047,0.07494,0.079452,0.085301,0.087892,0.089635,0.089903,0.091354,0.089414,0.090514,0.086903,0.081645]},{"section":17,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.033373,0.073126,0.094053,0.09989,0.09887,0.092992,0.092369,0.089583,0.087362,0.090025,0.078029,0.070328],"unified_progress":[0.036949,0.069437,0.082141,0.095469,0.09563,0.094142,0.097993,0.09504,0.092528,0.096918,0.081296,0.062456]},{"section":18,"text":"Maybe trauma?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.025707,0.062341,0.080547,0.089907,0.097466,0.098786,0.10138,0.10215,0.098902,0.095555,0.084752,0.062509],"unified_progress":[0.046175,0.06973,0.085409,0.095765,0.098555,0.097425,0.10163,0.098847,0.093645,0.090048,0.072361,0.05041]},{"section":19,"text":"Like biting her tongue or a sharp tooth?","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.035796,0.075613,0.083905,0.089636,0.094151,0.09909,0.099109,0.097752,0.096081,0.087916,0.078204,0.062747],"unified_progress":[0.049649,0.076872,0.088845,0.096372,0.10008,0.099865,0.097753,0.095919,0.091631,0.082628,0.068528,0.051853]},{"section":20,"text":"But the case doesn't mention any injury.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027982,0.0623,0.075492,0.083846,0.090792,0.096355,0.1019,0.1035,0.10208,0.098049,0.090394,0.067305],"unified_progress":[0.045516,0.068906,0.078879,0.08616,0.095004,0.093956,0.097664,0.10143,0.098286,0.10023,0.080528,0.053443]},{"section":21,"text":"But sometimes people don't recall minor trauma.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.029526,0.063944,0.076139,0.084514,0.092249,0.098927,0.10156,0.1025,0.10026,0.096163,0.086863,0.067352],"unified_progress":[0.063107,0.080184,0.083439,0.087816,0.091489,0.092738,0.096055,0.095861,0.091653,0.091493,0.074575,0.051589]},{"section":22,"text":"However, the description here seems more classic for aphthous.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.035445,0.067666,0.078022,0.084822,0.088868,0.090948,0.094955,0.095658,0.094946,0.095509,0.088721,0.08444],"unified_progress":[0.048786,0.063358,0.074098,0.083399,0.089123,0.091139,0.094737,0.095776,0.094976,0.097409,0.089074,0.078124]},{"section":23,"text":"Canker sore is another term for aphthous ulcers.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.036596,0.06822,0.078535,0.088246,0.095027,0.096732,0.098669,0.095801,0.090737,0.091686,0.081039,0.07871],"unified_progress":[0.044536,0.059331,0.076575,0.086234,0.091917,0.099933,0.098746,0.098587,0.095321,0.092667,0.083031,0.073123]},{"section":24,"text":"So minor aphthous ulcer is the most likely.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.029424,0.05988,0.072573,0.080897,0.086366,0.08894,0.092247,0.091384,0.092148,0.094318,0.092545,0.11928],"unified_progress":[0.029204,0.048048,0.061583,0.072781,0.077275,0.086551,0.087133,0.092597,0.096289,0.099029,0.11423,0.13528]},{"section":25,"text":"Major aphthae are larger and take longer to heal, but this is only 0.3 cm, so minor.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.034739,0.069683,0.07692,0.082959,0.088717,0.093481,0.097147,0.097585,0.095251,0.094429,0.087802,0.081287],"unified_progress":[0.036487,0.060029,0.070963,0.078842,0.086465,0.092854,0.094794,0.099888,0.10047,0.1029,0.094186,0.08213]},{"section":26,"text":"I don't think it's something like oral lichen planus or Behcet's because those are less common and might have other symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023916,0.055431,0.070965,0.083265,0.092367,0.097605,0.10463,0.10524,0.1025,0.10184,0.091615,0.070637],"unified_progress":[0.029081,0.055087,0.07278,0.083243,0.09269,0.098552,0.10219,0.10632,0.10484,0.10832,0.087446,0.059453]},{"section":27,"text":"Also, the self-limiting course points away from chronic conditions.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022448,0.054342,0.070074,0.079896,0.087301,0.093051,0.10122,0.10461,0.10482,0.10434,0.098452,0.07945],"unified_progress":[0.028556,0.054902,0.069071,0.078599,0.088698,0.093183,0.099332,0.10539,0.10582,0.11294,0.09506,0.068458]},{"section":28,"text":"So putting it all together: atraumatic, single ulcer, typical location, duration, and presentation.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.030697,0.060267,0.071144,0.078271,0.083729,0.087534,0.092144,0.094493,0.097646,0.10109,0.10079,0.1022],"unified_progress":[0.038136,0.052513,0.063665,0.073761,0.08172,0.089658,0.09504,0.098271,0.10134,0.1047,0.10437,0.096836]},{"section":29,"text":"The answer should be recurrent aphthous stomatitis, specifically a minor aphthous ulcer.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.024358,0.047798,0.056418,0.064506,0.072806,0.079886,0.08685,0.090928,0.097939,0.10142,0.11272,0.16436],"unified_progress":[0.024456,0.036065,0.045994,0.054875,0.061177,0.074872,0.078276,0.090843,0.10179,0.10808,0.13968,0.18389]}]}}