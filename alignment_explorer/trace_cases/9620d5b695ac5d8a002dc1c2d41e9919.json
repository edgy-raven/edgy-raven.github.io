ate":false,"model_progress":[0.11246,0.17791,0.1566,0.11246,0.084429,0.076819,0.0617,0.06184,0.046605,0.045527,0.033786,0.029866],"unified_progress":[0.10619,0.12334,0.1082,0.10821,0.091694,0.089515,0.078476,0.080294,0.065262,0.063556,0.048181,0.037071]},{"section":5,"text":"The headaches are on the right side, deep and excruciating.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.1195,0.19016,0.14532,0.099103,0.077039,0.080044,0.061054,0.067224,0.049422,0.042948,0.035917,0.03227],"unified_progress":[0.10487,0.13639,0.11171,0.10243,0.087582,0.08901,0.074821,0.081319,0.066136,0.057343,0.048939,0.039446]},{"section":6,"text":"Also, there are associated symptoms: tearing and reddening of the right eye, plus nasal stuffiness on the same side.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.10895,0.18036,0.1437,0.098717,0.078397,0.083647,0.06427,0.071473,0.054596,0.04512,0.038039,0.032736],"unified_progress":[0.095489,0.1294,0.11053,0.106,0.09088,0.092207,0.077583,0.082701,0.070587,0.057867,0.048547,0.038206]},{"section":7,"text":"Hmm, so the first thing that comes to mind is cluster headaches.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.081344,0.11701,0.12527,0.11929,0.1012,0.081707,0.075697,0.069178,0.05996,0.070299,0.049533,0.049524],"unified_progress":[0.09772,0.081587,0.085984,0.097243,0.095845,0.089455,0.090255,0.085549,0.07591,0.085254,0.063488,0.05171]},{"section":8,"text":"They're known for their severe pain, often around the eye or temple, and they can cause those autonomic symptoms like tearing, redness, and nasal congestion.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.052872,0.09581,0.099311,0.102,0.10248,0.099342,0.094326,0.087336,0.076832,0.073079,0.061833,0.054782],"unified_progress":[0.049985,0.076079,0.091504,0.093156,0.097166,0.10314,0.096608,0.095556,0.088564,0.083515,0.069099,0.055631]},{"section":9,"text":"The fact that they wake him from sleep fits too, since cluster headaches often occur at night.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.05185,0.093802,0.095077,0.094855,0.095316,0.096353,0.092962,0.08986,0.081616,0.079703,0.068213,0.060392],"unified_progress":[0.054575,0.077104,0.084741,0.089818,0.093105,0.097733,0.094887,0.095336,0.090476,0.087663,0.074767,0.059794]},{"section":10,"text":"The duration of an hour is typical for a cluster attack.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.052747,0.094547,0.096298,0.095018,0.09374,0.093097,0.090822,0.088955,0.081699,0.079909,0.069847,0.063321],"unified_progress":[0.064856,0.080095,0.085077,0.089576,0.091849,0.094357,0.092495,0.092814,0.087736,0.085574,0.074185,0.061385]},{"section":11,"text":"The frequency of two a day over three weeks also aligns with the episodic form of cluster headaches, which can last weeks to months.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.052559,0.093473,0.093309,0.09223,0.092638,0.094738,0.09128,0.089948,0.082101,0.080839,0.070727,0.066159],"unified_progress":[0.057501,0.079049,0.085397,0.088258,0.090283,0.09527,0.092041,0.093529,0.08828,0.086181,0.076998,0.067214]},{"section":12,"text":"Wait, but I should consider other possibilities.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.029839,0.063809,0.08464,0.093837,0.09921,0.098073,0.097392,0.094779,0.094056,0.090336,0.081494,0.072536],"unified_progress":[0.038339,0.073782,0.084604,0.10108,0.098938,0.094553,0.097898,0.092026,0.088132,0.097569,0.075952,0.057124]},{"section":13,"text":"Migraines can have unilateral pain, but they usually last longer\u2014like 4-72 hours.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.033198,0.06851,0.07832,0.087114,0.094182,0.097995,0.10223,0.10066,0.094493,0.093343,0.082494,0.067464],"unified_progress":[0.038814,0.064496,0.078209,0.08482,0.095447,0.10252,0.10029,0.10294,0.098225,0.096666,0.078806,0.058768]},{"section":14,"text":"Plus, migraines might have nausea or photophobia, which aren't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024629,0.057345,0.070863,0.080682,0.088198,0.094677,0.10418,0.10736,0.10573,0.10323,0.095501,0.06761],"unified_progress":[0.029291,0.056847,0.071654,0.080141,0.092333,0.096372,0.1013,0.10817,0.10726,0.11486,0.088355,0.053414]},{"section":15,"text":"The autonomic symptoms are more characteristic of cluster headaches.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.027234,0.060982,0.076059,0.085664,0.091411,0.094071,0.099319,0.099491,0.09762,0.099327,0.090687,0.078135],"unified_progress":[0.038848,0.057797,0.071998,0.083015,0.090577,0.09676,0.10208,0.10235,0.10088,0.10265,0.088072,0.064969]},{"section":16,"text":"Tension headaches are usually bilateral and not as severe.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023783,0.055906,0.069438,0.079771,0.088048,0.094526,0.10358,0.10668,0.10535,0.10439,0.096399,0.07213],"unified_progress":[0.029673,0.055505,0.070578,0.079565,0.091178,0.096275,0.10121,0.10766,0.10682,0.11277,0.090387,0.058375]},{"section":17,"text":"Another thought: maybe a sinus headache?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.023369,0.056888,0.074867,0.085096,0.093569,0.096553,0.10044,0.10393,0.1023,0.1029,0.091077,0.069004],"unified_progress":[0.029353,0.064993,0.082261,0.095227,0.0985,0.099135,0.1054,0.10257,0.098489,0.096492,0.077127,0.050457]},{"section":18,"text":"But sinus headaches typically have more facial pressure and maybe fever, and the pain isn't as strictly unilateral and severe as in clusters.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021112,0.052152,0.066806,0.077398,0.087632,0.094361,0.10437,0.10848,0.10778,0.10641,0.1002,0.073302],"unified_progress":[0.028948,0.056609,0.072607,0.081015,0.093931,0.097918,0.10194,0.10897,0.10665,0.10857,0.087727,0.055109]},{"section":19,"text":"The nasal stuffiness could be a clue, but combined with the eye symptoms, cluster still fits better.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023899,0.056927,0.071609,0.081224,0.087641,0.093378,0.10078,0.10334,0.10563,0.10302,0.096055,0.076504],"unified_progress":[0.030991,0.057332,0.072451,0.082721,0.092418,0.096288,0.10163,0.10469,0.10597,0.10694,0.088701,0.05988]},{"section":20,"text":"The neuro exam is nonfocal, so no signs of a structural issue like a tumor, which is reassuring.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028386,0.065764,0.079149,0.086302,0.089513,0.093516,0.098255,0.099361,0.10246,0.096986,0.08878,0.071528],"unified_progress":[0.030609,0.063834,0.079206,0.089418,0.097022,0.097423,0.10098,0.10144,0.10219,0.098666,0.081781,0.057432]},{"section":21,"text":"The timing and symptoms all point towards cluster headaches.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.031639,0.070272,0.088867,0.094161,0.09227,0.087541,0.088797,0.087479,0.086902,0.095976,0.086596,0.0895],"unified_progress":[0.031594,0.059725,0.072705,0.08465,0.088499,0.090499,0.098462,0.096346,0.096341,0.10215,0.094621,0.08441]},{"section":22,"text":"The key features here are the strict unilateral pain, the autonomic symptoms on the same side, the nocturnal occurrence, and the episodic pattern.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.031014,0.064005,0.073401,0.079925,0.08612,0.0911,0.094433,0.095692,0.097729,0.098407,0.098304,0.089871],"unified_progress":[0.034604,0.056846,0.06717,0.075609,0.084804,0.093677,0.096005,0.10056,0.10312,0.10493,0.099127,0.083541]},{"section":23,"text":"Yeah, I think that's it.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.3044,0.050042,0.051427,0.060471,0.061211,0.064287,0.063479,0.07266,0.073708,0.069594,0.072572,0.056148],"unified_progress":[0.19147,0.074081,0.062029,0.062569,0.072151,0.073736,0.089525,0.084197,0.082016,0.068483,0.065224,0.074524]}]}}