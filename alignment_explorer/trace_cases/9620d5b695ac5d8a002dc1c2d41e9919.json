.089559,0.082718,0.09947,0.080583,0.070542],"unified_progress":[0.042602,0.081949,0.090732,0.10827,0.10292,0.094939,0.097652,0.087532,0.081489,0.093605,0.06729,0.051024]},{"section":8,"text":"The fact that it's on one side, the tearing, and the eye redness makes me think of something related to the trigeminal nerve.","dimension":17,"group":6,"is_degenerate":false,"model_progress":[0.041753,0.081847,0.093179,0.10102,0.097888,0.094921,0.094144,0.090121,0.08571,0.080346,0.074072,0.065004],"unified_progress":[0.041537,0.07513,0.08985,0.10223,0.10136,0.099636,0.099462,0.095637,0.090667,0.0824,0.068534,0.053563]},{"section":9,"text":"Trigeminal neuralgia is a possibility because it causes severe, unilateral facial pain, often described as sharp or excruciating.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.04103,0.072211,0.083886,0.093019,0.095956,0.09686,0.10107,0.099448,0.092965,0.083825,0.074776,0.064958],"unified_progress":[0.041885,0.071829,0.088302,0.097066,0.10077,0.1083,0.10218,0.098224,0.091952,0.082931,0.066909,0.049656]},{"section":10,"text":"But wait, trigeminal neuralgia usually has shorter attacks, like seconds or minutes, not an hour.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.038859,0.065047,0.077295,0.084821,0.093439,0.096802,0.10201,0.10233,0.099179,0.09065,0.081644,0.067929],"unified_progress":[0.04579,0.074084,0.086615,0.093464,0.098785,0.10233,0.099502,0.098218,0.093397,0.086846,0.069922,0.051045]},{"section":11,"text":"Hmm, maybe it's a different condition.","dimension":5,"group":6,"is_degenerate":false,"model_progress":[0.027922,0.062221,0.078257,0.091223,0.093698,0.098152,0.10228,0.10365,0.10254,0.097097,0.082063,0.060897],"unified_progress":[0.032769,0.067443,0.085293,0.097179,0.10086,0.099558,0.103,0.10144,0.096611,0.09504,0.07372,0.04709]},{"section":12,"text":"Another possibility is a migraine, but migraines can be unilateral and severe.","dimension":6,"group":8,"is_degenerate":false,"model_progres