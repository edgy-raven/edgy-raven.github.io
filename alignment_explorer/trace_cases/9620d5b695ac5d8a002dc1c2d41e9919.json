ess":[0.039419,0.063969,0.077085,0.087688,0.094176,0.098156,0.10043,0.097475,0.097336,0.098188,0.086253,0.059821],"unified_progress":[0.041484,0.067485,0.082898,0.09166,0.096174,0.099839,0.10047,0.096348,0.091655,0.087821,0.078497,0.065665]},{"section":11,"text":"Let's consider the duration too.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.014831,0.057937,0.090324,0.10775,0.11172,0.11175,0.10593,0.10249,0.097971,0.092867,0.070472,0.035956],"unified_progress":[0.034118,0.070468,0.08277,0.10075,0.097995,0.095016,0.097951,0.094196,0.090978,0.09616,0.079161,0.060433]},{"section":12,"text":"These headaches last about an hour each time.","dimension":6,"group":5,"is_degenerate":false,"model_progress":[0.069361,0.074821,0.077829,0.084416,0.089297,0.091256,0.092311,0.089502,0.089123,0.090847,0.085792,0.065444],"unified_progress":[0.057468,0.076685,0.080752,0.087085,0.089145,0.092217,0.091053,0.093044,0.090249,0.087017,0.081365,0.073921]},{"section":13,"text":"That's pretty short compared to other types of headaches.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.049096,0.076342,0.085652,0.092461,0.095475,0.097262,0.097187,0.092907,0.09331,0.091166,0.077748,0.051394],"unified_progress":[0.048645,0.072436,0.08595,0.09154,0.097564,0.098209,0.097277,0.093946,0.090537,0.085473,0.076302,0.062121]},{"section":14,"text":"Cluster headaches usually come in clusters and are shorter, often lasting between 15 minutes to 3 hours.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.041207,0.05167,0.062805,0.07506,0.086835,0.096646,0.10499,0.10645,0.11028,0.11527,0.092717,0.056078],"unified_progress":[0.042172,0.061881,0.0791,0.088095,0.094311,0.10432,0.0998,0.099808,0.095571,0.090865,0.078662,0.065413]},{"section":15,"text":"So, this fits with that pattern.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.030476,0.066432,0.076902,0.084245,0.088214,0.091141,0.09266,0.090895,0.094403,0.095175,0.099683,0.089774],"unified_progress":[0.03552,0.063394,0.077298,0.085002,0.092089,0.093669,0.093863,0.093987,0.093607,0.091772,0.09212,0.087679]},{"section":16,"text":"Also, the frequency\u2014two times a day\u2014is another clue.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.039546,0.062054,0.074004,0.083152,0.088591,0.092142,0.094223,0.094568,0.097524,0.10245,0.098733,0.073008],"unified_progress":[0.042909,0.06675,0.077583,0.085706,0.091076,0.093727,0.096449,0.095668,0.09551,0.094836,0.087397,0.072389]},{"section":17,"text":"Cluster headaches tend to occur multiple times a day during their active phase.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.043762,0.051156,0.060808,0.071777,0.081936,0.091209,0.099763,0.10285,0.10835,0.11615,0.10258,0.069672],"unified_progress":[0.044247,0.060986,0.075088,0.082882,0.089892,0.099212,0.097498,0.09893,0.096556,0.09421,0.085632,0.074867]},{"section":18,"text":"This matches our patient's experience perfectly.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.035443,0.054885,0.062305,0.068865,0.074182,0.079133,0.084392,0.087054,0.094815,0.10638,0.12817,0.12438],"unified_progress":[0.037976,0.05693,0.066817,0.074558,0.081816,0.088845,0.089929,0.094199,0.097164,0.098668,0.10557,0.10753]},{"section":19,"text":"So, putting all these pieces together\u2014the location, the intensity, the autonomic symptoms, the duration, and the frequency\u2014it seems like we're looking at cluster headaches.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.020424,0.034043,0.043825,0.05209,0.059732,0.067636,0.076783,0.084367,0.097781,0.12239,0.16752,0.17341],"unified_progress":[0.026975,0.041598,0.05274,0.06169,0.070665,0.082389,0.086148,0.096392,0.10517,0.11229,0.12612,0.13783]},{"section":20,"text":"Yeah, that's got to be it.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.093931,0.075599,0.070714,0.06432,0.067109,0.072014,0.077558,0.091437,0.087406,0.064699,0.076357,0.15885],"u