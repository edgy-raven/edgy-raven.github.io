gress":[0.055726,0.077855,0.088379,0.092484,0.097686,0.098278,0.098025,0.094817,0.089256,0.081392,0.070023,0.05608],"unified_progress":[0.049014,0.074523,0.087403,0.093729,0.099213,0.1017,0.097574,0.096411,0.090252,0.086115,0.070834,0.053231]},{"section":5,"text":"The fact that she hit the tree on the left side suggests that the impact was significant enough to cause internal injuries.","dimension":3,"group":3,"is_degenerate":false,"model_progress":[0.052888,0.080476,0.086609,0.091463,0.094304,0.094824,0.096076,0.093822,0.09051,0.083644,0.0737,0.061685],"unified_progress":[0.045429,0.073504,0.086038,0.092982,0.097498,0.10065,0.098014,0.09697,0.093447,0.086943,0.072915,0.055608]},{"section":6,"text":"The pain in the lower chest and upper abdomen makes me think of possible internal organ damage, like a liver or spleen injury, which are common in blunt trauma.","dimension":17,"group":6,"is_degenerate":false,"model_progress":[0.043095,0.075978,0.089013,0.10022,0.096331,0.095552,0.096327,0.093834,0.089529,0.082636,0.074002,0.063481],"unified_progress":[0.039585,0.069095,0.084971,0.09432,0.098319,0.10066,0.09997,0.098268,0.094772,0.088661,0.074519,0.056862]},{"section":7,"text":"The left shoulder pain could be a fracture or a dislocation, but it's also possible that it's related to the same injury mechanism.","dimension":5,"group":6,"is_degenerate":false,"model_progress":[0.040087,0.06896,0.082423,0.0927,0.094973,0.097335,0.10035,0.09939,0.096989,0.088711,0.077186,0.060896],"unified_progress":[0.038294,0.067879,0.084041,0.093677,0.098722,0.10045,0.10075,0.099622,0.096038,0.090611,0.075166,0.054746]},{"section":8,"text":"I should also consider other possibilities.","dimension":6,"group":8,"is_degenerate":false,"model_progress":[0.027307,0.05658,0.079662,0.086426,0.098831,0.10125,0.093107,0.094159,0.088033,0.11088,0.086758,0.077014],"unified_progress":[0.034011,0.072765,0.085821,0.10474,0.10019,0.095495,0.10252,0.093272,0.088416,0.094232,0.074137,0.054396]},{"section":9,"text":"For example, a broken rib could cause chest pain, and if a rib is fractured, it might also lead to internal organ damage if there's a tear in the peritoneum.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.03955,0.057502,0.073389,0.084804,0.093492,0.098869,0.10417,0.10415,0.10294,0.094644,0.082079,0.064409],"unified_progress":[0.038665,0.066408,0.083477,0.097623,0.10038,0.10263,0.10149,0.09903,0.094905,0.087074,0.071908,0.056407]},{"section":10,"text":"Another thought is a diaphragm injury, which can cause pain in both the chest and abdomen.","dimension":3,"group":3,"is_degenerate":false,"model_progress":[0.037715,0.059128,0.075895,0.085572,0.094298,0.098703,0.1029,0.10312,0.10055,0.093462,0.081824,0.066833],"unified_progress":[0.041759,0.070043,0.086223,0.096283,0.10098,0.10505,0.1018,0.097971,0.093249,0.08553,0.069485,0.051637]},{"section":11,"text":"However, diaphragm injuries are less common and usually present with more severe symptoms.","dimension":0,"group":4,"is_degenerate":false,"model_progress":[0.037467,0.057979,0.071902,0.08031,0.090429,0.095426,0.10194,0.10406,0.10294,0.097072,0.087641,0.072843],"unified_progress":[0.044221,0.06932,0.081595,0.088749,0.095456,0.10048,0.098935,0.099776,0.095481,0.092888,0.076393,0.056706]},{"section":12,"text":"Looking at the symptoms, she has localized pain on the left side, which is concerning.","dimension":14,"group":5,"is_degenerate":false,"model_progress":[0.041315,0.07704,0.08335,0.083991,0.088329,0.088954,0.089701,0.090805,0.089211,0.089698,0.090208,0.087399],"unified_progress":[0.062259,0.095361,0.092374,0.093811,0.092996,0.092247,0.09112,0.089746,0.084611,0.080752,0.069263,0.05546]},{"section":13,"text":"I should think about whether there's any indication of internal bleeding.","dimension":6,"group":8,"is_degenerate":false,"model_progress":[0.041383,0.066218,0.081014,0.089066,0.093236,0.095211,0.095245,0.095643,0.09382,0.095623,0.083334,0.070205],"unified_progress":[0.042749,0.072882,0.086