.061498],"unified_progress":[0.053834,0.069626,0.084466,0.092033,0.097941,0.10053,0.10003,0.095367,0.090304,0.085651,0.073105,0.057113]},{"section":15,"text":"Recurrent upper respiratory infections might be a red herring, but maybe they're actually exacerbating her asthma, or perhaps she's having allergic rhinitis which can coexist.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.038046,0.074205,0.082783,0.089656,0.095594,0.10102,0.099476,0.097043,0.09199,0.088073,0.077713,0.064405],"unified_progress":[0.061729,0.084366,0.085254,0.08632,0.089912,0.094222,0.091474,0.094098,0.089936,0.086191,0.076416,0.060081]},{"section":16,"text":"But the key here is the combination of allergies, wheezing, respiratory distress signs, and the lab findings.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.031235,0.066101,0.081513,0.088319,0.091048,0.09095,0.093476,0.092203,0.092465,0.097487,0.092018,0.083185],"unified_progress":[0.038096,0.061263,0.072681,0.082633,0.090369,0.095024,0.09751,0.097703,0.098288,0.10203,0.091506,0.072895]},{"section":17,"text":"I don't think it's something like COPD since she's only 8.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.040305,0.07671,0.086472,0.090804,0.091942,0.092467,0.092059,0.092052,0.089612,0.091042,0.081561,0.074973],"unified_progress":[0.05692,0.078093,0.081789,0.086613,0.089491,0.090407,0.092083,0.093423,0.09053,0.091315,0.081952,0.067384]},{"section":18,"text":"Maybe croup?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.028758,0.065209,0.08238,0.090566,0.09606,0.096578,0.098562,0.09864,0.096218,0.095233,0.084319,0.067478],"unified_progress":[0.035227,0.070194,0.085872,0.097336,0.098318,0.097447,0.10071,0.097675,0.093899,0.092263,0.075747,0.055314]},{"section":19,"text":"But croup has a barking cough and is more common in younger kids.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022284,0.054604,0.069966,0.081324,0.091282,0.097251,0.10593,0.10794,0.10496,0.10274,0.094348,0.067364],"unified_progress":[0.035191,0.058137,0.074406,0.082598,0.095012,0.098863,0.10206,0.1078,0.10439,0.10618,0.083886,0.051483]},{"section":20,"text":"Bronchiolitis?","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028868,0.064499,0.077204,0.08735,0.094901,0.099625,0.10288,0.10172,0.099557,0.09488,0.082594,0.065929],"unified_progress":[0.036664,0.065034,0.082172,0.093211,0.098927,0.10381,0.10313,0.10214,0.099054,0.091631,0.07367,0.05055]},{"section":21,"text":"That's usually in infants with a history of RSV, and wheezing but not typically with allergies.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022983,0.055533,0.070381,0.082055,0.091447,0.098396,0.10609,0.10747,0.10463,0.10257,0.092362,0.066082],"unified_progress":[0.02993,0.058534,0.074955,0.084,0.095385,0.10049,0.10281,0.10768,0.10483,0.10818,0.082373,0.050833]},{"section":22,"text":"Another thought: could it be an acute exacerbation of asthma?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.028953,0.061337,0.07569,0.085255,0.093621,0.096401,0.099592,0.10245,0.099545,0.099984,0.088162,0.069008],"unified_progress":[0.038947,0.066858,0.082858,0.095251,0.097916,0.098229,0.10329,0.10026,0.095384,0.092294,0.075593,0.053124]},{"section":23,"text":"The chronic history of allergies and recurrent infections (maybe viral-induced asthma) fits.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.029276,0.063443,0.075864,0.084871,0.092901,0.10072,0.10154,0.10064,0.097694,0.09527,0.086482,0.071293],"unified_progress":[0.070444,0.08696,0.083892,0.083289,0.087226,0.092008,0.089698,0.093365,0.088745,0.085902,0.07679,0.061682]},{"section":24,"text":"The physical exam findings align with obstructive lung disease.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.02996,0.066356,0.080035,0.08767,0.091632,0.093844,0.09682,0.095001,0.097069,0.093962,0.087856,0.079796],"unified_progress":[0.050632,0.070