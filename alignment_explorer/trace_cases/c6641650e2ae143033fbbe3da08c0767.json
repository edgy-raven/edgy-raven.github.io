49,0.030991]},{"section":5,"text":"The blood gases show respiratory alkalosis, and her eosinophils are elevated.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.09179,0.15192,0.14234,0.11544,0.093667,0.085287,0.073664,0.068273,0.056335,0.047807,0.041161,0.032316],"unified_progress":[0.079412,0.12026,0.11265,0.10871,0.1058,0.096135,0.086688,0.078784,0.068156,0.057809,0.049236,0.036363]},{"section":6,"text":"Hmm, starting with the symptoms.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.10015,0.11894,0.1093,0.10367,0.09532,0.084396,0.078881,0.07472,0.065052,0.064961,0.053272,0.051344],"unified_progress":[0.1462,0.083369,0.083769,0.091362,0.09134,0.08606,0.084221,0.083154,0.072723,0.073111,0.058655,0.046038]},{"section":7,"text":"Expiratory wheezes are classic for asthma, especially in a child with a history of allergies.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.064878,0.10859,0.10927,0.1048,0.098418,0.092668,0.085721,0.081365,0.071116,0.071583,0.05854,0.053056],"unified_progress":[0.064643,0.088671,0.095831,0.097774,0.096308,0.096458,0.090988,0.089895,0.081617,0.080113,0.065113,0.052589]},{"section":8,"text":"Allergies are a common trigger for asthma.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.046342,0.087402,0.10119,0.1058,0.10303,0.097292,0.09279,0.085712,0.07785,0.079406,0.065121,0.058062],"unified_progress":[0.060707,0.079614,0.087594,0.093503,0.094762,0.096601,0.093667,0.092109,0.086128,0.085981,0.071899,0.057435]},{"section":9,"text":"The use of accessory muscles suggests she's working hard to breathe, which makes sense with an obstructive airway issue like asthma.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.050027,0.092367,0.093555,0.094047,0.094715,0.09583,0.093883,0.090754,0.083873,0.078552,0.070068,0.062327],"unified_progress":[0.053415,0.075564,0.08117,0.085595,0.090356,0.095693,0.093399,0.094658,0.092632,0.089507,0.081406,0.066604]},{"section":1