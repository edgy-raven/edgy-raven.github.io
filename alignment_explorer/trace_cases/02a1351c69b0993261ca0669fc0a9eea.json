69]},{"section":18,"text":"Also, he doesn't smoke, so maybe less likely to have severe atherosclerosis, but atherosclerosis can still be a source for thrombosis.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.032136,0.065938,0.076912,0.085394,0.092075,0.099589,0.099537,0.099313,0.097534,0.094734,0.085209,0.071629],"unified_progress":[0.061554,0.087205,0.086448,0.088278,0.089376,0.09225,0.090378,0.093509,0.089145,0.085671,0.075615,0.060571]},{"section":19,"text":"But given the rapid onset, embolism from the heart is more common.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.02705,0.060149,0.07465,0.084249,0.090617,0.094884,0.098725,0.097694,0.098533,0.096383,0.090406,0.08666],"unified_progress":[0.04984,0.065139,0.074819,0.082538,0.08776,0.09112,0.092716,0.094434,0.094576,0.094565,0.089893,0.082602]},{"section":20,"text":"So the most common cause here would be an arterial embolism, probably from the heart, like atrial fibrillation leading to a clot that embolizes to the leg.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027877,0.061137,0.073227,0.082893,0.089386,0.095114,0.098015,0.096412,0.099229,0.093773,0.089091,0.093846],"unified_progress":[0.034387,0.056278,0.07061,0.080531,0.086869,0.093488,0.093712,0.095573,0.099355,0.09571,0.096779,0.096708]},{"section":21,"text":"So the answer is arterial embolism.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.024391,0.049,0.058551,0.065528,0.072316,0.078364,0.085061,0.089475,0.097117,0.10026,0.1115,0.16843],"unified_progress":[0.023642,0.036049,0.044663,0.054081,0.059467,0.071107,0.075652,0.088831,0.099882,0.10813,0.14472,0.19378]}]}}