.069778,0.060972]},{"section":16,"text":"That's when someone on antipsychotic meds develops severe muscle issues, high fever, and autonomic instability.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.038558,0.049554,0.059812,0.071758,0.083647,0.093833,0.10272,0.10517,0.11037,0.11825,0.10095,0.065375],"unified_progress":[0.042268,0.063806,0.079444,0.089712,0.095724,0.10419,0.099886,0.099304,0.095045,0.089196,0.077541,0.063882]},{"section":17,"text":"Yeah, that makes sense because all these symptoms match up with NMS.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.026992,0.052484,0.061045,0.068082,0.07293,0.077137,0.080745,0.081146,0.087678,0.098204,0.1343,0.15925],"unified_progress":[0.029347,0.05003,0.061973,0.070584,0.077111,0.085197,0.086111,0.092009,0.095856,0.097987,0.11707,0.13672]},{"section":18,"text":"So, putting it all together, it looks like this is a classic case of Neuroleptic Malignancy Syndrome.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.020116,0.03297,0.041009,0.048343,0.053648,0.058779,0.06355,0.066667,0.075681,0.098967,0.18093,0.25934],"unified_progress":[0.017066,0.028803,0.036383,0.045407,0.050826,0.063636,0.067325,0.085819,0.0994,0.11191,0.15814,0.23529]},{"section":19,"text":"Everything lines up\u2014the timing with the medication, the specific symptoms, and the lab results.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.013337,0.022257,0.028637,0.035352,0.043781,0.053546,0.066958,0.079333,0.10024,0.13717,0.19929,0.2201],"unified_progress":[0.021523,0.032773,0.042927,0.05228,0.063888,0.079594,0.085423,0.098991,0.11454,0.12778,0.14126,0.13902]},{"section":20,"text":"Yep, I'm confident in saying that's what's going on here.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.081941,0.066059,0.062633,0.057848,0.061496,0.06779,0.074964,0.090907,0.089146,0.068309,0.082825,0.19608],"unified_progress":[0.16814,0.063793,0.055291,0.058321,0.066986,0.072276