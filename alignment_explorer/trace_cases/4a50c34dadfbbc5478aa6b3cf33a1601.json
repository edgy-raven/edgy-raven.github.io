"model_progress":[0.04303,0.078642,0.085455,0.090078,0.093544,0.098741,0.094738,0.09335,0.088278,0.088692,0.077185,0.068267],"unified_progress":[0.078189,0.098878,0.089178,0.087386,0.086629,0.088582,0.086279,0.088495,0.082673,0.080383,0.072385,0.060943]},{"section":16,"text":"No other drugs or infection, so that rules out other causes like an infection or another drug reaction.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.031809,0.068513,0.082517,0.089634,0.093436,0.096901,0.098637,0.097438,0.094846,0.093161,0.084512,0.068595],"unified_progress":[0.04786,0.079397,0.084636,0.090484,0.094016,0.094119,0.09422,0.095172,0.091553,0.091152,0.078349,0.059042]},{"section":17,"text":"Wait, could it be serotonin syndrome?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.032506,0.066268,0.081456,0.089624,0.095401,0.095786,0.097545,0.097745,0.094729,0.09459,0.084063,0.070288],"unified_progress":[0.044917,0.071274,0.085942,0.098004,0.098238,0.096534,0.10044,0.095647,0.090505,0.089701,0.074024,0.05477]},{"section":18,"text":"That can also have fever, rigidity, autonomic symptoms.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027604,0.059543,0.072777,0.083964,0.0936,0.09874,0.10407,0.10267,0.098707,0.096919,0.08853,0.072873],"unified_progress":[0.036194,0.058599,0.074928,0.083643,0.093666,0.10158,0.10139,0.10332,0.10064,0.099541,0.084344,0.062149]},{"section":19,"text":"But serotonin syndrome usually has more agitation, diarrhea, clonus, and different lab findings.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.020645,0.051664,0.06744,0.079898,0.089726,0.096947,0.10664,0.10899,0.10702,0.10503,0.096506,0.069498],"unified_progress":[0.027517,0.053901,0.071188,0.080919,0.093088,0.098039,0.10281,0.10847,0.10702,0.11328,0.089435,0.054332]},{"section":20,"text":"The patient here has akinesia, which is more like NMS.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026682,0.058212,0.069913,0