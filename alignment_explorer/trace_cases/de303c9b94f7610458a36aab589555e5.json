37]},{"section":12,"text":"Another possibility could be malingering, but that's usually for external gains like insurance or avoiding work, and there's no mention of that here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.037089,0.070043,0.079321,0.085924,0.090993,0.094224,0.097718,0.098512,0.094921,0.094155,0.085966,0.071134],"unified_progress":[0.043373,0.062538,0.0747,0.082483,0.090531,0.093885,0.097042,0.10095,0.099002,0.10218,0.087537,0.065781]},{"section":13,"text":"The key difference is that Munchausen is about the need to be seen as ill, not for tangible benefits.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.050738,0.079755,0.078301,0.082135,0.086882,0.090444,0.092283,0.093674,0.088506,0.09042,0.083042,0.083819],"unified_progress":[0.067294,0.062571,0.070113,0.076815,0.082712,0.089497,0.091341,0.095413,0.093243,0.094744,0.090632,0.085626]},{"section":14,"text":"So putting it all together: multiple unnecessary surgeries, fabricated medical history, persistent demand for tests, and lack of documentation.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.040472,0.071541,0.076578,0.079808,0.083686,0.087415,0.089843,0.092329,0.092741,0.095231,0.093949,0.096406],"unified_progress":[0.047392,0.059268,0.066635,0.074061,0.080419,0.088071,0.089671,0.094868,0.097551,0.10092,0.10241,0.098738]},{"section":15,"text":"Yep, Munchausen syndrome fits best here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028642,0.052011,0.061291,0.067563,0.072708,0.076353,0.082562,0.087016,0.094078,0.10102,0.11151,0.16524],"unified_progress":[0.028765,0.035777,0.04365,0.053008,0.058067,0.069962,0.074633,0.087733,0.099708,0.11006,0.14517,0.19348]}]}}