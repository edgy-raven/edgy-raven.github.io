055068]},{"section":17,"text":"The patient's history here doesn't mention liver issues, so maybe less likely unless there's a hidden history of alcohol-related liver disease.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.030876,0.066651,0.078676,0.086685,0.094198,0.10421,0.10122,0.10119,0.09736,0.093506,0.082632,0.062808],"unified_progress":[0.078537,0.10977,0.095372,0.089298,0.088814,0.088223,0.085318,0.089249,0.08252,0.079279,0.065357,0.04826]},{"section":18,"text":"But the question doesn't state that, so maybe not the first thought.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31769,0.051882,0.052653,0.061423,0.064565,0.063992,0.064494,0.068805,0.067605,0.066411,0.068199,0.052278],"unified_progress":[0.22484,0.093624,0.068382,0.065144,0.077511,0.07348,0.086282,0.077914,0.073047,0.058887,0.052975,0.047916]},{"section":19,"text":"Peptic ulcers can bleed, but they might present with more chronic symptoms or pain, and the hematemesis could be from an ulcer eroding into a vessel.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.038399,0.082391,0.059178,0.10039,0.10543,0.10178,0.10405,0.097925,0.09043,0.083298,0.07558,0.061152],"unified_progress":[0.057974,0.077692,0.060897,0.090766,0.097721,0.099452,0.10032,0.097549,0.093622,0.088988,0.07712,0.057897]},{"section":20,"text":"But the retching part is more specific to Mallory-Weiss.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.032709,0.068619,0.083125,0.090424,0.094061,0.093858,0.096235,0.094374,0.092054,0.091905,0.083544,0.079092],"unified_progress":[0.04639,0.06276,0.073733,0.084391,0.089529,0.092514,0.095205,0.096202,0.095195,0.09726,0.088977,0.077844]},{"section":21,"text":"Another thought: aortitis or other vascular issues?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.02309,0.057872,0.07566,0.086285,0.095576,0.099369,0.10264,0.10437,0.10363,0.098269,0.088215,0.065019],"unified_progress":[0.028898,0.067149,0.086493,0.099013,0.10149,0.1008,0.1039,0.10064,0.097305,0.090786,0.073342,0.050192]},{"section":22,"text":"Probably not.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.29838,0.049018,0.049595,0.059959,0.061052,0.064686,0.064471,0.072889,0.075684,0.070825,0.074914,0.058527],"unified_progress":[0.20648,0.076479,0.067157,0.066639,0.076,0.074878,0.093553,0.083348,0.079246,0.062781,0.058019,0.055414]},{"section":23,"text":"Gastric cancer is possible but less likely in this context without other symptoms like weight loss or dysphagia.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02303,0.053913,0.054404,0.093903,0.10224,0.099632,0.10857,0.10874,0.1036,0.096376,0.088995,0.066595],"unified_progress":[0.032297,0.062179,0.061773,0.087944,0.10226,0.097283,0.10228,0.11066,0.10719,0.10183,0.082784,0.051509]},{"section":24,"text":"So putting it together: forceful retching leading to a mucosal tear (Mallory-Weiss) after alcohol-induced vomiting.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.031443,0.06112,0.069802,0.078349,0.08547,0.091166,0.094884,0.09506,0.098202,0.094593,0.093365,0.10655],"unified_progress":[0.039591,0.051544,0.062984,0.07355,0.080405,0.088481,0.090499,0.093882,0.097986,0.096368,0.10644,0.11827]},{"section":25,"text":"The timing with the alcohol and the retching points towards that.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.028917,0.061826,0.075557,0.08323,0.088291,0.091593,0.095166,0.095578,0.097006,0.099052,0.094755,0.089028],"unified_progress":[0.047142,0.060761,0.068513,0.077103,0.083549,0.089018,0.091903,0.096557,0.099097,0.10271,0.098108,0.08554]},{"section":26,"text":"The food being vomited first makes sense because he was eating before, then retching caused the tear which led to bleeding.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.041163,0.074201,0.077036,0.082154,0.087642,0.093355,0.095999,0.096145,0.095254,0.091113,0.086395,0.079544],"unified_pr