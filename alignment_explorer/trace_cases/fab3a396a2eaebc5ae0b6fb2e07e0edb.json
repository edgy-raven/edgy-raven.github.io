0.026785]},{"section":3,"text":"That's not all; he was just in the woods in Massachusetts recently.","dimension":6,"group":5,"is_degenerate":false,"model_progress":[0.15873,0.16897,0.13395,0.10971,0.091351,0.076834,0.0651,0.053837,0.047694,0.041373,0.032303,0.020147],"unified_progress":[0.10205,0.1363,0.1154,0.10983,0.095545,0.091968,0.078342,0.075951,0.062054,0.05316,0.045102,0.0343]},{"section":4,"text":"Hmm, that could be important.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.15598,0.12996,0.11348,0.090477,0.08197,0.076322,0.071231,0.072535,0.060534,0.038642,0.037705,0.071164],"unified_progress":[0.23271,0.099965,0.07122,0.06612,0.078766,0.072628,0.084233,0.074196,0.06847,0.055083,0.050259,0.046348]},{"section":5,"text":"Now, looking at him, there's this distinctive rash - a bull's-eye pattern in the popliteal fossa.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.071038,0.090266,0.10387,0.11129,0.10968,0.10388,0.095168,0.083775,0.075318,0.070727,0.053291,0.031703],"unified_progress":[0.066966,0.10642,0.075385,0.1028,0.10504,0.10072,0.092357,0.088407,0.079851,0.072862,0.061907,0.047288]},{"section":6,"text":"That's ringing some bells.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.043947,0.11389,0.12286,0.12321,0.11568,0.10684,0.094557,0.077802,0.071343,0.057974,0.044813,0.027093],"unified_progress":[0.045648,0.090507,0.10481,0.10563,0.11398,0.1029,0.10091,0.087188,0.079708,0.068052,0.058647,0.042017]},{"section":7,"text":"It's like the classic sign you hear about when someone talks about Lyme disease.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.041845,0.07869,0.091111,0.10079,0.10629,0.10517,0.10239,0.093455,0.089594,0.084294,0.065455,0.040915],"unified_progress":[0.042635,0.074635,0.091486,0.10108,0.10555,0.10667,0.11141,0.091713,0.083081,0.075299,0.06473,0.051723]},{"section":8,"text":"Oh, and then there's the heart thing - an ECG showing a Mobitz I AV block.","dimension":9,"