8],"unified_progress":[0.087776,0.075905,0.080883,0.084373,0.090187,0.094778,0.092108,0.093571,0.085926,0.083022,0.070875,0.060596]},{"section":12,"text":"Onset is usually between 3 and 5 years, which fits this patient's age.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.050747,0.088589,0.086719,0.087193,0.090345,0.095618,0.093448,0.094804,0.086735,0.085494,0.075085,0.065224],"unified_progress":[0.074409,0.091417,0.090314,0.088025,0.088758,0.092714,0.08826,0.093196,0.083962,0.081865,0.069862,0.057216]},{"section":13,"text":"The presentation with proximal muscle weakness, like difficulty climbing stairs or standing from a sitting position, is classic.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.062436,0.10859,0.097308,0.088124,0.08686,0.091665,0.087531,0.092262,0.080731,0.076564,0.067878,0.060053],"unified_progress":[0.073578,0.096817,0.093888,0.091143,0.089409,0.094083,0.087783,0.091621,0.083251,0.077974,0.067083,0.05337]},{"section":14,"text":"Muscle biopsy in DMD typically shows variation in fiber size, necrosis, and regeneration, leading to those small fibers mentioned.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.045341,0.086184,0.093317,0.096412,0.096827,0.096219,0.095607,0.090846,0.087723,0.079913,0.070352,0.061258],"unified_progress":[0.061163,0.077839,0.092018,0.095759,0.099091,0.1002,0.095574,0.09204,0.088937,0.078576,0.065765,0.053035]},{"section":15,"text":"The absence of dystrophin on immunohistochemistry or Western blot is diagnostic.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.039214,0.080608,0.094345,0.099545,0.099205,0.0966,0.096789,0.090757,0.086984,0.080465,0.072181,0.063307],"unified_progress":[0.051439,0.076257,0.091262,0.098192,0.10275,0.10114,0.098766,0.091391,0.086782,0.077863,0.068031,0.056131]},{"section":16,"text":"Another condition that comes to mind is Becker Muscular Dystrophy (BMD), which is similar but has a later onset and milder symptoms.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030426,0.065381,0.079989,0.09239,0.10035,0.10297,0.10397,0.09851,0.090431,0.091955,0.076315,0.067315],"unified_progress":[0.036619,0.062587,0.08113,0.091636,0.096884,0.10834,0.10158,0.10089,0.09467,0.091375,0.075173,0.059118]},{"section":17,"text":"Since this child is 4 and presenting with significant issues, DMD is more likely.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.042135,0.077763,0.083335,0.08673,0.089616,0.093314,0.092709,0.09314,0.089601,0.089314,0.082476,0.079866],"unified_progress":[0.059133,0.076943,0.077747,0.081868,0.085153,0.088469,0.08829,0.092566,0.090031,0.091398,0.086956,0.081445]},{"section":18,"text":"Other possibilities might include other muscular dystrophies, but the absence of dystrophin is pretty specific.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.031109,0.067059,0.084058,0.091928,0.094269,0.092721,0.095077,0.093085,0.091132,0.094426,0.084777,0.080359],"unified_progress":[0.034028,0.062315,0.077364,0.087977,0.091966,0.09446,0.097286,0.096398,0.095616,0.098362,0.088255,0.075975]},{"section":19,"text":"For example, in myotonic dystrophy, there's a different protein involved.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026553,0.060523,0.076535,0.089838,0.099692,0.10312,0.10537,0.10152,0.094582,0.094732,0.08045,0.06708],"unified_progress":[0.031265,0.05843,0.078152,0.089805,0.097882,0.10687,0.10524,0.1046,0.099507,0.095278,0.076819,0.05616]},{"section":20,"text":"Also, congenital muscular dystrophies might present earlier, but the age here is a bit older.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023531,0.055272,0.070341,0.081536,0.090288,0.097064,0.1042,0.10612,0.10449,0.10261,0.094204,0.070346],"unified_progress":[0.032645,0.059153,0.073293,0.082211,0.092621,0.096559,0.10028,0.10612,0.10439,0.11062,0.085513,0.056599]},{"section":21,"text":"So putting it all together, the absence of dystrophin and the clinical presentation point strongly to Duchenne Muscular Dystrophy.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.03365,0.061763,0.070937,0.077217,0.080641,0.082613,0.086697,0.088655,0.091381,0.09694,0.098319,0.13118],"unified_progress":[0.038152,0.046865,0.056417,0.067032,0.072074,0.0797,0.085707,0.089663,0.09391,0.10108,0.12039,0.14901]}]}}