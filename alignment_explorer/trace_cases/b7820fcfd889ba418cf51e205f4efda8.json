065273,0.058953,0.055587,0.056899,0.055263,0.050189,0.051043,0.038935],"unified_progress":[0.23873,0.10509,0.070045,0.06482,0.078651,0.071005,0.084386,0.072182,0.066919,0.053585,0.049491,0.045098]},{"section":6,"text":"First, the symptoms: nausea and vomiting can be caused by a lot of things, like gastrointestinal issues, pregnancy, migraines, or even anxiety.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.06197,0.1308,0.080879,0.12267,0.10839,0.095327,0.085805,0.077284,0.068603,0.062456,0.056683,0.04913],"unified_progress":[0.065262,0.10975,0.073931,0.09521,0.098661,0.096248,0.089832,0.089349,0.083888,0.078671,0.0691,0.050093]},{"section":7,"text":"Leg pain might be musculoskeletal, but since labs are normal, maybe not an infection or inflammation.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.038713,0.081553,0.094965,0.099009,0.099015,0.096295,0.096729,0.092857,0.088158,0.083292,0.073027,0.056386],"unified_progress":[0.039437,0.07107,0.083458,0.092279,0.098109,0.09713,0.098304,0.098161,0.095387,0.09442,0.077577,0.054668]},{"section":8,"text":"But the key here is that all tests are normal, yet she's persistently seeking more investigations and treatment.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.051491,0.095512,0.099313,0.096287,0.092078,0.089413,0.086283,0.085204,0.080338,0.081959,0.072475,0.069646],"unified_progress":[0.052986,0.080353,0.082953,0.088384,0.089427,0.089587,0.09385,0.091644,0.088579,0.090587,0.081667,0.069982]},{"section":9,"text":"That makes me think of a psychological component rather than a physical one.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.050361,0.095432,0.11432,0.11484,0.10213,0.085775,0.081129,0.075449,0.069847,0.081432,0.063496,0.065795],"unified_progress":[0.049071,0.071185,0.082038,0.095608,0.094734,0.092149,0.096366,0.091864,0.088067,0.096207,0.078951,0.063761]},{"section":10,"text":"So, possible diagnoses.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.04348,0.087113,0.10885,0.11193,0.10298,0.089496,0.083995,0.07878,0.075368,0.079225,0.067888,0.07089],"unified_progress":[0.044084,0.068716,0.08116,0.093999,0.093072,0.090815,0.093992,0.090884,0.089044,0.095395,0.083959,0.074879]},{"section":11,"text":"Malingering is when someone fakes symptoms for some gain, but that's usually intentional.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.047584,0.083067,0.088878,0.093907,0.096516,0.095531,0.094458,0.091522,0.084997,0.08373,0.073864,0.065946],"unified_progress":[0.05738,0.067307,0.077849,0.084322,0.090867,0.095132,0.095295,0.09707,0.093197,0.092953,0.081099,0.067528]},{"section":12,"text":"Factitious disorder is when someone fabricates symptoms for the sake of playing the patient role.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.055582,0.090028,0.086718,0.088619,0.092342,0.095097,0.09375,0.092942,0.083636,0.082995,0.071849,0.066442],"unified_progress":[0.066681,0.072013,0.080869,0.084682,0.089231,0.095333,0.093893,0.096322,0.090654,0.087908,0.077022,0.065392]},{"section":13,"text":"Then there's somatic symptom disorder, which is when a person has physical symptoms without a medical cause and is excessively worried about them.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.051367,0.088311,0.08826,0.089356,0.092021,0.093816,0.093286,0.09277,0.084125,0.084448,0.073417,0.068825],"unified_progress":[0.055987,0.072066,0.082242,0.086716,0.09,0.095325,0.094075,0.09608,0.091206,0.089604,0.079105,0.067594]},{"section":14,"text":"In this case, her symptoms might be real to her, but there's no lab or physical evidence.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.052039,0.089914,0.093635,0.093012,0.091044,0.089407,0.088076,0.087619,0.082802,0.084742,0.075391,0.072319],"unified_progress":[0.059772,0.074034,0.079426,0.08699,0.089532,0.090881,0.091575,0.092987,0.089867,0.091638,0.08229,0.071009]},{"section":15,"text":"The persistence in seeking tests and treatment despite normal results points towards a psychological issue.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.043486,0.081531,0.088869,0.090679,0.090832,0.090472,0.090369,0.089486,0.086188,0.087205,0.081096,0.079788],"unified_progress":[0.050274,0.069251,0.075265,0.082374,0.085761,0.089379,0.090922,0.093035,0.092631,0.095453,0.091429,0.084226]},{"section":16,"text":"Somatic symptom disorder (SSD) fits here because it involves somatic symptoms with excessive thoughts or behaviors related to those symptoms.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.042234,0.074769,0.080381,0.086141,0.09061,0.092046,0.093536,0.091955,0.087634,0.088812,0.082485,0.089397],"unified_progress":[0.047454,0.059031,0.071103,0.077804,0.08365,0.091868,0.092032,0.095387,0.09508,0.095914,0.095239,0.095438]},{"section":17,"text":"The DSM-5 criteria for SSD include having one or more distressing somatic symptoms, excessive thoughts about the symptoms, and disproportionate levels of anxiety.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.05039,0.087432,0.084791,0.084804,0.088153,0.091658,0.091783,0.092342,0.085988,0.085967,0.078448,0.078244],"unified_progress":[0.054302,0.071874,0.077575,0.081269,0.085343,0.091864,0.091204,0.095264,0.092512,0.091474,0.086676,0.080643]},{"section":18,"text":"Another possibility is conversion disorder, but that usually presents with neurological symptoms like weakness or blindness, which aren't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027694,0.061369,0.074906,0.084489,0.091728,0.095994,0.10256,0.10311,0.10066,0.098166,0.090171,0.069155],"unified_progress":[0.031075,0.058518,0.074455,0.083169,0.092864,0.096751,0.10038,0.10457,0.10349,0.10798,0.087227,0.059527]},{"section":19,"text":"Factitious disorder might be considered, but it's more about falsifying symptoms, which is harder to assess without more info.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02333,0.053579,0.067572,0.078373,0.087442,0.094353,0.10293,0.10641,0.10546,0.1044,0.097555,0.078594],"unified_progress":[0.029548,0.053998,0.068691,0.078258,0.088464,0.093757,0.099303,0.10577,0.10565,0.11207,0.094971,0.069526]},{"section":20,"text":"Since she's seeking treatment for herself, not fabricating for secondary gain, SSD is more likely.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.036913,0.067738,0.072034,0.077182,0.083535,0.09045,0.09422,0.097807,0.09701,0.097358,0.093225,0.092527],"unified_progress":[0.049861,0.063663,0.068322,0.073778,0.079721,0.085398,0.08919,0.094849,0.095808,0.099945,0.099978,0.099488]},{"section":21,"text":"So putting it all together, the most likely diagnosis is Somatic Symptom Disorder.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.031558,0.052601,0.058538,0.064573,0.070594,0.075542,0.082402,0.087435,0.093971,0.10042,0.11144,0.17092],"unified_progress":[0.03409,0.035883,0.043103,0.052124,0.057029,0.067152,0.07265,0.083636,0.094367,0.10659,0.14661,0.20677]}]}}