7],"unified_progress":[0.084845,0.096305,0.098146,0.090472,0.090616,0.093757,0.087174,0.090897,0.078622,0.074345,0.062753,0.052068]},{"section":9,"text":"Topic shifting could be part of flight of ideas, which is a sign of mania.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.05582,0.093957,0.097514,0.099613,0.0998,0.096635,0.093808,0.088046,0.077823,0.076755,0.063019,0.057209],"unified_progress":[0.060062,0.073897,0.090684,0.093359,0.095474,0.10004,0.095741,0.093912,0.087169,0.083392,0.069606,0.056664]},{"section":10,"text":"The increased social activity, like chatting a lot, also fits with increased goal-directed activity common in manic episodes.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.057596,0.097682,0.094271,0.092265,0.092722,0.093695,0.091093,0.08932,0.080673,0.078541,0.06863,0.063512],"unified_progress":[0.062577,0.07862,0.083911,0.087267,0.09044,0.095284,0.092246,0.093744,0.088846,0.085736,0.076766,0.064562]},{"section":11,"text":"Wait, could it be just hyperthyroidism?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.044307,0.080899,0.091802,0.095785,0.097277,0.094646,0.093765,0.092303,0.086928,0.086376,0.074397,0.061515],"unified_progress":[0.052806,0.076187,0.088492,0.098884,0.098332,0.096203,0.097342,0.094214,0.088454,0.086615,0.07057,0.051901]},{"section":12,"text":"But hyperthyroidism has physical symptoms like weight loss, tremors, maybe heat intolerance.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.034029,0.070764,0.081637,0.089574,0.09617,0.099557,0.10215,0.1,0.093575,0.090423,0.080081,0.062043],"unified_progress":[0.039867,0.067267,0.082435,0.089057,0.097489,0.10173,0.10103,0.10185,0.096767,0.094287,0.076063,0.052159]},{"section":13,"text":"The case doesn't mention those.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31551,0.052172,0.053142,0.062,0.063117,0.064201,0.062316,0.070297,0.06998,0.06564,0.068175,0.053449],"unified_progress":[0.20507,0.078368,0.065754,0.06534,0.07551,0.075154,0.095993,0.084164,0.080325,0.063699,0.056925,0.053695]},{"section":14,"text":"So maybe not.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.29812,0.053109,0.26755,0.059033,0.040795,0.038907,0.035741,0.041814,0.044923,0.044666,0.043449,0.031898],"unified_progress":[0.18034,0.060805,0.23827,0.080486,0.057607,0.05618,0.0558,0.064629,0.063305,0.052299,0.04685,0.043429]},{"section":15,"text":"Bipolar disorder comes to mind, specifically a manic episode.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.059173,0.12442,0.08665,0.12203,0.10482,0.093846,0.083141,0.075583,0.068704,0.063319,0.05841,0.059899],"unified_progress":[0.061544,0.093883,0.078909,0.10193,0.098536,0.096367,0.087736,0.085394,0.080564,0.07651,0.071401,0.067228]},{"section":16,"text":"The key features here are the pressured speech, flight of ideas, and increased social activity.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.054327,0.096344,0.094917,0.091165,0.092072,0.092012,0.089313,0.087583,0.081346,0.079015,0.073596,0.068311],"unified_progress":[0.05648,0.077371,0.082968,0.086141,0.090082,0.095332,0.091778,0.093482,0.089956,0.087718,0.080549,0.068142]},{"section":17,"text":"The patient is more talkative and loud, which aligns with the increased energy and euphoric mood in mania.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.058782,0.097681,0.091695,0.087796,0.08822,0.090689,0.088775,0.088866,0.081555,0.07999,0.073549,0.072403],"unified_progress":[0.064698,0.076937,0.079779,0.081914,0.085458,0.091538,0.089819,0.092958,0.08953,0.08808,0.083613,0.075675]},{"section":18,"text":"Another thought: maybe anxiety?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.034873,0.070535,0.087374,0.09425,0.097531,0.094608,0.095538,0.094756,0.091841,0.091902,0.080597,0.066194],"unified_progress":[0.040768,0.07183,0.086268,0.099845,0.098215,0.095994,0.098598,0.095758,0.091679,0.091518,0.074932,0.054594]},{"section":19,"text":"But anxiety might make someone more restless, but the topic shifting and excessive talking are more classic for mania.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.032427,0.066069,0.076092,0.083409,0.090461,0.094419,0.10004,0.10135,0.098254,0.096239,0.089208,0.07203],"unified_progress":[0.040516,0.063505,0.075539,0.082656,0.091857,0.095621,0.098026,0.1025,0.10004,0.10119,0.086044,0.062511]},{"section":20,"text":"Also, substance use could cause similar symptoms, like amphetamines.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.02977,0.062676,0.075584,0.084916,0.093329,0.097754,0.10108,0.10213,0.098465,0.097463,0.087354,0.069472],"unified_progress":[0.039607,0.066774,0.080377,0.089876,0.094382,0.097871,0.10042,0.10049,0.096914,0.095354,0.080245,0.057698]},{"section":21,"text":"But the case doesn't mention any substance use, so unless there's a hint, maybe not the first choice.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026936,0.058923,0.072902,0.081676,0.089748,0.096374,0.10055,0.10295,0.10241,0.099473,0.092779,0.07528],"unified_progress":[0.043653,0.073483,0.08027,0.087353,0.092063,0.092337,0.095657,0.098195,0.09507,0.098365,0.082832,0.06072]},{"section":22,"text":"So putting it all together, the most likely diagnosis is a manic episode, which is part of bipolar I disorder.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028782,0.051227,0.058886,0.066156,0.072531,0.077951,0.084283,0.088596,0.09407,0.10018,0.10988,0.16746],"unified_progress":[0.033556,0.038911,0.047426,0.057015,0.062306,0.071693,0.077209,0.084932,0.093401,0.10474,0.13987,0.18895]},{"section":23,"text":"The symptoms fit better here than other possibilities.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.02871,0.055982,0.067709,0.073752,0.077414,0.079973,0.085668,0.089891,0.095995,0.1027,0.10599,0.13622],"unified_progress":[0.028627,0.040353,0.04892,0.0590