]},{"section":19,"text":"But those are variations or associated conditions.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.019921,0.050582,0.068177,0.079342,0.089822,0.096283,0.10342,0.10667,0.10649,0.10406,0.097719,0.077503],"unified_progress":[0.036227,0.064007,0.076711,0.086084,0.093427,0.094603,0.098776,0.10252,0.09951,0.1023,0.085219,0.060612]},{"section":20,"text":"The fundoscopic findings are pointing more directly to RP.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.026302,0.05945,0.075036,0.083191,0.087336,0.089771,0.093877,0.094848,0.097952,0.098642,0.094574,0.099023],"unified_progress":[0.031511,0.056315,0.069556,0.081057,0.086296,0.090254,0.095266,0.095423,0.097673,0.099748,0.099085,0.097816]},{"section":21,"text":"The optic disc changes: waxy pallor could be from long-standing disease leading to optic nerve damage, but not necessarily glaucoma since pressure is normal.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030575,0.066833,0.079156,0.087383,0.091736,0.095939,0.097915,0.095919,0.098631,0.091595,0.085714,0.078604],"unified_progress":[0.036461,0.063785,0.079221,0.091449,0.096137,0.098449,0.098259,0.096601,0.097563,0.089729,0.081749,0.070597]},{"section":22,"text":"Maybe the optic atrophy is part of the retinal degeneration's effect.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.030592,0.064323,0.076608,0.086294,0.092656,0.096943,0.099995,0.097719,0.098712,0.09245,0.085671,0.078037],"unified_progress":[0.044193,0.060336,0.074421,0.084629,0.092125,0.09587,0.097245,0.097314,0.098489,0.093257,0.086652,0.075469]},{"section":23,"text":"Putting it all together: Night blindness (nyctalopia) is an early symptom of RP due to rod photoreceptor degeneration.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.03436,0.068524,0.079831,0.088542,0.094303,0.096466,0.098243,0.095194,0.090838,0.092354,0.082144,0.079201],"unified_progress":[0.040564,0.060226,0.075585,0.085098,0.091054,0.10067,0.099083,0.098639,0.096177,0.094076,0.084857,0.073972]},{"section":24,"text":"The bone spicules, narrowed visual fields (tubular vision), and ring scotomas all fit.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.030338,0.062076,0.071802,0.079581,0.086982,0.092879,0.09671,0.096798,0.099835,0.097661,0.097001,0.088339],"unified_progress":[0.036816,0.057186,0.070111,0.079411,0.08842,0.098475,0.097642,0.099606,0.10196,0.098944,0.093426,0.078008]},{"section":25,"text":"The optic disc changes might be from secondary optic atrophy as the retinal degeneration progresses.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.028658,0.060891,0.072544,0.082659,0.090031,0.096005,0.10044,0.098773,0.10068,0.094841,0.090374,0.084108],"unified_progress":[0.038676,0.053019,0.067246,0.077834,0.088136,0.095588,0.097498,0.099235,0.10334,0.1001,0.09547,0.083849]},{"section":26,"text":"So the most likely diagnosis is retinitis pigmentosa.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.021033,0.042711,0.052859,0.060966,0.069438,0.076691,0.084606,0.089962,0.09845,0.10267,0.11735,0.18327],"unified_progress":[0.020356,0.030958,0.040058,0.049654,0.055374,0.070249,0.075405,0.091372,0.10476,0.11218,0.15077,0.19887]}]}}