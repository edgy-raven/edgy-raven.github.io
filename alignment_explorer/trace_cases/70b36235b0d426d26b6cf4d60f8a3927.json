.063268,0.064088,0.073141,0.072831,0.098582,0.080681,0.078043,0.063038,0.058732,0.057123]},{"section":12,"text":"First, alcohol withdrawal typically starts within 8-24 hours after the last drink, right?","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.077387,0.15244,0.060788,0.09603,0.092214,0.096393,0.08513,0.079616,0.074048,0.069019,0.062182,0.054749],"unified_progress":[0.097893,0.11137,0.066901,0.094516,0.090689,0.09983,0.086517,0.083959,0.079133,0.073734,0.064216,0.051238]},{"section":13,"text":"The tremors and restlessness fit with the early symptoms.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.052257,0.094909,0.098563,0.095537,0.095359,0.093167,0.091652,0.088518,0.081251,0.078525,0.069741,0.06052],"unified_progress":[0.076613,0.083769,0.087444,0.090604,0.092451,0.093784,0.090535,0.091327,0.084289,0.082567,0.070492,0.056123]},{"section":14,"text":"Seizures can occur around 12-48 hours after stopping.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.050403,0.088479,0.090435,0.092837,0.095574,0.096983,0.09536,0.09205,0.084251,0.081035,0.070688,0.061907],"unified_progress":[0.060951,0.078009,0.088343,0.090492,0.093835,0.098325,0.09464,0.094067,0.087814,0.08387,0.071786,0.057868]},{"section":15,"text":"But delirium tremens usually presents later, like 2-4 days after cessation.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.04385,0.078061,0.083853,0.090531,0.095945,0.098018,0.098501,0.094964,0.087475,0.086255,0.074648,0.067898],"unified_progress":[0.052523,0.066866,0.082463,0.088431,0.09344,0.09972,0.097348,0.097161,0.092129,0.089238,0.076892,0.06379]},{"section":16,"text":"Wait, the patient here is only one day after abstinence.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.046773,0.082866,0.085221,0.087839,0.092439,0.098534,0.095534,0.095189,0.089551,0.085071,0.076945,0.064039],"unified_progress":[0.099642,0.097894,0.088505,0.086253,0.086606,0.087151,0.084404,0.08802,0.080328,0.077384,0.067865,0.05595]},{"section":17,"text":"So maybe the seizures are part of the acute withdrawal seizures, but the delirium might be coming on early.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.045017,0.078206,0.085041,0.089969,0.092467,0.092559,0.093978,0.092732,0.088644,0.088168,0.079079,0.074139],"unified_progress":[0.06221,0.070541,0.079589,0.087081,0.090842,0.091785,0.092493,0.092408,0.090036,0.090813,0.081707,0.070494]},{"section":18,"text":"Alternatively, could it be alcohol withdrawal delirium even at this time?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.041131,0.074311,0.083483,0.089072,0.093405,0.093412,0.094858,0.0951,0.091549,0.091081,0.081294,0.071304],"unified_progress":[0.051266,0.070067,0.083116,0.093101,0.094347,0.094715,0.096487,0.094992,0.091383,0.089228,0.077833,0.063465]},{"section":19,"text":"The symptoms of confusion, disorientation (thinking he's in jail), and perceptual disturbances (like hallucinations maybe, though not mentioned here) are classic for delirium tremens.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.043979,0.081119,0.082485,0.084886,0.089719,0.094083,0.095773,0.095924,0.090911,0.087748,0.081186,0.072187],"unified_progress":[0.050203,0.072884,0.08008,0.084317,0.090013,0.095842,0.094489,0.09684,0.093983,0.091919,0.082352,0.06708]},{"section":20,"text":"The coarse tremors and seizures also align.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.036363,0.072017,0.08153,0.086726,0.090752,0.093161,0.095663,0.094829,0.094542,0.091245,0.086376,0.076797],"unified_progress":[0.052998,0.068403,0.077544,0.084859,0.090922,0.094496,0.094921,0.095527,0.095012,0.092747,0.0838,0.068771]},{"section":21,"text":"Wait, the patient isn't mentioned to have hallucinations, but the disorientation and altered mental status are there.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.039044,0.072155,0.078083,0.082158,0.087928,0.