093031,0.097531,0.097437,0.10064,0.10121,0.10012,0.098638,0.081518,0.060438]},{"section":17,"text":"Hydatid disease (echinococcosis) is the main suspect here.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026732,0.059545,0.074851,0.087236,0.095492,0.098463,0.10046,0.097096,0.092786,0.09321,0.084211,0.089921],"unified_progress":[0.029991,0.053179,0.069767,0.082786,0.08896,0.10333,0.098673,0.099035,0.097253,0.095145,0.091673,0.090211]},{"section":18,"text":"The patient's exposure to dogs and livestock increases his risk.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.029556,0.063294,0.07532,0.084146,0.093086,0.10326,0.10112,0.1011,0.098023,0.095199,0.086631,0.069272],"unified_progress":[0.10111,0.10738,0.089798,0.082657,0.083092,0.084163,0.081479,0.087134,0.080879,0.076435,0.069153,0.056719]},{"section":19,"text":"The chronic symptoms over months also align with the slow-growing cysts of echinococcosis.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.032604,0.06754,0.079045,0.086338,0.090352,0.093562,0.095577,0.094617,0.094467,0.094089,0.086626,0.085184],"unified_progress":[0.047046,0.069736,0.080461,0.086885,0.090648,0.09258,0.092874,0.091733,0.092168,0.092697,0.085427,0.077746]},{"section":20,"text":"I don't think other parasites like schistosomiasis would present with liver calcifications like that.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.029289,0.063189,0.076728,0.085796,0.091547,0.094755,0.09929,0.099008,0.097764,0.096596,0.088361,0.077677],"unified_progress":[0.03455,0.060298,0.076591,0.0861,0.093574,0.097253,0.098706,0.10013,0.098891,0.099055,0.086276,0.06858]},{"section":21,"text":"So yeah, echinococcosis is the most likely.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.0235,0.049083,0.061435,0.069103,0.07493,0.079435,0.085397,0.089008,0.095291,0.09989,0.10899,0.16393],"unified_progress":[0.022976,0.037444,0.046937,0.057726,0.062499,0.072843,0.077348,0.