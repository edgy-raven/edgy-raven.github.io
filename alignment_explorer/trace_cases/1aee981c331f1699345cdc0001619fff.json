42],"unified_progress":[0.055239,0.074047,0.082081,0.088034,0.09233,0.097418,0.094498,0.095416,0.091452,0.089708,0.077914,0.061863]},{"section":10,"text":"The rash is on the face, which is typical for systemic lupus erythematosus (SLE).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.045194,0.081155,0.088721,0.095594,0.098892,0.098165,0.097254,0.091634,0.08399,0.083901,0.070395,0.065105],"unified_progress":[0.050563,0.065829,0.083387,0.090322,0.095924,0.10189,0.099616,0.09767,0.092445,0.088232,0.074068,0.060052]},{"section":11,"text":"But she's on hydralazine, so maybe it's drug-induced lupus.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.058669,0.089451,0.090345,0.0928,0.092805,0.091622,0.089251,0.087026,0.081426,0.082527,0.07211,0.071969],"unified_progress":[0.082541,0.078153,0.081023,0.086052,0.08848,0.089627,0.088682,0.090633,0.085509,0.083538,0.07652,0.069242]},{"section":12,"text":"But wait, drug-induced lupus usually presents with arthritis, serositis, and constitutional symptoms like fever.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.040033,0.073556,0.082957,0.091725,0.098007,0.09916,0.1004,0.095704,0.088303,0.087492,0.076188,0.066477],"unified_progress":[0.046903,0.064763,0.08542,0.089586,0.095971,0.10287,0.099968,0.098743,0.093741,0.090214,0.074542,0.057276]},{"section":13,"text":"The rash in drug-induced lupus might not be as classic as the malar rash seen in SLE.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.033583,0.068005,0.079572,0.090118,0.097502,0.1004,0.10296,0.09871,0.092237,0.092016,0.078141,0.066756],"unified_progress":[0.038595,0.061236,0.080114,0.089964,0.096582,0.10301,0.10228,0.10201,0.09741,0.094562,0.076566,0.057682]},{"section":14,"text":"However, the scaling erythematous rash on the face could still be part of it.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.041663,0.078909,0.084944,0.08912,0.091741,0.094049,0.094818,0.093137,0.0921