4]},{"section":5,"text":"Next, the intraocular pressure was 18mm.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.052985,0.094609,0.10158,0.10827,0.10388,0.098659,0.095447,0.083907,0.075534,0.07132,0.063033,0.050769],"unified_progress":[0.048297,0.084823,0.095622,0.10493,0.1048,0.098096,0.09588,0.089656,0.084346,0.077489,0.064707,0.051362]},{"section":6,"text":"Wait, that's quite low.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.3357,0.14323,0.076074,0.055636,0.063844,0.061713,0.054059,0.059524,0.052895,0.037705,0.038038,0.021579],"unified_progress":[0.21778,0.085073,0.070105,0.06676,0.07659,0.074917,0.087431,0.080001,0.075153,0.060367,0.055055,0.05077]},{"section":7,"text":"Normal IOP is usually around 10-21 mmHg, so 18 is within the normal range.","dimension":7,"group":7,"is_degenerate":false,"model_progress":[0.064182,0.087134,0.12607,0.13211,0.12575,0.10795,0.091874,0.075155,0.06322,0.051652,0.042338,0.032564],"unified_progress":[0.048249,0.085646,0.080955,0.10942,0.11274,0.10044,0.10849,0.089072,0.082295,0.074022,0.063035,0.045651]},{"section":8,"text":"So maybe the low pressure isn't the primary issue here.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.05668,0.083951,0.096702,0.10308,0.10286,0.098789,0.098304,0.086034,0.079356,0.075686,0.066632,0.051929],"unified_progress":[0.04519,0.072423,0.084814,0.094923,0.099442,0.096859,0.1005,0.095137,0.090023,0.088444,0.074946,0.057297]},{"section":9,"text":"Looking at the fundoscopic exam: attenuation of the aeroles and waxy pallor of the optic disc.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.029714,0.067383,0.09508,0.12584,0.12147,0.12144,0.1146,0.10072,0.078538,0.059679,0.048402,0.037141],"unified_progress":[0.033367,0.074868,0.096438,0.11425,0.11385,0.10705,0.10128,0.092057,0.095292,0.070097,0.056413,0.045039]},{"section":10,"text":"Waxy pallor suggests that the optic disc is edematous, which can be seen in conditions like papilledema, which is associated with increased intracranial pressure.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.039207,0.058212,0.079782,0.095598,0.10809,0.11253,0.11337,0.10671,0.09536,0.078994,0.061678,0.050477],"unified_progress":[0.038777,0.065888,0.085934,0.099852,0.10342,0.12304,0.10627,0.097546,0.090315,0.079565,0.062535,0.046865]},{"section":11,"text":"But wait, the IOP was normal, so maybe it's not due to papilledema from high pressure.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.04531,0.059013,0.079931,0.090138,0.096824,0.10037,0.10177,0.099556,0.096126,0.09116,0.080744,0.059052],"unified_progress":[0.045354,0.066902,0.08125,0.089422,0.097881,0.097479,0.09908,0.099519,0.095669,0.095061,0.077071,0.055313]},{"section":12,"text":"Alternatively, waxy pallor can also be seen in conditions like chronic glaucoma, where the optic disc becomes edematous over time.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.039327,0.053407,0.07238,0.085191,0.09647,0.1032,0.10544,0.10731,0.10346,0.093527,0.077723,0.062564],"unified_progress":[0.04054,0.063641,0.083151,0.093986,0.099514,0.10616,0.10307,0.10089,0.095805,0.088356,0.072327,0.052557]},{"section":13,"text":"Then there are bony corpuscles like spicules of pigmentation in the mid-peripheral retina.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.026492,0.060114,0.086349,0.10709,0.11565,0.11945,0.11857,0.10709,0.088078,0.069654,0.057487,0.043975],"unified_progress":[0.032463,0.072872,0.095076,0.10747,0.11333,0.10773,0.10301,0.094807,0.094832,0.073502,0.058416,0.046487]},{"section":14,"text":"That makes me think of a condition where there's a build-up of pigment in the retina, which could be related to something like retinal pigment epithelial changes.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.034298,0.056404,0.076874,0.093404,0.10251,0.10707,0.11261,0.10629,0.097779,0.088159,0.069061,0.055534],"unified_progress":[0.