generate":false,"model_progress":[0.049325,0.098091,0.1046,0.10339,0.097393,0.095487,0.090499,0.085126,0.087851,0.072363,0.063147,0.052726],"unified_progress":[0.046345,0.083931,0.095275,0.10495,0.10651,0.10093,0.098115,0.091034,0.09044,0.074775,0.061049,0.046644]},{"section":7,"text":"Fundoscopy shows arteriole attenuation and waxy optic disc pallor.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.048805,0.096391,0.1006,0.10057,0.096611,0.096288,0.091789,0.08648,0.089273,0.073454,0.064078,0.055662],"unified_progress":[0.047977,0.082753,0.095236,0.10419,0.10688,0.10345,0.098724,0.091566,0.090585,0.072583,0.058965,0.047093]},{"section":8,"text":"Waxy pallor usually indicates chronic optic atrophy, which could be from long-standing damage.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.037245,0.079835,0.093799,0.1009,0.10129,0.099304,0.097625,0.090526,0.088273,0.081896,0.068655,0.060657],"unified_progress":[0.043737,0.070131,0.087632,0.098305,0.10252,0.1067,0.10097,0.094945,0.091988,0.082008,0.067097,0.053962]},{"section":9,"text":"The key here is the \"bony corpuscles like spicules of pigmentation\" in the mid-peripheral retina.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.045603,0.089513,0.095118,0.097727,0.095602,0.096312,0.093159,0.088115,0.091272,0.077421,0.068226,0.061931],"unified_progress":[0.04866,0.077937,0.092001,0.1029,0.10566,0.10174,0.098476,0.09243,0.090926,0.074963,0.062133,0.052182]},{"section":10,"text":"That description sounds classic for bone spicule pigmentation, which I remember is a hallmark of retinitis pigmentosa.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.041192,0.077467,0.089108,0.097554,0.10027,0.098077,0.097507,0.090773,0.085141,0.083932,0.070464,0.068512],"unified_progress":[0.046292,0.063861,0.082788,0.093744,0.097629,0.11076,0.10091,0.095807,0.090896,0.084941,0.071614,0.060759]},{"section":11,"text":"Then the perimetry shows ring scotomas.","dimension":