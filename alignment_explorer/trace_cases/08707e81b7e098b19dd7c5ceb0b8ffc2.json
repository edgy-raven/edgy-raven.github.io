666,0.044442,0.041285]},{"section":17,"text":"High pressure without abnormal protein or glucose levels and no cells in the CSF makes me think it's not an infection or inflammation.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.03129,0.062229,0.087998,0.1067,0.11088,0.10984,0.10675,0.097744,0.089984,0.084768,0.067796,0.044011],"unified_progress":[0.047361,0.081865,0.084847,0.11121,0.11257,0.10349,0.097581,0.09211,0.083926,0.075248,0.063331,0.046466]},{"section":18,"text":"It's probably something causing non-infectious increased pressure.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.02207,0.054197,0.079817,0.099634,0.10854,0.11344,0.11293,0.1069,0.097817,0.091816,0.072138,0.040703],"unified_progress":[0.032951,0.069056,0.088839,0.10121,0.10307,0.10161,0.10307,0.098759,0.092995,0.087515,0.070504,0.050413]},{"section":19,"text":"Let's consider what could cause this.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.013075,0.054967,0.087802,0.10885,0.11511,0.1154,0.10905,0.10514,0.097692,0.090968,0.067671,0.034276],"unified_progress":[0.032817,0.069076,0.083426,0.10483,0.099464,0.096086,0.10343,0.094665,0.089967,0.093656,0.075611,0.056979]},{"section":20,"text":"Idiopathic Intracranial Hypertension, or IIH, fits the picture.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.017195,0.03655,0.05528,0.074378,0.092313,0.10669,0.11844,0.11992,0.12228,0.12387,0.0877,0.045387],"unified_progress":[0.026695,0.054243,0.075378,0.088777,0.099647,0.11402,0.1055,0.10347,0.097728,0.092565,0.076625,0.065352]},{"section":21,"text":"It's also known as pseudotumor cerebri, where you have high pressure without any obvious mass or infection.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.017185,0.031647,0.046995,0.064206,0.083291,0.1013,0.11655,0.1227,0.1305,0.13782,0.099326,0.048473],"unified_progress":[0.026278,0.052388,0.074526,0.091457,0.098773,0.11025,0.10938,0.10677,0.10111,0.094779,0.07579