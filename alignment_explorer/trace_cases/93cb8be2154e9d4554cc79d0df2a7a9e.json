86605,0.079165,0.081728,0.063885,0.050217]},{"section":8,"text":"The drop arm test is a classic sign for a rotator cuff injury, specifically the infraspinatus or supraspinatus tendon.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.050098,0.091943,0.10155,0.10627,0.10423,0.098364,0.093204,0.084517,0.078015,0.072557,0.060896,0.058358],"unified_progress":[0.050042,0.071795,0.091342,0.10064,0.10121,0.1043,0.09766,0.092431,0.087764,0.079095,0.066113,0.057603]},{"section":9,"text":"Wait, but the sudden drop when lowering the arm overhead...","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.061722,0.099233,0.095722,0.094248,0.093323,0.092538,0.08942,0.087219,0.081907,0.076089,0.067548,0.06103],"unified_progress":[0.076469,0.082683,0.087632,0.093535,0.095549,0.093908,0.091676,0.090942,0.085618,0.079705,0.067276,0.055008]},{"section":10,"text":"Oh right, the drop arm test is typically associated with a supraspinatus tear.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.044211,0.079736,0.088879,0.095974,0.098968,0.09766,0.096934,0.091195,0.085712,0.082155,0.070786,0.067791],"unified_progress":[0.05104,0.067608,0.087131,0.093997,0.096891,0.10328,0.097682,0.093919,0.089612,0.083262,0.071898,0.063683]},{"section":11,"text":"The supraspinatus is responsible for the initial abduction of the arm.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.040843,0.077159,0.084978,0.092965,0.0984,0.099949,0.1006,0.095264,0.089238,0.084377,0.072658,0.063574],"unified_progress":[0.074628,0.070289,0.08306,0.090825,0.095232,0.10015,0.096203,0.09474,0.088752,0.08116,0.068194,0.056766]},{"section":12,"text":"If it's torn, the patient can't control the arm when lowering it, so it drops.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.053648,0.087865,0.086298,0.089146,0.092485,0.094507,0.095074,0.093048,0.08733,0.082184,0.073001,0.065412],"unified_progress":[0.076024,0.078133,0.085146,0.088703,0.092362,0.095079,0.091938,0.092912,0.087267,0.081197,0.070938,0.060301]},{"section":13,"text":"External rotation weakness is also a sign of rotator cuff involvement because the infraspinatus and teres minor are responsible for external rotation.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039113,0.075557,0.086023,0.09458,0.098852,0.099451,0.099879,0.093978,0.089207,0.084936,0.072594,0.065831],"unified_progress":[0.049933,0.068019,0.0889,0.095138,0.098911,0.10424,0.09939,0.095138,0.090814,0.082403,0.069077,0.058033]},{"section":14,"text":"The patient's symptoms got worse with exercise, which makes sense because using a torn tendon would cause more pain and weakness.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.04211,0.079005,0.083315,0.087447,0.092279,0.09642,0.097556,0.095952,0.090603,0.086839,0.079136,0.069338],"unified_progress":[0.055079,0.068569,0.075155,0.080785,0.087859,0.095314,0.09392,0.096534,0.095545,0.093597,0.086757,0.070885]},{"section":15,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.033633,0.074384,0.095875,0.10154,0.098904,0.091761,0.091109,0.088036,0.085646,0.09181,0.076449,0.070852],"unified_progress":[0.03417,0.068956,0.081463,0.096053,0.096363,0.094666,0.097345,0.094542,0.092353,0.097895,0.081947,0.064248]},{"section":16,"text":"Maybe a nerve injury like axillary nerve palsy, but the distribution here points more to the rotator cuff.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030756,0.070494,0.086183,0.094534,0.097311,0.097924,0.09816,0.095252,0.094299,0.088688,0.078726,0.067673],"unified_progress":[0.03241,0.06514,0.083205,0.099439,0.10058,0.10096,0.10103,0.098241,0.09611,0.088932,0.074343,0.059613]},{"section":17,"text":"The axillary nerve affects the deltoid, leading to weakness in abduction, but the drop arm test is more specific for supraspinatus.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032273,0.068894,0.080527,0.090602,0.097053,0.10031,0.10179,0.097447,0.093963,0.088697,0.078129,0.070315],"unified_progress":[0.040201,0.062702,0.079431,0.091232,0.09749,0.10754,0.10148,0.099232,0.095777,0.087942,0.075023,0.061951]},{"section":18,"text":"Also, the patient's history of overexertion fits an acute injury rather than a chronic nerve issue.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.0337,0.068917,0.078947,0.086092,0.092373,0.099177,0.098796,0.09832,0.095288,0.093318,0.08394,0.071132],"unified_progress":[0.058121,0.083856,0.083039,0.084944,0.088775,0.092196,0.091389,0.094707,0.091524,0.089348,0.078923,0.063177]},{"section":19,"text":"Diabetes can contribute to neuropathies, but the physical exam findings are more consistent with a tendon injury.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029384,0.06314,0.076631,0.085534,0.091481,0.095803,0.099468,0.098771,0.097543,0.096649,0.089037,0.076559],"unified_progress":[0.042884,0.066734,0.07645,0.083782,0.090668,0.094009,0.096127,0.097948,0.097328,0.098016,0.087313,0.068742]},{"section":20,"text":"The medications don't seem directly related except maybe the steroids, but he's not on them.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.03369,0.069259,0.079705,0.08613,0.092271,0.10099,0.098725,0.099548,0.095839,0.09418,0.083913,0.065749],"unified_progress":[0.072382,0.10599,0.094616,0.089971,0.089267,0.08894,0.087578,0.089092,0.082389,0.079794,0.068701,0.051282]},{"section":21,"text":"So putting it all together, the most likely diagnosis is a rotator cuff tear, specifically involving the supraspinatus tendon.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.029488,0.057272,0.066963,0.074344,0.07896,0.082977,0.087735,0.088416,0.098062,0.094662,0.099885,0.14124],"unified_progress":[0.036909,0.05103,0.062377,0.07173,0.07593,0.079986,0.083491,0.085535,0.093094,0.0952,0.11719,0.14753]},{"section":22,"text":"The drop arm test is pathognomonic for that.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028031,0.056888,0.067829,0.075291,0.080914,0.084933,0.090106,0.092003,0.095913,0.099475,0.10156,0.12705],"unified_progress":[0.029108,0.04565,0.056854,0.066733,0.072364,0.08133,0.083554,0.091896,0.098939,0.10465,0.12149,0.14743]}]}}