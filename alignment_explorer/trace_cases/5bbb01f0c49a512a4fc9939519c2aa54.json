ress":[0.046389,0.061755,0.073032,0.079957,0.088676,0.095594,0.09669,0.098241,0.097897,0.098539,0.090224,0.073005]},{"section":13,"text":"The pruritic lesions... wait, celiac can sometimes present with skin manifestations like dermatitis herpetiformis, which is intensely itchy and typically on elbows, knees, and buttocks.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031594,0.067117,0.078418,0.089285,0.097781,0.10209,0.10399,0.099712,0.092373,0.092233,0.078076,0.067335],"unified_progress":[0.035035,0.059855,0.078618,0.086233,0.094857,0.10309,0.10359,0.10337,0.099139,0.095552,0.07998,0.060675]},{"section":14,"text":"That matches her lesions' location and the itching.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.041296,0.079806,0.087146,0.090204,0.091347,0.092314,0.093289,0.0926,0.090168,0.089301,0.08063,0.071899],"unified_progress":[0.047961,0.070625,0.078714,0.08664,0.092239,0.094855,0.095474,0.097228,0.095657,0.095628,0.081467,0.063513]},{"section":15,"text":"Her growth percentiles are lower, which could indicate failure to thrive or growth issues from malnutrition, common in untreated celiac.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.034688,0.070258,0.080919,0.08803,0.093387,0.097427,0.098513,0.0964,0.092666,0.090837,0.083227,0.073649],"unified_progress":[0.044714,0.067035,0.075232,0.08098,0.088074,0.094223,0.095376,0.097483,0.096945,0.096475,0.089472,0.073991]},{"section":16,"text":"The IgA tTG being so high makes me think this is the main issue.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.040269,0.078124,0.09213,0.096255,0.094039,0.089588,0.090301,0.08739,0.085066,0.087207,0.079293,0.080337],"unified_progress":[0.044188,0.067704,0.079327,0.088351,0.092448,0.092415,0.095074,0.092146,0.091086,0.091316,0.086606,0.07934]},{"section":17,"text":"The lactose intolerance might be a misdiagnosis if the real problem is celiac.","dimension":11,"group":5,"is_degenerate":false,"model_p