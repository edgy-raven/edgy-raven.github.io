687,0.072108,0.058888,0.052335],"unified_progress":[0.058385,0.077399,0.096081,0.097631,0.097787,0.099119,0.094784,0.091879,0.084784,0.082068,0.066424,0.053658]},{"section":7,"text":"The uprolling of the eyes might be a sign of that.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.065401,0.10444,0.10019,0.097588,0.094417,0.091541,0.087922,0.084575,0.077071,0.074059,0.06358,0.059219],"unified_progress":[0.074566,0.079922,0.085362,0.090835,0.093242,0.094296,0.091437,0.091573,0.0865,0.081894,0.071337,0.059034]},{"section":8,"text":"Let me think about the types of EPS.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.038864,0.07138,0.088851,0.096352,0.099592,0.096583,0.094884,0.091686,0.089895,0.086363,0.076551,0.068997],"unified_progress":[0.049973,0.075287,0.084617,0.10094,0.098521,0.093776,0.095022,0.090304,0.085853,0.094422,0.073351,0.057933]},{"section":9,"text":"There's dystonia, akathisia, tardive dyskinesia, and drug-induced parkinsonism.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037065,0.072167,0.08312,0.094631,0.1021,0.10378,0.10326,0.096142,0.086717,0.086908,0.071117,0.062987],"unified_progress":[0.042017,0.063276,0.082038,0.090442,0.099686,0.11073,0.10262,0.10027,0.093402,0.087827,0.070483,0.057211]},{"section":10,"text":"Dystonia can occur early, even after the first dose.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.043263,0.077567,0.084063,0.091315,0.096811,0.09891,0.098935,0.09514,0.087315,0.088494,0.073443,0.064744],"unified_progress":[0.054229,0.066168,0.080127,0.089663,0.095046,0.10069,0.099602,0.099157,0.093648,0.089929,0.073906,0.057836]},{"section":11,"text":"Oculogyric crisis is a form of dystonia where the eyes roll up.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.040375,0.075811,0.083176,0.092464,0.099434,0.10186,0.10208,0.096215,0.087352,0.08739,0.07047,0.063382],"unified_progress":[0.045269,0.064526,0.084205,0.092331,0.097744,0.10583,0.10263,0.10049,0.094492,0.087194,0.070301,0.054994]},{"section":12,"text":"That fits here.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31636,0.05184,0.05329,0.062772,0.063444,0.06391,0.060868,0.069568,0.071148,0.064662,0.069315,0.052822],"unified_progress":[0.20881,0.080365,0.06425,0.064862,0.074299,0.072882,0.10342,0.080881,0.077629,0.061413,0.056939,0.054248]},{"section":13,"text":"The timing is right because it happened the next day.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.075248,0.15279,0.068051,0.10155,0.091897,0.092681,0.081179,0.076562,0.071574,0.06761,0.062835,0.058022],"unified_progress":[0.088261,0.11335,0.069058,0.091714,0.090182,0.096658,0.085225,0.084173,0.08002,0.075931,0.069272,0.056156]},{"section":14,"text":"Also, the absence of spasticity and other neurological issues might rule out other causes.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.042192,0.084089,0.09327,0.094358,0.094172,0.093291,0.094607,0.092175,0.089356,0.08396,0.076334,0.062196],"unified_progress":[0.042247,0.073631,0.083716,0.09143,0.097358,0.096275,0.096947,0.096398,0.094481,0.092387,0.077797,0.057334]},{"section":15,"text":"Since the vision and ophthalmoscopic exam are normal, it's not an eye problem itself.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.040325,0.081787,0.091377,0.094463,0.093349,0.093427,0.093674,0.091063,0.092159,0.084359,0.076688,0.067328],"unified_progress":[0.041463,0.071674,0.084329,0.093302,0.098347,0.09704,0.098008,0.095218,0.095218,0.087884,0.07661,0.060906]},{"section":16,"text":"Drug-induced parkinsonism can cause rigidity and tremors, but the patient doesn't have spasticity.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.036612,0.072505,0.080853,0.087712,0.09327,0.096578,0.099615,0.098065,0.093454,0.09055,0.082027,0.068758],"unified_progress":[0.04112,0.065304,0.078694,0.086271,0.093888,0.10112,0.099625,0.10042,0.097102,0.094897,0.080741,0.060818]},{"section":17,"text":"Akathisia is more about restlessness.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034804,0.068859,0.077673,0.086131,0.093725,0.097991,0.1018,0.10051,0.094801,0.093226,0.082644,0.067839],"unified_progress":[0.044579,0.063951,0.078143,0.086333,0.093492,0.10036,0.10037,0.10171,0.097574,0.096197,0.079576,0.057711]},{"section":18,"text":"Tardive dyskinesia is a longer-term issue.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028812,0.061196,0.074697,0.087018,0.096186,0.10063,0.10473,0.10181,0.095904,0.096507,0.082876,0.069628],"unified_progress":[0.033837,0.056932,0.077119,0.087512,0.095424,0.10329,0.10352,0.104,0.10016,0.09807,0.080516,0.059615]},{"section":19,"text":"So oculogyric crisis from dystonic reaction due to haloperidol seems the most likely.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.031575,0.06095,0.07095,0.079134,0.085082,0.088638,0.092563,0.092523,0.093152,0.095214,0.09308,0.11714],"unified_progress":[0.034601,0.048086,0.06016,0.071448,0.077153,0.087213,0.088246,0.094069,0.097033,0.099314,0.11287,0.12981]},{"section":20,"text":"I should check if there are other possibilities, but given the info, this fits best.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.02685,0.05718,0.073917,0.082162,0.087867,0.09023,0.093541,0.095508,0.098726,0.099336,0.095672,0.099011],"unified_progress":[0.031674,0.056499,0.067687,0.080734,0.083837,0.086742,0.090785,0.095268,0.098327,0.10706,0.10343,0.097957]}]}}