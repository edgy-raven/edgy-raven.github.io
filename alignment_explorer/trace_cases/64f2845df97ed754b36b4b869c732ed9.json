3,0.10594,0.099445,0.088019,0.067573,0.048717]},{"section":4,"text":"So likely FNH.","dimension":8,"group":0,"is_degenerate":false,"model_progress":[0.033362,0.04906,0.060185,0.076269,0.082335,0.092432,0.10014,0.10203,0.09961,0.095139,0.10693,0.10251],"unified_progress":[0.018556,0.032935,0.042104,0.053174,0.059285,0.07471,0.076965,0.092125,0.098707,0.10726,0.15004,0.19414]},{"section":5,"text":"The lesion is oval, well-demarcated, central scar.","dimension":11,"group":1,"is_degenerate":false,"model_progress":[0.050283,0.073244,0.083736,0.08961,0.09324,0.093732,0.091925,0.098673,0.096018,0.09126,0.082035,0.056244],"unified_progress":[0.028918,0.057348,0.072121,0.083753,0.091765,0.09515,0.098259,0.10008,0.10341,0.099152,0.091873,0.078179]},{"section":6,"text":"So answer: Focal nodular hyperplasia.assistantfinal The description fits a classic focal nodular hyperplasia (FNH).","dimension":0,"group":9,"is_degenerate":false,"model_progress":[0.028106,0.039868,0.047675,0.056617,0.061326,0.073768,0.080759,0.092199,0.10781,0.12104,0.12722,0.1636],"unified_progress":[0.022713,0.036651,0.049201,0.059479,0.07167,0.083169,0.090884,0.099885,0.1094,0.11562,0.12883,0.1325]},{"section":7,"text":"FNH is a benign liver lesion that is most common in young women, often asymptomatic, and typically presents as a well\u2011demarcated oval mass with a central stellate scar.","dimension":9,"group":0,"is_degenerate":false,"model_progress":[0.021459,0.035332,0.044603,0.053559,0.058943,0.067484,0.069389,0.080588,0.10332,0.13369,0.17003,0.1616],"unified_progress":[0.014839,0.031389,0.044386,0.054556,0.063529,0.078423,0.083932,0.097225,0.1076,0.11275,0.13651,0.17487]},{"section":8,"text":"The surgical pathology of a single, well\u2011circumscribed lesion with a prominent central white scar is characteristic of FNH.","dimension":11,"group":1,"is_degenerate":false,"model_progress":[0.024359,0.035918,0.042103,0.047288,0.051331,0.057287,0.060259,0.072058,0.090023,0.1326,0.18724,0.19953],"unified_pro