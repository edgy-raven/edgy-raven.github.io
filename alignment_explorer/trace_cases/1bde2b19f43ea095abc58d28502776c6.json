275]},{"section":15,"text":"Herpes simplex or zoster can cause ulcers too, but they might have dendritic ulcers, not the feathery edges.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023491,0.056001,0.0711,0.084122,0.093565,0.099629,0.10662,0.10538,0.10203,0.1008,0.088581,0.068684],"unified_progress":[0.029575,0.056768,0.077927,0.086932,0.096447,0.10391,0.1039,0.10583,0.10345,0.10189,0.08081,0.052556]},{"section":16,"text":"The rural background and vegetative injury point more towards fungus.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.029199,0.063433,0.07724,0.085931,0.092052,0.097461,0.098591,0.098458,0.097769,0.096461,0.087999,0.075405],"unified_progress":[0.068725,0.081365,0.081557,0.085218,0.089063,0.09127,0.092668,0.093375,0.090774,0.088293,0.076692,0.061]},{"section":17,"text":"Common fungi in such cases are Fusarium or Aspergillus.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.027782,0.062171,0.077598,0.088807,0.096141,0.099588,0.10146,0.098012,0.093952,0.094287,0.082729,0.077477],"unified_progress":[0.038302,0.06725,0.085938,0.091379,0.095033,0.1017,0.098656,0.096168,0.092258,0.088482,0.077713,0.067118]},{"section":18,"text":"The symptoms and exam findings align with fungal keratitis.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.028968,0.06516,0.081704,0.089111,0.091308,0.091079,0.093594,0.09237,0.092701,0.095421,0.08921,0.089375],"unified_progress":[0.032422,0.059787,0.073201,0.085121,0.089982,0.094141,0.095252,0.09662,0.097117,0.099553,0.093036,0.083767]},{"section":19,"text":"I think that's the most likely diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.030377,0.061974,0.076879,0.083208,0.084945,0.083941,0.08647,0.087665,0.09052,0.095551,0.095416,0.12306],"unified_progress":[0.031461,0.047215,0.057662,0.068412,0.072705,0.079466,0.083945,0.090695,0.097025,0.10548,0.12193,0.144]}]}}