9,0.09541,0.096926,0.097063,0.092636,0.089793,0.087505,0.074981,0.074979],"unified_progress":[0.045886,0.061502,0.078414,0.089604,0.095192,0.10075,0.099003,0.097719,0.095572,0.087977,0.077806,0.070579]},{"section":8,"text":"The brown spots are probably the superficial lesions, maybe chocolate cysts if they're deeper.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.038471,0.078344,0.087484,0.093288,0.093952,0.095924,0.09546,0.091538,0.095062,0.084383,0.074904,0.07119],"unified_progress":[0.040529,0.06731,0.084066,0.09569,0.10139,0.10104,0.099493,0.096284,0.096807,0.083372,0.07149,0.062525]},{"section":9,"text":"The fact that they biopsied and found glands without atypia fits because endometriosis isn't cancerous.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.040648,0.079909,0.088638,0.09327,0.093496,0.094006,0.093657,0.09059,0.091174,0.085385,0.075932,0.073294],"unified_progress":[0.04269,0.068273,0.082748,0.093114,0.098688,0.099993,0.098853,0.095454,0.094424,0.085264,0.074745,0.065755]},{"section":10,"text":"No cytologic atypia rules out other neoplastic stuff.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.037109,0.076844,0.089082,0.094214,0.094792,0.094315,0.095292,0.092444,0.091122,0.086668,0.077997,0.070122],"unified_progress":[0.036595,0.068684,0.083804,0.093531,0.099425,0.10015,0.10088,0.096491,0.09426,0.087804,0.076118,0.062256]},{"section":11,"text":"The pain worsening with menstruation is typical because the ectopic tissue bleeds too.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.041761,0.080397,0.084034,0.086974,0.090828,0.095101,0.095795,0.095072,0.090808,0.087908,0.079742,0.071581],"unified_progress":[0.050806,0.069716,0.076927,0.083034,0.08903,0.096206,0.094953,0.097658,0.095966,0.092944,0.083795,0.068965]},{"section":12,"text":"So putting it all together, the diagnosis should be endometriosis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.039565,0.0670