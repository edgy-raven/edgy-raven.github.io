7328,0.081705,0.090161,0.094658,0.098034,0.1018,0.1012,0.10393,0.090951,0.069113]},{"section":24,"text":"Factitious disorder is another option, but it usually involves more deliberate symptoms.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.030325,0.050369,0.066365,0.07698,0.08908,0.096082,0.10456,0.10855,0.10826,0.10424,0.091155,0.074032],"unified_progress":[0.031262,0.055932,0.074249,0.085394,0.093748,0.10114,0.10283,0.10478,0.10215,0.10193,0.084876,0.061703]},{"section":25,"text":"Given the context, conversion disorder seems more likely because it's a common presentation where stress leads to physical symptoms without underlying pathology.","dimension":8,"group":0,"is_degenerate":false,"model_progress":[0.04173,0.052309,0.062431,0.070064,0.078868,0.085042,0.091915,0.097183,0.10054,0.10534,0.10588,0.10869],"unified_progress":[0.033393,0.050079,0.062024,0.071869,0.079514,0.089106,0.091164,0.097718,0.10011,0.10377,0.1086,0.11267]},{"section":26,"text":"The glove-like anesthesia is a classic presentation in such cases, especially when there's no trauma and the symptoms are unilateral and don't fit a typical nerve injury pattern.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.043661,0.056628,0.067152,0.074454,0.082363,0.087736,0.09457,0.098881,0.10182,0.10124,0.098796,0.092706],"unified_progress":[0.035106,0.054298,0.066824,0.075498,0.084073,0.092594,0.095013,0.10048,0.10274,0.10405,0.099725,0.08959]},{"section":27,"text":"So, putting it all together, the most likely diagnosis is conversion disorder, specifically a somatoform disorder where the symptom is anesthesia of the right hand following psychological stress.","dimension":8,"group":0,"is_degenerate":false,"model_progress":[0.02544,0.040047,0.047601,0.052872,0.060576,0.066612,0.0735,0.082632,0.090902,0.11711,0.14638,0.19633],"unified_progress":[0.01941,0.034146,0.043405,0.053064,0.058599,0.071824,0.075847,0.089063,0.099574,0.10869,0.14668,0.19969]},{"section":28,"text":"Th