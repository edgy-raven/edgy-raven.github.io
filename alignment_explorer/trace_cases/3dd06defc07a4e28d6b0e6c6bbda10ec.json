0.093623,0.070529],"unified_progress":[0.026369,0.053402,0.070081,0.08119,0.093276,0.099657,0.10199,0.10757,0.10702,0.11241,0.088337,0.05869]},{"section":22,"text":"So yeah, multiple myeloma is the most likely.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.019406,0.042949,0.055478,0.063884,0.071275,0.077578,0.084974,0.090356,0.097477,0.10315,0.11519,0.17829],"unified_progress":[0.018834,0.032551,0.041394,0.051777,0.057346,0.070136,0.075636,0.088202,0.09724,0.10843,0.14928,0.20917]}]}}