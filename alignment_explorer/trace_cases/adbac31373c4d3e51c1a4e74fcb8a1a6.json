96746,0.095066,0.091501,0.091671,0.07896,0.065369]},{"section":11,"text":"The clinical presentation with bilateral infiltrates and hilar lymphadenopathy is classic for sarcoidosis.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.039898,0.079149,0.09001,0.095651,0.095982,0.095125,0.093678,0.089262,0.088576,0.084587,0.076473,0.071608],"unified_progress":[0.042796,0.066414,0.081084,0.093883,0.096724,0.099805,0.097844,0.096112,0.094702,0.088586,0.077198,0.064851]},{"section":12,"text":"The Heerfordt syndrome or L\u00f6fgren's syndrome are subsets, but those usually have more specific symptoms like erythema nodosum or arthritis, which aren't mentioned here.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032483,0.068077,0.07971,0.090494,0.098482,0.10168,0.10371,0.099279,0.091771,0.090834,0.077548,0.065938],"unified_progress":[0.034281,0.059965,0.07865,0.088126,0.095968,0.10918,0.10359,0.10296,0.097851,0.095116,0.077026,0.057281]},{"section":13,"text":"The patient's job as a secretary doesn't suggest exposure to asbestos, silica, or other occupational hazards, so that rules out things like asbestosis or hypersensitivity pneumonitis.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.033501,0.069671,0.080823,0.088805,0.095062,0.10218,0.10035,0.098754,0.094938,0.091973,0.079943,0.063992],"unified_progress":[0.059498,0.088858,0.08838,0.089941,0.092774,0.09491,0.093277,0.094798,0.089998,0.08538,0.070168,0.052017]},{"section":14,"text":"Other possibilities might include berylliosis, but that's occupational and she doesn't have exposure.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02736,0.061126,0.075605,0.085748,0.093451,0.099762,0.10267,0.10242,0.098993,0.098076,0.087549,0.067242],"unified_progress":[0.047727,0.078068,0.086082,0.091156,0.094633,0.096915,0.096288,0.098192,0.092775,0.091487,0.074438,0.052238]},{"section":15,"text":"Wegener's granulomatosis (now called granulomatosis with polyangiitis) can have granulomas but they might be necrotizing, and there's usually other systemic symptoms like sinus issues or renal involvement.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.024362,0.056971,0.073014,0.088533,0.099616,0.10459,0.10909,0.10414,0.096182,0.096905,0.08079,0.065803],"unified_progress":[0.030437,0.056165,0.082155,0.091188,0.099466,0.11058,0.10629,0.10519,0.099517,0.094341,0.074177,0.0505]},{"section":16,"text":"Also, ANCA tests would be positive in that case, which I don't think are mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025164,0.059199,0.075671,0.085137,0.091071,0.095615,0.10259,0.10382,0.10261,0.09796,0.091624,0.069541],"unified_progress":[0.031018,0.06288,0.078792,0.087384,0.096582,0.096794,0.099333,0.10255,0.10031,0.10496,0.082591,0.056808]},{"section":17,"text":"Another thought: could it be a drug reaction?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.02127,0.052959,0.071285,0.082861,0.09421,0.098596,0.10318,0.10772,0.1049,0.10453,0.092641,0.065837],"unified_progress":[0.030301,0.067316,0.085663,0.098629,0.10095,0.10046,0.10508,0.10252,0.096755,0.092999,0.073191,0.046136]},{"section":18,"text":"But the case doesn't mention any recent medications.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.026588,0.059152,0.072009,0.080449,0.089283,0.097584,0.10144,0.10464,0.10338,0.10143,0.093573,0.070462],"unified_progress":[0.061516,0.088241,0.087375,0.08623,0.091563,0.090841,0.091195,0.096694,0.090953,0.089261,0.07474,0.05139]},{"section":19,"text":"The insidious onset also fits sarcoidosis better than some other conditions.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025478,0.057279,0.071624,0.081206,0.087987,0.093016,0.099947,0.10192,0.10143,0.10304,0.096152,0.080916],"unified_progress":[0.037751,0.063419,0.075637,0.084423,0.091971,0.094308,0.098477,0.1002,0.098731,0.10166,0.087434,0.065988]},{"section":20,"text":"Since the biopsy is non-necrotizing and the stains are negative, sarcoidosis is the most likely diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.027915,0.059108,0.072223,0.079014,0.082542,0.085255,0.089972,0.091634,0.095462,0.097336,0.099057,0.12048],"unified_progress":[0.030573,0.052431,0.063921,0.073599,0.07905,0.084508,0.088227,0.09151,0.095743,0.099415,0.11211,0.12891]},{"section":21,"text":"No other obvious exposures or systemic symptoms pointing elsewhere.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02423,0.056571,0.071175,0.079609,0.085421,0.090184,0.097189,0.10069,0.10273,0.1038,0.099942,0.088453],"unified_progress":[0.02778,0.053423,0.066047,0.075483,0.08451,0.088928,0.094984,0.10201,0.10521,0.11387,0.10331,0.084456]},{"section":22,"text":"Yeah, I think that's it.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.29812,0.048851,0.04986,0.059031,0.061105,0.064487,0.064081,0.073357,0.074336,0.072219,0.075413,0.059144],"unified_progress":[0.1902,0.072051,0.063015,0.06354,0.073924,0.076099,0.091837,0.089039,0.087107,0.071212,0.063521,0.058456]}]}}