.073239,0.080892,0.058893,0.045529]},{"section":6,"text":"First, the key points: young age, renal failure starting in adolescence, hematuria, hearing loss, and it's familial.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.062485,0.10738,0.11002,0.1051,0.096527,0.088913,0.082227,0.079065,0.071972,0.073132,0.064215,0.058976],"unified_progress":[0.064144,0.085243,0.08842,0.092976,0.093274,0.092896,0.091075,0.090225,0.084371,0.085313,0.073127,0.058936]},{"section":7,"text":"The combination of renal issues and hearing loss makes me think of Alport syndrome.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.050683,0.099403,0.12179,0.12155,0.10611,0.086838,0.08034,0.072463,0.066341,0.076198,0.058581,0.0597],"unified_progress":[0.045262,0.074555,0.086664,0.1003,0.098573,0.095179,0.095837,0.090818,0.086486,0.092435,0.074496,0.059398]},{"section":8,"text":"Alport is an inherited condition, often X-linked, but can be autosomal recessive or dominant.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.033771,0.072574,0.089341,0.10109,0.10758,0.106,0.10222,0.093612,0.084276,0.081609,0.06812,0.059803],"unified_progress":[0.059617,0.070363,0.083137,0.089394,0.096288,0.1043,0.098078,0.096662,0.08923,0.084296,0.069979,0.058658]},{"section":9,"text":"It's characterized by glomerulonephritis leading to renal failure and sensorineural hearing loss.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.033232,0.070389,0.082696,0.093983,0.10183,0.10437,0.10426,0.09701,0.087402,0.089017,0.071681,0.064135],"unified_progress":[0.038552,0.062296,0.082999,0.091025,0.096441,0.10558,0.10247,0.10015,0.095175,0.089855,0.075218,0.060231]},{"section":10,"text":"The hematuria is usually painless, which fits.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.037163,0.076678,0.087411,0.092779,0.09552,0.096109,0.097215,0.094283,0.08915,0.088252,0.077879,0.067561],"unified_progress":[0.052435,0.070361,0.08018,0.088102,0.093575,0.097095,0.09623,0.097029,0.093515,0.092497,0.078335,0.060645]},{"section":11,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.034713,0.077198,0.098952,0.104,0.10031,0.092061,0.090178,0.086816,0.083721,0.088351,0.07428,0.069419],"unified_progress":[0.035499,0.071083,0.083578,0.097451,0.0974,0.094939,0.09848,0.094169,0.090939,0.096057,0.0789,0.061505]},{"section":12,"text":"Maybe hereditary nephritis?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.028215,0.06497,0.08252,0.092464,0.099492,0.10006,0.1007,0.099159,0.094312,0.092493,0.080616,0.065002],"unified_progress":[0.034835,0.068107,0.084945,0.095094,0.099197,0.10148,0.1027,0.099509,0.09431,0.089951,0.073953,0.055918]},{"section":13,"text":"But that's another term for Alport syndrome.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024054,0.056478,0.073271,0.085094,0.094235,0.098613,0.1025,0.10156,0.098237,0.09713,0.088127,0.080695],"unified_progress":[0.03716,0.05986,0.074421,0.084682,0.091307,0.097001,0.098351,0.10021,0.097484,0.097708,0.086931,0.074889]},{"section":14,"text":"Let me think of other causes.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.021066,0.051191,0.072067,0.08333,0.0945,0.099477,0.10133,0.10213,0.10408,0.097771,0.091473,0.081584],"unified_progress":[0.032302,0.069724,0.082344,0.098689,0.097409,0.09477,0.10246,0.094803,0.091569,0.098426,0.079549,0.057958]},{"section":15,"text":"Polycystic kidney disease can cause renal failure and sometimes hearing loss, but usually presents with cysts and maybe liver issues.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02112,0.053618,0.070064,0.084071,0.094905,0.10162,0.10835,0.10627,0.10166,0.10047,0.088632,0.06922],"unified_progress":[0.029672,0.05763,0.074941,0.084183,0.096832,0.10601,0.10381,0.10653,0.10227,0.10032,0.079921,0.057882]},{"section":16,"text":"But the hematuria is more classic for Alport.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02348,0.056431,0.072154,0.082461,0.08933,0.094502,0.10204,0.10394,0.10298,0.10257,0.094817,0.075296],"unified_progress":[0.032689,0.056238,0.071343,0.081396,0.091485,0.096058,0.10055,0.10499,0.10409,0.10961,0.089247,0.062305]},{"section":17,"text":"Also, the age of onset here is a bit young for adult polycystic kidney disease, which typically shows up in 30s-50s.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.030452,0.063878,0.07486,0.084084,0.092082,0.098867,0.10148,0.10189,0.098004,0.097491,0.086523,0.070392],"unified_progress":[0.04816,0.074185,0.080381,0.085122,0.091039,0.09678,0.097413,0.099788,0.09596,0.09527,0.079061,0.056842]},{"section":18,"text":"Another thought: medullary cystic kidney disease?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.027514,0.06095,0.0763,0.087762,0.096697,0.10038,0.10306,0.10116,0.098741,0.095867,0.083339,0.06822],"unified_progress":[0.035899,0.066076,0.086476,0.09742,0.10045,0.1033,0.10309,0.099456,0.095312,0.088893,0.071645,0.051985]},{"section":19,"text":"But that usually doesn't have the hearing component.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018681,0.049093,0.066427,0.078375,0.088481,0.095422,0.10576,0.10958,0.10955,0.10688,0.10054,0.071198],"unified_progress":[0.026158,0.055548,0.072857,0.08247,0.09498,0.09706,0.10199,0.10866,0.10675,0.1134,0.086934,0.053192]},{"section":20,"text":"The family history is important.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.024509,0.056114,0.072449,0.081716,0.08966,0.094948,0.097881,0.099604,0.1004,0.1015,0.09666,0.084555],"unified_progress":[0.057185,0.071115,0.075306,0.081399,0.086828,0.091625,0.097701,0.096043,0.095006,0.0959,0.086022,0.06587]},{"section":21,"text":"Alport can be X-linked, so if the brother is affected, maybe the mother is a carrier.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.026518,0.058892,0.072422,0.083517,0.09368,0.10197,0.10412,0.1036,0.10055,0.096775,0.08852,0.069445],"unified_progress":[0.12334,0.097185,0.086503,0.082908,0.083255,0.085154,0.082807,0.087771,0.077295,0.074373,0.064991,0.054424]},{"section":22,"text":"Or autosomal recessive if both parents are carriers.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.02828,0.062318,0.075474,0.085799,0.094674,0.10269,0.1034,0.10213,0.098731,0.094146,0.084904,0.067448],"unified_progress":[0.10283,0.1059,0.098341,0.091517,0.087654,0.089632,0.082229,0.089544,0.074752,0.070202,0.059068,0.04833]},{"section":23,"text":"The combination of renal and hearing symptoms in a familial pattern points strongly to Alport.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.028826,0.062106,0.077653,0.086422,0.090994,0.092717,0.095547,0.094182,0.094631,0.098494,0.092302,0.086127],"unified_progress":[0.053847,0.072905,0.081444,0.089258,0.092092,0.09406,0.093192,0.091923,0.089537,0.091733,0.081281,0.068728]},{"section":24,"text":"I don't think it's something like Goodpasture syndrome because that involves anti-GBM antibodies and usually presents with rapid kidney failure and pulmonary hemorrhage, which isn't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02452,0.057232,0.071857,0.083282,0.092049,0.097532,0.10432,0.10463,0.10175,0.10053,0.091026,0.071279],"unified_progress":[0.031377,0.058965,0.077516,0.085472,0.096066,0.10024,0.1021,0.10414,0.10122,0.10191,0.08408,0.056902]},{"section":25,"text":"So putting it all together: progressive renal failure starting in teens, hematuria, sensorineural hearing loss, and familial.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.024365,0.05082,0.062575,0.071867,0.08203,0.09013,0.09607,0.099285,0.10396,0.10614,0.11055,0.10221],"unified_progress":[0.03435,0.050548,0.062924,0.073009,0.083454,0.096762,0.097737,0.10198,0.10519,0.10558,0.1033,0.08517]},{"section":26,"text":"Alport syndrome is the most likely diagnosis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.016353,0.03751,0.050289,0.058809,0.066707,0.073309,0.082486,0.088987,0.10012,0.10781,0.12584,0.19178],"unified_progress":[0.017981,0.029799,0.038369,0.047786,0.053955,0.071938,0.075282,0.094504,0.10718,0.11439,0.15062,0.1982]}]}}