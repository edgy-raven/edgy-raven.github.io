053693]},{"section":16,"text":"We've got a polyp with a tubular architecture, and there's a family history of colorectal cancer.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.063899,0.069578,0.074918,0.080008,0.082879,0.085234,0.087374,0.086355,0.088326,0.096677,0.10268,0.082072],"unified_progress":[0.063278,0.084839,0.060959,0.085256,0.090952,0.09382,0.097638,0.0914,0.089435,0.087262,0.082587,0.072575]},{"section":17,"text":"This combination makes me think about the possibility of a serrated pathway to cancer.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.031847,0.059122,0.075397,0.087242,0.093086,0.097411,0.099558,0.097599,0.097791,0.098571,0.091535,0.070841],"unified_progress":[0.037279,0.06385,0.080005,0.089499,0.093517,0.095663,0.097355,0.095909,0.094501,0.091511,0.085288,0.075624]},{"section":18,"text":"Serrated polyps can sometimes look similar on a biopsy, and they're known for being tricky because they can progress to cancer without much warning.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.031745,0.043851,0.05766,0.071657,0.084801,0.096935,0.10762,0.11106,0.11705,0.12278,0.097619,0.057218],"unified_progress":[0.038299,0.057553,0.076206,0.087286,0.095037,0.10404,0.10244,0.10204,0.098128,0.093763,0.080594,0.064616]},{"section":19,"text":"Given everything\u2014the age, the family history, the type of polyp\u2014it seems like we're dealing with something serious.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.027415,0.043054,0.053945,0.063634,0.071505,0.078737,0.086128,0.090811,0.098831,0.11343,0.13835,0.13416],"unified_progress":[0.033446,0.052198,0.063237,0.072925,0.079848,0.089844,0.090317,0.096057,0.099525,0.10132,0.10912,0.11217]},{"section":20,"text":"It's probably best to consider this a high-risk situation.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.029259,0.046095,0.059743,0.071423,0.07838,0.084024,0.087945,0.08896,0.092815,0.10214,0.12478,0.134