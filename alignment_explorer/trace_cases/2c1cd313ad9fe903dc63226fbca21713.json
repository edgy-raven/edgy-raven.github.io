e,"model_progress":[0.041031,0.077415,0.084959,0.089904,0.094702,0.1031,0.096616,0.095423,0.09,0.088702,0.076392,0.061758],"unified_progress":[0.090661,0.11842,0.099133,0.091143,0.087271,0.086826,0.083268,0.084601,0.076125,0.07138,0.062066,0.049106]},{"section":18,"text":"The combination of bone cysts, pathologic fractures, and jaw pain (which could be osteonecrosis of the jaw, but that's more related to bisphosphonates, which he might be on too?","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.037462,0.073611,0.08197,0.089225,0.095029,0.10052,0.10009,0.097437,0.092903,0.087675,0.077913,0.066169],"unified_progress":[0.057063,0.079278,0.09125,0.091127,0.094763,0.098389,0.093826,0.093062,0.089152,0.082584,0.072207,0.057298]},{"section":19,"text":"Wait, but the question doesn't mention that.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.32211,0.052602,0.053381,0.062153,0.063304,0.06396,0.061813,0.068895,0.068729,0.064379,0.067108,0.051567],"unified_progress":[0.2151,0.084831,0.06634,0.065347,0.075043,0.073121,0.090529,0.079314,0.075187,0.060735,0.056195,0.058258]},{"section":20,"text":"Alternatively, the brown tumor can affect the jaw as well.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.047432,0.099966,0.060947,0.099927,0.10171,0.099409,0.096575,0.092495,0.087076,0.080688,0.073105,0.060667],"unified_progress":[0.064242,0.089946,0.070499,0.10001,0.1028,0.1034,0.094947,0.092111,0.084827,0.078157,0.067824,0.051239]},{"section":21,"text":"So putting it together: chronic kidney disease leading to secondary hyperparathyroidism, which causes brown tumors (osteitis fibrosa cystica).","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.040256,0.069558,0.077138,0.085464,0.091678,0.093918,0.095621,0.092275,0.089425,0.088035,0.082682,0.093949],"unified_progress":[0.049844,0.057158,0.072133,0.081626,0.086093,0.095285,0.092905,0.092754,0.092867,0.09029,0.092583,0.096463]},{"section":22,"text":"The cystic bone lesions and fractures are classic.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031149,0.064684,0.077115,0.085715,0.090989,0.094247,0.097723,0.09548,0.097557,0.092609,0.08923,0.083502],"unified_progress":[0.055919,0.06131,0.073719,0.083491,0.08999,0.094083,0.093561,0.094798,0.095657,0.092244,0.087165,0.078062]},{"section":23,"text":"The jaw pain could be from a brown tumor there too.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.030158,0.064404,0.076003,0.084892,0.090528,0.095397,0.098454,0.096762,0.098781,0.092753,0.087773,0.084096],"unified_progress":[0.037396,0.057866,0.072528,0.083105,0.090426,0.094211,0.096108,0.09675,0.099828,0.096088,0.092007,0.083689]},{"section":24,"text":"Alternatively, could it be metastatic disease?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.022262,0.054215,0.071562,0.082716,0.093861,0.097926,0.10296,0.10691,0.10556,0.10237,0.092694,0.066951],"unified_progress":[0.030212,0.066478,0.085497,0.099494,0.1002,0.099074,0.10379,0.10055,0.096407,0.092046,0.074659,0.051597]},{"section":25,"text":"But he's on dialysis, but the bone cysts in multiple areas and the context of renal failure makes me lean more towards a metabolic bone disease.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.028502,0.061699,0.074329,0.083059,0.090292,0.097309,0.09963,0.10034,0.1002,0.097797,0.090384,0.076457],"unified_progress":[0.055548,0.082988,0.085533,0.088041,0.09239,0.093704,0.092337,0.094615,0.090853,0.086799,0.076415,0.060778]},{"section":26,"text":"Also, metastases are less likely to present as cystic lesions.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.020644,0.051509,0.067276,0.078844,0.087648,0.094568,0.10452,0.10704,0.10815,0.10555,0.099329,0.074919],"unified_progress":[0.030276,0.057502,0.073168,0.082183,0.094481,0.096347,0.10083,0.10528,0.10498,0.10722,0.088737,0.058997]},{"section":27,"text":"Another possibility is osteomalacia, but that's more about soft bones and fractures, maybe not cysts.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.020914,0.051506,0.067047,0.07921,0.089536,0.09669,0.10535,0.10854,0.10699,0.10546,0.096566,0.072187],"unified_progress":[0.029582,0.056765,0.073885,0.084654,0.09392,0.099372,0.10283,0.10702,0.10489,0.10629,0.085919,0.054869]},{"section":28,"text":"Adynamic bone disease from too much cinacalcet or excessive suppression of PTH might lead to fractures but not cysts.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029137,0.063116,0.076073,0.086206,0.09434,0.09925,0.10305,0.10164,0.097066,0.094741,0.08447,0.070909],"unified_progress":[0.036519,0.064436,0.0798,0.089156,0.09595,0.1019,0.10118,0.10084,0.09714,0.092324,0.079823,0.060936]},{"section":29,"text":"So the most likely diagnosis here is osteitis fibrosa cystica, which is part of renal osteodystrophy due to secondary hyperparathyroidism.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.025355,0.05009,0.060456,0.07098,0.080714,0.087521,0.093349,0.094348,0.096365,0.098758,0.10167,0.14039],"unified_progress":[0.028986,0.040661,0.053396,0.064181,0.070331,0.083828,0.084304,0.093409,0.098388,0.10192,0.12496,0.15564]}]}}