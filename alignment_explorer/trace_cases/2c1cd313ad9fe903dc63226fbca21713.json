on.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.042094,0.082125,0.097671,0.10548,0.10531,0.099596,0.095717,0.087937,0.079678,0.080284,0.064893,0.059213],"unified_progress":[0.051875,0.075387,0.092334,0.098717,0.09926,0.10098,0.096551,0.092522,0.085984,0.084008,0.067452,0.054929]},{"section":8,"text":"But what type?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.33002,0.05394,0.054087,0.062944,0.063509,0.064157,0.060103,0.06735,0.068028,0.062402,0.065291,0.048169],"unified_progress":[0.21909,0.08487,0.066453,0.065152,0.074567,0.072968,0.09799,0.078784,0.075181,0.059631,0.054774,0.050542]},{"section":9,"text":"There are different forms like osteitis fibrosa, adynamic bone disease, or osteoporosis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037625,0.081465,0.062923,0.10932,0.11612,0.10877,0.10677,0.095173,0.083776,0.077071,0.066452,0.054532],"unified_progress":[0.042646,0.074034,0.066477,0.10286,0.10873,0.10493,0.10414,0.1026,0.094471,0.085788,0.066554,0.046777]},{"section":10,"text":"Wait, the presence of cysts and fractures makes me think of cystic lesions in bones.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.044056,0.08585,0.098264,0.10187,0.10049,0.096005,0.093145,0.087153,0.084183,0.080151,0.06767,0.061163],"unified_progress":[0.050672,0.073944,0.087489,0.099445,0.10227,0.099536,0.097274,0.094481,0.090903,0.083565,0.067948,0.052473]},{"section":11,"text":"Another thought: maybe brown tumor?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.04139,0.080489,0.096375,0.10123,0.10036,0.094423,0.092483,0.089274,0.085109,0.085329,0.071737,0.061804],"unified_progress":[0.04885,0.074169,0.089164,0.10083,0.10085,0.09758,0.099377,0.094063,0.088428,0.086005,0.068545,0.052145]},{"section":12,"text":"That's associated with hyperparathyroidism.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031467,0.068167,0.084749,0.097574,0.10525,0.1057,0.10488,0.0972