[0.046617,0.073134,0.081039,0.086147,0.091966,0.096695,0.09564,0.097983,0.094757,0.094099,0.08037,0.061552]},{"section":11,"text":"But the case mentions visual illusions and hallucinations.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.040625,0.075429,0.082313,0.085364,0.088881,0.091185,0.09255,0.093258,0.092607,0.091266,0.087122,0.079399],"unified_progress":[0.048935,0.068612,0.076542,0.083943,0.089193,0.093523,0.094995,0.095839,0.095,0.095029,0.086822,0.071568]},{"section":12,"text":"Delirium tremens can present with both.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034582,0.065653,0.07694,0.087425,0.094782,0.096832,0.09972,0.096578,0.092018,0.092543,0.083125,0.079801],"unified_progress":[0.042862,0.056656,0.074566,0.08305,0.090521,0.099108,0.099028,0.099641,0.097105,0.095633,0.086358,0.075471]},{"section":13,"text":"Also, the sudden onset and acute confusion.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.036022,0.071027,0.079758,0.084855,0.089215,0.092235,0.095082,0.095598,0.094143,0.093579,0.08826,0.080225],"unified_progress":[0.043198,0.06577,0.07441,0.082258,0.088406,0.093569,0.094494,0.09778,0.09741,0.098904,0.089651,0.07415]},{"section":14,"text":"Since there's no mention of seizures, which can also occur in DTs, but maybe they didn't happen here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.030452,0.064433,0.076742,0.084167,0.089847,0.09408,0.098783,0.10038,0.099333,0.09728,0.090104,0.074396],"unified_progress":[0.035837,0.062611,0.074778,0.083563,0.091468,0.09375,0.098076,0.10105,0.10029,0.10418,0.089122,0.065277]},{"section":15,"text":"Other possibilities?","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.027644,0.063881,0.084199,0.092073,0.095541,0.093923,0.095189,0.094785,0.093858,0.096157,0.085363,0.077387],"unified_progress":[0.031172,0.065312,0.079296,0.092628,0.094257,0.094043,0.10284,0.097128,0.094587,0.099385,0.084154,0.0652]},{"section":16,"text":"Maybe Wernicke-Korsakoff syndrome, but that's more about memory issues, ophthalmoplegia, ataxia.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.027385,0.061675,0.076717,0.090264,0.10007,0.10382,0.10604,0.1011,0.093689,0.093312,0.079045,0.066883],"unified_progress":[0.030901,0.057201,0.076577,0.088012,0.098529,0.10925,0.10568,0.10535,0.099895,0.095062,0.076359,0.057187]},{"section":17,"text":"The patient here has acute confusion and hallucinations, which are more acute, so maybe not Wernicke's.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025205,0.057867,0.072051,0.081525,0.088692,0.094276,0.101,0.10292,0.10238,0.10012,0.094616,0.07935],"unified_progress":[0.029353,0.055062,0.069082,0.078791,0.088946,0.094293,0.09779,0.10411,0.10437,0.11153,0.093996,0.072683]},{"section":18,"text":"Alcoholic hallucinosis is another consideration.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.027178,0.059566,0.0738,0.084416,0.093081,0.096995,0.10038,0.10044,0.097028,0.097922,0.088128,0.081062],"unified_progress":[0.031342,0.057487,0.073877,0.085686,0.091347,0.09868,0.10069,0.1014,0.098881,0.097551,0.087812,0.075252]},{"section":19,"text":"That typically occurs after longer periods of abstinence and the hallucinations are usually auditory, not visual.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029001,0.062177,0.07327,0.083926,0.093458,0.099416,0.10399,0.10282,0.097421,0.097652,0.085759,0.071104],"unified_progress":[0.038585,0.058654,0.073765,0.083477,0.092616,0.10054,0.10188,0.10468,0.10141,0.1008,0.082641,0.060948]},{"section":20,"text":"The patient here has visual ones, so maybe not that.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024746,0.056607,0.07157,0.080992,0.088876,0.094556,0.10084,0.10347,0.10398,0.10047,0.095086,0.078815],"unified_progress":[0.03131,0.059613,0.072767,0.083534,0.091257,0.09357,0.098823,0.10194,0.1015,0.10853,0.090077,0.06708]},{"section":21,"tex