.065245,0.053595,0.044036,0.035134]},{"section":4,"text":"First, I need to think about the possible causes of bilateral hilar adenopathy.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.10317,0.1299,0.12664,0.1162,0.096905,0.079014,0.072205,0.066373,0.055716,0.062349,0.04558,0.045955],"unified_progress":[0.12591,0.08283,0.086451,0.094525,0.094184,0.087563,0.087013,0.084186,0.073955,0.076798,0.059309,0.047274]},{"section":5,"text":"Common differentials include sarcoidosis, tuberculosis, histoplasmosis, lymphoma, or other granulomatous diseases.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.043897,0.085697,0.10471,0.11185,0.11024,0.10081,0.095687,0.084798,0.075664,0.074047,0.059465,0.053136],"unified_progress":[0.037595,0.069477,0.095038,0.10103,0.10273,0.10554,0.10046,0.09429,0.08898,0.084492,0.06713,0.053236]},{"section":6,"text":"Since there's no caseous necrosis, which is typical in TB, that might make TB less likely, but not impossible.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.038539,0.081649,0.098991,0.10396,0.10076,0.094847,0.093601,0.08892,0.083396,0.083291,0.071257,0.060793],"unified_progress":[0.036694,0.068327,0.083097,0.093853,0.098492,0.097096,0.098227,0.097945,0.094245,0.096229,0.077841,0.057955]},{"section":7,"text":"However, the presence of non-caseating granulomas is a key point here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.043793,0.086329,0.10057,0.10412,0.09968,0.092764,0.090148,0.085078,0.080967,0.081637,0.070051,0.064864],"unified_progress":[0.043958,0.069735,0.083633,0.094783,0.097544,0.097921,0.099875,0.095195,0.091909,0.089895,0.076051,0.059501]},{"section":8,"text":"Sarcoidosis is a major consideration, especially in young adults, and it's more common in African-Americans.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.038711,0.076011,0.090213,0.09829,0.10059,0.098906,0.096036,0.090706,0.083769,0.086225,0.072474,0.068071],"unified_progress":[0.05174,0.074142,0.082694,0.089287,0.092608,0.098618,0.095488,0.095741,0.090181,0.089064,0.07636,0.064077]},{"section":9,"text":"The combination of hilar lymph node enlargement (which is Bilateral hilar adenopathy) and pulmonary infiltrates fits the typical presentation.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.039613,0.080472,0.089705,0.094959,0.095946,0.096764,0.095525,0.090998,0.09129,0.083603,0.073884,0.067241],"unified_progress":[0.043305,0.071636,0.086245,0.096286,0.099339,0.10113,0.098006,0.095283,0.094591,0.08429,0.071489,0.0584]},{"section":10,"text":"Sarcoidosis often presents with non-caseating granulomas on biopsy, which matches the case here.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039191,0.075055,0.086589,0.094446,0.097286,0.096072,0.096506,0.091435,0.086723,0.087179,0.075549,0.07397],"unified_progress":[0.044463,0.062875,0.079557,0.089862,0.094879,0.10323,0.098956,0.096543,0.093059,0.089559,0.078647,0.068373]},{"section":11,"text":"Histoplasmosis can also cause granulomatous inflammation, but it's more common in endemic areas.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029255,0.06239,0.077344,0.090975,0.10034,0.10358,0.10562,0.10007,0.092739,0.094024,0.07784,0.065822],"unified_progress":[0.035886,0.058949,0.078848,0.089746,0.097205,0.10704,0.10441,0.10353,0.09829,0.094908,0.075426,0.055754]},{"section":12,"text":"The patient's background might be a factor here, but the absence of caseation might still point more towards sarcoidosis.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.030935,0.065453,0.078149,0.0863,0.092135,0.098349,0.099474,0.099602,0.097614,0.094941,0.086119,0.070928],"unified_progress":[0.054311,0.081589,0.08297,0.085575,0.090407,0.091832,0.092197,0.096317,0.092927,0.093465,0.078089,0.06032]},{"section":13,"text":"Also, histoplasmosis might have a more variable presentation, sometimes with more nodules or in immunocompromised patients.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022951,0.055381,0.070462,0.082166,0.09122,0.09786,0.10565,0.10622,0.10408,0.10202,0.092906,0.06908],"unified_progress":[0.031139,0.058928,0.07587,0.083697,0.094567,0.099706,0.10182,0.10552,0.10404,0.10506,0.08497,0.054679]},{"section":14,"text":"Another thought: Lymphoma can present with hilar adenopathy, but the biopsy showing granulomas would be less typical unless it's a Hodgkin's lymphoma with granulomatous reaction, but that's rare.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026348,0.059114,0.072924,0.084491,0.092439,0.09794,0.10343,0.10303,0.10232,0.098814,0.087941,0.071207],"unified_progress":[0.033054,0.058104,0.076211,0.087839,0.096131,0.10193,0.10276,0.10419,0.10278,0.098997,0.081136,0.056861]},{"section":15,"text":"Silicosis or berylliosis are occupational lung diseases causing granulomas, but the patient's history isn't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026929,0.06043,0.073957,0.084434,0.092821,0.099886,0.10298,0.10303,0.10055,0.098789,0.087434,0.06876],"unified_progress":[0.043964,0.073298,0.081803,0.087866,0.094112,0.098681,0.098692,0.10063,0.096993,0.094706,0.076142,0.053118]},{"section":16,"text":"So putting it all together: young adult, African-American, bilateral hilar nodes, reticular opacities, non-caseating granulomas.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.029672,0.059029,0.069636,0.077898,0.085038,0.090731,0.095199,0.096398,0.10176,0.10044,0.10103,0.093168],"unified_progress":[0.040978,0.057335,0.070751,0.079767,0.08931,0.09703,0.097743,0.099038,0.10155,0.097943,0.092314,0.076239]},{"section":17,"text":"Sarcoidosis is the most likely diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.01937,0.04285,0.055987,0.063945,0.07045,0.075475,0.083172,0.088131,0.097357,0.10472,0.1189,0.17965],"unified_progress":[0.018787,0.033966,0.043378,0.053429,0.058751,0.0733,0.0774,0.09274,0.10453,0.11181,0.14517,0.18674]},{"section":18,"text":"The absence of caseous necrosis helps differentiate from TB.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.023921,0.053371,0.066154,0.074437,0.081131,0.086832,0.093799,0.097613,0.10237,0.10496,0.10661,0.1088],"unified_progress":[0.03129,0.047248,0.05899,0.06863,0.076948,0.08491,0.089797,0.098121,0.1049,0.11181,0.11462,0.11274]},{"section":19,"text":"The reticular densities could represent interstitial involvement in sarcoidosis.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.02739,0.061213,0.073739,0.082811,0.088369,0.09355,0.097692,0.096989,0.10149,0.096213,0.091971,0.088569],"unified_progress":[0.033438,0.054097,0.068716,0.080021,0.087861,0.093793,0.096375,0.098556,0.10334,0.10034,0.096404,0.087065]},{"section":20,"text":"Wait, but could it be another condition like hypersensitivity pneumonitis?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.021883,0.051411,0.067502,0.079351,0.092002,0.097584,0.10368,0.10855,0.10755,0.10477,0.096135,0.069585],"unified_progress":[0.030998,0.062932,0.081739,0.095238,0.098038,0.098992,0.10449,0.10251,0.098848,0.095085,0.077573,0.053557]},{"section":21,"text":"That can have granulomas too, but usually there's a history of exposure to an antigen, which isn't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018553,0.048024,0.064731,0.076605,0.087978,0.09562,0.10524,0.10951,0.10945,0.10806,0.10191,0.07431],"unified_progress":[0.035459,0.059647,0.073792,0.0816,0.093453,0.096596,0.1007,0.10747,0.10463,0.1066,0.086318,0.053733]},{"section":22,"text":"So yeah, I think sarcoidosis is the best fit here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.022309,0.044976,0.05595,0.064322,0.072372,0.078999,0.086118,0.091556,0.098147,0.10319,0.11327,0.1688],"unified_progress":[0.025617,0.034968,0.043523,0.053933,0.059053,0.069679,0.076081,0.085517,0.093873