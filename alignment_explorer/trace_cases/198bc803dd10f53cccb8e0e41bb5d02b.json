4,0.049218,0.0394,0.032539,0.026754,0.021827,0.018328,0.014009]},{"section":2,"text":"She's got these hypopigmented, ulcerated, and crusted patches on her face and forearms.","dimension":6,"group":5,"is_degenerate":false,"model_progress":[0.20962,0.17872,0.12715,0.10251,0.083768,0.069114,0.057792,0.047308,0.040691,0.036807,0.02875,0.017768],"unified_progress":[0.14473,0.16195,0.13199,0.11138,0.085288,0.081273,0.064763,0.062954,0.050854,0.042378,0.035048,0.027398]},{"section":3,"text":"That sounds like it could be something serious, maybe related to sun exposure?","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.073432,0.13488,0.13781,0.12788,0.11269,0.09853,0.083856,0.067567,0.058234,0.047955,0.036324,0.020832],"unified_progress":[0.063519,0.10884,0.11443,0.11667,0.11325,0.098419,0.092188,0.079244,0.070083,0.0599,0.049262,0.034194]},{"section":4,"text":"Kids don't usually have skin cancer, so there must be more to this.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.06776,0.09043,0.10058,0.10473,0.10325,0.099633,0.094451,0.08802,0.082249,0.075161,0.058402,0.035331],"unified_progress":[0.062135,0.086046,0.093171,0.10034,0.10014,0.09564,0.09564,0.089343,0.082034,0.078216,0.066175,0.051122]},{"section":5,"text":"Now, she also developed an indurated, crater-like nodule on the back of her hand.","dimension":6,"group":5,"is_degenerate":false,"model_progress":[0.098405,0.099876,0.096349,0.098722,0.098669,0.095344,0.090119,0.08198,0.076206,0.072692,0.057434,0.034205],"unified_progress":[0.073458,0.09554,0.094929,0.096095,0.095029,0.094935,0.08948,0.089156,0.083113,0.074389,0.06321,0.050664]},{"section":6,"text":"That's not just any kind of bump; it's a nodular lesion, which is often seen in advanced stages of skin conditions.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.053907,0.10756,0.11472,0.11482,0.10918,0.10292,0.094024,0.080618,0.075254,0.065586,0.051314,0.030097],"unified_progress":[0.050635,0.087869,0.10129,