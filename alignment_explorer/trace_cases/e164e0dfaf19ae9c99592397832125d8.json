45748],"unified_progress":[0.093211,0.12542,0.074038,0.09887,0.094126,0.098769,0.082252,0.081249,0.075305,0.070002,0.061617,0.045147]},{"section":6,"text":"Waddling gait makes me think of neuromuscular disorders.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.059004,0.10412,0.11417,0.11015,0.10441,0.093084,0.087047,0.079238,0.070183,0.070022,0.056737,0.051838],"unified_progress":[0.060307,0.082183,0.093942,0.10106,0.099285,0.098602,0.094602,0.089951,0.082938,0.080925,0.06496,0.05124]},{"section":7,"text":"The calf hypertrophy is interesting because sometimes in muscle diseases, certain muscles can enlarge even though overall strength is lost.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.042389,0.085485,0.097005,0.1019,0.10207,0.098979,0.097286,0.090702,0.084082,0.077807,0.067468,0.054832],"unified_progress":[0.088276,0.076718,0.084811,0.091602,0.094526,0.094593,0.092433,0.091469,0.084938,0.080579,0.066889,0.053169]},{"section":8,"text":"High CPK levels point to muscle damage.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.042393,0.08616,0.10216,0.10569,0.10152,0.094107,0.092772,0.086567,0.080766,0.080205,0.068467,0.059192],"unified_progress":[0.057036,0.078879,0.088104,0.09792,0.10008,0.096632,0.095749,0.090645,0.085693,0.084471,0.070347,0.054449]},{"section":9,"text":"Duchenne Muscular Dystrophy (DMD) comes to mind.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.047705,0.083965,0.094685,0.10018,0.099228,0.093545,0.091127,0.085728,0.079049,0.081981,0.069743,0.073065],"unified_progress":[0.055628,0.066651,0.080323,0.09041,0.093099,0.097053,0.094631,0.093351,0.08905,0.088526,0.079238,0.07204]},{"section":10,"text":"Let me recall the typical presentation.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.033616,0.068241,0.087051,0.095207,0.098947,0.097018,0.095651,0.092943,0.091694,0.088155,0.079448,0.07203],"unified_progress":[0.042564,0.072769,0.083979,0.099127,0.09754,0.094507,0.095236,0.092712,0.089384,0.094785,0.077214,0.060184]},{"section":11,"text":"DMD usually affects boys, starts in early childhood, around 3-5 years.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.039672,0.074849,0.081764,0.089568,0.096506,0.10021,0.10098,0.097666,0.090578,0.087562,0.076795,0.063852],"unified_progress":[0.094504,0.076773,0.081009,0.08382,0.0901,0.095039,0.0918,0.093311,0.085199,0.081582,0.06902,0.057843]},{"section":12,"text":"They have proximal muscle weakness leading to difficulty running, climbing stairs, and a waddling gait.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.052687,0.093713,0.089123,0.088145,0.091457,0.095865,0.094744,0.095072,0.084733,0.082075,0.070948,0.061438],"unified_progress":[0.072373,0.088901,0.092952,0.08916,0.090461,0.096025,0.090773,0.093973,0.084694,0.079919,0.067296,0.053473]},{"section":13,"text":"Gower's sign (using hands to push up from a sitting position) is common but not mentioned here.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.056958,0.10108,0.095411,0.090429,0.09087,0.094597,0.091785,0.092074,0.082918,0.078157,0.068019,0.057697],"unified_progress":[0.070765,0.090623,0.093332,0.093135,0.0931,0.095809,0.090916,0.092292,0.084324,0.079465,0.06552,0.050721]},{"section":14,"text":"Toe walking difficulty fits because the calves are involved.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.05187,0.096887,0.097416,0.094639,0.09321,0.094538,0.091827,0.089821,0.085216,0.077487,0.068193,0.058897],"unified_progress":[0.06261,0.085849,0.091587,0.094866,0.09621,0.097073,0.092612,0.091669,0.087893,0.079168,0.067168,0.053296]},{"section":15,"text":"Calf muscle hypertrophy is a classic sign in DMD.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.038139,0.075885,0.088866,0.096333,0.09879,0.097006,0.097221,0.09174,0.087089,0.085513,0.074971,0.068447],"unified_progress":[0.054078,0.06799,0.084025,0.091435,0.095686,0.10091,0.097443,0.094333,0.090203,0.086499,0.074727,0.062671]},{"section":16,"text":"The muscles might enlarge due to fatty infiltration or fibrosis, even as they become weaker.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.03886,0.075964,0.08447,0.091658,0.096245,0.098765,0.09952,0.095247,0.091811,0.085176,0.075943,0.066341],"unified_progress":[0.054967,0.068205,0.081398,0.089688,0.095309,0.099312,0.096995,0.095639,0.093284,0.086678,0.076153,0.062372]},{"section":17,"text":"High CPK is also a hallmark; normal CPK is around 100-200, so 10,000 is way elevated, which is typical for DMD.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.046763,0.088606,0.10017,0.10172,0.098577,0.093846,0.094198,0.088998,0.082786,0.076655,0.069678,0.058001],"unified_progress":[0.048499,0.08257,0.095807,0.10085,0.10549,0.09965,0.099422,0.089775,0.083824,0.075636,0.066689,0.051782]},{"section":18,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.034733,0.076358,0.098052,0.10314,0.10094,0.093791,0.092103,0.088988,0.084798,0.085371,0.073927,0.067798],"unified_progress":[0.038612,0.073185,0.08627,0.10162,0.098897,0.095737,0.095801,0.094166,0.089484,0.090753,0.07619,0.059283]},{"section":19,"text":"Becker Muscular Dystrophy is similar but later onset.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.027718,0.063437,0.080095,0.093289,0.10239,0.10485,0.10505,0.099509,0.091619,0.090373,0.076616,0.065041],"unified_progress":[0.045298,0.066154,0.080932,0.089042,0.097077,0.10571,0.10095,0.10035,0.094021,0.089543,0.073465,0.057456]},{"section":20,"text":"Maybe limb-girdle MD, but that's autosomal recessive and less specific.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024609,0.058595,0.07486,0.087742,0.097184,0.10285,0.10639,0.1037,0.098111,0.097669,0.083299,0.064989],"unified_progress":[0.037535,0.065179,0.081096,0.089349,0.096442,0.10138,0.1016,0.10294,0.098178,0.097322,0.075827,0.053147]},{"section":21,"text":"The age here is right for DMD.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.029336,0.064294,0.07895,0.087287,0.092745,0.097088,0.098634,0.098403,0.095922,0.095287,0.08704,0.075015],"unified_progress":[0.068073,0.080404,0.080739,0.084334,0.08779,0.089714,0.091098,0.093392,0.089507,0.090731,0.079317,0.064902]},{"section":22,"text":"Also, the combination of elevated CPK, calf hypertrophy, and the specific gait issues really point towards DMD.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.027193,0.059044,0.073469,0.081711,0.087517,0.090654,0.094846,0.095348,0.097956,0.1012,0.099851,0.09121],"unified_progress":[0.037074,0.058798,0.071457,0.080264,0.088735,0.094693,0.097418,0.098224,0.099981,0.10227,0.094324,0.076766]},{"section":23,"text":"I should consider other causes like metabolic myopathies, but they usually present with exercise intolerance or rhabdomyolysis after exertion.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026277,0.05942,0.07327,0.084389,0.093313,0.09841,0.10325,0.10252,0.098933,0.098168,0.088425,0.073632],"unified_progress":[0.030919,0.057053,0.074384,0.083754,0.093434,0.10006,0.10269,0.10426,0.10183,0.10155,0.086815,0.063247]},{"section":24,"text":"The waddling gait and age make DMD the top candidate.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027301,0.06029,0.074425,0.0827,0.088035,0.09157,0.096287,0.097298,0.098072,0.099247,0.094788,0.089987],"unified_progress":[0.031133,0.05462,0.067618,0.078222,0.086178,0.092951,0.096306,0.10028,0.10172,0.10568,0.098895,0.086396]},{"section":25,"text":"Genetic testing would confirm dystrophin gene mutations.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.029916,0.065371,0.08028,0.088169,0.092152,0.093657,0.096589,0.09493,0.09418,0.092032,0.086815,0.085908],"unified_progress":[0.04974,0.063735,0.07524,0.083307,0.088672,0.091831,0.093468,0.093756,0.0932,0.091302,0.089425,0.086324]},{"section":26,"text":"So yeah, the most likely diagnosis is Duchenne Muscular Dystrophy.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.024405,0.046801,0.055725,0.062974,0.070519,0.077234,0.084131,0.08912,0.096693,0.10073,0.11401,0.17766],"unified_progress":[0.024867,0.034489,0.0428,0.052503,0.057087,0.068255,0.072194,0.085011,0.097797,0.10833,0.14996,0.20671]}]}}