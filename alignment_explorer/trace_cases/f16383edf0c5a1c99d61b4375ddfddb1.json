542,0.07592,0.069307,0.057607,0.062991,0.045537,0.042625],"unified_progress":[0.1105,0.086675,0.091065,0.098386,0.096315,0.091188,0.087968,0.084406,0.072825,0.077238,0.058139,0.045294]},{"section":5,"text":"The symptoms here are pointing towards a neurological or metabolic issue.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.064529,0.10875,0.12603,0.12255,0.10544,0.085365,0.078109,0.07039,0.062799,0.069734,0.053169,0.053135],"unified_progress":[0.062492,0.079547,0.086332,0.10109,0.098279,0.093633,0.092669,0.088811,0.083282,0.087371,0.070093,0.056399]},{"section":6,"text":"The key symptoms are the combination of fever, rigidity, altered mental status, and autonomic instability.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.061751,0.10477,0.10145,0.09759,0.093832,0.091095,0.086745,0.083785,0.076521,0.073885,0.067269,0.061307],"unified_progress":[0.064877,0.083688,0.085467,0.087385,0.090177,0.092319,0.090611,0.092478,0.087231,0.085727,0.076552,0.063489]},{"section":7,"text":"Fever and rigidity make me think of neuroleptic malignant syndrome (NMS).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.050905,0.085639,0.093805,0.099175,0.099457,0.094673,0.093282,0.087627,0.079813,0.081623,0.068587,0.065416],"unified_progress":[0.057868,0.066096,0.082589,0.089205,0.093893,0.098802,0.09723,0.095366,0.090255,0.089327,0.076125,0.063244]},{"section":8,"text":"That's a known severe reaction to antipsychotic drugs.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.050178,0.084759,0.0934,0.098338,0.097933,0.093655,0.09148,0.086673,0.079697,0.083536,0.069926,0.070428],"unified_progress":[0.059987,0.067135,0.078433,0.087662,0.091099,0.094918,0.094193,0.094741,0.090588,0.090623,0.080133,0.070488]},{"section":9,"text":"NMS typically develops within the first few weeks of starting the medication or with a dose increase.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.049643,0.0866,0.088132,0.091252,0.094794,0.09811,0.095033,0.092662,0.084377,0.083031,0.071841,0.064525],"unified_progress":[0.062236,0.077042,0.083412,0.085943,0.089997,0.095712,0.093012,0.095443,0.089774,0.086684,0.076238,0.064508]},{"section":10,"text":"The symptoms include hyperthermia, muscle rigidity (especially lead-pipe rigidity), altered mental status like confusion or delirium, autonomic instability (tachycardia, hypertension), and elevated creatine kinase due to muscle breakdown.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.043249,0.08158,0.086039,0.09016,0.094774,0.097918,0.098441,0.095607,0.087529,0.084224,0.074441,0.066036],"unified_progress":[0.046197,0.06951,0.082503,0.086407,0.092564,0.099978,0.097281,0.097314,0.09419,0.089765,0.079968,0.064323]},{"section":11,"text":"Other possibilities might include serotonin syndrome, but that usually has more agitation, diarrhea, myoclonus, and clonus.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02767,0.061816,0.075704,0.087031,0.095457,0.099804,0.1052,0.10336,0.097928,0.096311,0.08466,0.065056],"unified_progress":[0.030665,0.057978,0.076643,0.085396,0.095131,0.10119,0.10299,0.10494,0.10181,0.10341,0.083477,0.056361]},{"section":12,"text":"The rigidity in NMS is more pronounced and different from the tremors in serotonin syndrome.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026894,0.060343,0.073211,0.083806,0.092155,0.097617,0.10401,0.10383,0.10051,0.098444,0.088666,0.070524],"unified_progress":[0.043194,0.058283,0.072446,0.082102,0.09145,0.097958,0.10022,0.10406,0.10206,0.10345,0.085077,0.059705]},{"section":13,"text":"Also, the patient is on antipsychotics, not serotonergic drugs.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.035403,0.069935,0.079362,0.085858,0.091357,0.097372,0.097399,0.097641,0.094797,0.093982,0.084635,0.072258],"unified_progress":[0.061866,0.087485,0.085978,0.086682,0.08944,0.091763,0.091641,0.09349,0.088967,0.086943,0.075665,0.060081]},{"section":14,"text":"Another thought: could it be an infection?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.026383,0.060896,0.079493,0.088895,0.095924,0.095963,0.099187,0.10051,0.098025,0.099967,0.087576,0.067185],"unified_progress":[0.034893,0.071865,0.089014,0.10402,0.10095,0.09768,0.10164,0.096605,0.091538,0.090589,0.071658,0.049547]},{"section":15,"text":"But the sudden onset with the antipsychotic use makes NMS more likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02888,0.062256,0.075699,0.083612,0.089387,0.093023,0.097666,0.098635,0.09782,0.098313,0.092263,0.082446],"unified_progress":[0.03924,0.063429,0.074426,0.083286,0.089943,0.094052,0.095928,0.098757,0.097808,0.099329,0.089855,0.073945]},{"section":16,"text":"The vital signs support NMS because of the high fever and autonomic issues.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027446,0.059011,0.070971,0.079923,0.087962,0.0939,0.099749,0.10018,0.1002,0.09864,0.096569,0.085454],"unified_progress":[0.035528,0.056125,0.067985,0.075982,0.086371,0.093944,0.096981,0.10047,0.10305,0.10447,0.09891,0.080188]},{"section":17,"text":"The confusion and decreased communication fit with the mental status changes seen in NMS.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.030748,0.06165,0.070549,0.078364,0.086066,0.092175,0.097662,0.099008,0.099258,0.098453,0.095869,0.090198],"unified_progress":[0.038444,0.05361,0.063393,0.071298,0.081513,0.090498,0.094355,0.10018,0.10405,0.10713,0.10455,0.090992]},{"section":18,"text":"I should also consider heat stroke, but the context of antipsychotic use is a big clue.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.030921,0.064678,0.079396,0.086816,0.090159,0.091669,0.094226,0.0948,0.094401,0.098757,0.089936,0.084242],"unified_progress":[0.042729,0.065897,0.072819,0.0808,0.085908,0.089755,0.093562,0.096929,0.0973,0.10186,0.093823,0.078618]},{"section":19,"text":"Antipsychotics can interfere with thermoregulation.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.033773,0.066249,0.076702,0.085948,0.093497,0.097993,0.099987,0.098068,0.094042,0.093012,0.084437,0.076291],"unified_progress":[0.046268,0.06384,0.07563,0.082278,0.089287,0.096619,0.096855,0.098306,0.096601,0.095435,0.086525,0.072355]},{"section":20,"text":"So putting it all together, the most likely diagnosis is neuroleptic malignant syndrome.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.03507,0.058142,0.064452,0.070913,0.076212,0.079625,0.085055,0.088017,0.092199,0.097008,0.10335,0.14995],"unified_progress":[0.040201,0.041214,0.050033,0.059904,0.065073,0.076033,0.078956,0.089596,0.097184,0.10425,0.13157,0.16598]}]}}