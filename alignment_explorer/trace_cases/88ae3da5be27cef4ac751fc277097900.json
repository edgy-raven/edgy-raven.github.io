ension":10,"group":5,"is_degenerate":false,"model_progress":[0.16923,0.31358,0.079331,0.11829,0.068248,0.065255,0.046633,0.038244,0.03157,0.026723,0.02283,0.020056],"unified_progress":[0.19212,0.19287,0.093531,0.11507,0.082743,0.081407,0.058764,0.050573,0.043206,0.036452,0.030637,0.02263]},{"section":3,"text":"The vital signs are high temp (104\u00b0F), tachycardia (120), hypertension (150/100), and disorientation.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.12806,0.21194,0.16272,0.092142,0.074991,0.079704,0.056043,0.062043,0.041655,0.035581,0.030022,0.025093],"unified_progress":[0.11174,0.1508,0.12189,0.10614,0.09215,0.091138,0.072271,0.075688,0.056701,0.049014,0.041227,0.031241]},{"section":4,"text":"Hmm, antipsychotics can have some serious side effects.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.089022,0.12319,0.12727,0.11927,0.10069,0.084095,0.076525,0.069504,0.058106,0.063341,0.045993,0.042991],"unified_progress":[0.1066,0.086874,0.091315,0.099644,0.096908,0.091583,0.088372,0.084459,0.073261,0.077342,0.058382,0.045262]},{"section":5,"text":"The key symptoms here are the combination of hyperthermia, rigidity, altered mental status, and autonomic instability.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.064546,0.10978,0.1066,0.10089,0.095561,0.091432,0.085847,0.082732,0.073276,0.070857,0.062343,0.056144],"unified_progress":[0.064473,0.087408,0.089687,0.09089,0.092496,0.094371,0.090349,0.091322,0.084719,0.082905,0.072489,0.058891]},{"section":6,"text":"That makes me think of neuroleptic malignant syndrome (NMS).","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.060641,0.093281,0.098957,0.10186,0.098467,0.09046,0.087968,0.082698,0.075123,0.079001,0.065237,0.06631],"unified_progress":[0.071656,0.067625,0.080926,0.089013,0.09243,0.094715,0.093991,0.09252,0.087137,0.087897,0.075994,0.066096]},{"section":7,"text":"NMS is a rare but life-threatening reaction to antipsychotic drugs.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.04664,0.080417,0.08918,0.095917,0.098694,0.096609,0.095073,0.089663,0.082158,0.083542,0.071294,0.070813],"unified_progress":[0.052992,0.063022,0.078193,0.086125,0.09091,0.097269,0.095665,0.096056,0.092622,0.091416,0.082047,0.073681]},{"section":8,"text":"The symptoms fit: fever, muscle rigidity (especially lead-pipe rigidity), confusion, and autonomic dysfunction like tachycardia and hypertension.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.046574,0.085946,0.086858,0.088658,0.09232,0.095688,0.095752,0.09398,0.086833,0.083791,0.075521,0.06808],"unified_progress":[0.048032,0.071158,0.079234,0.083523,0.089834,0.097286,0.095226,0.097268,0.095047,0.091833,0.083415,0.068144]},{"section":9,"text":"The patient's recent use of antipsychotics for four weeks is a risk factor.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.04509,0.082963,0.089886,0.092665,0.093945,0.098965,0.092395,0.090729,0.085638,0.087061,0.074807,0.065856],"unified_progress":[0.080644,0.10519,0.092416,0.090244,0.087077,0.088,0.084551,0.087345,0.080262,0.077905,0.068875,0.057495]},{"section":10,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035651,0.077655,0.099903,0.10511,0.10037,0.091262,0.089651,0.084787,0.081592,0.089415,0.074051,0.07055],"unified_progress":[0.039538,0.074828,0.085456,0.101,0.098627,0.094191,0.097007,0.09038,0.086446,0.096896,0.075539,0.060093]},{"section":11,"text":"Maybe serotonin syndrome?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.02722,0.063545,0.081387,0.090756,0.097687,0.098313,0.10059,0.10045,0.09664,0.094292,0.083989,0.065134],"unified_progress":[0.036225,0.067538,0.084903,0.09447,0.099233,0.099405,0.10255,0.09956,0.094779,0.091399,0.075249,0.054691]},{"section":12,"text":"But that usually has more agitation, diarrhea, myoclonus, and maybe clonus.","dimension":1,"group":4,"is_degenerate":false,"mode