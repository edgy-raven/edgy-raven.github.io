nerate":false,"model_progress":[0.041617,0.068258,0.090544,0.11105,0.11888,0.11589,0.10817,0.093986,0.08295,0.076287,0.058424,0.033951],"unified_progress":[0.044268,0.074942,0.092365,0.10068,0.10504,0.10475,0.099272,0.092952,0.091705,0.076556,0.064089,0.053378]},{"section":7,"text":"These are classic signs pointing towards Graves' disease.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.035934,0.079532,0.092984,0.10259,0.10508,0.10589,0.10201,0.092026,0.088514,0.081288,0.067586,0.046569],"unified_progress":[0.038779,0.071977,0.089401,0.096973,0.10273,0.10409,0.10159,0.093714,0.088134,0.0803,0.072152,0.060168]},{"section":8,"text":"It's a type of autoimmune disorder that affects the thyroid.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.034259,0.048401,0.062576,0.076893,0.090299,0.10065,0.10891,0.10868,0.11107,0.1146,0.089149,0.054521],"unified_progress":[0.036837,0.057605,0.076014,0.088681,0.095173,0.10671,0.10221,0.10163,0.096093,0.091378,0.079381,0.068287]},{"section":9,"text":"Oh, and the lab results show high levels of antibodies against the TSH receptor.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.026642,0.055548,0.082469,0.10649,0.11721,0.11761,0.11101,0.099374,0.088681,0.083002,0.06763,0.044333],"unified_progress":[0.036071,0.065968,0.083062,0.095349,0.10159,0.10041,0.098988,0.096535,0.097737,0.085305,0.074282,0.064697]},{"section":10,"text":"This is a big clue!","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.11411,0.092368,0.086546,0.077838,0.08032,0.082225,0.082581,0.089197,0.079076,0.053757,0.055148,0.10683],"unified_progress":[0.2017,0.07819,0.06636,0.065858,0.07635,0.075162,0.089871,0.083929,0.080128,0.064686,0.060038,0.057726]},{"section":11,"text":"In Graves' disease, these antibodies cause the thyroid to overproduce hormones because they mimic the action of TSH, tricking the thyroid into working overtime.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[