.073555,0.065743],"unified_progress":[0.060518,0.073721,0.090678,0.10061,0.10287,0.10064,0.0964,0.09101,0.090754,0.07537,0.063423,0.054001]},{"section":20,"text":"So that ratio reversal fits.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.032769,0.067124,0.082631,0.090639,0.095506,0.09619,0.097567,0.095334,0.094738,0.089184,0.082437,0.07588],"unified_progress":[0.061031,0.073102,0.083584,0.094408,0.09573,0.092256,0.092976,0.090741,0.0871,0.087453,0.075371,0.066247]},{"section":21,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.029839,0.068349,0.089633,0.096533,0.097598,0.093732,0.093818,0.091913,0.090885,0.092545,0.080926,0.07423],"unified_progress":[0.035724,0.071085,0.084592,0.097629,0.097328,0.094461,0.097127,0.093874,0.091175,0.094554,0.079107,0.063344]},{"section":22,"text":"Maybe idiopathic constipation, but the transition zone is more specific.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026734,0.062603,0.079743,0.088295,0.093345,0.094301,0.098121,0.09873,0.096952,0.097001,0.088589,0.075586],"unified_progress":[0.030765,0.062544,0.07856,0.088962,0.094605,0.09622,0.099866,0.10018,0.098176,0.098865,0.084967,0.066286]},{"section":23,"text":"Maybe a rectal stenosis or some structural issue.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.024308,0.06174,0.078336,0.088654,0.095627,0.10019,0.10206,0.10159,0.10434,0.094062,0.084132,0.064963],"unified_progress":[0.031685,0.067678,0.086989,0.10129,0.1039,0.10294,0.10319,0.099338,0.097303,0.086049,0.069627,0.050008]},{"section":24,"text":"But the transition zone and the ratio change are key here.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.024088,0.05625,0.072534,0.081932,0.088921,0.092962,0.098125,0.099443,0.10179,0.10104,0.097157,0.085755],"unified_progress":[0.035898,0.057499,0.071873,0.082569,0.091357,0.095314,0.098413,0.10079,0.10084,0.1012,0.090615,0.073634]},{"section":25,"text":"Also, Hirschsprung's is a common cause of congenital intestinal obstruction.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026582,0.057395,0.071153,0.082021,0.090186,0.094863,0.098202,0.097648,0.09635,0.09796,0.091729,0.095912],"unified_progress":[0.036227,0.057468,0.070112,0.079528,0.085344,0.094312,0.095108,0.097855,0.097508,0.097079,0.095338,0.094122]},{"section":26,"text":"So putting it all together, the most likely diagnosis is Hirschsprung disease.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.025842,0.049193,0.058999,0.066075,0.07209,0.077055,0.083473,0.087872,0.09573,0.10065,0.11187,0.17116],"unified_progress":[0.026604,0.035219,0.043717,0.053972,0.058939,0.07081,0.07409,0.086617,0.09685,0.10729,0.14618,0.19971]}]}}