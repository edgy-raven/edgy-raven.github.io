0.04065,0.077215,0.090028,0.10649,0.10304,0.097345,0.10021,0.090642,0.086865,0.084523,0.069057,0.053937]},{"section":6,"text":"The infant has slight hypotonia, which means low muscle tone.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.047845,0.088364,0.10101,0.10313,0.10074,0.095147,0.091618,0.085839,0.079937,0.073161,0.069813,0.0634],"unified_progress":[0.054381,0.086782,0.094651,0.09934,0.10039,0.099043,0.095748,0.091472,0.084867,0.07639,0.065025,0.051913]},{"section":7,"text":"Hypotonia can be a sign of various neurological or genetic disorders.","dimension":17,"group":6,"is_degenerate":false,"model_progress":[0.038407,0.076211,0.091905,0.10563,0.099857,0.098532,0.099026,0.096099,0.089779,0.080847,0.068719,0.05499],"unified_progress":[0.037079,0.068506,0.087973,0.097803,0.10136,0.1038,0.10282,0.099987,0.093782,0.088974,0.070415,0.047507]},{"section":8,"text":"The Moro reflex is also poor.","dimension":12,"group":4,"is_degenerate":false,"model_progress":[0.034816,0.066817,0.087606,0.097168,0.10227,0.10204,0.10172,0.097729,0.092631,0.085373,0.073229,0.058596],"unified_progress":[0.037294,0.068147,0.085567,0.095951,0.10207,0.10252,0.1023,0.099715,0.095332,0.089348,0.071689,0.050067]},{"section":9,"text":"The Moro reflex is a normal newborn reflex that's usually present, so a poor response could indicate some neurological issue or perhaps something like Down syndrome.","dimension":17,"group":6,"is_degenerate":false,"model_progress":[0.037227,0.073284,0.089897,0.099615,0.099307,0.098549,0.099147,0.096356,0.091598,0.083509,0.072585,0.058927],"unified_progress":[0.034246,0.065606,0.083901,0.094661,0.10027,0.10347,0.10326,0.10124,0.096542,0.090711,0.073797,0.052293]},{"section":10,"text":"Looking at the facial features: upslanting palpebral fissures.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.037893,0.075337,0.09247,0.10043,0.10368,0.10109,0.09985,0.092005,0.085357,0.07759,0.070986,0.063319],"unified_progress":[0.043354,0.078896,0.092031,0.10068,0.10527,0.10179,0.098868,0.093804,0.092248,0.078291,0.064705,0.050058]},{"section":11,"text":"That's when the eyes are slanting upwards, which is a common feature in Down syndrome.","dimension":17,"group":6,"is_degenerate":false,"model_progress":[0.037066,0.092788,0.10975,0.12036,0.10653,0.098461,0.093558,0.086176,0.077305,0.068583,0.059177,0.050247],"unified_progress":[0.032769,0.071918,0.09273,0.10559,0.10711,0.1047,0.10582,0.097981,0.092568,0.0817,0.063549,0.043562]},{"section":12,"text":"Epicanthal folds are the folds from the upper eyelid over the corner of the eye, which are also more pronounced in Down syndrome.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.040123,0.075042,0.094355,0.10586,0.10889,0.10507,0.10389,0.093968,0.085491,0.072721,0.062514,0.052067],"unified_progress":[0.036402,0.073238,0.093746,0.10472,0.11194,0.10807,0.10299,0.095844,0.092592,0.075118,0.060174,0.045169]},{"section":13,"text":"The infant also has excess nuchal skin, which is the skin at the back of the neck, and that's another classic sign associated with Down syndrome.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.039195,0.075307,0.093082,0.10408,0.10533,0.10279,0.10193,0.094561,0.087103,0.07588,0.065652,0.055091],"unified_progress":[0.037119,0.072529,0.091865,0.10383,0.10895,0.10738,0.1039,0.09573,0.092636,0.077202,0.061529,0.047327]},{"section":14,"text":"The tongue is enlarged, which can cause the baby to have a protruding tongue appearance.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.038426,0.06949,0.08801,0.097752,0.10281,0.10241,0.10251,0.097124,0.0914,0.08099,0.070916,0.058161],"unified_progress":[0.040559,0.073055,0.08997,0.10018,0.106,0.10649,0.10238,0.096729,0.092848,0.080867,0.06387,0.047046]},{"section":15,"text":"Clinodactyly of the fifth fingers refers to the fifth fingers that are permanently flexed, curving inward.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.0