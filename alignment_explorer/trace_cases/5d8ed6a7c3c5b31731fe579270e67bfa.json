1,"group":4,"is_degenerate":false,"model_progress":[0.030016,0.042774,0.054676,0.066274,0.078138,0.092263,0.10615,0.11981,0.12897,0.1286,0.099861,0.052469],"unified_progress":[0.038087,0.060931,0.074056,0.08169,0.092107,0.095796,0.098751,0.10402,0.10282,0.10474,0.08731,0.059701]},{"section":22,"text":"Plus, the leg swelling and high heart rate don't really match a heart attack as closely as they do with a clot in the lungs.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.022465,0.034191,0.04727,0.059537,0.071263,0.084653,0.09862,0.11078,0.12195,0.13254,0.12829,0.088447],"unified_progress":[0.034842,0.052635,0.067534,0.077405,0.087865,0.09508,0.098467,0.10348,0.105,0.10606,0.096454,0.075177]},{"section":23,"text":"Let's consider pneumonia.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.01048,0.035112,0.056031,0.071452,0.083606,0.097454,0.1101,0.12569,0.13593,0.13565,0.097181,0.041314],"unified_progress":[0.02661,0.057699,0.0731,0.085278,0.092924,0.094933,0.10193,0.10406,0.10328,0.11016,0.090712,0.059309]},{"section":24,"text":"It can cause breathing problems, sure, but the leg swelling isn't typical for pneumonia.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.01967,0.034094,0.045333,0.056543,0.06862,0.082827,0.098517,0.11196,0.12504,0.13707,0.13235,0.087976],"unified_progress":[0.032299,0.053128,0.067758,0.077273,0.088649,0.097079,0.10003,0.10528,0.1063,0.10729,0.095091,0.069828]},{"section":25,"text":"And the rapid heart rate and low blood pressure aren't really fitting either.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.020701,0.036213,0.050045,0.063275,0.075066,0.087006,0.099275,0.11031,0.12193,0.13167,0.12465,0.079859],"unified_progress":[0.033542,0.053728,0.068617,0.078529,0.089466,0.095523,0.099031,0.10268,0.10513,0.10559,0.095314,0.072845]},{"section":26,"text":"Hmm, what about a cardiac arrhythmia?","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.012493,0.0331