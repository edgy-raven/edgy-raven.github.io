ress":[0.064628,0.10741,0.1139,0.11261,0.10553,0.096161,0.089601,0.079904,0.068683,0.064819,0.052501,0.044245],"unified_progress":[0.066474,0.086166,0.10119,0.10383,0.10385,0.10314,0.09712,0.087421,0.077847,0.071796,0.057532,0.04363]},{"section":5,"text":"When HBeAg turns negative and anti-HBe becomes positive, that typically indicates a switch to a phase where the virus is replicating less, maybe in a chronic phase but with low replication.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.057665,0.097793,0.099786,0.10084,0.099965,0.097189,0.092974,0.086675,0.077163,0.073427,0.061405,0.05512],"unified_progress":[0.063526,0.079849,0.0913,0.096389,0.098589,0.1007,0.0957,0.091759,0.084475,0.077531,0.065969,0.054214]},{"section":6,"text":"But wait, the HBV DNA here is 100,000 copies/mL. Hmm, I thought that in HBeAg-negative chronic hepatitis B, the viral load is usually lower, but maybe this is still considered elevated?","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.062186,0.10139,0.10278,0.1003,0.096336,0.092229,0.089136,0.085222,0.076966,0.073252,0.064044,0.05615],"unified_progress":[0.070715,0.085692,0.093081,0.096991,0.099889,0.096313,0.094916,0.088871,0.081459,0.07521,0.065078,0.051785]},{"section":7,"text":"Or maybe this is an HBeAg-negative phase but with ongoing replication.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.050002,0.08606,0.092979,0.09642,0.097269,0.095324,0.094021,0.090562,0.085109,0.080821,0.070819,0.060613],"unified_progress":[0.061563,0.07776,0.089327,0.097061,0.098689,0.097116,0.096514,0.091825,0.086182,0.080359,0.068669,0.054937]},{"section":8,"text":"The ALT and AST (SGOT/SGPT) are elevated six times the upper limit.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.054979,0.099687,0.10392,0.10059,0.096207,0.092603,0.090833,0.087085,0.07992,0.07314,0.066601,0.05443],"unified_progress":[0.05457,0.091045,0.098931,0.10116,0.10448,0.098749,0.097945,0.088584,0.081117,0.07