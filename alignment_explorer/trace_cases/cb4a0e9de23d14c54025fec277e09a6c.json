034,0.10651,0.098787,0.091391,0.08297,0.074556,0.058669,0.042212]},{"section":12,"text":"But if CD23 is negative here, that might point to a different diagnosis.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.045915,0.087076,0.10237,0.10565,0.10344,0.096031,0.093253,0.086475,0.079994,0.076607,0.065784,0.057405],"unified_progress":[0.053253,0.077087,0.089575,0.10014,0.1015,0.09762,0.095704,0.092086,0.086326,0.08268,0.069293,0.054736]},{"section":13,"text":"What about mantle cell lymphoma?","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.035437,0.07222,0.088077,0.097311,0.10205,0.10045,0.099313,0.094634,0.088576,0.086016,0.073225,0.0627],"unified_progress":[0.041724,0.068546,0.086914,0.097947,0.10068,0.10331,0.10124,0.097086,0.09118,0.086091,0.070539,0.054743]},{"section":14,"text":"Mantle cell lymphoma is CD5 positive too, but they are CD23 negative.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031146,0.066167,0.08148,0.094806,0.10346,0.10529,0.10589,0.098534,0.089506,0.088803,0.072612,0.062305],"unified_progress":[0.036726,0.061314,0.082952,0.094584,0.10116,0.10925,0.10548,0.10158,0.09486,0.087884,0.070477,0.053734]},{"section":15,"text":"Oh right!","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31912,0.052516,0.053667,0.062885,0.063553,0.064334,0.060724,0.069558,0.070345,0.064063,0.067752,0.051481],"unified_progress":[0.21015,0.07875,0.066,0.065835,0.074596,0.07363,0.10391,0.081287,0.077584,0.06099,0.055578,0.051686]},{"section":16,"text":"Mantle cell often co-expresses CD5 but lacks CD23.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.043871,0.091866,0.061462,0.10474,0.10943,0.10513,0.10211,0.092261,0.083632,0.077573,0.068195,0.059735],"unified_progress":[0.048545,0.074634,0.066237,0.10075,0.10534,0.10374,0.10307,0.098791,0.091711,0.084314,0.068941,0.053926]},{"section":17,"text":"Also, they have the t(11;14) translocation, but flow might not show that.","dimension"