egenerate":false,"model_progress":[0.03603,0.066882,0.0779,0.084367,0.087208,0.087074,0.089554,0.088805,0.089373,0.092131,0.089959,0.11072],"unified_progress":[0.041572,0.053885,0.065672,0.076147,0.080023,0.087206,0.088074,0.093253,0.095631,0.097085,0.1049,0.11655]},{"section":23,"text":"Because CLL would be CD5+ and CD23+.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.027581,0.05947,0.073596,0.084139,0.092349,0.096091,0.10122,0.099606,0.098039,0.095287,0.090614,0.082006],"unified_progress":[0.068739,0.058746,0.069733,0.077404,0.085205,0.090908,0.092416,0.096058,0.095238,0.095192,0.089575,0.080785]},{"section":24,"text":"The absence of CD23 here is a key differentiator.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.029694,0.064681,0.079622,0.08713,0.091047,0.092596,0.096027,0.095194,0.095007,0.093865,0.089135,0.086002],"unified_progress":[0.046272,0.063882,0.074493,0.083782,0.088693,0.091587,0.093146,0.093998,0.094396,0.09501,0.091038,0.083704]},{"section":25,"text":"Also, mantle cell often presents with splenomegaly and lymphadenopathy, and can have leukocytosis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028494,0.061045,0.073451,0.084286,0.092979,0.098474,0.10206,0.09988,0.097502,0.095565,0.088104,0.078165],"unified_progress":[0.036828,0.057876,0.074292,0.083053,0.091497,0.10001,0.099271,0.10072,0.10001,0.097636,0.087455,0.071361]},{"section":26,"text":"Another possibility: maybe a different B-cell lymphoma?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.025609,0.057771,0.073886,0.084369,0.093945,0.097095,0.1013,0.10383,0.10223,0.099643,0.090137,0.070184],"unified_progress":[0.034369,0.066652,0.084487,0.097577,0.098987,0.098504,0.10155,0.09956,0.09562,0.090813,0.07587,0.056013]},{"section":27,"text":"But the combination of CD5 and CD23 neg makes me think mantle cell.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.027218,0.057241,0.070987,0.080286,0.088208,0.092906,0.097674,0.098778,0.10034,0.099142,0.09599,0.091225],"unified_progress":[0.039333,0.057623,0.071218,0.081474,0.088458,0.095512,0.095903,0.097598,0.098048,0.09777,0.093031,0.084032]},{"section":28,"text":"Let me confirm.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30022,0.049585,0.050883,0.060303,0.061622,0.064879,0.06336,0.072761,0.074583,0.070722,0.074394,0.05669],"unified_progress":[0.20238,0.077215,0.063258,0.064042,0.072991,0.073944,0.092114,0.083064,0.080645,0.066346,0.061557,0.062448]},{"section":29,"text":"Yes, the classic markers for mantle cell are CD5+, CD23-, cyclin D1 positive (but flow might not test that).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037914,0.079667,0.061947,0.10216,0.10649,0.10198,0.10182,0.094055,0.08862,0.083268,0.074668,0.067408],"unified_progress":[0.044953,0.074201,0.067666,0.097708,0.10328,0.099733,0.10354,0.096664,0.091586,0.085963,0.074264,0.060442]},{"section":30,"text":"The presence in blood with high leukocyte count also points to a leukemia phase, so mantle cell leukemia.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.032265,0.06694,0.07962,0.088192,0.093884,0.096888,0.098724,0.095701,0.094212,0.089989,0.084064,0.079522],"unified_progress":[0.040984,0.06517,0.077459,0.085966,0.091885,0.096491,0.095507,0.095388,0.094811,0.091057,0.086835,0.078448]},{"section":31,"text":"So the most likely diagnosis is mantle cell lymphoma, possibly leukemic phase.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.022033,0.0444,0.054158,0.062357,0.071098,0.078745,0.086032,0.09061,0.098559,0.10082,0.11463,0.17655],"unified_progress":[0.022193,0.03353,0.042679,0.052401,0.057955,0.071521,0.074955,0.089128,0.10052,0.10832,0.14719,0.1996]}]}}