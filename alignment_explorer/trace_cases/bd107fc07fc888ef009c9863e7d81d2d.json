,0.10484,0.10714,0.097147,0.089906,0.083628,0.070563,0.051931]},{"section":14,"text":"No fever or neurologic symptoms, so it's less likely to be something like meningitis or another infection that affects the brain.","dimension":5,"group":6,"is_degenerate":false,"model_progress":[0.032733,0.062152,0.078544,0.088631,0.093705,0.097228,0.10132,0.10001,0.09841,0.09301,0.083907,0.070343],"unified_progress":[0.034276,0.067287,0.084636,0.095956,0.10112,0.1009,0.10028,0.098266,0.096448,0.087669,0.074436,0.058721]},{"section":15,"text":"It's more about the kidneys and blood.","dimension":0,"group":4,"is_degenerate":false,"model_progress":[0.037186,0.05878,0.074217,0.083575,0.091146,0.095388,0.098917,0.10021,0.099718,0.097457,0.088107,0.075302],"unified_progress":[0.039413,0.065159,0.079108,0.089093,0.094667,0.096621,0.098727,0.098625,0.095988,0.094749,0.082182,0.065667]},{"section":16,"text":"Putting it together: bloody diarrhea, hematuria, renal failure, schistocytes, low platelets.","dimension":14,"group":5,"is_degenerate":false,"model_progress":[0.033005,0.069656,0.075815,0.077821,0.084928,0.087172,0.089136,0.090746,0.090207,0.087826,0.10164,0.11204],"unified_progress":[0.065301,0.098813,0.091751,0.088386,0.088122,0.087848,0.085525,0.086344,0.081958,0.076707,0.075811,0.073432]},{"section":17,"text":"This sounds like hemolytic-uremic syndrome (HUS).","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.031322,0.058484,0.071496,0.082064,0.087817,0.091453,0.09731,0.099157,0.096625,0.095403,0.093096,0.095774],"unified_progress":[0.036107,0.063401,0.08577,0.091092,0.094276,0.10096,0.097461,0.093932,0.090891,0.08627,0.081596,0.078245]},{"section":18,"text":"HUS is often associated with gastrointestinal infections, like E. coli O157:H7, which can cause bloody diarrhea.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.026845,0.04922,0.065218,0.077677,0.091385,0.099025,0.11049,0.11404,0.10859,0.099665,0.085666,0.07218],"unified_progress":[0.029136,