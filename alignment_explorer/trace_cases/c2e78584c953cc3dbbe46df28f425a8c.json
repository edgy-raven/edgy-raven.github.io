90216,0.079301,0.086373,0.070064,0.06644,0.056117,0.044641]},{"section":5,"text":"Let me think about possible causes.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.04634,0.087007,0.10863,0.1123,0.10659,0.094664,0.089022,0.081634,0.077363,0.076671,0.06307,0.056712],"unified_progress":[0.049724,0.083426,0.091432,0.10869,0.10256,0.094576,0.0954,0.085754,0.079666,0.091802,0.066259,0.050709]},{"section":6,"text":"Lymphadenopathy can be due to infections, autoimmune conditions, or malignancies.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.040081,0.085712,0.10629,0.11158,0.10643,0.095797,0.091781,0.084187,0.076993,0.079287,0.064411,0.05746],"unified_progress":[0.047558,0.072328,0.0873,0.097597,0.099162,0.098611,0.097801,0.093519,0.088213,0.088855,0.072229,0.056828]},{"section":7,"text":"Since it's painless, that might point away from something like bacterial infection, which often causes tender nodes.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.037079,0.079199,0.094863,0.10065,0.09976,0.095791,0.095906,0.092076,0.086233,0.085616,0.073427,0.059399],"unified_progress":[0.040744,0.067528,0.08154,0.090877,0.096891,0.097787,0.098947,0.099324,0.095528,0.09681,0.078167,0.055857]},{"section":8,"text":"But viral infections can also be painless.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.030236,0.068257,0.083928,0.092495,0.096864,0.097704,0.10104,0.099255,0.094232,0.092178,0.081365,0.062447],"unified_progress":[0.050525,0.064049,0.077186,0.085752,0.09362,0.096441,0.099623,0.10105,0.097416,0.098927,0.08026,0.055147]},{"section":9,"text":"However, the combination with night sweats and pruritus makes me think of other possibilities.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.036221,0.077521,0.093996,0.098883,0.096716,0.091973,0.092128,0.089448,0.085715,0.090014,0.078012,0.069372],"unified_progress":[0.038747,0.068075,0.079312,0.091199,0.094425,0.095501,0.101,0.097341,0.094705,0.098411,0.081596,0.059692]},{"section":10,"text":"Night sweats are a classic B-symptom in lymphomas.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.03851,0.076946,0.089735,0.097235,0.099841,0.097829,0.097187,0.092078,0.085302,0.085895,0.073877,0.065566],"unified_progress":[0.04298,0.065546,0.080589,0.089538,0.096064,0.10218,0.10097,0.09895,0.094119,0.092225,0.077039,0.059795]},{"section":11,"text":"Hodgkin lymphoma often presents with painless lymphadenopathy, especially in the cervical area.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032801,0.069298,0.082225,0.094273,0.1024,0.10462,0.10482,0.097616,0.088796,0.088805,0.072087,0.062257],"unified_progress":[0.043158,0.061029,0.080665,0.090883,0.098053,0.10687,0.10397,0.10199,0.095854,0.089938,0.072077,0.055514]},{"section":12,"text":"The pruritus is another B-symptom in Hodgkin's.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.03534,0.073431,0.086731,0.094761,0.09835,0.098235,0.098388,0.093413,0.086889,0.089427,0.075066,0.069971],"unified_progress":[0.037522,0.064125,0.079996,0.090917,0.095621,0.10132,0.099877,0.098847,0.094782,0.092454,0.079196,0.065341]},{"section":13,"text":"So that's a strong possibility.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.038909,0.080335,0.099777,0.10407,0.099245,0.090541,0.088188,0.08414,0.080853,0.085428,0.073232,0.075279],"unified_progress":[0.041448,0.067212,0.079367,0.09214,0.093198,0.092355,0.09425,0.093313,0.091055,0.095511,0.085063,0.075088]},{"section":14,"text":"But what else? Other malignancies like non-Hodgkin lymphoma can also present with lymphadenopathy and B symptoms, but Hodgkin's is more commonly associated with pruritus.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031524,0.067939,0.084156,0.095464,0.10143,0.10093,0.10117,0.095532,0.08861,0.089224,0.076175,0.067854],"unified_progress":[0.034443,0.059098,0.077125,0.087223,0.095941,0.10446,0.10175,0.1018,0.098024,0.096425,0.080108,0.063601]},{"section":15,"text":"Then there's infectious mononucleosis, which can cause lymphadenopathy and sweats, but the pruritus isn't typical.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024989,0.059265,0.0749,0.086701,0.09538,0.10023,0.10534,0.10362,0.098924,0.097686,0.086346,0.066607],"unified_progress":[0.028028,0.055915,0.073683,0.084374,0.094534,0.10152,0.10331,0.10629,0.10413,0.10622,0.084584,0.057397]},{"section":16,"text":"Maybe a systemic infection like tuberculosis?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.021363,0.054658,0.072457,0.084136,0.094699,0.099917,0.10466,0.10731,0.10459,0.10132,0.090563,0.064332],"unified_progress":[0.030633,0.066261,0.082944,0.094381,0.098831,0.099989,0.10342,0.10299,0.099006,0.095812,0.076575,0.049165]},{"section":17,"text":"But TB usually has more constitutional symptoms like weight loss and maybe night sweats, but the pruritus is less common.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.017574,0.04789,0.064542,0.075969,0.087027,0.094595,0.10627,0.11127,0.1108,0.10903,0.10325,0.071789],"unified_progress":[0.025772,0.054714,0.071186,0.079321,0.093435,0.097086,0.10203,0.11032,0.10859,0.11302,0.090884,0.053639]},{"section":18,"text":"Autoimmune conditions like SLE can cause lymphadenopathy and other symptoms, but pruritus might be from a rash, but not sure.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018248,0.047935,0.063846,0.076794,0.087569,0.096173,0.10687,0.11077,0.10938,0.10875,0.10057,0.073094],"unified_progress":[0.025074,0.051029,0.067841,0.078542,0.090441,0.098212,0.10306,0.11034,0.11019,0.11449,0.093781,0.057]},{"section":19,"text":"Also, the age is young, and Hodgkin's is more common in younger adults.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.025929,0.058056,0.071218,0.081213,0.090513,0.099553,0.10243,0.10462,0.10204,0.10103,0.091429,0.071975],"unified_progress":[0.076763,0.087435,0.08205,0.081332,0.085689,0.088489,0.090924,0.09339,0.089993,0.090534,0.07669,0.056711]},{"section":20,"text":"The triad of painless lymphadenopathy, night sweats, and pruritus is classic for Hodgkin lymphoma.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.027123,0.057616,0.069643,0.080443,0.08985,0.095835,0.10041,0.099361,0.097819,0.099717,0.094482,0.087702],"unified_progress":[0.039243,0.059348,0.079129,0.083106,0.090841,0.099506,0.098424,0.098164,0.097029,0.095018,0.086907,0.073284]},{"section":21,"text":"Let me check if there are other clues.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.021441,0.051339,0.071952,0.083058,0.093901,0.098635,0.10086,0.1026,0.10467,0.098302,0.092526,0.080708],"unified_progress":[0.03375,0.071649,0.084352,0.099421,0.098909,0.095385,0.096212,0.09406,0.090831,0.09661,0.079065,0.059757]},{"section":22,"text":"The pruritus in Hodgkin's can be severe and is thought to be due to eosinophilia or other immune mediators.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.025618,0.058359,0.072321,0.084328,0.094326,0.10065,0.10528,0.10244,0.098309,0.095907,0.087053,0.075406],"unified_progress":[0.037605,0.055763,0.070471,0.0788,0.090546,0.10039,0.099375,0.10128,0.10065,0.099874,0.090029,0.075216]},{"section":23,"text":"Another thought: could it be sarcoidosis?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.02059,0.052083,0.070184,0.082274,0.094181,0.098779,0.10432,0.10841,0.10662,0.10283,0.093407,0.066316],"unified_progress":[0.029298,0.066597,0.086087,0.10104,0.10096,0.10011,0.10323,0.10099,0.096748,0.09132,0.073943,0.049676]},{"section":24,"text":"But sarcoid usually has bilateral hilar adenopathy on imaging, and the pruritus isn't a main symptom.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.017776,0.048051,0.065137,0.076846,0.08814,0.095196,0.10566,0.11004,0.11003,0.10784,0.10203,0.073251],"unified_progress":[0.025804,0.05638,0.074389,0.083416,0.096625,0.099283,0.10295,0.10939,0.10645,0.1074,0.085974,0.05193]},{"section":25,"text":"Maybe a drug reaction?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.016292,0.046037,0.064365,0.077507,0.091818,0.10012,0.10666,0.11303,0.11125,0.10892,0.0981,0.065902],"unified_progress":[0.031373,0.06675,0.084325,0.095958,0.10022,0.10074,0.10427,0.10437,0.098911,0.095023,0.07385,0.044201]},{"section":26,"text":"But the history doesn't mention medications.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018664,0.048608,0.065062,0.075521,0.086484,0.094878,0.10401,0.10967,0.11064,0.10874,0.10326,0.074467],"unified_progress":[0.038378,0.0687,0.078663,0.0848,0.093955,0.094227,0.098411,0.10438,0.1008,0.1034,0.083382,0.050899]},{"section":27,"text":"So putting it all together, the most likely diagnosis is Hodgkin lymphoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.024433,0.046948,0.056425,0.064258,0.071189,0.07733,0.084404,0.089499,0.096164,0.10242,0.11324,0.17369],"unified_progress":[0.029349,0.037806,0.046426,0.056543,0.061638,0.070896,0.077556,0.084841,0.09265,0.10412,0.14152,0.19666]},{"section":28,"text":"The combination of the symptoms and the typical presentation in a young adult points there.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.027058,0.055675,0.068977,0.076465,0.081598,0.085068,0.090455,0.093934,0.099056,0.10625,0.10721,0.10826],"unified_progress":[0.033601,0.04876,0.057876,0.067808,0.075514,0.085281,0.089713,0.098476,0.10655,0.11602,0.11682,0.10359]},{"section":29,"text":"I should also consider other lymphomas, but the classic B symptoms and pruritus lean more towards Hodgkin's.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.023096,0.050467,0.06397,0.072725,0.079819,0.084967,0.091648,0.095407,0.10054,0.10443,0.10799,0.12495],"unified_progress":[0.025852,0.043575,0.054599,0.063957,0.071819,0.081377,0.086826,0.096094,0.10408,0.11198,0.1245,0.13533]}]