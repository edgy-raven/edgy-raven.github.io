.11443,0.12346,0.1185,0.10117,0.082044,0.076392,0.070138,0.061024,0.072103,0.050786,0.050959],"unified_progress":[0.095607,0.079809,0.084762,0.096265,0.095424,0.089424,0.090678,0.086348,0.076905,0.086886,0.064827,0.053066]},{"section":8,"text":"They're known for their severe pain, often around the eye or temple, and they can cause those autonomic symptoms like tearing, redness, and nasal congestion on the affected side.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.052017,0.094946,0.098081,0.10076,0.10155,0.099193,0.094354,0.087966,0.077707,0.073951,0.063056,0.056425],"unified_progress":[0.049115,0.075519,0.090479,0.092429,0.096435,0.10262,0.096401,0.095894,0.089186,0.084182,0.07034,0.057403]},{"section":9,"text":"The fact that they wake him from sleep fits too, since cluster headaches often occur at night.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.050536,0.09195,0.093687,0.093817,0.094691,0.096212,0.093206,0.090574,0.082586,0.081005,0.069682,0.062054],"unified_progress":[0.05347,0.075651,0.083446,0.088789,0.092375,0.097501,0.09495,0.095824,0.091316,0.088917,0.076299,0.061462]},{"section":10,"text":"The duration of an hour is typical for a cluster attack.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.051557,0.092881,0.094826,0.093852,0.093026,0.092959,0.091019,0.089672,0.082649,0.081147,0.071312,0.065099],"unified_progress":[0.063138,0.078711,0.083848,0.088537,0.091149,0.094121,0.09258,0.093381,0.088655,0.086809,0.07581,0.06326]},{"section":11,"text":"The frequency of two a day over three weeks might indicate a cluster period, which can last weeks to months.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.051563,0.093319,0.092446,0.09048,0.091162,0.09486,0.09145,0.091423,0.084277,0.081549,0.072508,0.064965],"unified_progress":[0.062194,0.081707,0.084738,0.087164,0.089283,0.093316,0.090831,0.093586,0.08862,0.086335,0.076962,0.065264]},{"section":12,"text":"Wait, but I should consider other possibilities.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.02908,0.06266,0.083531,0.092998,0.098601,0.097727,0.097546,0.095082,0.094657,0.091655,0.08265,0.073813],"unified_progress":[0.037864,0.073006,0.083533,0.10063,0.098486,0.094194,0.098484,0.091779,0.088068,0.099162,0.076597,0.058195]},{"section":13,"text":"Migraines can have unilateral pain and autonomic features, but migraines usually last longer, like 4-72 hours, and the autonomic symptoms (like photophobia, nausea) are different.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.030045,0.064579,0.075878,0.086241,0.094561,0.099211,0.10398,0.10194,0.095864,0.095058,0.083988,0.068656],"unified_progress":[0.034798,0.061236,0.076298,0.083752,0.095545,0.1044,0.1015,0.10432,0.099912,0.098304,0.080112,0.059825]},{"section":14,"text":"Plus, migraines don't typically wake someone as abruptly.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.030395,0.063156,0.072856,0.080553,0.087144,0.093307,0.10076,0.10395,0.10208,0.10063,0.093212,0.071957],"unified_progress":[0.036171,0.058943,0.071106,0.079137,0.08972,0.094294,0.09883,0.10537,0.10453,0.11177,0.089556,0.060569]},{"section":15,"text":"Tension headaches are usually bilateral and not associated with those symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021219,0.051574,0.065955,0.077206,0.086115,0.09349,0.10481,0.10917,0.10877,0.10827,0.10088,0.072537],"unified_progress":[0.027203,0.0523,0.067948,0.077445,0.089873,0.095669,0.10207,0.11002,0.11037,0.11789,0.093833,0.055383]},{"section":16,"text":"Trigeminal neuralgia is another thought, but that's more like electric shocks and not\u6301\u7eed an hour.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025279,0.056299,0.069044,0.080643,0.089918,0.096458,0.104,0.10603,0.10363,0.10389,0.09268,0.07213],"unified_progress":[0.030856,0.05479,0.071595,0.083084,0.092483,0.10061,0.10367,0.10807,0.10631,0.10742,0.086085,0.05502]},{"section":17,"text":"The nasal stuffiness and eye symptoms make me think more of cluster.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026717,0.060797,0.074342,0.083221,0.08923,0.094289,0.099299,0.10001,0.1026,0.098725,0.092206,0.078567],"unified_progress":[0.0318,0.059842,0.074943,0.085891,0.094071,0.098111,0.10065,0.10211,0.1034,0.10046,0.085175,0.063552]},{"section":18,"text":"Also, the nonfocal neuro exam rules out a structural issue.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02956,0.066926,0.079884,0.086482,0.089615,0.093098,0.097295,0.098245,0.10031,0.096295,0.088711,0.073577],"unified_progress":[0.031522,0.064534,0.079071,0.08891,0.096398,0.096439,0.099978,0.10052,0.10072,0.098281,0.082706,0.060927]},{"section":19,"text":"So yeah, cluster headache seems to fit best here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.03088,0.063764,0.079007,0.084615,0.085059,0.082954,0.085569,0.086281,0.087942,0.096003,0.093723,0.1242],"unified_progress":[0.030559,0.049249,0.059771,0.071345,0.074711,0.079379,0.087012,0.089984,0.094364,0.10374,0.11882,0.14107]}]}}