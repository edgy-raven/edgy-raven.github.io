],"unified_progress":[0.03215,0.05133,0.062036,0.070916,0.076213,0.082375,0.087503,0.095347,0.09973,0.10392,0.11291,0.12558]},{"section":14,"text":"The spicules of pigmentation and the scotomas make me think of something like retinitis pigmentosa, which is a group of disorders causing progressive loss of vision due to the accumulation of pigment in the retina.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.024468,0.038651,0.055966,0.069099,0.085939,0.097245,0.10445,0.11228,0.11468,0.10557,0.094583,0.097064],"unified_progress":[0.025889,0.047769,0.069583,0.081345,0.090428,0.10164,0.10381,0.10534,0.10419,0.10021,0.089893,0.079896]},{"section":15,"text":"In retinitis pigmentosa, the rods are affected first, leading to night blindness, and as the disease progresses, the cones can be affected, causing central vision loss.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.023776,0.039315,0.056278,0.070184,0.089609,0.1021,0.1105,0.11948,0.11937,0.1044,0.086849,0.078139],"unified_progress":[0.026903,0.050352,0.072306,0.089133,0.096447,0.10824,0.10954,0.10812,0.10317,0.097338,0.077794,0.060668]},{"section":16,"text":"The waxy pallor of the optic disc is due to the accumulation of pigment in the retinal pigment epithelium, and the spicules are areas where the pigment has accumulated in the outer parts of the retina.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.033013,0.042454,0.06085,0.076252,0.09257,0.10304,0.10894,0.11281,0.10912,0.095821,0.086028,0.079101],"unified_progress":[0.034209,0.055467,0.074808,0.089073,0.096774,0.10402,0.10346,0.1023,0.10064,0.091483,0.07977,0.06799]},{"section":17,"text":"The ring scotomas are a result of the loss of vision in the central areas, creating a ring-shaped blind spot.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.038441,0.048592,0.064039,0.077147,0.090341,0.099717,0.1045,0.10765,0.10508,0.094451,0.087436,0.082595],"unified_progress":[0.039855,0.058583,0.07