.077452,0.094145,0.10513,0.10852,0.10327,0.099539,0.0895,0.079457,0.080318,0.064185,0.059779],"unified_progress":[0.038378,0.062882,0.085892,0.095008,0.10116,0.10965,0.1028,0.098463,0.092103,0.08747,0.069823,0.056377]},{"section":9,"text":"IgA. Let's think.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.036138,0.068214,0.082924,0.09235,0.09919,0.099566,0.09848,0.095627,0.092267,0.087308,0.077837,0.070099],"unified_progress":[0.047022,0.070121,0.083724,0.097717,0.098776,0.097058,0.096868,0.094763,0.089944,0.091273,0.074302,0.058431]},{"section":10,"text":"Pemphigus vulgaris has intraepithelial acantholytic cells and IgG deposits between cells, but the basement membrane is more about pemphigoid.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031588,0.067437,0.08152,0.094747,0.10271,0.10539,0.10555,0.097173,0.089527,0.088373,0.071945,0.064039],"unified_progress":[0.034385,0.060859,0.082615,0.094673,0.10199,0.11238,0.10454,0.10092,0.094859,0.086997,0.069265,0.056523]},{"section":11,"text":"Bullous pemphigoid typically has subepithelial bullae, which matches the tense blisters here.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034435,0.070159,0.080984,0.092136,0.099765,0.10293,0.10378,0.096969,0.089901,0.091289,0.072511,0.06514],"unified_progress":[0.03845,0.06164,0.080695,0.093607,0.099523,0.10901,0.10473,0.10153,0.096337,0.088083,0.070948,0.055445]},{"section":12,"text":"The immunofluorescence in BP usually shows linear IgG and C3 along the basement membrane zone.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.037339,0.0745,0.086131,0.093851,0.097186,0.097891,0.099383,0.093854,0.090672,0.085594,0.075434,0.068164],"unified_progress":[0.043389,0.067766,0.084963,0.094597,0.10066,0.10332,0.10022,0.096284,0.092893,0.082894,0.072449,0.06056]},{"section":13,"text":"That's exactly what's described here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.041484,0.079094,0.09306,0.