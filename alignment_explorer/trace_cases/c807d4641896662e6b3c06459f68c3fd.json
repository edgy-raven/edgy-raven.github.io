085977,0.087627,0.074115,0.062358]},{"section":10,"text":"The EEG showing three-per-second activity is significant.","dimension":17,"group":6,"is_degenerate":false,"model_progress":[0.040801,0.074409,0.089815,0.09653,0.095843,0.093374,0.091415,0.088354,0.085122,0.083505,0.081747,0.079084],"unified_progress":[0.045312,0.07516,0.085001,0.093161,0.094619,0.093837,0.094326,0.093274,0.090933,0.087142,0.079007,0.068227]},{"section":11,"text":"I remember that in epilepsy, certain patterns on EEG can point to specific types.","dimension":12,"group":4,"is_degenerate":false,"model_progress":[0.030603,0.061204,0.080471,0.093151,0.097676,0.10046,0.1021,0.10187,0.099268,0.09399,0.079517,0.059688],"unified_progress":[0.02948,0.058924,0.076343,0.087001,0.095987,0.098117,0.10228,0.10507,0.10269,0.10509,0.084398,0.054618]},{"section":12,"text":"Three per second is in the range of a spike-and-wave complex, which is typical for absence seizures.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.034503,0.068224,0.087638,0.097533,0.099486,0.09865,0.099995,0.097208,0.092538,0.084935,0.075575,0.063716],"unified_progress":[0.032655,0.06422,0.082192,0.092916,0.099735,0.10247,0.10189,0.10129,0.098807,0.091511,0.076766,0.055544]},{"section":13,"text":"Absence seizures, also known as petit mal seizures, are characterized by brief periods of altered consciousness.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.037116,0.064825,0.07659,0.083788,0.092968,0.09659,0.10306,0.10374,0.098228,0.090223,0.081414,0.071466],"unified_progress":[0.04261,0.070568,0.083449,0.092661,0.097369,0.10666,0.10207,0.099778,0.093577,0.086718,0.070858,0.053679]},{"section":14,"text":"The child stops responding, has a blank stare, and sometimes eye blinking.","dimension":14,"group":5,"is_degenerate":false,"model_progress":[0.047229,0.086018,0.082668,0.077509,0.082875,0.083687,0.087395,0.089919,0.090054,0.081903,0.094682,0.096062],"unified_progress":[0.08758,0.11936,0.10022,0.092253,0.