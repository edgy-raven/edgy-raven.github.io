18,0.083599,0.090304,0.098807,0.097204,0.097726,0.0951,0.092482,0.087443,0.079241]},{"section":14,"text":"And absence seizures usually happen in kids around this age, too.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.038833,0.050193,0.062014,0.072267,0.080883,0.089261,0.096678,0.10156,0.10854,0.11564,0.10663,0.077494],"unified_progress":[0.043705,0.060353,0.072564,0.081647,0.088297,0.094216,0.095402,0.097853,0.096969,0.098252,0.090806,0.079936]},{"section":15,"text":"So, that fits.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.10954,0.088243,0.081625,0.073081,0.074591,0.077398,0.080683,0.090614,0.083044,0.057984,0.06125,0.12195],"unified_progress":[0.19992,0.077728,0.062302,0.063164,0.072929,0.073847,0.095334,0.083689,0.08163,0.066898,0.06222,0.060337]},{"section":16,"text":"Plus, they often don't have any warning signs before they start, which matches with how quickly this kid goes from normal to spaced-out and back again.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.064387,0.062508,0.065824,0.070366,0.074629,0.079417,0.084752,0.087698,0.093223,0.10519,0.11545,0.096553],"unified_progress":[0.064887,0.080598,0.056022,0.080118,0.085605,0.092445,0.09578,0.091602,0.091586,0.091462,0.088663,0.081233]},{"section":17,"text":"So, putting it all together, the frequent staring, the blinking, the EEG findings, and the age all point towards absence seizures.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.023342,0.036484,0.047573,0.056384,0.063707,0.070787,0.078991,0.08538,0.097292,0.11917,0.15961,0.16128],"unified_progress":[0.031181,0.04511,0.05572,0.06585,0.074407,0.084768,0.088967,0.095371,0.10369,0.10828,0.11946,0.1272]},{"section":18,"text":"It seems pretty clear that this is what's going on with him.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.016783,0.02672,0.031951,0.037688,0.042472,0.047735,0.053592,0.057714,0.069579,0.098021,0.20584,0.31191],"unified_progress"