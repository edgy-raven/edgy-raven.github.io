5,"is_degenerate":false,"model_progress":[0.086516,0.14541,0.1308,0.1069,0.092396,0.089158,0.077043,0.074723,0.061598,0.053759,0.044564,0.037136],"unified_progress":[0.08592,0.11243,0.11016,0.10567,0.097649,0.097977,0.085248,0.082638,0.071603,0.061748,0.050351,0.038602]},{"section":6,"text":"That's a classic sign of constrictive pericarditis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.054575,0.09995,0.10944,0.11099,0.10528,0.096992,0.091404,0.081842,0.073663,0.070199,0.055406,0.050257],"unified_progress":[0.052916,0.07881,0.097928,0.10312,0.10283,0.10492,0.096969,0.090319,0.084328,0.076876,0.061676,0.049315]},{"section":7,"text":"Then there's an early diastolic filling sound, the pericardial knock.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.061282,0.10834,0.1057,0.10156,0.096427,0.094459,0.088874,0.083711,0.078857,0.068988,0.059233,0.052562],"unified_progress":[0.061778,0.08926,0.097127,0.10291,0.10304,0.099442,0.094037,0.089416,0.084278,0.071214,0.059334,0.048163]},{"section":8,"text":"That's another clue pointing towards constrictive pericarditis.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.057369,0.096735,0.10374,0.10427,0.098589,0.090809,0.08743,0.081408,0.075924,0.076603,0.06281,0.064317],"unified_progress":[0.062697,0.074029,0.086239,0.09535,0.096702,0.097418,0.094295,0.090477,0.086053,0.082716,0.071219,0.062804]},{"section":9,"text":"Wait, let me think again.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.33343,0.05458,0.054509,0.063437,0.063146,0.063475,0.059508,0.066149,0.067208,0.061969,0.06505,0.047537],"unified_progress":[0.22335,0.087584,0.064876,0.065053,0.074273,0.072651,0.09237,0.078233,0.074767,0.060067,0.055451,0.051321]},{"section":10,"text":"The patient had heart surgery before.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.052554,0.10614,0.063192,0.10282,0.10521,0.1032,0.094261,0.090647,0.082019,0.077528,0.068228,0.054202],"unified_progress":[0.14307,0.18257,0.082211,0.088615,0.083136,0.082616,0.07045,0.06646,0.061037,0.054901,0.048784,0.036149]},{"section":11,"text":"Constrictive pericarditis can develop after cardiac surgeries because of scarring from the pericardial trauma.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.040503,0.07873,0.087975,0.095944,0.099451,0.10287,0.098647,0.091662,0.0957,0.080366,0.068279,0.059873],"unified_progress":[0.074578,0.099227,0.11121,0.10507,0.09996,0.098759,0.088035,0.083213,0.07979,0.063997,0.052819,0.043344]},{"section":12,"text":"The combination of elevated JVP, Kussmaul's, and the pericardial knock all fit.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.043581,0.083184,0.090922,0.094205,0.094299,0.09374,0.093172,0.089869,0.088172,0.084318,0.075338,0.069198],"unified_progress":[0.05486,0.080656,0.092029,0.097861,0.10024,0.099661,0.094889,0.090389,0.086525,0.079296,0.067993,0.055605]},{"section":13,"text":"Also, the dyspnea and edema suggest fluid retention, which can happen with right heart issues.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.02907,0.063322,0.075891,0.08586,0.094064,0.099136,0.10329,0.099922,0.096341,0.092094,0.086156,0.074854],"unified_progress":[0.035982,0.054632,0.068226,0.075298,0.087351,0.09656,0.097856,0.10077,0.10309,0.103,0.097866,0.079367]},{"section":14,"text":"Constrictive pericarditis limits the heart's ability to expand, leading to elevated pressures.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.035962,0.07247,0.081428,0.088962,0.093707,0.097336,0.098863,0.09563,0.094462,0.088244,0.079649,0.073287],"unified_progress":[0.040765,0.060696,0.074179,0.083372,0.091746,0.097413,0.098862,0.098282,0.099039,0.095186,0.086468,0.073991]},{"section":15,"text":"Other possibilities?","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.032204,0.071492,0.092445,0.098406,0.098002,0.093093,0.092553,0.090308,0.088457,0.091631,0.078534,0.072874],"unified_progress":[0.034575,0.068276,0.081004,0.093799,0.095272,0.093724,0.096377,0.095599,0.093387,0.098295,0.083049,0.066645]},{"section":16,"text":"Maybe restrictive cardiomyopathy, but that usually doesn't have Kussmaul's.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025699,0.061082,0.07768,0.089181,0.096772,0.099359,0.10388,0.10176,0.097056,0.095705,0.084362,0.067457],"unified_progress":[0.028452,0.057854,0.076346,0.08662,0.096739,0.10277,0.10314,0.10493,0.1018,0.1008,0.081813,0.058729]},{"section":17,"text":"It might have a pericardial knock though.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028272,0.063221,0.077229,0.088083,0.095109,0.099406,0.1031,0.10101,0.098958,0.094591,0.083106,0.067912],"unified_progress":[0.032946,0.059557,0.077482,0.089468,0.097494,0.10288,0.10284,0.10341,0.10141,0.096778,0.078945,0.056787]},{"section":18,"text":"But the history of prior cardiac surgery makes constrictive more likely.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.030207,0.065723,0.0793,0.087204,0.091708,0.09648,0.096604,0.095795,0.095647,0.094116,0.085405,0.08181],"unified_progress":[0.050174,0.078474,0.080951,0.085299,0.088476,0.090589,0.091165,0.093107,0.091658,0.089676,0.083479,0.076953]},{"section":19,"text":"Also, in restrictive cardiomyopathy, the JVP might be elevated but Kussmaul's is more specific for constrictive.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030082,0.064501,0.077243,0.086846,0.093493,0.096899,0.10112,0.098969,0.095884,0.09364,0.085414,0.07591],"unified_progress":[0.037838,0.062702,0.079927,0.086999,0.094273,0.10027,0.098792,0.098664,0.096439,0.093941,0.082506,0.067653]},{"section":20,"text":"Another thought: tamponade?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.027964,0.063534,0.080026,0.088773,0.095014,0.09685,0.099162,0.09952,0.098158,0.095209,0.085405,0.070388],"unified_progress":[0.0336,0.068426,0.085049,0.096774,0.099632,0.099293,0.10139,0.09869,0.095167,0.09059,0.075465,0.055925]},{"section":21,"text":"But tamponade would have pulsus paradoxus, and Kussmaul's is actually a sign against tamponade.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029969,0.065484,0.078035,0.087737,0.095215,0.099076,0.10305,0.10101,0.096206,0.093196,0.083114,0.067907],"unified_progress":[0.036457,0.064299,0.080641,0.089545,0.097883,0.10364,0.10222,0.10195,0.097507,0.092973,0.07687,0.056014]},{"section":22,"text":"In tamponade, JVP decreases during inspiration (paradoxical), so Kussmaul's is the opposite.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037439,0.072346,0.080706,0.088698,0.094869,0.098014,0.10051,0.097315,0.092423,0.089333,0.078744,0.069606],"unified_progress":[0.046585,0.066882,0.081247,0.0901,0.096002,0.10171,0.099763,0.098176,0.094042,0.088312,0.076059,0.061124]},{"section":23,"text":"So that's more constrictive.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.030621,0.0617,0.076133,0.084707,0.091218,0.093853,0.096608,0.096538,0.096717,0.093483,0.088685,0.089735],"unified_progress":[0.03895,0.062145,0.074376,0.086718,0.089618,0.091295,0.09311,0.094289,0.093535,0.097154,0.091572,0.087238]},{"section":24,"text":"So putting it all together: post-cardiac surgery, constrictive pericarditis with the classic signs.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.034892,0.06441,0.073396,0.080237,0.084134,0.08707,0.089873,0.090297,0.093477,0.094608,0.094044,0.11356],"unified_progress":[0.04252,0.053511,0.064078,0.074837,0.078864,0.084998,0.08668,0.090814,0.095355,0.09778,0.10825,0.12231]},{"section":25,"text":"The pericardial knock is a diastolic sound from the stiff pericardium resisting filling.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.036977,0.074722,0.083943,0.090878,0.092861,0.095515,0.096271,0.092393,0.095433,0.08608,0.079177,0.075749],"unified_progress":[0.041046,0.064521,0.08149,0.093571,0.098044,0.099411,0.098162,0.095302,0.095523,0.086131,0.077693,0.069106]},{"section":26,"text":"Yeah, I think that's it.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31835,0.052589,0.053924,0.062521,0.062383,0.063986,0.06076,0.069186,0.07019,0.064825,0.069007,0.052276],"unified_progress":[0.2123,0.081387,0.066996,0.066767,0.075766,0.073989,0.088357,0.081215,0.077172,0.062383,0.05758,0.056089]}]}}