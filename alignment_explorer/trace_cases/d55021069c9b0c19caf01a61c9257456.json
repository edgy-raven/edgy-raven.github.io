281,0.065539,0.048441]},{"section":5,"text":"He also has a family history of benign tumors\u2014his mother has had low-grade gliomas and meningiomas.","dimension":0,"group":5,"is_degenerate":false,"model_progress":[0.035607,0.080983,0.09119,0.092617,0.093015,0.094951,0.099066,0.095767,0.092162,0.092383,0.074425,0.057832],"unified_progress":[0.071481,0.10405,0.094681,0.091668,0.092732,0.091918,0.088381,0.090967,0.084611,0.074459,0.063555,0.051501]},{"section":6,"text":"Gliomas are brain tumors that can occur in various areas, and meningiomas are another type of benign tumor that can affect the brain, spine, or meninges.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.025085,0.046287,0.065687,0.077305,0.097697,0.10756,0.11195,0.11677,0.11325,0.096837,0.077408,0.064167],"unified_progress":[0.033047,0.059376,0.095725,0.095204,0.1005,0.11808,0.10594,0.099563,0.092613,0.084639,0.066086,0.049227]},{"section":7,"text":"Since both his mother and he have these tumors, it's possible there's a genetic component.","dimension":0,"group":5,"is_degenerate":false,"model_progress":[0.04173,0.072293,0.082356,0.085214,0.086533,0.089255,0.095202,0.093994,0.094061,0.1001,0.085336,0.073921],"unified_progress":[0.06598,0.091966,0.087722,0.08853,0.089806,0.090544,0.088644,0.092384,0.086598,0.081907,0.073395,0.062525]},{"section":8,"text":"Schwannomas, especially in the cerebellopontine angle, are often inherited in families.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.032784,0.05402,0.068738,0.078919,0.091293,0.098479,0.10311,0.1061,0.10461,0.097028,0.085951,0.078967],"unified_progress":[0.03726,0.062931,0.086612,0.092184,0.096388,0.10381,0.10026,0.096892,0.094351,0.088156,0.075769,0.065391]},{"section":9,"text":"There's a condition called Neurofibromatosis type 2 (NF2), which is associated with schwannomas in the cerebellopontine angle and other areas like the optic nerve.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.021016,0.