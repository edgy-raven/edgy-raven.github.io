e is Neurofibromatosis type 2.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.027294,0.051513,0.060812,0.068789,0.07548,0.08067,0.086546,0.089646,0.094338,0.10015,0.10796,0.15681],"unified_progress":[0.032598,0.042592,0.053715,0.062217,0.067052,0.076137,0.080566,0.086805,0.095174,0.10397,0.13228,0.1669]}]}}