0642,0.07499,0.084384,0.090563,0.095732,0.098797,0.098203,0.098053,0.097383,0.087536,0.067924]},{"section":18,"text":"Uveitis is more common in Beh\u00e7et's, but maybe the conjunctivitis is part of that.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029973,0.063404,0.076692,0.08758,0.095396,0.099114,0.10216,0.09931,0.095925,0.093433,0.083622,0.073386],"unified_progress":[0.038727,0.0605,0.078026,0.087532,0.094816,0.10118,0.10115,0.10055,0.097498,0.093845,0.081063,0.065109]},{"section":19,"text":"The arthritis is another feature.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.026314,0.061248,0.078241,0.087606,0.093638,0.095998,0.10013,0.099181,0.098172,0.095684,0.089219,0.074569],"unified_progress":[0.063642,0.064376,0.074847,0.084117,0.090768,0.093383,0.095507,0.097129,0.094961,0.095686,0.082378,0.063206]},{"section":20,"text":"Abdominal pain could be from GI involvement, like ulcers in the intestines.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029838,0.065333,0.077266,0.086967,0.093653,0.099049,0.10193,0.099245,0.099085,0.091489,0.084164,0.071978],"unified_progress":[0.041867,0.060976,0.076268,0.085992,0.093573,0.098493,0.098423,0.098325,0.099452,0.09405,0.084629,0.067953]},{"section":21,"text":"Other possibilities?","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.02579,0.061059,0.081974,0.09088,0.096439,0.096659,0.098178,0.097808,0.097065,0.095164,0.085125,0.073858],"unified_progress":[0.036181,0.069747,0.083428,0.096992,0.097372,0.094579,0.0977,0.095118,0.091947,0.096016,0.079568,0.061352]},{"section":22,"text":"Let's think.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30539,0.051008,0.051409,0.06044,0.061798,0.065514,0.062399,0.071414,0.074138,0.069147,0.072776,0.054567],"unified_progress":[0.21142,0.080929,0.067157,0.064893,0.074733,0.075063,0.091826,0.082093,0.078816,0.062942,0.057712,0.052415]},{"section":23,"text":"Reiter's syndrome (Reactive Arthritis) can have urethral discharge, arthritis, and conjunctivitis (the old triad), but the genital ulcers here might not fit as neatly.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029195,0.065517,0.058603,0.10217,0.11202,0.10726,0.11001,0.1017,0.091835,0.085647,0.075727,0.060316],"unified_progress":[0.036079,0.065257,0.063015,0.096804,0.10647,0.1028,0.10579,0.10689,0.10059,0.093256,0.073359,0.049693]},{"section":24,"text":"Also, Reiter's is often after an infection, but the timing here is 2 weeks.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026163,0.059907,0.073845,0.085376,0.094299,0.10269,0.10511,0.10539,0.10122,0.09687,0.086845,0.062288],"unified_progress":[0.061089,0.083225,0.083146,0.084609,0.091321,0.092357,0.09324,0.098454,0.093835,0.09644,0.07405,0.048236]},{"section":25,"text":"Infectious causes: HIV can present with oral ulcers, but usually more systemic symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021079,0.052823,0.068926,0.081304,0.091098,0.098382,0.10695,0.1079,0.10498,0.10335,0.094614,0.068596],"unified_progress":[0.033228,0.060819,0.076167,0.083737,0.09437,0.098591,0.1015,0.10535,0.10328,0.10504,0.08501,0.052916]},{"section":26,"text":"Syphilis can have mucocutaneous lesions, but the arthritis and conjunctivitis aren't typical.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.019727,0.050907,0.067009,0.079981,0.090225,0.097883,0.10702,0.1088,0.10664,0.10492,0.095938,0.070956],"unified_progress":[0.026338,0.053842,0.071999,0.082262,0.093727,0.10052,0.10357,0.10878,0.10722,0.1095,0.087978,0.054254]},{"section":27,"text":"Sarcoidosis can have oral ulcers and uveitis, but arthritis and GI issues are less common.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018657,0.049266,0.066009,0.079762,0.090665,0.098485,0.10747,0.10924,0.10704,0.10593,0.096131,0.07135],"unified_progress":[0.025159,0.052563,0.071346,0.083073,0.094065,0.10156,0.10464,0.1097,0.10772,0.11016,0.086878,0.053134]},{"section":28,"text":"Crohn's disease can have oral ulcers and abdominal pain, but the genital ulcers and conjunctivitis are less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.020448,0.051062,0.065938,0.078172,0.088466,0.096837,0.1055,0.10803,0.10757,0.10554,0.09795,0.074491],"unified_progress":[0.02708,0.05369,0.070554,0.081422,0.092511,0.099481,0.10295,0.10848,0.10786,0.11067,0.088773,0.056524]},{"section":29,"text":"So Beh\u00e7et's seems to fit best.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.02577,0.054043,0.067435,0.07556,0.081351,0.084762,0.089743,0.092396,0.095387,0.099845,0.10147,0.13224],"unified_progress":[0.029579,0.045403,0.055437,0.066069,0.071029,0.080112,0.085387,0.091702,0.095996,0.10307,0.12349,0.15273]},{"section":30,"text":"The combination of the ulcers in mouth and genitals, along with arthritis, conjunctivitis, and abdominal pain (GI involvement) is classic.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.019302,0.044691,0.058357,0.069025,0.080241,0.08916,0.096735,0.10061,0.10771,0.11074,0.11633,0.1071],"unified_progress":[0.028639,0.04314,0.055425,0.065314,0.077251,0.091134,0.094635,0.10278,0.11151,0.11798,0.11667,0.095514]},{"section":31,"text":"The timing of 2 weeks might be acute, but Beh\u00e7et's is a chronic relapsing condition.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.026231,0.056628,0.06836,0.078161,0.087341,0.094942,0.099813,0.10192,0.10184,0.1022,0.096612,0.085951],"unified_progress":[0.065459,0.067362,0.069885,0.074263,0.081548,0.087901,0.091538,0.096301,0.096517,0.097999,0.092451,0.078777]},{"section":32,"text":"However, the presentation can have acute flare-ups.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.025349,0.057222,0.071169,0.081283,0.090207,0.096499,0.10219,0.10329,0.10199,0.09936,0.093602,0.077844],"unified_progress":[0.070058,0.067671,0.072538,0.078797,0.085308,0.089101,0.091831,0.096719,0.094247,0.097907,0.086735,0.069088]},{"section":33,"text":"Another thought: Systemic lupus erythematosus (SLE) can have oral ulcers, arthritis, and maybe serositis, but the genital ulcers and conjunctivitis are possible but not the strongest pointers.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022045,0.052598,0.067801,0.080325,0.090734,0.097689,0.10512,0.10589,0.10402,0.10284,0.095183,0.075745],"unified_progress":[0.030687,0.056079,0.075311,0.083932,0.093727,0.099389,0.102,0.10426,0.10329,0.10343,0.087035,0.060851]},{"section":34,"text":"But the key triad for Beh\u00e7et's is there: oral and genital ulcers plus uveitis/conjunctivitis.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.021967,0.04876,0.062465,0.074554,0.086232,0.094312,0.10037,0.10174,0.10368,0.10519,0.10419,0.096546],"unified_progress":[0.030663,0.048778,0.064458,0.076118,0.086148,0.099526,0.099613,0.1034,0.10483,0.10379,0.099036,0.08364]},{"section":35,"text":"Adding arthritis and GI symptoms makes it even more likely.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.024393,0.054558,0.068507,0.077559,0.08481,0.089851,0.095883,0.098158,0.10106,0.10207,0.10096,0.10219],"unified_progress":[0.036746,0.051465,0.062848,0.072923,0.080706,0.088979,0.091651,0.098491,0.10174,0.1054,0.10634,0.10272]},{"section":36,"text":"So I think the most likely diagnosis here is Beh\u00e7et's disease.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.01904,0.038877,0.048909,0.057042,0.065888,0.074155,0.082773,0.089719,0.10028,0.10578,0.12301,0.19453],"unified_progress":[0.018685,0.027857,0.035729,0.044945,0.050667,0.06459,0.069623,0.08561,0.10046,0.11281,0.16032,0.22871]}]}}