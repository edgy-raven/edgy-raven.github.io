5771,0.065323,0.054845,0.044862],"unified_progress":[0.037727,0.075784,0.09532,0.10734,0.10847,0.10583,0.10413,0.095498,0.089549,0.077502,0.06018,0.042667]},{"section":6,"text":"Then, the CT scan of the orbit shows a left orbital mass with calcification, mainly centered within the globe.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.034933,0.081143,0.10062,0.11258,0.1147,0.10805,0.10438,0.090006,0.079562,0.066224,0.057476,0.050319],"unified_progress":[0.035015,0.077276,0.0987,0.1107,0.1166,0.10786,0.10199,0.092384,0.09111,0.068843,0.054925,0.044599]},{"section":7,"text":"So, the mass is inside the eye, not just in the orbit around it.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.031128,0.074334,0.096094,0.11285,0.11562,0.11122,0.10821,0.09425,0.083214,0.067331,0.056922,0.048827],"unified_progress":[0.032831,0.075076,0.098345,0.11365,0.11887,0.10909,0.10543,0.093222,0.092187,0.068449,0.051227,0.041625]},{"section":8,"text":"Calcifications in an orbital mass could suggest a few things.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.038745,0.073374,0.092342,0.10548,0.1064,0.10428,0.10259,0.095398,0.087088,0.076212,0.064484,0.053604],"unified_progress":[0.035061,0.069395,0.090103,0.10364,0.10859,0.10726,0.10521,0.097206,0.09277,0.079887,0.062939,0.047937]},{"section":9,"text":"I'm thinking about possible tumors or inflammatory conditions.","dimension":6,"group":8,"is_degenerate":false,"model_progress":[0.03596,0.075142,0.092994,0.10216,0.10094,0.099151,0.094655,0.091706,0.084671,0.088751,0.072181,0.061696],"unified_progress":[0.034648,0.07097,0.087619,0.10175,0.10167,0.099529,0.10272,0.096881,0.090973,0.090108,0.071127,0.051999]},{"section":10,"text":"In children, some common orbital tumors include dermoid cysts, which can have calcifications.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.033438,0.06131,0.078077,0.090064,0.099963,0.10313,0.10849,0.10543,0.097547,0.088084,0.073834,0.06064],"unified_progress":[0.033508,0.06454,0.085346,0.10059,0.10481,0.10997,0.10492,0.099887,0.094174,0.083882,0.066517,0.051849]},{"section":11,"text":"Retinoblastoma is another possibility, but that's more of an intraocular tumor, often presenting with a white reflex and proptosis.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.028791,0.057599,0.073951,0.08626,0.096528,0.10122,0.10944,0.10912,0.10228,0.091383,0.078641,0.064797],"unified_progress":[0.03062,0.061467,0.082826,0.096909,0.10266,0.1136,0.10663,0.10217,0.096526,0.087533,0.068303,0.050755]},{"section":12,"text":"However, retinoblastoma typically doesn't calcify as much as other tumors.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.030961,0.052908,0.069072,0.081389,0.093994,0.10034,0.10906,0.11023,0.10581,0.096334,0.082965,0.066942],"unified_progress":[0.032359,0.059985,0.080371,0.093654,0.10088,0.10912,0.10572,0.10305,0.098259,0.091622,0.072102,0.052881]},{"section":13,"text":"Another option is a choroidal melanoma, but that's more common in adults.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.025851,0.051833,0.06853,0.081071,0.092896,0.099603,0.109,0.11112,0.10723,0.099501,0.085073,0.068282],"unified_progress":[0.028797,0.058508,0.079469,0.093167,0.10025,0.10829,0.1061,0.10445,0.099674,0.094819,0.073931,0.052538]},{"section":14,"text":"Wait, there's also the possibility of a foreign body, but the history doesn't mention any trauma or foreign object.","dimension":6,"group":8,"is_degenerate":false,"model_progress":[0.030151,0.054314,0.070868,0.081041,0.092125,0.098513,0.10204,0.10423,0.10309,0.1047,0.08818,0.070751],"unified_progress":[0.035993,0.067439,0.082625,0.094601,0.098894,0.099843,0.10191,0.099852,0.095949,0.09404,0.07516,0.053698]},{"section":15,"text":"So maybe it's a tumor.","dimension":5,"group":6,"is_degenerate":false,"model_progress":[0.020153,0.043576,0.061059,0.076354,0.088757,0.10087,0.11107,0.11574,0.11806,0.10888,0.091014,0.064467],"unified_progress":[0.028802,0.067086,0.086419,0.098018,0.10138,0.10019,0.10483,0.10228,0.097065,0.092412,0.073053,0.048468]},{"section":16,"text":"Orbital dermoids are usually in the posterior orbit and can cause proptosis.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.02959,0.054575,0.072182,0.08607,0.096918,0.10196,0.10906,0.10698,0.10251,0.091601,0.080768,0.067778],"unified_progress":[0.035705,0.069329,0.089273,0.10135,0.10807,0.10693,0.10283,0.097834,0.094535,0.07901,0.064974,0.050161]},{"section":17,"text":"They often have calcifications, which would explain the CT findings.","dimension":12,"group":4,"is_degenerate":false,"model_progress":[0.037807,0.056358,0.072114,0.083007,0.092072,0.096865,0.1018,0.10286,0.10166,0.095568,0.086431,0.073456],"unified_progress":[0.038627,0.064885,0.080878,0.091122,0.097829,0.10282,0.1009,0.099323,0.096038,0.090655,0.076632,0.060286]},{"section":18,"text":"The white reflex could be due to the mass pressing on the retina or the lens.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.031886,0.056296,0.075944,0.089836,0.099083,0.10318,0.10765,0.10407,0.10049,0.08916,0.078248,0.064143],"unified_progress":[0.033568,0.067335,0.08824,0.1009,0.10712,0.1059,0.10316,0.09774,0.097738,0.08241,0.066398,0.049491]},{"section":19,"text":"Alternatively, consider optic glioma, but those usually don't calcify.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.026854,0.050951,0.069899,0.082754,0.095373,0.10188,0.10887,0.10948,0.10519,0.098728,0.083211,0.066801],"unified_progress":[0.031272,0.061952,0.082458,0.096535,0.10143,0.11373,0.1058,0.10067,0.095192,0.088552,0.070187,0.052224]},{"section":20,"text":"Another thought is a hemangioma, but those are more vascular and might not have calcifications.","dimension":0,"group":4,"is_degenerate":false,"model_progress":[0.028024,0.050099,0.067031,0.079678,0.091635,0.098857,0.10776,0.11023,0.10873,0.10126,0.087899,0.068799],"unified_progress":