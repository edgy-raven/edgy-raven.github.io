.06571,0.078527,0.055425,0.047286,0.03906,0.029887]},{"section":5,"text":"Also, he's not really interested in other kids, and people think he's self-centered and disinterested.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.13476,0.21508,0.16106,0.095651,0.068878,0.077215,0.052815,0.063594,0.041461,0.035699,0.029096,0.024696],"unified_progress":[0.1195,0.15107,0.11664,0.10896,0.083607,0.08886,0.068496,0.078756,0.058822,0.050443,0.042255,0.032593]},{"section":6,"text":"Hmm, delayed speech at four years old is a red flag.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.083569,0.13497,0.13703,0.12064,0.098944,0.084184,0.072972,0.067235,0.056107,0.060388,0.043772,0.040177],"unified_progress":[0.082987,0.099447,0.097367,0.10567,0.098338,0.092993,0.088524,0.082774,0.072124,0.077324,0.057485,0.044971]},{"section":7,"text":"But what else?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.3594,0.059774,0.058073,0.0655,0.064057,0.062447,0.057459,0.061349,0.060519,0.055174,0.0558,0.040447],"unified_progress":[0.23463,0.095571,0.067439,0.06504,0.075371,0.072314,0.087947,0.075239,0.070949,0.05667,0.051771,0.047064]},{"section":8,"text":"The interest in spinning objects... that makes me think of repetitive behaviors.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.066919,0.13629,0.073109,0.11204,0.10189,0.095173,0.084893,0.078502,0.072183,0.066322,0.059881,0.052794],"unified_progress":[0.082672,0.1179,0.074151,0.097789,0.096521,0.097899,0.085768,0.084903,0.078766,0.07302,0.063761,0.046846]},{"section":9,"text":"And social interaction issues, like not engaging with other children.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.061745,0.10967,0.10369,0.094243,0.09265,0.092005,0.088158,0.087136,0.077873,0.073297,0.064776,0.05475],"unified_progress":[0.08008,0.094312,0.092698,0.091926,0.091794,0.09175,0.088283,0.089945,0.081551,0.078139,0.066695,0.052826]},{"section":10,"text":"Those are key points.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.33556,0.055826,0.055972,0.063988,0.063698,0.06299,0.060109,0.065708,0.06534,0.060501,0.062712,0.047597],"unified_progress":[0.22928,0.092702,0.065491,0.064793,0.075276,0.072303,0.087617,0.076765,0.072624,0.058309,0.053578,0.051263]},{"section":11,"text":"So, putting this together: developmental delays, especially in speech; fascination with certain objects (spinning things); lack of interest in peers; being seen as self-centered.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.084507,0.16248,0.067399,0.098454,0.089393,0.090071,0.080084,0.074464,0.069465,0.065784,0.061156,0.056739],"unified_progress":[0.099323,0.12592,0.070237,0.090443,0.089217,0.092283,0.084436,0.08042,0.076141,0.071751,0.065606,0.054224]},{"section":12,"text":"These symptoms remind me of autism spectrum disorder (ASD).","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.057771,0.098405,0.1128,0.1086,0.099946,0.085863,0.081893,0.075787,0.07015,0.076303,0.063404,0.069072],"unified_progress":[0.060543,0.075371,0.083259,0.095822,0.093284,0.091185,0.091257,0.087487,0.083648,0.088127,0.078197,0.07182]},{"section":13,"text":"Wait, the developmental milestones are otherwise normal except for speech.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.052472,0.094548,0.098883,0.097413,0.094612,0.092485,0.08837,0.086197,0.081234,0.078697,0.071136,0.063954],"unified_progress":[0.055092,0.08156,0.086543,0.090715,0.092766,0.092509,0.091682,0.09189,0.08804,0.087177,0.077811,0.064216]},{"section":14,"text":"But ASD can present with varying degrees.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.034248,0.071258,0.086724,0.095046,0.098825,0.097866,0.099323,0.095473,0.09039,0.088086,0.078382,0.064377],"unified_progress":[0.086875,0.073268,0.079503,0.085406,0.09003,0.09098,0.091917,0.093245,0.087359,0.088437,0.074666,0.058314]},{"section":15,"text":"Some kids might have delays in specific areas like speech but have other skills intact.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.036195,0.072831,0.082643,0.090219,0.096237,0.098939,0.10086,0.098364,0.092529,0.088258,0.078881,0.064042],"unified_progress":[0.08947,0.075546,0.082094,0.085707,0.089958,0.092243,0.091636,0.09388,0.086499,0.08476,0.071608,0.0566]},{"section":16,"text":"The repetitive behaviors, like staring at spinning objects, are classic.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.038452,0.075469,0.082794,0.088292,0.09321,0.096184,0.097982,0.096333,0.092353,0.088525,0.080647,0.069758],"unified_progress":[0.07115,0.078274,0.085866,0.088769,0.092001,0.09471,0.092452,0.09347,0.087611,0.084033,0.072528,0.059136]},{"section":17,"text":"Social interaction problems are a core feature.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.031077,0.067398,0.082861,0.091623,0.096078,0.096045,0.099278,0.096384,0.092763,0.092053,0.082896,0.071544],"unified_progress":[0.077393,0.069521,0.078685,0.086259,0.090925,0.092879,0.093064,0.093884,0.088846,0.089952,0.076659,0.061932]},{"section":18,"text":"The parents struggling to get him interested in other kids points to social communication deficits.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.05397,0.094629,0.08881,0.085832,0.087182,0.090985,0.090484,0.091575,0.086312,0.083246,0.076859,0.070117],"unified_progress":[0.067711,0.091418,0.087581,0.08503,0.086861,0.09055,0.087742,0.091912,0.086083,0.083632,0.076536,0.064944]},{"section":19,"text":"Are there other possibilities?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.32465,0.053723,0.054179,0.062622,0.062874,0.062894,0.061078,0.067564,0.068132,0.064046,0.067,0.051234],"unified_progress":[0.21782,0.088264,0.065674,0.064176,0.075,0.072874,0.088426,0.078579,0.074912,0.061171,0.056852,0.056255]},{"section":20,"text":"Maybe a language disorder without the social aspects, but the combination of social and behavioral symptoms points more towards ASD.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.038562,0.083556,0.067747,0.1064,0.10498,0.096331,0.097056,0.092986,0.087345,0.081786,0.076129,0.067122],"unified_progress":[0.048085,0.084689,0.067375,0.090848,0.098586,0.095708,0.095035,0.097229,0.093281,0.088928,0.078847,0.06139]},{"section":21,"text":"Also, the age is right, as ASD symptoms usually appear in early childhood.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.03978,0.075064,0.084253,0.090028,0.09424,0.096237,0.095526,0.093856,0.089572,0.088648,0.079854,0.072942],"unified_progress":[0.05847,0.07777,0.081697,0.085292,0.088921,0.091935,0.0922,0.093536,0.089866,0.089637,0.081068,0.069608]},{"section":22,"text":"I should consider other differential diagnoses.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.028723,0.062288,0.081788,0.090597,0.096312,0.096631,0.097055,0.095429,0.095414,0.092633,0.084703,0.078428],"unified_progress":[0.038286,0.072091,0.082715,0.09789,0.09616,0.093331,0.097622,0.091794,0.088746,0.096702,0.07994,0.064723]},{"section":23,"text":"Like global developmental delay, but the problem here is specific to speech and social aspects.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.032015,0.06815,0.080401,0.087185,0.09179,0.094033,0.097361,0.097443,0.09501,0.094549,0.086743,0.07532],"unified_progress":[0.039119,0.066319,0.078998,0.086935,0.093046,0.095469,0.097301,0.098598,0.096368,0.096734,0.084033,0.06708]},{"section":24,"text":"Maybe a sensory processing disorder?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.023482,0.057295,0.074791,0.085816,0.095443,0.099006,0.10363,0.10475,0.10212,0.098678,0.089067,0.065923],"unified_progress":[0.053411,0.067923,0.082366,0.092603,0.096365,0.096762,0.099959,0.098929,0.094201,0.091268,0.074463,0.051751]},{"section":25,"text":"But again, the social component is key here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022278,0.05368,0.07023,0.080222,0.088675,0.093942,0.1013,0.1043,0.105,0.10302,0.097492,0.079858],"unified_progress":[0.031613,0.059024,0.073105,0.084713,0.092844,0.094691,0.099415,0.1027,0.10179,0.10573,0.089473,0.064903]},{"section":26,"text":"No mention of other sensory issues beyond the spinning objects.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028139,0.061827,0.073456,0.080882,0.08794,0.093848,0.099697,0.10262,0.10279,0.1002,0.093919,0.074685],"unified_progress":[0.040489,0.064996,0.076505,0.084682,0.092129,0.094697,0.099778,0.10149,0.10023,0.10184,0.085045,0.05812]},{"section":27,"text":"The fact that people comment on his disinterest suggests he's not engaging in typical social ways.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.045665,0.083596,0.082285,0.0823,0.086096,0.092111,0.093368,0.095797,0.092852,0.088965,0.083511,0.073455],"unified_progress":[0.062784,0.081048,0.081652,0.084085,0.087771,0.091076,0.091513,0.093794,0.091197,0.088673,0.080193,0.066215]},{"section":28,"text":"So, putting it all together, the most likely diagnosis is autism spectrum disorder.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.029364,0.056396,0.068353,0.07453,0.077933,0.079246,0.0844,0.086534,0.091436,0.097523,0.10342,0.15086],"unified_progress":[0.029909,0.042883,0.051893,0.062516,0.066267,0.074572,0.079957,0.087092,0.095321,0.10519,0.13343,0.17098]}]}}