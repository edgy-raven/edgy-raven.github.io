s":[0.031228,0.0685,0.084503,0.092061,0.095169,0.095751,0.09895,0.097135,0.093539,0.090801,0.083004,0.069359],"unified_progress":[0.037626,0.069765,0.083302,0.09076,0.097379,0.097295,0.1002,0.097206,0.093204,0.092141,0.079509,0.061615]},{"section":15,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.030586,0.070063,0.091097,0.097657,0.098175,0.09388,0.093514,0.091896,0.089277,0.091384,0.079882,0.072588],"unified_progress":[0.033553,0.068779,0.082751,0.096926,0.096876,0.095406,0.10115,0.096272,0.092564,0.095348,0.079895,0.060481]},{"section":16,"text":"Alport syndrome?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.024265,0.059377,0.07748,0.088323,0.097442,0.1002,0.10289,0.10303,0.099266,0.096479,0.085511,0.065734],"unified_progress":[0.044994,0.069127,0.084398,0.093869,0.098048,0.099188,0.10165,0.099282,0.093633,0.08935,0.072971,0.053491]},{"section":17,"text":"But that usually has more progressive kidney disease and maybe hearing loss or eye issues, which aren't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.017181,0.047815,0.065278,0.077048,0.087728,0.095157,0.10652,0.11113,0.11079,0.10849,0.10244,0.070426],"unified_progress":[0.025672,0.054939,0.071836,0.080629,0.094824,0.097277,0.10246,0.1102,0.10842,0.11337,0.088551,0.051824]},{"section":18,"text":"Hereditary nephritis?","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.024104,0.056823,0.071748,0.083674,0.093664,0.10028,0.10405,0.10467,0.10135,0.099893,0.088236,0.071507],"unified_progress":[0.039269,0.067247,0.079831,0.089649,0.09498,0.10166,0.10154,0.1019,0.097871,0.09371,0.077209,0.055141]},{"section":19,"text":"But again, the trigger after infections is a key point here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024461,0.057624,0.073496,0.083094,0.08974,0.094961,0.10077,0.10269,0.10244,0.1021,0.094427,0.074187],"unified_progress":[0.038483,0.066252,0.076301,0.084072,0.092295,0.094746,0.097863,0.10233,0.10041,0.10483,0.084387,0.058038]},{"section":20,"text":"Post-streptococcal glomerulonephritis can cause hematuria after infections, but that's typically acute and in kids, not recurring over years.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028893,0.061314,0.073802,0.086253,0.09591,0.10139,0.10479,0.10216,0.096083,0.095936,0.083399,0.070061],"unified_progress":[0.039426,0.060976,0.078063,0.086831,0.094544,0.10488,0.10235,0.10326,0.098847,0.095215,0.078798,0.056812]},{"section":21,"text":"So maybe not that.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31182,0.050564,0.051833,0.061324,0.062934,0.064267,0.062292,0.071059,0.071975,0.066872,0.070644,0.054415],"unified_progress":[0.20497,0.078046,0.064255,0.064745,0.074204,0.073828,0.10067,0.082693,0.07951,0.063173,0.057878,0.056037]},{"section":22,"text":"Focal segmental glomerulosclerosis (FSGS) usually presents with more proteinuria, maybe nephrotic range, but the link to infections isn't there.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032126,0.07184,0.059591,0.1038,0.11173,0.10643,0.10788,0.099061,0.089706,0.083687,0.074137,0.06001],"unified_progress":[0.037067,0.066652,0.064221,0.097916,0.1064,0.10328,0.10524,0.10561,0.09912,0.091665,0.072715,0.050105]},{"section":23,"text":"So putting it all together: young male, recurrent hematuria post URI, RBC casts, normal renal function, negative ANA/ANCA.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.026608,0.056943,0.070708,0.080049,0.088109,0.093643,0.09778,0.098016,0.10027,0.099076,0.099784,0.089011],"unified_progress":[0.033915,0.056047,0.069187,0.078845,0.088633,0.10048,0.098707,0.10036,0.1018,0.099818,0.095154,0.077057]},{"section":24,"text":"IgA nephropathy is the most likely diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.023811,0.050457,0.063389,0.071355,0.076962,0.080572,0.08662,0.089487,0.095227,0.10068,