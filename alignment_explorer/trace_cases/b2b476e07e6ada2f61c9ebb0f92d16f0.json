te":false,"model_progress":[0.068319,0.13456,0.074305,0.11344,0.10413,0.095037,0.088754,0.079277,0.071939,0.064583,0.057486,0.048172],"unified_progress":[0.076576,0.11426,0.075694,0.097723,0.10053,0.094971,0.093741,0.084343,0.078255,0.072092,0.06369,0.048124]},{"section":6,"text":"She has elevated serum creatinine, so there's some kidney dysfunction.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.058188,0.10667,0.10972,0.10277,0.098364,0.09424,0.089148,0.08419,0.075806,0.069491,0.061256,0.050161],"unified_progress":[0.058141,0.092326,0.096554,0.098263,0.10173,0.096812,0.097046,0.087822,0.081206,0.074653,0.065384,0.050058]},{"section":7,"text":"RBC casts in the urine are a key finding here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.051724,0.10001,0.11065,0.10828,0.099753,0.091645,0.087375,0.081543,0.07723,0.073435,0.062715,0.055637],"unified_progress":[0.048553,0.084659,0.094374,0.10264,0.10291,0.098339,0.099183,0.089186,0.08431,0.078416,0.066115,0.051308]},{"section":8,"text":"RBC casts are indicative of glomerular disease because they form in the glomeruli.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039502,0.080599,0.094011,0.10215,0.10363,0.10065,0.098608,0.090455,0.084926,0.079243,0.066887,0.059339],"unified_progress":[0.058281,0.069906,0.086194,0.096573,0.1001,0.1051,0.098794,0.09426,0.088897,0.080645,0.066712,0.054535]},{"section":9,"text":"Now, her blood pressure is elevated at 146/94, which is important.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.06142,0.10885,0.10476,0.097557,0.092955,0.09178,0.088202,0.086385,0.077817,0.072058,0.064548,0.053672],"unified_progress":[0.062634,0.098794,0.098908,0.097678,0.099519,0.095059,0.092187,0.088866,0.08089,0.073247,0.06348,0.048738]},{"section":10,"text":"She mentions a sore throat with fever about two weeks prior.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.064908,0.11301,0.10198,0.090919,0.088718,0.097822,0.086307,0.088579,0.078464,0.073237,0.064055,0.052],"unified_progress":[0.081913,0.11429,0.099709,0.095259,0.089129,0.090642,0.083322,0.086705,0.077902,0.070968,0.061958,0.0482]},{"section":11,"text":"That timeline is classic for a post-infectious process.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.045521,0.085939,0.097051,0.101,0.099311,0.099223,0.092861,0.087669,0.081066,0.082834,0.068125,0.059397],"unified_progress":[0.068082,0.094286,0.095203,0.098171,0.09406,0.095246,0.089972,0.08865,0.080597,0.07916,0.065147,0.051426]},{"section":12,"text":"The sore throat could be a strep infection, which often precedes post-streptococcal glomerulonephritis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037753,0.073897,0.085123,0.094912,0.10099,0.10342,0.10122,0.094738,0.086432,0.08541,0.071705,0.064403],"unified_progress":[0.052213,0.073818,0.08957,0.092028,0.095725,0.10339,0.096979,0.095047,0.088721,0.083424,0.071084,0.058004]},{"section":13,"text":"Also, her classmates being sick might suggest an infectious agent going around, supporting a post-infectious etiology.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.038119,0.075089,0.084099,0.090085,0.09505,0.10295,0.09764,0.095793,0.091001,0.088318,0.077092,0.064766],"unified_progress":[0.07592,0.10435,0.093508,0.090315,0.088753,0.090673,0.085459,0.088893,0.081927,0.076916,0.067983,0.055307]},{"section":14,"text":"The absence of abdominal or costovertebral angle tenderness makes pyelonephritis less likely.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.040388,0.082379,0.088201,0.090447,0.091639,0.095258,0.095439,0.095191,0.097484,0.083977,0.075957,0.063639],"unified_progress":[0.048334,0.083428,0.092719,0.097816,0.099993,0.098582,0.095018,0.092505,0.092004,0.080091,0.067705,0.051808]},{"section":15,"text":"RBC casts plus acute kidney injury (elevated creatinine) and hypertension point towards a glomerulonephritis.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.036089,0.073886,0.085276,0.091617,0.094681,0.095795,0.097742,0.094124,0.091453,0.0873,0.080135,0.071902],"unified_progress":[0.041488,0.068793,0.082905,0.089836,0.096312,0.099393,0.098388,0.095255,0.093389,0.088005,0.080132,0.066104]},{"section":16,"text":"Post-streptococcal GN typically presents 1-2 weeks after a pharyngitis or skin infection.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031712,0.066063,0.078016,0.089777,0.098858,0.10403,0.10401,0.098956,0.091425,0.091302,0.077107,0.068746],"unified_progress":[0.044902,0.069053,0.082035,0.088627,0.094199,0.10461,0.10003,0.099331,0.093392,0.087835,0.074968,0.061009]},{"section":17,"text":"The presence of RBC casts, hematuria, proteinuria, hypertension, and acute renal impairment all fit.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.030759,0.065749,0.077606,0.085314,0.091563,0.095735,0.099319,0.097497,0.09614,0.093363,0.088839,0.078116],"unified_progress":[0.03938,0.067119,0.079917,0.087303,0.094481,0.10022,0.098055,0.097156,0.096176,0.091311,0.082789,0.066092]},{"section":18,"text":"Other possibilities like IgA nephropathy usually present after a upper respiratory infection but with hematuria starting within days, not weeks.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026329,0.060032,0.07402,0.086572,0.096069,0.10151,0.10572,0.10299,0.097098,0.096723,0.083889,0.069056],"unified_progress":[0.03009,0.057275,0.077173,0.086864,0.096294,0.10536,0.10455,0.10487,0.10043,0.098612,0.080761,0.057722]},{"section":19,"text":"Also, IgA doesn't typically have as much acute renal impairment or RBC casts as post-strep GN.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027621,0.06008,0.072812,0.083249,0.091118,0.096486,0.10231,0.10198,0.099373,0.098432,0.089249,0.07729],"unified_progress":[0.032374,0.056393,0.072544,0.08303,0.091893,0.0983,0.099902,0.1033,0.10163,0.10297,0.088002,0.069662]},{"section":20,"text":"Lupus nephritis is possible, but she's young and the history of a recent infection fits better.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022624,0.054236,0.068733,0.079371,0.088234,0.097451,0.10382,0.10721,0.10626,0.10468,0.096697,0.070688],"unified_progress":[0.042252,0.071549,0.076592,0.080309,0.08887,0.092105,0.095889,0.10259,0.10112,0.10695,0.085855,0.055918]},{"section":21,"text":"No mention of malar rash or other autoimmune symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.020158,0.051032,0.065986,0.076838,0.085753,0.094201,0.10499,0.10961,0.10971,0.1086,0.10172,0.07141],"unified_progress":[0.030957,0.058733,0.072044,0.080029,0.091815,0.095135,0.10093,0.10762,0.10731,0.11255,0.090139,0.052734]},{"section":22,"text":"So the most likely is post-streptococcal glomerulonephritis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.026293,0.053259,0.063012,0.072362,0.080501,0.087105,0.092648,0.094724,0.097113,0.09882,0.10094,0.13323],"unified_progress":[0.029577,0.044149,0.056131,0.066543,0.072661,0.083284,0.085434,0.091724,0.095922,0.1,0.12112,0.15345]},{"section":23,"text":"<answer> Post-streptococcal glomerulonephritis </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.035958,0.05834,0.06004,0.066128,0.073628,0.0803,0.086546,0.090591,0.094809,0.099032,0.10521,0.14942],"unified_progress":[0.039279,0.039896,0.047608,0.055673,0.061997,0.073146,0.076054,0.088374,0.096531,0.10406,0.13404,0.18335]}]}}