96044,0.099103,0.10294,0.099802,0.096248,0.091251,0.084929,0.069489,0.056846]},{"section":11,"text":"I remember that's a condition associated with areca nut chewing, commonly found in South Asia.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.033429,0.068307,0.082649,0.095309,0.10382,0.10666,0.10445,0.097076,0.087519,0.089092,0.070545,0.061139],"unified_progress":[0.047158,0.071739,0.086544,0.093993,0.097369,0.10801,0.10152,0.099041,0.090988,0.08509,0.067095,0.051454]},{"section":12,"text":"It causes fibrosis of the oral mucosa, leading to stiffness and reduced mouth opening.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.035999,0.073331,0.082231,0.090666,0.097125,0.10076,0.102,0.097288,0.092694,0.087359,0.074762,0.065784],"unified_progress":[0.06112,0.068735,0.082229,0.090135,0.095454,0.10075,0.097612,0.096619,0.092894,0.084357,0.071545,0.058554]},{"section":13,"text":"The key features are difficulty in opening the mouth, which progresses over time, and the absence of ulcers might be because the active lesions have healed, leaving fibrotic tissue.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.046355,0.088744,0.089588,0.089889,0.091532,0.094961,0.094355,0.093133,0.08772,0.084242,0.073614,0.065867],"unified_progress":[0.049451,0.07878,0.085907,0.089595,0.093561,0.098171,0.095044,0.095786,0.091956,0.086936,0.074637,0.060178]},{"section":14,"text":"Other causes of trismus could be infections like tetanus, but she doesn't have other symptoms like lockjaw or muscle spasms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.03321,0.069698,0.079398,0.085922,0.091552,0.095901,0.10066,0.10126,0.097219,0.094319,0.085509,0.065361],"unified_progress":[0.0364,0.064575,0.077686,0.084973,0.093833,0.097764,0.099564,0.10277,0.10031,0.10196,0.083326,0.05684]},{"section":15,"text":"Maybe a temporomandibular joint disorder, but that's less likely with a long history of tobacco use.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02836,0.064145,0.076982,0.085577,0.091248,0.096756,0.10104,0.10155,0.10198,0.096731,0.087518,0.068116],"unified_progress":[0.034605,0.064112,0.0775,0.086403,0.09461,0.097772,0.10026,0.10263,0.10267,0.1008,0.082587,0.056044]},{"section":16,"text":"Also, tumors or cancers could cause trismus, but the exam didn't show ulcers, so maybe it's more the fibrotic process rather than a mass.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024864,0.059571,0.074597,0.084248,0.089763,0.09458,0.10061,0.10152,0.10518,0.099284,0.09133,0.074454],"unified_progress":[0.029387,0.05844,0.07467,0.085728,0.094689,0.096652,0.10062,0.10285,0.10458,0.10244,0.086441,0.063497]},{"section":17,"text":"Oral submucous fibrosis typically presents with a burning sensation, stiffness, and progressive trismus.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.03115,0.064461,0.074386,0.085242,0.09441,0.099613,0.10267,0.099975,0.095304,0.093564,0.083719,0.075507],"unified_progress":[0.036646,0.058933,0.074712,0.086268,0.0934,0.10806,0.10281,0.10275,0.099247,0.093535,0.080313,0.063336]},{"section":18,"text":"The patient's history of long-term tobacco use fits, especially if the tobacco includes areca nut, which is common in some chewing mixes.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.032995,0.06714,0.076718,0.084717,0.093379,0.10516,0.1004,0.10017,0.095908,0.094158,0.082855,0.066402],"unified_progress":[0.092687,0.11447,0.095429,0.087183,0.085694,0.087318,0.082781,0.087707,0.079238,0.073071,0.063384,0.051043]},{"section":19,"text":"Since she's from a rural background, that's a region where this condition is more prevalent.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.037093,0.070323,0.078257,0.085903,0.092702,0.10776,0.098126,0.098717,0.093211,0.092716,0.08083,0.064364],"unified_progress":[0.1103,0.13797,0.1071,0.098457,0.081049,0.087327,0.071867,0.085461,0.066581,0.059757,0.051727,0.042401]},{"section":20,"text":"So putting it all together, the most likely diagnosis is oral submucous fibrosis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.034626,0.059689,0.067264,0.073748,0.077907,0.080416,0.085561,0.087257,0.090885,0.096238,0.10098,0.14543],"unified_progress":[0.050329,0.055331,0.065168,0.07327,0.076325,0.078717,0.08359,0.083156,0.085755,0.094931,0.11344,0.13998]},{"section":21,"text":"It explains the chronic use leading to fibrosis and the trismus without current ulcers.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.02595,0.055526,0.066979,0.075696,0.083687,0.090104,0.096515,0.098024,0.10073,0.10209,0.10282,0.10188],"unified_progress":[0.035628,0.050002,0.0602,0.068949,0.077646,0.088216,0.09005,0.097478,0.10436,0.11057,0.11287,0.10404]}]}}