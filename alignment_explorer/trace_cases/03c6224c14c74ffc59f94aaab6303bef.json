:false,"model_progress":[0.077596,0.134,0.11317,0.12258,0.087483,0.07625,0.080614,0.065269,0.063019,0.073056,0.06242,0.044549],"unified_progress":[0.043824,0.086648,0.096359,0.11277,0.10485,0.094307,0.097678,0.085862,0.078907,0.087759,0.063291,0.047748]},{"section":6,"text":"Tobacco use, especially chewing, can lead to various health issues.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.060877,0.092046,0.10017,0.099073,0.098878,0.094399,0.093313,0.086874,0.081011,0.076246,0.064174,0.052944],"unified_progress":[0.052879,0.080673,0.09114,0.096565,0.099173,0.10137,0.097228,0.093616,0.086015,0.080705,0.066951,0.053681]},{"section":7,"text":"One thing that comes to mind is oral submucous fibrosis (OSF).","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.050143,0.085234,0.091075,0.09928,0.097039,0.095356,0.096409,0.09055,0.085216,0.083892,0.06996,0.055846],"unified_progress":[0.038114,0.07219,0.089841,0.10285,0.10237,0.10153,0.1007,0.094958,0.089677,0.085961,0.068901,0.05291]},{"section":8,"text":"I remember that OSF is a condition where the mouth's lining becomes stiff and can't move properly, making it hard to open the mouth.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.035563,0.058666,0.074983,0.085813,0.10096,0.10724,0.10929,0.10972,0.10377,0.087611,0.068743,0.057643],"unified_progress":[0.03545,0.06333,0.084686,0.096778,0.10326,0.1159,0.10729,0.10199,0.093335,0.084858,0.064939,0.048175]},{"section":9,"text":"It's common in areas where people chew a lot, like betel nuts or tobacco.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.037287,0.068387,0.080406,0.085932,0.095118,0.10012,0.10388,0.10472,0.10096,0.091613,0.072998,0.058589],"unified_progress":[0.054171,0.081925,0.089435,0.095353,0.097721,0.10282,0.099091,0.097189,0.088816,0.081167,0.064087,0.048229]},{"section":10,"text":"Wait, but she doesn't have any ulcers.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.051244,