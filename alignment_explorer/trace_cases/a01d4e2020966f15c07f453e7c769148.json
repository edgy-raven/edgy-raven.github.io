5534]},{"section":17,"text":"The hemoptysis could be due to the lung cancer itself.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.026382,0.059319,0.072446,0.083487,0.092645,0.099369,0.10369,0.10046,0.10118,0.094212,0.088599,0.078212],"unified_progress":[0.039807,0.059149,0.072338,0.078267,0.089437,0.095363,0.096633,0.097896,0.10203,0.097878,0.09356,0.077644]},{"section":18,"text":"The elevated and non-suppressible ACTH points to ectopic production.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.034081,0.069714,0.081572,0.088083,0.091381,0.093247,0.096201,0.094714,0.094198,0.090276,0.085393,0.08114],"unified_progress":[0.039242,0.064504,0.078129,0.086092,0.092916,0.095048,0.097497,0.094935,0.095077,0.091604,0.086917,0.078039]},{"section":19,"text":"Putting it all together: chronic smoking (risk factor for lung CA), hemoptysis (possible lung cancer symptom), Cushingoid features (obesity, HTN) from ectopic ACTH leading to Cushing's syndrome, and the dexamethasone test not suppressing ACTH confirms it's ectopic.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.030346,0.062251,0.073575,0.082348,0.089378,0.094396,0.097854,0.09672,0.096378,0.095195,0.091497,0.090062],"unified_progress":[0.038488,0.056937,0.069447,0.077253,0.085207,0.093069,0.094298,0.097245,0.099401,0.098912,0.098122,0.091621]},{"section":20,"text":"So the diagnosis should be ectopic ACTH syndrome, likely from a bronchial (lung) carcinoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.027259,0.056809,0.066926,0.075267,0.080867,0.087,0.091192,0.091609,0.10019,0.094759,0.098625,0.1295],"unified_progress":[0.02884,0.045679,0.058961,0.06982,0.075996,0.084537,0.086022,0.09258,0.10072,0.09949,0.11623,0.14112]}]}}