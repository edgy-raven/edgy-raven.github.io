model_progress":[0.072672,0.10722,0.12402,0.12564,0.10847,0.095472,0.08769,0.074423,0.062731,0.054098,0.046841,0.040728],"unified_progress":[0.046862,0.088704,0.080028,0.11174,0.11806,0.10724,0.10016,0.091777,0.078748,0.070218,0.059805,0.046653]},{"section":6,"text":"Suprasellar masses are typically located near the pituitary gland, which is in the center of the brain.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.039878,0.08158,0.10168,0.11493,0.11543,0.10834,0.10391,0.090505,0.078974,0.064403,0.054227,0.046144],"unified_progress":[0.034632,0.074411,0.095843,0.11075,0.1172,0.11002,0.10485,0.093425,0.092089,0.069234,0.054003,0.043549]},{"section":7,"text":"These kinds of masses can press on the optic nerves or the chiasm, which is where the optic nerves from both eyes meet.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.035282,0.07211,0.093216,0.10926,0.1126,0.10927,0.10746,0.095803,0.085449,0.070305,0.059248,0.049998],"unified_progress":[0.032548,0.070239,0.092974,0.10823,0.11504,0.11101,0.10652,0.09596,0.094636,0.073124,0.055641,0.044071]},{"section":8,"text":"If there's pressure there, it can cause problems with peripheral vision, which aligns with the child ignoring objects on the sides.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.043802,0.070658,0.086286,0.097039,0.10094,0.10107,0.10193,0.097657,0.091786,0.081407,0.070072,0.05736],"unified_progress":[0.035548,0.065186,0.083664,0.096191,0.10311,0.10865,0.10499,0.099983,0.096037,0.085764,0.069084,0.051796]},{"section":9,"text":"The child isn't mentally retarded and has good school grades, so it's not something like a genetic disorder affecting intelligence.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.046351,0.083746,0.088033,0.092128,0.093167,0.093282,0.094856,0.093049,0.090553,0.085551,0.076091,0.063194],"unified_progress":[0.045901,0.075829,0.085202,0.091837,0.096624,0.099312,0.09826,0.097519,0.093213,0.087391,0.072973,0.05594]},{"section":10,"text":"The diminished visual acuity and field defects point more towards a structural issue in the brain affecting vision.","dimension":3,"group":3,"is_degenerate":false,"model_progress":[0.04378,0.061768,0.077206,0.086084,0.09211,0.094642,0.097356,0.09684,0.095065,0.090991,0.085174,0.078984],"unified_progress":[0.037077,0.059283,0.077052,0.086646,0.093056,0.10057,0.098603,0.098116,0.097418,0.091585,0.084496,0.076097]},{"section":11,"text":"A common cause of a suprasellar mass with calcification in children is a craniopharyngioma.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.033795,0.059266,0.075044,0.085992,0.094741,0.098378,0.10376,0.10188,0.097753,0.090686,0.082715,0.075988],"unified_progress":[0.034222,0.062695,0.081195,0.093119,0.099217,0.1028,0.10051,0.097608,0.097375,0.08628,0.076433,0.068542]},{"section":12,"text":"These tumors arise from the remnants of the Rathke's pouch during embryonic development and can cause hydrocephalus or press on the optic nerves.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.03362,0.059365,0.076815,0.090729,0.099771,0.10291,0.10862,0.1042,0.097783,0.085589,0.075168,0.065429],"unified_progress":[0.03253,0.064626,0.086004,0.10016,0.10692,0.10956,0.10477,0.098082,0.097839,0.080527,0.065448,0.053538]},{"section":13,"text":"They often have calcifications, which would show up on a CT scan.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.039085,0.060846,0.077045,0.088746,0.095752,0.098715,0.10268,0.10098,0.097423,0.089406,0.080189,0.069132],"unified_progress":[0.035472,0.062993,0.080871,0.092938,0.1005,0.10371,0.10281,0.099619,0.097917,0.088882,0.074612,0.059677]},{"section":14,"text":"Another possibility could be a germinoma, but those are more common in older children and young adults.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.028054,0.053422,0.06884,0.079797,0.091657,0.09829,0.1068,0.10933,0.10621,0.1007,0.08631,0.070591],"unif