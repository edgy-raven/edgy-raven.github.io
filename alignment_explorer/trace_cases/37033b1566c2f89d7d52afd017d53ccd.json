enerate":false,"model_progress":[0.054875,0.066912,0.077257,0.085615,0.088618,0.091666,0.095121,0.095054,0.09486,0.09401,0.085049,0.070962],"unified_progress":[0.058405,0.08275,0.064312,0.091416,0.096659,0.096946,0.095223,0.09446,0.090473,0.085241,0.077134,0.066981]},{"section":19,"text":"But hold on, let's not jump to conclusions.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.12214,0.098471,0.089885,0.078582,0.077922,0.078093,0.079469,0.08683,0.078291,0.052997,0.054092,0.10323],"unified_progress":[0.21491,0.083447,0.064215,0.064279,0.074667,0.073486,0.093872,0.08096,0.077562,0.062361,0.056914,0.053324]},{"section":20,"text":"What else could it be?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.12002,0.10962,0.097146,0.079979,0.078898,0.078755,0.077699,0.087114,0.079673,0.052466,0.051165,0.087462],"unified_progress":[0.18444,0.061544,0.24388,0.081092,0.056951,0.05535,0.054703,0.062863,0.061271,0.050549,0.045364,0.041995]},{"section":21,"text":"Poisoning from certain plants or fungi is another possibility.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.034258,0.057764,0.076321,0.08941,0.095324,0.10197,0.10736,0.10804,0.10799,0.10545,0.07641,0.039704],"unified_progress":[0.048509,0.083352,0.079719,0.10479,0.10924,0.10149,0.098043,0.095176,0.088201,0.080397,0.065562,0.045514]},{"section":22,"text":"Some plants in Hawaii might cause similar symptoms, but I'd need more info to be sure.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.033122,0.048417,0.063555,0.07573,0.085508,0.095731,0.10433,0.11108,0.11603,0.11542,0.093947,0.057124],"unified_progress":[0.043743,0.06512,0.079037,0.088304,0.095323,0.097651,0.098021,0.09867,0.095202,0.095268,0.080948,0.062715]},{"section":23,"text":"Alright, let's go back to the idea of an allergy.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.016204,0.048162,0.073971,0.089525,0.096699,0.10214,0.10349,0.10654,0.10742,0.10692,0.089503,0.059425],"unified_progress":[0.033137,0.064217,0.076777,0.090752,0.092306,0.092621,0.098948,0.095476,0.093952,0.099698,0.087942,0.074174]},{"section":24,"text":"Anaphylaxis is definitely a strong contender here.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.026497,0.04904,0.061859,0.072689,0.081159,0.089047,0.096158,0.098997,0.10469,0.11059,0.11212,0.097148],"unified_progress":[0.03348,0.055908,0.070322,0.078496,0.087045,0.093733,0.094596,0.096908,0.097965,0.098879,0.098159,0.09451]},{"section":25,"text":"It's sudden, it's severe, and it matches the symptoms perfectly.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.025208,0.036674,0.043443,0.05048,0.059575,0.069576,0.082404,0.09246,0.10832,0.13281,0.16154,0.13751],"unified_progress":[0.034755,0.048848,0.061343,0.069163,0.08036,0.092636,0.094556,0.10042,0.10555,0.10858,0.10898,0.094823]},{"section":26,"text":"Plus, it's common enough in places where people eat a lot of seafood.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.040966,0.04162,0.049784,0.058642,0.068033,0.079053,0.091286,0.10203,0.11505,0.12905,0.12844,0.09604],"unified_progress":[0.046401,0.054415,0.064749,0.072581,0.081641,0.089523,0.093751,0.099816,0.10162,0.10451,0.10117,0.089832]},{"section":27,"text":"So, putting it all together, I'm leaning towards anaphylactic shock caused by a shellfish allergy.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.020282,0.032026,0.041222,0.049696,0.056176,0.063028,0.06953,0.074198,0.083565,0.10391,0.17185,0.23453],"unified_progress":[0.019987,0.033418,0.043068,0.052778,0.058082,0.070796,0.075396,0.088342,0.10018,0.11006,0.14779,0.2001]},{"section":28,"text":"It fits the situation well, especially since he was in Hawaii and tried something new.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.03261,0.037139,0.041318,0.046753,0.053121,0.060869,0.070573,0.079345,0.094151,0.11994,0.1698,0.19438],"unified_progress":[0.031499,0.04