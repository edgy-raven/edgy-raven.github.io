29,0.097057,0.097515,0.0982,0.081641,0.052903],"unified_progress":[0.055815,0.069432,0.082384,0.090318,0.095271,0.099895,0.097971,0.09553,0.090249,0.085403,0.074896,0.062835]},{"section":6,"text":"Hmm, I remember that Osgood-Schlatter disease often affects teenagers, especially those involved in sports.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.030697,0.046728,0.061944,0.076402,0.089642,0.10142,0.11077,0.11315,0.11748,0.12132,0.087379,0.043065],"unified_progress":[0.035372,0.059515,0.081322,0.091706,0.097105,0.10642,0.1033,0.10124,0.095799,0.092205,0.075532,0.06049]},{"section":7,"text":"It's known for causing pain and swelling at the tibial tuberosity because of stress on the growth plate.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.031945,0.040193,0.053003,0.067744,0.08317,0.097258,0.10942,0.11393,0.12064,0.12863,0.09925,0.054824],"unified_progress":[0.037103,0.055704,0.075209,0.088369,0.095432,0.106,0.10426,0.10336,0.098865,0.093349,0.078201,0.064149]},{"section":8,"text":"So, this kid fits the age group and the activity profile perfectly.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.035604,0.055502,0.063844,0.071317,0.077157,0.082442,0.087406,0.089365,0.096133,0.10455,0.12062,0.11606],"unified_progress":[0.039478,0.057624,0.068579,0.076862,0.084154,0.09051,0.090593,0.094735,0.096228,0.096429,0.10209,0.10272]},{"section":9,"text":"But wait, there's more.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.10518,0.083506,0.078609,0.070921,0.072248,0.075719,0.079513,0.090882,0.084607,0.059958,0.066276,0.13258],"unified_progress":[0.18928,0.073761,0.061279,0.062244,0.07179,0.074051,0.092696,0.085362,0.084144,0.071204,0.067324,0.066867]},{"section":10,"text":"The radiographs didn't show anything unusual.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.037376,0.064677,0.090542,0.11042,0.11689,0.11354,0.1053,0.092538,0.082242,0.078485,0.063995,0.04399],"unified_progress":[0.049649,0.081016,0.071812,0.10178,0.10712,0.10481,0.098382,0.094904,0.086005,0.079879,0.069757,0.054891]},{"section":11,"text":"That's interesting because if it were something like an infection or a fracture, we'd probably see some changes on the X-ray.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.037969,0.054812,0.075776,0.093552,0.1026,0.1073,0.10778,0.10345,0.098791,0.093807,0.076367,0.047798],"unified_progress":[0.044906,0.063649,0.080179,0.090917,0.098036,0.098739,0.10025,0.098085,0.095621,0.089476,0.077481,0.062657]},{"section":12,"text":"But since they're clear, it makes me lean even more towards something like Osgood-Schlatter, which doesn't usually show up on X-rays until later stages.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.0302,0.040985,0.05782,0.073008,0.084302,0.094149,0.10176,0.10595,0.10956,0.11216,0.10456,0.085546],"unified_progress":[0.036344,0.051455,0.067127,0.07818,0.086381,0.09291,0.095054,0.098908,0.1005,0.10098,0.098128,0.094034]},{"section":13,"text":"So, putting all these pieces together\u2014the age, the recent start of basketball, the specific location of the pain and swelling, and the normal X-rays\u2014it really seems like Osgood-Schlatter disease is the most likely explanation.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.019858,0.029681,0.037773,0.045846,0.053473,0.061357,0.070066,0.076738,0.08886,0.11329,0.1786,0.22446],"unified_progress":[0.021879,0.032935,0.042265,0.052205,0.059597,0.073074,0.077403,0.089966,0.10179,0.11178,0.1463,0.1908]},{"section":14,"text":"Yeah, that makes sense.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.088409,0.071709,0.067769,0.062156,0.065481,0.070851,0.077421,0.092554,0.090074,0.067449,0.082259,0.16387],"unified_progress":[0.16573,0.063381,0.054864,0.057868,0.066944,0.07174,0.099368,0.088609,0.091744,0.081043,0.079279,0.079435]},{"section":15,"text":"It's a classic scenario for this condition.","dimensi