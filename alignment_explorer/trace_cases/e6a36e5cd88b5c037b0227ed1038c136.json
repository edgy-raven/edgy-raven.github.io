.061577,0.079014,0.090626,0.097302,0.10277,0.10077,0.099781,0.097612,0.091039,0.078365,0.063257]},{"section":20,"text":"Since they were unremarkable, maybe it's not that.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.034454,0.053311,0.071724,0.081459,0.088676,0.095059,0.098768,0.10286,0.10381,0.10252,0.095571,0.071792],"unified_progress":[0.037319,0.061051,0.074595,0.083265,0.092476,0.094154,0.098035,0.102,0.1011,0.10386,0.08731,0.064835]},{"section":21,"text":"Or maybe the X-rays weren't detailed enough.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.040289,0.062993,0.075917,0.084188,0.089815,0.094496,0.098899,0.099522,0.099489,0.098346,0.088831,0.067214],"unified_progress":[0.043509,0.070075,0.081159,0.08974,0.094397,0.095122,0.098521,0.097642,0.095904,0.093653,0.08012,0.060158]},{"section":22,"text":"Alternatively, it could be patellar tendinitis, which can present with similar symptoms.","dimension":8,"group":6,"is_degenerate":false,"model_progress":[0.031564,0.05128,0.065611,0.074418,0.085571,0.094537,0.10012,0.1088,0.11311,0.10911,0.095325,0.07056],"unified_progress":[0.037092,0.066942,0.084124,0.095043,0.097338,0.099331,0.10119,0.099251,0.094762,0.090187,0.076098,0.058644]},{"section":23,"text":"However, patellar tendinitis might also show some changes on X-rays, but maybe not as clearly as Osgood-Schlatter's.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.032607,0.045772,0.063233,0.074665,0.087111,0.096727,0.10297,0.10976,0.11188,0.10628,0.095539,0.073446],"unified_progress":[0.0356,0.060347,0.078551,0.089419,0.096825,0.10056,0.10201,0.10231,0.098877,0.096063,0.080034,0.059398]},{"section":24,"text":"Another thought: could it be a stress fracture?","dimension":8,"group":6,"is_degenerate":false,"model_progress":[0.020171,0.045699,0.062292,0.07264,0.084917,0.095647,0.10329,0.11443,0.12059,0.11756,0.099774,0.062981],"unified_progress":[0.029953,0.068232,0.087523,0.099616,0.10199,0.1008,0.1043,0.10199,