0.065855,0.054378,0.042529]},{"section":5,"text":"Hmm, what could this be?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.34488,0.059948,0.059786,0.066985,0.065033,0.062821,0.058442,0.062815,0.061366,0.056291,0.057845,0.043787],"unified_progress":[0.22799,0.094618,0.068466,0.065846,0.077233,0.073102,0.085417,0.076646,0.071541,0.05748,0.052595,0.04907]},{"section":6,"text":"First, the tibial tubercle is the bony bump at the top of the shinbone where the patellar tendon attaches.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.089499,0.18755,0.059753,0.099209,0.089344,0.097214,0.079281,0.072143,0.065924,0.060072,0.053724,0.046293],"unified_progress":[0.10387,0.11097,0.068706,0.10601,0.097359,0.10971,0.085872,0.080783,0.072317,0.065378,0.055701,0.043324]},{"section":7,"text":"Since he's a teenager and just started a sport, maybe it's an overuse injury.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.061329,0.10084,0.10451,0.099458,0.097547,0.095747,0.089179,0.084978,0.076189,0.074659,0.062585,0.052982],"unified_progress":[0.096979,0.10247,0.095493,0.092757,0.090577,0.089713,0.084574,0.089522,0.075573,0.073074,0.060574,0.048699]},{"section":8,"text":"Osgood-Schlatter disease comes to mind.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.05018,0.084615,0.094981,0.10083,0.099881,0.094227,0.092035,0.086415,0.078353,0.082185,0.067534,0.068761],"unified_progress":[0.059929,0.06871,0.087619,0.093829,0.095293,0.098308,0.095298,0.09162,0.085783,0.086518,0.072736,0.064357]},{"section":9,"text":"That's when there's inflammation at the growth plate of the tibial tubercle, common in active adolescents.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.046113,0.080129,0.086597,0.093932,0.098001,0.098023,0.097325,0.092131,0.08574,0.083572,0.071577,0.066862],"unified_progress":[0.058826,0.06633,0.082141,0.091431,0.095432,0.099897,0.096927,0.095796,0.090948,0.085116,0.07335,0.063807]},{"section":10,"text":"The pain and swelling fit.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.040433,0.082217,0.095443,0.098229,0.09606,0.091913,0.091355,0.08839,0.084134,0.086766,0.075205,0.069857],"unified_progress":[0.054042,0.072725,0.079725,0.089179,0.092157,0.093095,0.093103,0.094366,0.091438,0.093931,0.080504,0.065735]},{"section":11,"text":"But why would the X-rays be normal?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.036176,0.075956,0.0918,0.09697,0.096008,0.092691,0.093287,0.091103,0.08902,0.088578,0.079106,0.069304],"unified_progress":[0.040624,0.06893,0.081451,0.091811,0.095985,0.094524,0.097337,0.095804,0.094054,0.095163,0.081097,0.06322]},{"section":12,"text":"Sometimes Osgood-Schlatter doesn't show up on X-ray, or maybe the changes are subtle.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.037476,0.075187,0.086754,0.093394,0.095724,0.09617,0.09655,0.093602,0.092065,0.086841,0.077586,0.068651],"unified_progress":[0.042672,0.067562,0.082685,0.093773,0.098054,0.099404,0.099347,0.096403,0.094342,0.088032,0.075931,0.061796]},{"section":13,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.031273,0.071092,0.092665,0.099045,0.098459,0.093094,0.092855,0.09057,0.088331,0.092062,0.078849,0.071704],"unified_progress":[0.033188,0.068101,0.082096,0.096043,0.097102,0.094769,0.099523,0.096609,0.093466,0.097635,0.079982,0.061487]},{"section":14,"text":"Maybe a fracture, but he's not complaining of an injury, more like gradual onset.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.031936,0.068147,0.077075,0.082882,0.088521,0.09369,0.099687,0.10259,0.10005,0.097589,0.090206,0.067626],"unified_progress":[0.037764,0.064585,0.075401,0.081675,0.091422,0.093654,0.098131,0.10446,0.10268,0.10499,0.086646,0.058599]},{"section":15,"text":"Patellar tendinitis is possible, but that's more about the tendon itself.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025576,0.058529,0.073021,0.084275,0.092442,0.09695,0.10356,0.10372,0.10132,0.099276,0.089896,0.071437],"unified_progress":[0.042878,0.057693,0.073313,0.083134,0.091867,0.098296,0.1009,0.10374,0.10193,0.10195,0.084921,0.059375]},{"section":16,"text":"The prominence and tenderness over the tubercle point more towards Osgood-Schlatter.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.035486,0.072486,0.081583,0.0875,0.08975,0.092782,0.094155,0.092619,0.096515,0.090231,0.08361,0.083284],"unified_progress":[0.040721,0.064996,0.078495,0.088781,0.093921,0.096431,0.096441,0.095313,0.097134,0.088853,0.082693,0.076221]},{"section":17,"text":"Also, the age is right\u2014common in kids going through growth spurts who do a lot of running and jumping, like basketball.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.03815,0.072425,0.079501,0.085863,0.092281,0.099559,0.097455,0.09702,0.09246,0.093034,0.081763,0.070491],"unified_progress":[0.070576,0.092109,0.086485,0.085455,0.086655,0.091601,0.0888,0.092449,0.086715,0.083845,0.074171,0.061139]},{"section":18,"text":"So I think that's the most likely diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.033801,0.064361,0.077377,0.083279,0.084353,0.083119,0.08616,0.086328,0.088272,0.095256,0.093692,0.124],"unified_progress":[0.039418,0.052484,0.061376,0.072658,0.075938,0.080299,0.084893,0.087853,0.09155,0.10215,0.11569,0.13569]}]}}