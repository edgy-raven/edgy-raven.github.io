,0.11648,0.099775,0.085991,0.076754,0.070612,0.061235,0.064505,0.050034,0.047801],"unified_progress":[0.0849,0.088433,0.090963,0.10145,0.096463,0.09155,0.08968,0.085311,0.077151,0.079195,0.063794,0.051107]},{"section":6,"text":"The vomiting blood (hematemesis) which is red or brown suggests upper GI bleeding.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.061909,0.1106,0.10728,0.10126,0.096049,0.093649,0.087423,0.083936,0.074933,0.068748,0.060454,0.05375],"unified_progress":[0.065829,0.088249,0.091603,0.093659,0.093831,0.094778,0.09039,0.090486,0.084179,0.079193,0.069654,0.058149]},{"section":7,"text":"But the physical exam findings are really important here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.047996,0.095581,0.11352,0.11297,0.10168,0.088247,0.084022,0.078066,0.073104,0.08056,0.063896,0.060358],"unified_progress":[0.044383,0.076157,0.085104,0.097853,0.097633,0.094153,0.095379,0.091932,0.088383,0.094064,0.076019,0.058938]},{"section":8,"text":"Tense abdomen, board-like rigidity, and rebound tenderness are signs of peritonitis.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.048811,0.094395,0.098181,0.098516,0.09574,0.095279,0.091211,0.086455,0.084297,0.075613,0.068321,0.063181],"unified_progress":[0.04782,0.078627,0.088078,0.10084,0.098033,0.097841,0.094587,0.092153,0.090101,0.080173,0.070336,0.061417]},{"section":9,"text":"That's a red flag for a surgical emergency.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.044432,0.088403,0.10646,0.10887,0.101,0.089559,0.086568,0.080442,0.076025,0.083916,0.066668,0.067656],"unified_progress":[0.04389,0.069543,0.082312,0.094506,0.095976,0.09383,0.096004,0.092794,0.090118,0.094201,0.079437,0.067388]},{"section":10,"text":"Peptic ulcers can perforate, leading to perforation.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.0386,0.077432,0.090297,0.098194,0.10031,0.098787,0.096967,0.090887,0.086346,0.082553,0.072228,0.067401],"unified_progress":[0.050356,0.063742,0.078646,0.091075,0.094639,0.09929,0.097221,0.095817,0.093319,0.088946,0.078322,0.068628]},{"section":11,"text":"When an ulcer perforates, gastric contents including acid spill into the abdominal cavity, causing chemical peritonitis and potentially leading to infection.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.037361,0.074542,0.083812,0.091838,0.096621,0.099377,0.09989,0.095082,0.091833,0.085628,0.075838,0.068178],"unified_progress":[0.042634,0.062518,0.077553,0.087303,0.094115,0.10067,0.098765,0.097849,0.097245,0.091167,0.081671,0.068509]},{"section":12,"text":"The classic signs of peritonitis are the board-like abdomen, tenderness, and rebound.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.03947,0.076623,0.082308,0.087509,0.092186,0.095934,0.097312,0.095059,0.092091,0.087769,0.08011,0.073628],"unified_progress":[0.044912,0.067142,0.077975,0.085245,0.091682,0.0986,0.097189,0.097436,0.096066,0.091469,0.08239,0.069893]},{"section":13,"text":"The erect x-ray might show free air under the diaphragm (pneumoperitoneum), which is a sign of perforation.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.03466,0.076995,0.089012,0.095332,0.09562,0.09752,0.096954,0.091655,0.096342,0.083027,0.074351,0.068532],"unified_progress":[0.035308,0.06916,0.087022,0.098066,0.10345,0.10252,0.10008,0.094693,0.096962,0.081849,0.070367,0.060521]},{"section":14,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.034523,0.078285,0.10122,0.10517,0.1005,0.091014,0.089212,0.085414,0.081868,0.090631,0.072904,0.069255],"unified_progress":[0.033565,0.071188,0.085583,0.098187,0.098283,0.093779,0.097983,0.094915,0.091089,0.096368,0.077599,0.061461]},{"section":15,"text":"Well, maybe a ruptured abdominal aortic aneurysm, but the history of peptic ulcer makes that less likely.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031751,0.071961,0.086632,0.094509,0.097314,0.099614,0.098184,0.095175,0.094037,0.087741,0.077513,0.065569],"unified_progress":[0.041999,0.075901,0.087357,0.1004,0.099197,0.098476,0.097186,0.095624,0.092318,0.084022,0.070568,0.056952]},{"section":16,"text":"Mesenteric ischemia?","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.027502,0.065285,0.080275,0.090691,0.097131,0.101,0.1025,0.09947,0.10043,0.091192,0.08017,0.064356],"unified_progress":[0.032875,0.067203,0.086191,0.097909,0.1028,0.10545,0.10291,0.098945,0.097032,0.086651,0.070249,0.051789]},{"section":17,"text":"But the presentation here with the peritonitis signs points more towards perforation.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025268,0.059891,0.074722,0.08436,0.090638,0.09532,0.10103,0.1011,0.10206,0.098344,0.091284,0.075977],"unified_progress":[0.030737,0.058633,0.074085,0.084467,0.094289,0.097325,0.099928,0.10264,0.10275,0.10233,0.087122,0.065696]},{"section":18,"text":"The vomiting blood could be from the ulcer itself, but the abdominal exam is pointing towards a perforation complication.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027075,0.060961,0.074201,0.084129,0.090773,0.096172,0.10023,0.098896,0.10112,0.095466,0.089665,0.081316],"unified_progress":[0.032742,0.053904,0.068351,0.080105,0.08931,0.095688,0.098714,0.10065,0.10463,0.1012,0.095196,0.079518]},{"section":19,"text":"The antacids not working might mean the ulcer is severe or there's a complication.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.031901,0.066828,0.078209,0.086071,0.092331,0.098055,0.098916,0.098557,0.096414,0.095058,0.08515,0.07251],"unified_progress":[0.054092,0.076981,0.079206,0.083551,0.088308,0.091563,0.093686,0.095111,0.093934,0.092205,0.083453,0.067909]},{"section":20,"text":"The fact that he's having repeated vomiting could be part of the perforation leading to obstruction or just the body's attempt to clear the stomach contents.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.030768,0.063135,0.072596,0.081764,0.090636,0.097624,0.10196,0.10104,0.098936,0.094398,0.089143,0.078002],"unified_progress":[0.040466,0.055042,0.06637,0.073473,0.084841,0.093348,0.096051,0.10025,0.10384,0.10407,0.099373,0.082882]},{"section":21,"text":"So putting it all together: peptic ulcer disease with perforation leading to peritonitis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.032679,0.061405,0.070865,0.078037,0.082698,0.085947,0.090184,0.091102,0.094726,0.096504,0.096509,0.11934],"unified_progress":[0.036778,0.046239,0.056823,0.066904,0.073676,0.083788,0.086855,0.095108,0.10208,0.10479,0.11647,0.1305]},{"section":22,"text":"The x-ray will confirm free air, but based on the symptoms and exam, perforated ulcer is the top diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.026092,0.055871,0.068808,0.075499,0.079104,0.082364,0.087489,0.089759,0.096307,0.098925,0.10357,0.13621],"unified_progress":[0.02356,0.041865,0.052535,0.062978,0.068504,0.07656,0.080897,0.090651,0.10083,0.10846,0.13078,0.16237]}]}}