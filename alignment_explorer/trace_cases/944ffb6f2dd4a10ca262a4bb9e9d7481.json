se,"model_progress":[0.063784,0.11137,0.10349,0.094525,0.090433,0.090346,0.085859,0.086649,0.076116,0.073784,0.065465,0.058179],"unified_progress":[0.077649,0.098729,0.093437,0.090699,0.089574,0.091532,0.086522,0.089644,0.080586,0.078304,0.068074,0.05525]},{"section":9,"text":"But the key here is the duration.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.04843,0.093906,0.11295,0.11331,0.10186,0.087424,0.083292,0.077326,0.072566,0.081983,0.06434,0.062622],"unified_progress":[0.048545,0.076398,0.084843,0.099004,0.097541,0.093931,0.095272,0.090155,0.085878,0.094334,0.074907,0.059193]},{"section":10,"text":"Wait, major depressive disorder typically has episodes, right?","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.045572,0.083153,0.094546,0.1001,0.10036,0.095511,0.093638,0.088802,0.082884,0.080922,0.070966,0.063551],"unified_progress":[0.075293,0.071251,0.08135,0.088431,0.092614,0.094086,0.093844,0.092632,0.08693,0.086579,0.074304,0.062685]},{"section":11,"text":"But if it's been\u6301\u7eed without remission for years, maybe since childhood, that might not fit.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.048335,0.087271,0.09132,0.092923,0.093955,0.094429,0.092618,0.091233,0.085178,0.082943,0.073716,0.066079],"unified_progress":[0.067239,0.079744,0.084009,0.088367,0.090296,0.091557,0.090658,0.092576,0.087166,0.086462,0.076417,0.065508]},{"section":12,"text":"Then there's persistent depressive disorder, which used to be called dysthymia.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039626,0.075061,0.086022,0.093708,0.097931,0.097502,0.097104,0.093124,0.086123,0.087049,0.074708,0.072041],"unified_progress":[0.044392,0.065374,0.083404,0.090628,0.093769,0.099476,0.097535,0.095741,0.091399,0.089432,0.078914,0.069936]},{"section":13,"text":"That's a chronic form of depression with milder symptoms but lasting at least two years.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039764,0.075522,0.082673,0.08973,0.095656,0.098065,0.098919,0.095633,0.088191,0.088182,0.076391,0.071272],"unified_progress":[0.054511,0.065904,0.078119,0.085699,0.090897,0.097369,0.096061,0.097478,0.092927,0.090678,0.080122,0.070235]},{"section":14,"text":"The patient is 25, so if it's been since he can remember, that's more than two years.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.050321,0.085646,0.085389,0.086917,0.090831,0.098217,0.09339,0.093687,0.087882,0.085159,0.07614,0.066422],"unified_progress":[0.091318,0.10635,0.092043,0.085984,0.084541,0.086279,0.081761,0.087709,0.079408,0.075618,0.068892,0.060097]},{"section":15,"text":"Also, the symptoms here: depressed mood, sleep/appetite disturbance, low self-esteem, poor work performance, and dissatisfaction.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.06322,0.10815,0.094761,0.08391,0.082958,0.088741,0.085068,0.093918,0.081728,0.078155,0.073699,0.065689],"unified_progress":[0.07625,0.10269,0.094633,0.090913,0.087118,0.091417,0.084439,0.089881,0.080572,0.076436,0.069125,0.056528]},{"section":16,"text":"Those align with persistent depressive disorder.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.040476,0.078089,0.092601,0.097046,0.09498,0.089067,0.089867,0.086258,0.083272,0.088432,0.077814,0.082099],"unified_progress":[0.057949,0.068157,0.078379,0.087728,0.08923,0.09045,0.091171,0.090045,0.087108,0.092076,0.085372,0.082334]},{"section":17,"text":"But let me check the criteria.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31623,0.051783,0.052143,0.061013,0.062167,0.064331,0.061262,0.069485,0.071225,0.067175,0.07118,0.052002],"unified_progress":[0.21413,0.084189,0.063021,0.063485,0.072852,0.072696,0.094596,0.080078,0.077829,0.06366,0.059154,0.054313]},{"section":18,"text":"For persistent depressive disorder, the person has a depressed mood for most of the day, more days than not, for at least two years.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.070948,0.13917,0.060504,0.094221,0.092466,0.09463,0.087707,0.081916,0.076701,0.072217,0.066305,0.063213],"unified_progress":[0.086923,0.10724,0.065351,0.090869,0.090234,0.094991,0.088303,0.085482,0.081519,0.077161,0.069585,0.062343]},{"section":19,"text":"There should be some symptoms like poor appetite, insomnia, low energy, low self-esteem, poor concentration, or feelings of hopelessness.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.059973,0.1058,0.098172,0.088707,0.089934,0.092501,0.089697,0.089877,0.080038,0.076106,0.068394,0.060807],"unified_progress":[0.068247,0.090109,0.092933,0.091676,0.091587,0.094506,0.089726,0.091143,0.08349,0.079618,0.069639,0.057326]},{"section":20,"text":"The patient's work performance isn't up to par, which could relate to low energy or concentration.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.058019,0.1004,0.096097,0.090346,0.089657,0.092309,0.089437,0.089781,0.082321,0.078275,0.071233,0.062125],"unified_progress":[0.078686,0.090072,0.087424,0.088176,0.08889,0.090823,0.087565,0.090079,0.083944,0.081181,0.072881,0.06028]},{"section":21,"text":"He's been working, so maybe it's not severe enough to prevent work, which fits with the milder symptoms of PDD compared to major depression.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.046216,0.084119,0.087527,0.088654,0.091013,0.095225,0.093135,0.092999,0.087435,0.084847,0.077632,0.071199],"unified_progress":[0.062351,0.08078,0.082412,0.085091,0.087006,0.090019,0.088802,0.09196,0.087965,0.087611,0.082394,0.073608]},{"section":22,"text":"Also, he doesn't mention any manic episodes, so bipolar is less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.03242,0.068377,0.080966,0.087098,0.091418,0.094226,0.097991,0.098697,0.096124,0.094011,0.08685,0.071822],"unified_progress":[0.036314,0.066367,0.077524,0.08613,0.092736,0.0936,0.097034,0.099135,0.097584,0.10109,0.087037,0.065454]},{"section":23,"text":"Another possibility is adjustment disorder, but that's usually in response to a stressor and doesn't last as long.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026487,0.058316,0.071762,0.081664,0.089794,0.095274,0.10244,0.10494,0.10252,0.10169,0.093368,0.071741],"unified_progress":[0.034799,0.059672,0.073293,0.081858,0.091178,0.095084,0.099878,0.10489,0.10321,0.10736,0.088653,0.060113]},{"section":24,"text":"Or maybe personality disorder like borderline or avoidant, but the key here is the chronic depressive symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025549,0.057729,0.071508,0.080808,0.089125,0.094873,0.10065,0.10394,0.10253,0.10248,0.094353,0.076467],"unified_progress":[0.032865,0.061815,0.075196,0.0847,0.091324,0.094981,0.099811,0.10268,0.10092,0.10324,0.087695,0.064773]},{"section":25,"text":"So putting it all together, the most likely diagnosis is Persistent Depressive Disorder (Dysthymia).","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.026308,0.047985,0.055982,0.063616,0.071477,0.078061,0.08503,0.090039,0.096507,0.10108,0.11215,0.17177],"unified_progress":[0.029172,0.035409,0.043761,0.054096,0.059125,0.071475,0.075638,0.08553,0.095409,0.10558,0.14455,0.20026]}]}}