e,"model_progress":[0.054189,0.062227,0.071976,0.082266,0.090149,0.095241,0.099023,0.097535,0.097977,0.099778,0.087567,0.062074],"unified_progress":[0.049458,0.066596,0.076965,0.084631,0.090691,0.097157,0.094767,0.096056,0.093151,0.091417,0.083682,0.075428]},{"section":10,"text":"This guy is still holding down a job, even if it's not ideal, so maybe it's not that severe? Dysthymia, or Persistent Depressive Disorder, fits better here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.049768,0.055558,0.064191,0.073148,0.081061,0.089354,0.096718,0.10193,0.10751,0.10989,0.097946,0.072927],"unified_progress":[0.047676,0.061451,0.071818,0.078969,0.086291,0.09144,0.093114,0.097555,0.096919,0.098888,0.092525,0.083353]},{"section":11,"text":"It's a type of depression where people feel persistently sad for years, often without the super intense episodes you see in major depression.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.050372,0.051887,0.05821,0.06703,0.076353,0.086012,0.095562,0.10053,0.10806,0.11773,0.10866,0.07959],"unified_progress":[0.047785,0.059834,0.071986,0.078915,0.085752,0.094912,0.094908,0.09864,0.097508,0.097079,0.090927,0.081755]},{"section":12,"text":"And yeah, dysthymia tends to cause less severe symptoms, which would explain why he's still able to work.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.043746,0.044244,0.052582,0.061495,0.070258,0.079528,0.089414,0.09706,0.1073,0.12039,0.12743,0.10655],"unified_progress":[0.046721,0.053927,0.064382,0.072457,0.080991,0.089568,0.091795,0.097795,0.10019,0.10319,0.10241,0.096573]},{"section":13,"text":"So, putting all this together, I'm thinking this is probably Dysthymia.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.019013,0.031294,0.039444,0.046816,0.052262,0.057805,0.063104,0.067078,0.076967,0.099559,0.18201,0.26465],"unified_progress":[0.017248,0.029384,0.037746,0.047201,0.052331,0.065934,0.071012,0.086183,0.10044,0.11193,0.157