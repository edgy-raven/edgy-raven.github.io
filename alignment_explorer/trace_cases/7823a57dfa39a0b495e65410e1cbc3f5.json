09158,0.0839,0.080027,0.064731,0.048277]},{"section":24,"text":"P. falciparum's pigment is more diffuse, while others like vivax have more clumped pigment.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.033992,0.070731,0.084357,0.095803,0.10275,0.10411,0.10444,0.09733,0.089592,0.085763,0.071617,0.05952],"unified_progress":[0.05286,0.068853,0.089131,0.097003,0.10117,0.10584,0.10078,0.096539,0.089469,0.082593,0.065902,0.049864]},{"section":25,"text":"But the description here says yellow-brown, which might be more typical of P. vivax or ovale.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.035224,0.069192,0.08086,0.089203,0.095368,0.097828,0.099772,0.097347,0.093952,0.088987,0.080773,0.071494],"unified_progress":[0.052395,0.069407,0.082687,0.092165,0.096038,0.097049,0.095982,0.094824,0.090716,0.08806,0.07646,0.064217]},{"section":26,"text":"Wait, but the size of the schizont is key here.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31283,0.052109,0.053127,0.062208,0.063067,0.064732,0.061988,0.070014,0.071148,0.066384,0.069657,0.052732],"unified_progress":[0.21928,0.084093,0.0655,0.065513,0.074458,0.073531,0.092395,0.080097,0.076508,0.061337,0.055785,0.051503]},{"section":27,"text":"Wait, another point: the presence of all stages.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.040498,0.083474,0.059295,0.093106,0.097198,0.096968,0.09398,0.093829,0.09369,0.090203,0.082741,0.075017],"unified_progress":[0.056133,0.09793,0.072569,0.094103,0.098633,0.09595,0.093918,0.091445,0.086737,0.082352,0.074336,0.055896]},{"section":28,"text":"P. falciparum tends to have asynchronous schizogony, so all stages are present at the same time.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037,0.072418,0.082024,0.091021,0.097714,0.10007,0.10154,0.09674,0.091264,0.087079,0.076794,0.066342],"unified_progress":[0.072357,0.072157,0.08515,0.091556,0.096556,0.10073,0.096454,0.093623,0.086903,0.080378,0.067899,0.056235]},{"section":29,"text":"Other species like P. vivax have more synchronous development, so you might see more ring forms or trophozoites in a particular stage.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032833,0.068809,0.081285,0.091869,0.099165,0.10211,0.10391,0.098789,0.092734,0.08924,0.076034,0.06322],"unified_progress":[0.058177,0.06898,0.08692,0.093907,0.098363,0.10287,0.099202,0.09657,0.090314,0.08436,0.068082,0.052256]},{"section":30,"text":"The case mentions \"all stages of the parasite are seen,\" which is characteristic of P. falciparum.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.041723,0.076672,0.082512,0.086718,0.090144,0.092354,0.093573,0.092238,0.090051,0.087787,0.082535,0.083693],"unified_progress":[0.051098,0.069153,0.078991,0.08581,0.089829,0.094307,0.092165,0.092613,0.090809,0.08739,0.085702,0.082132]},{"section":31,"text":"Putting it all together: large schizonts (20 microns), presence of all stages, and the merozoite count (though maybe the number here is a bit off, but perhaps the key is the size and the stage presence).","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.040791,0.071604,0.079056,0.084218,0.088447,0.090555,0.093106,0.092939,0.093421,0.09154,0.089057,0.085268],"unified_progress":[0.052093,0.063694,0.074522,0.082282,0.088697,0.092636,0.093437,0.094286,0.094541,0.093774,0.089903,0.080137]},{"section":32,"text":"The yellow-brown pigment is common in all, but the size and stage distribution point to P. falciparum.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.031782,0.061071,0.072506,0.080009,0.085792,0.088997,0.093162,0.093599,0.096147,0.095924,0.096152,0.10486],"unified_progress":[0.037949,0.052941,0.065257,0.074288,0.080866,0.087989,0.090181,0.094432,0.098455,0.099965,0.10628,0.1114]},{"section":33,"text":"Wait, but let me confirm.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30111,0.049806,0.050859,0.