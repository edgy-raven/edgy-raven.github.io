2,0.088768,0.066728],"unified_progress":[0.041647,0.061288,0.075079,0.08347,0.093686,0.096303,0.099144,0.10366,0.10124,0.10615,0.082645,0.055684]},{"section":16,"text":"The key here is the mass shrinking postpartum, which points more towards something related to lactation.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.036344,0.074777,0.087383,0.092509,0.092773,0.091862,0.092638,0.091131,0.090379,0.090945,0.08128,0.07798],"unified_progress":[0.040377,0.065879,0.077574,0.088358,0.092122,0.093987,0.099184,0.095485,0.094936,0.094414,0.084978,0.072706]},{"section":17,"text":"Intraductal papilloma?","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034041,0.07194,0.084945,0.094351,0.098999,0.10021,0.099937,0.094851,0.092398,0.086679,0.074769,0.06688],"unified_progress":[0.03675,0.064801,0.084226,0.096999,0.10099,0.10629,0.10257,0.098546,0.095108,0.085555,0.070894,0.057271]},{"section":18,"text":"Those are usually painful or cause discharge, and might not shrink with pregnancy ending.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021742,0.054978,0.071195,0.083269,0.092374,0.098449,0.1066,0.10737,0.10474,0.10178,0.092232,0.065267],"unified_progress":[0.028382,0.055956,0.073337,0.083158,0.095321,0.10045,0.10294,0.10804,0.10575,0.11049,0.083679,0.052501]},{"section":19,"text":"Infections like abscesses could be possible, but they're usually tender and might have other signs like redness or fever, which aren't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.015975,0.045786,0.0628,0.075453,0.084975,0.093953,0.10772,0.11373,0.11403,0.1122,0.10441,0.068954],"unified_progress":[0.022227,0.050213,0.067518,0.077088,0.091051,0.095655,0.103,0.11274,0.11328,0.12276,0.094042,0.050428]},{"section":20,"text":"Phyllodes tumor?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.027449,0.059743,0.07287,0.083999,0.093081,0.09856,0.10233,0.10314,0.10251,0.098208,0.086807,0.071296],"unified_progress":[0.035559,0.061506,0.078744,0.091721,0.09757,0.10318,0.10408,0.10302,0.10037,0.093047,0.076817,0.054384]},{"section":21,"text":"That's more rare, and while they can grow during pregnancy, they might not regress afterward.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022173,0.053369,0.069201,0.081456,0.091255,0.0977,0.10547,0.10683,0.10489,0.10351,0.093693,0.070467],"unified_progress":[0.029889,0.057095,0.074084,0.084241,0.09502,0.10027,0.10284,0.10712,0.10447,0.10697,0.083261,0.054742]},{"section":22,"text":"The fact that it's in a pregnant woman and resolves postpartum leans away from that.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.031995,0.067177,0.077996,0.084756,0.089278,0.094384,0.096565,0.097272,0.098902,0.095353,0.088175,0.078147],"unified_progress":[0.045151,0.071236,0.07908,0.085956,0.091502,0.094145,0.096285,0.09668,0.096714,0.093482,0.082593,0.067176]},{"section":23,"text":"So, considering the timing and the change in size after delivery, galactocele is the most likely.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035463,0.071314,0.085854,0.090851,0.089779,0.086553,0.087758,0.086487,0.087235,0.093389,0.086455,0.098861],"unified_progress":[0.038621,0.059044,0.070476,0.081773,0.085257,0.088021,0.092471,0.092584,0.094173,0.099012,0.098643,0.099925]},{"section":24,"text":"It's a benign collection of milk, and the resolution with lactation starting makes sense.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.034013,0.068989,0.079682,0.086601,0.090494,0.093009,0.094698,0.092922,0.092658,0.090807,0.086375,0.089753],"unified_progress":[0.036288,0.056185,0.068792,0.07944,0.085078,0.091572,0.092692,0.095733,0.098748,0.098922,0.099108,0.097442]},{"section":25,"text":"Also, since breastfeeding is going well, it's not obstructing the ducts severely.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.037403,0.075552,0.08233,0.086457,0.089786,0.094393,0.095414,0.094906,0.094545,0.089247,0.083336,0.076632],"unified_progress":[0.039813,0.065027,0.074714,0.082652,0.08906,0.092808,0.094397,0.096616,0.098413,0.096315,0.090669,0.079516]},{"section":26,"text":"Yeah, I think that's it.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31636,0.05213,0.052953,0.061503,0.062391,0.06382,0.061929,0.06953,0.069966,0.066364,0.069621,0.053434],"unified_progress":[0.20195,0.078253,0.064872,0.064567,0.0743,0.074321,0.08862,0.083402,0.080346,0.066132,0.061215,0.062021]}]}}