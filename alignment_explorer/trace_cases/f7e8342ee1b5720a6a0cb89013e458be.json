74493,0.079947,0.084442,0.089905,0.089929,0.093748,0.091534,0.092881,0.088239,0.081872]},{"section":17,"text":"So illness anxiety disorder seems more accurate.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.030326,0.058205,0.071074,0.078067,0.082629,0.084178,0.088336,0.089528,0.093005,0.095701,0.098318,0.13063],"unified_progress":[0.030575,0.043939,0.054182,0.064699,0.068313,0.077055,0.080599,0.087946,0.096176,0.10421,0.12905,0.16325]},{"section":18,"text":"Another possibility could be Munchausen syndrome, where patients fabricate symptoms, but the case doesn't mention fabrication, just insistence on having tests.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.037578,0.068117,0.072857,0.078599,0.085469,0.090867,0.095087,0.098324,0.097069,0.097912,0.092542,0.085578],"unified_progress":[0.043261,0.057306,0.066785,0.074403,0.08191,0.088026,0.092483,0.099674,0.1018,0.10691,0.099914,0.087522]},{"section":19,"text":"Since all investigations are normal, it's less likely he's faking.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.034149,0.066769,0.075625,0.081219,0.086385,0.091488,0.095178,0.097501,0.097049,0.096131,0.091795,0.086711],"unified_progress":[0.040888,0.062397,0.07037,0.077177,0.083585,0.087909,0.091471,0.096805,0.098121,0.10211,0.098392,0.090774]},{"section":20,"text":"So putting it together, the most likely diagnosis is illness anxiety disorder.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.026597,0.047605,0.055988,0.063069,0.069936,0.075677,0.082829,0.088025,0.095669,0.10149,0.11439,0.17873],"unified_progress":[0.027556,0.032592,0.040085,0.049584,0.054741,0.065417,0.071225,0.083259,0.095009,0.10832,0.15288,0.21933]},{"section":21,"text":"The key elements are the preoccupation with having a serious illness (brain tumor), repeated exams and tests that are normal, and ongoing anxiety despite reassurance.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.037276,0.06812,0.067977,0.070153,0.076165,0.083525,0.088884,0.09436,0.097152,0.10055,0.10399,0.11185],"unified_progress":[0.039012,0.054245,0.057561,0.062262,0.06951,0.079428,0.083245,0.094201,0.10235,0.11025,0.12062,0.12731]},{"section":22,"text":"That fits illness anxiety disorder better than somatic symptom disorder or factitious disorder.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.025731,0.050928,0.061118,0.069636,0.077603,0.083163,0.090265,0.093785,0.098139,0.1021,0.1076,0.13993],"unified_progress":[0.026061,0.039218,0.050394,0.058844,0.065658,0.076216,0.081625,0.091834,0.10034,0.10961,0.13338,0.16682]}]}}