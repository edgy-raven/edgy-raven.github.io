n.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.029885,0.054879,0.07418,0.091361,0.10179,0.10826,0.11077,0.10552,0.10238,0.10044,0.075949,0.044573],"unified_progress":[0.034959,0.063092,0.086011,0.095852,0.1,0.11043,0.10266,0.09733,0.092782,0.084664,0.072196,0.060016]},{"section":11,"text":"These tests help pinpoint where the problem might be by irritating certain nerves.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.030802,0.054284,0.073246,0.088771,0.097101,0.10172,0.10278,0.098843,0.096119,0.096703,0.090247,0.069385],"unified_progress":[0.038254,0.062957,0.078998,0.090197,0.09496,0.098303,0.09823,0.097195,0.094792,0.089976,0.08286,0.073277]},{"section":12,"text":"But wait, let's not jump to conclusions too quickly.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.11514,0.091566,0.085434,0.076681,0.077451,0.078996,0.080607,0.088823,0.079904,0.054626,0.058113,0.11266],"unified_progress":[0.20444,0.077618,0.064509,0.064861,0.074017,0.073864,0.094894,0.082563,0.07962,0.064673,0.060394,0.058553]},{"section":13,"text":"We should consider other possibilities.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.11629,0.10642,0.094952,0.078791,0.078289,0.078734,0.078279,0.088436,0.081616,0.054209,0.053161,0.090824],"unified_progress":[0.17904,0.060472,0.23791,0.080072,0.057358,0.05595,0.055747,0.064593,0.063475,0.052798,0.047816,0.044767]},{"section":14,"text":"Could it be a muscle strain?","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.029501,0.058866,0.080182,0.096585,0.10135,0.10499,0.10966,0.10884,0.10557,0.098424,0.070124,0.035902],"unified_progress":[0.039296,0.078791,0.082728,0.10471,0.1109,0.10047,0.098708,0.098787,0.092399,0.082824,0.067485,0.042905]},{"section":15,"text":"Well, those usually don't cause such sharp, shooting pains down the leg.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.038654,0.050061,0.060072,0.070239,0.079978,0.089785,0.0990