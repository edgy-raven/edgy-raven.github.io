.099802],"unified_progress":[0.032841,0.051306,0.064052,0.073334,0.084364,0.09422,0.097354,0.10177,0.10567,0.10769,0.10262,0.084784]},{"section":22,"text":"So the most likely is a herniated lumbar disc causing sciatica.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.024379,0.051929,0.063561,0.071472,0.076851,0.081625,0.087352,0.090178,0.098059,0.10077,0.10769,0.14613],"unified_progress":[0.025729,0.041906,0.053462,0.064132,0.070142,0.082123,0.084703,0.094981,0.10368,0.10604,0.12408,0.14902]},{"section":23,"text":"<answer> Herniated lumbar disc (sciatica) </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028911,0.051916,0.056032,0.061554,0.068798,0.076362,0.083435,0.089348,0.097552,0.10177,0.11384,0.17048],"unified_progress":[0.028285,0.036082,0.042622,0.050293,0.05622,0.067327,0.071725,0.08631,0.098226,0.10833,0.14736,0.20723]}]}}