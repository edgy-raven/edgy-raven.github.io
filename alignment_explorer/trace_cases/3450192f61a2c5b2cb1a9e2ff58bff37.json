3,0.087143,0.07083,0.066864],"unified_progress":[0.036827,0.057716,0.079042,0.090834,0.098266,0.11301,0.1036,0.10202,0.094912,0.089813,0.073828,0.060125]},{"section":13,"text":"It's characterized by IgA deposits at the dermal papillae, which matches the immunofluorescence here.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034494,0.070779,0.082759,0.092379,0.098275,0.1004,0.10102,0.094955,0.090196,0.089275,0.075529,0.069937],"unified_progress":[0.037909,0.062439,0.080454,0.092274,0.098372,0.10423,0.10194,0.09953,0.095996,0.087979,0.07578,0.063092]},{"section":14,"text":"The neutrophilic infiltration at the tips of the papillae is also a feature.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.037261,0.078028,0.088513,0.094795,0.096034,0.097608,0.097109,0.091815,0.093425,0.083931,0.074484,0.066996],"unified_progress":[0.040345,0.070258,0.087017,0.09769,0.10334,0.10379,0.1006,0.09574,0.09471,0.081646,0.068872,0.055981]},{"section":15,"text":"The patient's history of malabsorption and positive antigliadin antibodies (which are part of celiac serology) supports the link between his skin condition and celiac.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.035394,0.072797,0.085879,0.092131,0.094909,0.096149,0.095623,0.09272,0.08935,0.089719,0.080745,0.074584],"unified_progress":[0.051066,0.079884,0.085573,0.0904,0.093047,0.09464,0.093672,0.092361,0.088476,0.085581,0.077792,0.067508]},{"section":16,"text":"Other possibilities?","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.031266,0.070527,0.091854,0.098474,0.098338,0.093444,0.092815,0.090377,0.088489,0.090893,0.079479,0.074044],"unified_progress":[0.035305,0.070532,0.083475,0.0975,0.096768,0.094333,0.096593,0.093707,0.090692,0.095926,0.080458,0.064711]},{"section":17,"text":"Maybe bullous pemphigoid, but that usually has linear IgG or IgA along the basement membrane, and it's more common in the elderly.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.025387,0.060295,0.077383,0.09222,0.10234,0.10529,0.10773,0.10162,0.093585,0.092743,0.077873,0.063537],"unified_progress":[0.028554,0.056425,0.077705,0.089072,0.10062,0.11141,0.1063,0.1059,0.1002,0.095552,0.074736,0.053524]},{"section":18,"text":"Pemphigus vulgaris is intraepithelial acantholysis with IgG, but the location here is different.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026431,0.061211,0.076382,0.090458,0.10042,0.10496,0.10782,0.10192,0.094181,0.096539,0.076722,0.062958],"unified_progress":[0.029222,0.057408,0.077998,0.092604,0.099909,0.10917,0.10752,0.10607,0.10064,0.095162,0.073282,0.051014]},{"section":19,"text":"Linear IgA bullous dermatosis can have IgA deposits but typically in a linear pattern at the basement membrane zone.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026601,0.060603,0.076257,0.09127,0.10149,0.1057,0.10824,0.10116,0.093839,0.095991,0.075158,0.063685],"unified_progress":[0.030659,0.056596,0.079014,0.09435,0.10137,0.11064,0.10823,0.10526,0.099661,0.091687,0.071129,0.051415]},{"section":20,"text":"The combination of IgA deposits at the dermal papillae tips, along with the clinical context of celiac, points more towards dermatitis herpetiformis.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.029327,0.061684,0.074366,0.084406,0.091403,0.09574,0.098643,0.096168,0.096667,0.095466,0.088793,0.087337],"unified_progress":[0.035252,0.055641,0.071794,0.084294,0.091729,0.10106,0.098903,0.09936,0.099228,0.093829,0.088853,0.080056]},{"section":21,"text":"Also, the term \"pruritic\" is key because DH is intensely itchy.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.035161,0.068009,0.076794,0.082314,0.087448,0.090725,0.093631,0.094886,0.094913,0.09676,0.092994,0.086365],"unified_progress":[0.042563,0.060782,0.070138,0.078572,0.086217,0.09379,0.095286,0.098661,0.099498,0.10088,0.094353,0.079257]},{"section":22,"text":"The size of the vesicles (0.4-0.7 cm) fits.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.05547,0.098526,0.091524,0.086339,0.086075,0.089849,0.088531,0.090431,0.085831,0.081661,0.075978,0.069787],"unified_progress":[0.057084,0.084855,0.085729,0.087556,0.090316,0.0934,0.092337,0.093037,0.089705,0.085287,0.076745,0.063948]},{"section":23,"text":"The biopsy showing subepidermal blisters from separation at the DEJ is consistent.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.040936,0.083443,0.092042,0.09552,0.094185,0.094658,0.093829,0.088738,0.095421,0.079999,0.073513,0.067717],"unified_progress":[0.043726,0.073327,0.088801,0.097966,0.10244,0.10064,0.097472,0.092142,0.096687,0.078524,0.06878,0.059486]},{"section":24,"text":"The presence of neutrophils at the papillae is a hallmark.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.03318,0.070561,0.083,0.090941,0.094016,0.096185,0.097106,0.093418,0.09691,0.088049,0.083377,0.073256],"unified_progress":[0.040289,0.066169,0.083056,0.093198,0.1008,0.10111,0.10038,0.096091,0.096256,0.085517,0.075009,0.062122]},{"section":25,"text":"The antigliadin antibodies are part of celiac serology, and DH is considered the skin manifestation of celiac.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028979,0.061693,0.075418,0.085434,0.09275,0.096802,0.099207,0.097054,0.094751,0.093835,0.087964,0.086114],"unified_progress":[0.048738,0.067074,0.07687,0.08374,0.088599,0.096094,0.094638,0.094732,0.092447,0.089611,0.086354,0.081102]},{"section":26,"text":"So putting it all together, the most likely diagnosis is dermatitis herpetiformis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.023702,0.045922,0.055636,0.06359,0.071357,0.077796,0.08493,0.089392,0.097022,0.10141,0.11403,0.17521],"unified_progress":[0.025399,0.034776,0.043971,0.05396,0.058905,0.07163,0.074502,0.08756,0.098141,0.10721,0.14577,0.19818]}]}}