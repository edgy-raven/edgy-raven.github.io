,{"section":18,"text":"Since the USG saw gallstones, that's a strong indicator.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.03674,0.076459,0.089094,0.095537,0.095908,0.096698,0.095482,0.090862,0.093125,0.085157,0.075311,0.069628],"unified_progress":[0.049705,0.078171,0.089479,0.097587,0.10119,0.097752,0.095729,0.091756,0.089977,0.079591,0.069131,0.059937]},{"section":19,"text":"The CT would confirm the pancreatitis and maybe show the stone in the duct.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031909,0.077942,0.093247,0.10126,0.098675,0.099701,0.096568,0.088503,0.1017,0.078904,0.068874,0.062719],"unified_progress":[0.034421,0.074241,0.095538,0.11149,0.11354,0.10523,0.10163,0.091588,0.094387,0.070949,0.057448,0.049533]},{"section":20,"text":"Wait, could it be another cause?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.03073,0.065793,0.083324,0.09129,0.097649,0.097511,0.098398,0.098662,0.095816,0.093522,0.082008,0.065298],"unified_progress":[0.042037,0.074107,0.090949,0.10264,0.10282,0.096679,0.102,0.09563,0.088761,0.086922,0.067647,0.049806]},{"section":21,"text":"Like alcoholic?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.02384,0.057839,0.075143,0.08546,0.095722,0.10002,0.10347,0.10542,0.10247,0.09899,0.087943,0.063681],"unified_progress":[0.043681,0.074463,0.089172,0.098252,0.10022,0.098449,0.10137,0.098471,0.091803,0.087971,0.06925,0.046897]},{"section":22,"text":"But no info on alcohol use.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026575,0.060395,0.074469,0.082945,0.091171,0.098488,0.10177,0.10383,0.10201,0.098782,0.090731,0.068837],"unified_progress":[0.058033,0.086676,0.088067,0.090159,0.093796,0.092469,0.093067,0.095889,0.089716,0.088991,0.073106,0.05003]},{"section":23,"text":"Since gallstones are present, that's the likely culprit.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.03007,0.064527,0.078463,0.08658,0.090812,0.