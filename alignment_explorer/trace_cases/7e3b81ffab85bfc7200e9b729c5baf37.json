3,0.089417,0.10065,0.098914,0.10261,0.10973,0.10659,0.099613,0.082129,0.052989]},{"section":22,"text":"Well, CF usually presents differently, often with chronic lung issues and digestive problems, and it doesn't typically involve eosinophilia.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021725,0.034238,0.047505,0.060402,0.074046,0.089955,0.10625,0.12054,0.132,0.13726,0.11321,0.062869],"unified_progress":[0.032363,0.054207,0.069671,0.079927,0.091647,0.099335,0.10157,0.10698,0.1063,0.10677,0.089511,0.061714]},{"section":23,"text":"So, that's less likely.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.10247,0.082794,0.07818,0.071384,0.074593,0.078584,0.084048,0.094946,0.08829,0.061428,0.060383,0.1229],"unified_progress":[0.19829,0.074723,0.063727,0.064741,0.074481,0.075585,0.09303,0.086413,0.083256,0.066723,0.059604,0.059427]},{"section":24,"text":"What about bronchopulmonary aspergillosis?","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.023606,0.043091,0.059834,0.076197,0.087726,0.1016,0.11356,0.11901,0.1238,0.12492,0.085431,0.041227],"unified_progress":[0.034188,0.064405,0.063839,0.097112,0.10632,0.1032,0.1043,0.10741,0.10102,0.093627,0.073735,0.050839]},{"section":25,"text":"That's more common in people with pre-existing lung conditions, and while it does cause respiratory symptoms, it wouldn't explain the eosinophilia as well as asthma would.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.019697,0.030518,0.043051,0.055541,0.06994,0.086514,0.10385,0.118,0.13138,0.14035,0.12445,0.076711],"unified_progress":[0.032524,0.051903,0.068173,0.079817,0.091126,0.10124,0.10146,0.10572,0.10525,0.10689,0.09018,0.065722]},{"section":26,"text":"Hmm, considering everything, asthma still makes the most sense.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.014089,0.028098,0.037306,0.046092,0.053942,0.062961,0.072054,0.080201,0.091982,0.11061,0.17303,0.22963],"unified_progress":[0.01