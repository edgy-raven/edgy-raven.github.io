"is_degenerate":false,"model_progress":[0.032234,0.066095,0.081695,0.096777,0.10629,0.10664,0.10548,0.095997,0.085177,0.088497,0.069221,0.065893],"unified_progress":[0.034225,0.054724,0.079035,0.090869,0.098809,0.11069,0.10536,0.10291,0.096802,0.091288,0.074129,0.061156]},{"section":8,"text":"GPA is known for upper and lower respiratory tract involvement along with renal disease.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028368,0.063211,0.078441,0.091212,0.10012,0.10335,0.10557,0.099496,0.092289,0.094605,0.077306,0.066041],"unified_progress":[0.051952,0.058654,0.075183,0.088279,0.095038,0.10208,0.10231,0.10221,0.097346,0.093782,0.075292,0.057867]},{"section":9,"text":"The nasal ulcer and cavitary lung lesions are classic for GPA.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.029939,0.068936,0.082853,0.091446,0.09485,0.098043,0.099216,0.095125,0.097339,0.089839,0.080572,0.071844],"unified_progress":[0.040223,0.066285,0.083328,0.094489,0.10023,0.10155,0.099765,0.097263,0.097065,0.086916,0.073221,0.059671]},{"section":10,"text":"The cavitary lesions in the lungs can be from granulomatous inflammation and necrosis.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031932,0.072577,0.085347,0.094233,0.096161,0.099292,0.099043,0.093452,0.099069,0.085389,0.075505,0.067999],"unified_progress":[0.036194,0.066561,0.085985,0.10007,0.10551,0.10503,0.10232,0.096142,0.097153,0.081057,0.067308,0.056666]},{"section":11,"text":"ANCA positivity, especially PR3-ANCA, is common in GPA.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.033631,0.070947,0.086214,0.095041,0.098783,0.098046,0.10028,0.095453,0.089763,0.086564,0.077558,0.067721],"unified_progress":[0.052398,0.068743,0.084512,0.093008,0.098695,0.10454,0.10015,0.094875,0.088893,0.082957,0.072288,0.058943]},{"section":12,"text":"Another possibility could be Churg-Strauss syndrome, but that typically has asthma and eosinophilia.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.025254,0.059133,0.075593,0.089004,0.098319,0.10243,0.10598,0.10257,0.096034,0.097774,0.081889,0.066016],"unified_progress":[0.0293,0.058673,0.079776,0.091479,0.098809,0.10641,0.10492,0.1043,0.099101,0.097046,0.076349,0.053839]},{"section":13,"text":"Since the case doesn't mention eosinophilia or asthma, maybe less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022146,0.054122,0.069637,0.079693,0.087664,0.094591,0.1032,0.10703,0.10706,0.10411,0.098331,0.072414],"unified_progress":[0.029833,0.058108,0.072338,0.080878,0.092042,0.094227,0.099528,0.10628,0.10548,0.11429,0.08913,0.057857]},{"section":14,"text":"Goodpasture's syndrome involves anti-GBM antibodies leading to pulmonary hemorrhage and kidney disease, but that's usually negative for ANCA.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.02153,0.053456,0.070025,0.084857,0.09571,0.1018,0.10784,0.10589,0.10057,0.10026,0.087494,0.070569],"unified_progress":[0.027703,0.053935,0.073809,0.086139,0.095372,0.10713,0.1049,0.10765,0.10407,0.10108,0.082547,0.055655]},{"section":15,"text":"The cavitary lesions might not be as typical there.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021774,0.054869,0.070492,0.081192,0.088228,0.0951,0.10275,0.10493,0.10858,0.10224,0.09589,0.073946],"unified_progress":[0.028333,0.056031,0.072838,0.083567,0.094651,0.097169,0.10097,0.10561,0.10705,0.10995,0.085899,0.05793]},{"section":16,"text":"The combination of upper and lower respiratory tract issues with renal GN and ANCA points strongly towards GPA.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.022309,0.051556,0.067046,0.077084,0.084951,0.090369,0.096025,0.098188,0.10277,0.10557,0.10599,0.098141],"unified_progress":[0.032417,0.051095,0.064862,0.076537,0.08594,0.094062,0.099749,0.10198,0.10513,0.10585,0.10017,0.082212]},{"section":17,"text":"The cavitary lesions on CXR are a big clue.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.025369,0.059205,0.074022,0.082819,0.087231,0.091322,0.0951,0.095318,0.10202,0.099723,0.09684,0.09103],"unified_progress":[0.03398,0.055948,0.07084,0.083896,0.091293,0.095846,0.098027,0.098528,0.10204,0.099723,0.091282,0.0786]},{"section":18,"text":"So I think the most likely diagnosis is Granulomatosis with Polyangiitis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028253,0.051812,0.059596,0.067349,0.074599,0.080175,0.086459,0.090069,0.095577,0.10026,0.10906,0.1568],"unified_progress":[0.031589,0.039024,0.048998,0.058657,0.064862,0.076903,0.081159,0.091507,0.10072,0.107,0.13396,0.16563]}]}}