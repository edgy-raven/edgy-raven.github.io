:[0.041936,0.057848,0.063393,0.069824,0.07582,0.083736,0.086583,0.094347,0.099274,0.10511,0.11018,0.11195]},{"section":23,"text":"The fact that the symptoms started after the earthquake and have persisted supports this.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.045649,0.081644,0.082245,0.082215,0.084369,0.088488,0.089132,0.091625,0.089739,0.091122,0.087343,0.08643],"unified_progress":[0.051892,0.068092,0.070409,0.075191,0.079758,0.085736,0.087982,0.093955,0.095523,0.09935,0.098817,0.093295]},{"section":24,"text":"The time frame is beyond three months, so it's chronic PTSD.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.039273,0.072827,0.079389,0.082425,0.085231,0.088659,0.089861,0.09124,0.090866,0.091524,0.089669,0.099036],"unified_progress":[0.04401,0.06178,0.067412,0.073529,0.077723,0.083246,0.085735,0.091049,0.094111,0.098212,0.10682,0.11637]},{"section":25,"text":"I don't think it's something like panic disorder because the panic here is tied directly to the traumatic event through the nightmares and memories.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.049553,0.079587,0.079171,0.081552,0.085056,0.087773,0.090525,0.093107,0.09013,0.091447,0.086409,0.085689],"unified_progress":[0.060636,0.062296,0.068742,0.075311,0.081118,0.086176,0.089259,0.095177,0.095888,0.099723,0.096499,0.089176]},{"section":26,"text":"So the most likely diagnosis is PTSD.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.026204,0.048248,0.058174,0.064808,0.071092,0.075845,0.082882,0.087428,0.095621,0.10048,0.11332,0.1759],"unified_progress":[0.024663,0.033301,0.041462,0.051548,0.055551,0.067174,0.072435,0.083532,0.097636,0.10914,0.15213,0.21142]}]}}