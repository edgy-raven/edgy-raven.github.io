63599,0.081258,0.090687,0.098004,0.1048,0.10309,0.10267,0.097279,0.094525,0.075219,0.052261]},{"section":9,"text":"More concerning are conditions like meningitis or a brain abscess, which can present with severe headaches and neurological deficits.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.040435,0.063183,0.075464,0.083937,0.091215,0.095172,0.1013,0.10237,0.098832,0.091601,0.083521,0.072963],"unified_progress":[0.042712,0.067976,0.081059,0.089639,0.094941,0.10131,0.099696,0.099722,0.095635,0.090153,0.076731,0.060424]},{"section":10,"text":"The thick cord-like structure on the lateral head makes me think of something like a sinus infection, maybe a mucocele or a abscess.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.030836,0.063108,0.079934,0.09209,0.097214,0.10011,0.10395,0.10103,0.097187,0.088111,0.07885,0.067587],"unified_progress":[0.033744,0.068477,0.087562,0.099229,0.10392,0.10245,0.10103,0.09674,0.097276,0.083112,0.06992,0.05654]},{"section":11,"text":"The maxillary sinuses are on the sides of the face, and if they're infected, they can cause swelling and even protrude outward, creating a cord-like structure.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.034923,0.064881,0.082837,0.09628,0.10276,0.1036,0.10629,0.099906,0.093908,0.081571,0.071958,0.061078],"unified_progress":[0.033761,0.06923,0.090076,0.10317,0.11006,0.10749,0.10389,0.096744,0.096043,0.078177,0.062445,0.04891]},{"section":12,"text":"Sinusitis can lead to complications like orbital cellulitis, which can affect vision.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.041252,0.053524,0.07028,0.082034,0.093909,0.099856,0.10779,0.10896,0.10368,0.093457,0.080168,0.065101],"unified_progress":[0.041235,0.062408,0.079915,0.092083,0.097696,0.11707,0.10488,0.10065,0.094039,0.087399,0.070411,0.052212]},{"section":13,"text":"The elevated ESR supports an inflammatory or infectious process.","dimension":10,"group":1,"is_dege