557,0.097892,0.10121,0.1052,0.099575,0.1023,0.087702,0.079488,0.071236,0.06236,0.04867]},{"section":6,"text":"HBsAg is the surface antigen of hepatitis B, and if it's positive, that means current infection.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.050157,0.089938,0.10063,0.10441,0.10254,0.097026,0.094261,0.087039,0.078312,0.075231,0.064732,0.055727],"unified_progress":[0.058089,0.079021,0.091721,0.098801,0.10244,0.10178,0.10446,0.090595,0.082048,0.075425,0.064538,0.051082]},{"section":7,"text":"IgM anti-HBc is the core antibody in the IgM form, which is typically present during acute hepatitis B infection.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.04078,0.079537,0.092732,0.10009,0.10228,0.099888,0.099291,0.091952,0.083854,0.080737,0.069219,0.059648],"unified_progress":[0.049113,0.071537,0.088951,0.096906,0.10261,0.10497,0.10529,0.094398,0.086546,0.07907,0.067178,0.053424]},{"section":8,"text":"HBeAg is the e-antigen, which indicates high viral replication and infectivity.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039932,0.077896,0.089636,0.097289,0.10058,0.099996,0.099846,0.093474,0.085507,0.084052,0.070748,0.061042],"unified_progress":[0.043314,0.069556,0.087097,0.096404,0.10204,0.10578,0.10537,0.096653,0.089573,0.082039,0.068799,0.053378]},{"section":9,"text":"Putting this together: acute hepatitis B.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.050355,0.08649,0.097067,0.099735,0.094853,0.086959,0.0854,0.081954,0.077863,0.084112,0.073001,0.082212],"unified_progress":[0.057276,0.065246,0.075374,0.088231,0.089997,0.090512,0.091221,0.092329,0.089895,0.091912,0.086247,0.081759]},{"section":10,"text":"The presence of all three markers (HBsAg, IgM anti-HBc, and HBeAg) is classic for acute infection.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.043307,0.079475,0.089149,0.093371,0.094234,0.092716,0.092602,0.089,0.085525,0.084178,0.078801,0.077643],"unifi