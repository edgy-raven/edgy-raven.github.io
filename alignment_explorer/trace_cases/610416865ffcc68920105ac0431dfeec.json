ension":3,"group":8,"is_degenerate":false,"model_progress":[0.094346,0.14018,0.14548,0.11918,0.10196,0.083203,0.072359,0.064422,0.052813,0.051156,0.039793,0.035101],"unified_progress":[0.094109,0.10608,0.10146,0.11112,0.10153,0.093182,0.084689,0.080774,0.068093,0.067052,0.051766,0.040145]},{"section":4,"text":"She's presenting with abdominal pain, and the ultrasound shows fluid in the pouch of Douglas.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.096981,0.15709,0.1271,0.10244,0.087372,0.085933,0.072955,0.073289,0.061366,0.052095,0.044315,0.039072],"unified_progress":[0.086601,0.11933,0.10972,0.10598,0.096302,0.091584,0.082336,0.083335,0.071456,0.060497,0.050915,0.041934]},{"section":5,"text":"The pouch of Douglas is the space between the uterus and the rectum, so fluid there might be blood.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.059446,0.1092,0.11314,0.11,0.10032,0.094561,0.08762,0.079022,0.083101,0.063609,0.053524,0.046454],"unified_progress":[0.061052,0.086681,0.101,0.10927,0.11047,0.10106,0.094853,0.086094,0.089944,0.065,0.051757,0.042818]},{"section":6,"text":"They did an aspiration and got dark, non-clotted blood.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.070545,0.11943,0.10946,0.1001,0.092891,0.091405,0.084395,0.081749,0.075947,0.065884,0.057022,0.051179],"unified_progress":[0.070879,0.096889,0.099414,0.10102,0.10147,0.095691,0.091651,0.08736,0.08116,0.068939,0.057599,0.047933]},{"section":7,"text":"Hmm, the key points here are the amenorrhea, abdominal pain, and the culdocentesis result.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.062812,0.1031,0.10629,0.102,0.094526,0.087372,0.083359,0.080234,0.075226,0.077206,0.065455,0.062416],"unified_progress":[0.070052,0.080303,0.086513,0.09369,0.095084,0.092932,0.092199,0.090144,0.08544,0.084053,0.071088,0.058503]},{"section":8,"text":"Culdocentesis is when they take fluid from the vaginal vault.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.0546,0.094258,0.098023,0.099507,0.096836,0.094523,0.091096,0.085905,0.083697,0.074955,0.066137,0.060462],"unified_progress":[0.063474,0.078287,0.091567,0.10125,0.10145,0.098691,0.09511,0.090005,0.086494,0.075366,0.063632,0.054674]},{"section":9,"text":"If the blood doesn't clot, that suggests it's old blood, maybe from internal bleeding.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.055788,0.093546,0.095864,0.097222,0.095712,0.093689,0.091863,0.087563,0.083256,0.076943,0.067461,0.061096],"unified_progress":[0.065928,0.077257,0.08851,0.09528,0.099124,0.097672,0.095469,0.091288,0.086829,0.078308,0.067776,0.05656]},{"section":10,"text":"The fact that it's dark also points to old blood rather than fresh.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.053327,0.093269,0.098595,0.098679,0.095527,0.091982,0.090126,0.086437,0.082095,0.078501,0.068727,0.062733],"unified_progress":[0.059074,0.078736,0.088518,0.095662,0.098553,0.096291,0.095577,0.091224,0.086847,0.081302,0.070357,0.057859]},{"section":11,"text":"So, the combination of missed period, abdominal pain, and finding blood in the pouch of Douglas makes me think of an ectopic pregnancy.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.058758,0.094428,0.099025,0.099628,0.094628,0.088275,0.085779,0.081922,0.078878,0.080102,0.068946,0.069632],"unified_progress":[0.069504,0.07191,0.08197,0.092192,0.094121,0.093346,0.092977,0.091206,0.087989,0.085489,0.074677,0.06462]},{"section":12,"text":"Ectopic means the embryo is implanted outside the uterus, usually in the fallopian tube.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.042373,0.080777,0.090738,0.097909,0.10002,0.099492,0.097368,0.090945,0.08691,0.08057,0.069666,0.063231],"unified_progress":[0.05602,0.070354,0.087609,0.096952,0.099165,0.10231,0.097599,0.093971,0.089314,0.08067,0.067729,0.058302]},{"section":13,"text":"If it ruptures, it can cause internal bleeding, which would collect in the pouch of Douglas.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.039779,0.076964,0.085047,0.092241,0.09594,0.098398,0.098657,0.093887,0.091998,0.08422,0.074816,0.068055],"unified_progress":[0.047365,0.065716,0.080876,0.090055,0.096436,0.1007,0.097936,0.096045,0.095089,0.08672,0.077378,0.065687]},{"section":14,"text":"The blood there wouldn't clot because the body's clotting factors might not be activated there as quickly, or maybe because it's in the peritoneal cavity where fibrinolysis is more active.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.041889,0.078014,0.085917,0.092322,0.095627,0.097223,0.098158,0.094274,0.091545,0.084234,0.075378,0.065419],"unified_progress":[0.051625,0.068662,0.082817,0.091256,0.097614,0.099686,0.098465,0.095339,0.093056,0.085821,0.074816,0.060843]},{"section":15,"text":"Another possibility could be a ruptured corpus luteum cyst, but those usually occur in the luteal phase of the menstrual cycle, not necessarily with a missed period.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.038351,0.073981,0.082921,0.091407,0.096921,0.10023,0.10052,0.096689,0.091708,0.08837,0.075128,0.063777],"unified_progress":[0.046301,0.068135,0.083917,0.092285,0.097699,0.10423,0.10056,0.098678,0.093912,0.087779,0.071813,0.054696]},{"section":16,"text":"An incomplete abortion might also present with bleeding, but the non-clotted blood and the ultrasound findings might lean more towards ectopic.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028669,0.063455,0.076909,0.085935,0.0918,0.095954,0.10118,0.10053,0.099994,0.095582,0.088017,0.071974],"unified_progress":[0.03333,0.060231,0.075537,0.085251,0.094446,0.09789,0.099641,0.10206,0.10162,0.10179,0.084993,0.063209]},{"section":17,"text":"Also, the positive pregnancy test (though not mentioned here) is common in ectopic cases.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.03468,0.070656,0.081941,0.087867,0.091632,0.095021,0.096643,0.096402,0.094227,0.092362,0.084867,0.073701],"unified_progress":[0.048095,0.076317,0.083083,0.087525,0.092554,0.093605,0.095146,0.094919,0.092259,0.090479,0.080798,0.06522]},{"section":18,"text":"Wait, the case didn't mention a pregnancy test, but the amenorrhea is six weeks, so pregnancy should be considered first.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.040022,0.074482,0.082597,0.087584,0.091761,0.097065,0.095057,0.095067,0.091949,0.090073,0.082028,0.072316],"unified_progress":[0.070699,0.094011,0.089347,0.090287,0.08955,0.0896,0.088852,0.088948,0.083316,0.081184,0.07291,0.061296]},{"section":19,"text":"Alternatively, a ruptured ovarian cyst could cause pain and bleeding, but again, the culdocentesis findings and the amenorrhea make ectopic more likely.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030103,0.063643,0.076026,0.085,0.090797,0.094835,0.098873,0.097361,0.1018,0.094007,0.088448,0.079108],"unified_progress":[0.040562,0.065203,0.081252,0.090724,0.096282,0.096785,0.097052,0.095732,0.09746,0.09057,0.080773,0.067604]},{"section":20,"text":"The failure to clot is a classic sign of old blood in the peritoneal cavity, which happens in cases of internal bleeding like ectopic rupture or maybe a miscarriage.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029924,0.061757,0.073339,0.083796,0.091664,0.096891,0.10091,0.098931,0.098455,0.094454,0.088049,0.081834],"unified_progress":[0.038974,0.05581,0.071278,0.081903,0.090258,0.0983,0.098148,0.099151,0.10028,0.096639,0.090756,0.0785]},{"section":21,"text":"But with the location and the symptoms, ectopic seems more likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025239,0.055836,0.070805,0.080019,0.086322,0.090261,0.096583,0.098735,0.10058,0.10138,0.097964,0.096273],"unified_progress":[0.030014,0.050786,0.06367,0.074181,0.082636,0.08849,0.092918,0.10014,0.10333,0.10964,0.10645,0.097742]},{"section":22,"text":"So putting it all together: ectopic pregnancy with possible rupture leading to hemoperitoneum, hence the blood in the pouch of Douglas that doesn't clot.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.034543,0.062887,0.068835,0.075606,0.080982,0.086462,0.090762,0.092235,0.097471,0.095129,0.09719,0.1179],"unified_progress":[0.040474,0.048351,0.05862,0.068776,0.075127,0.082787,0.085565,0.091783,0.098749,0.10005,0.11486,0.13486]},{"section":23,"text":"The diagnosis would be ectopic pregnancy.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.020112,0.042386,0.052674,0.0603,0.068051,0.075547,0.083685,0.089289,0.099831,0.10394,0.11933,0.18486],"unified_progress":[0.017611,0.029868,0.03845,0.047511,0.053114,0.064751,0.070523,0.085261,0.10037,0.11194,0.15696,0.22364]}]}}