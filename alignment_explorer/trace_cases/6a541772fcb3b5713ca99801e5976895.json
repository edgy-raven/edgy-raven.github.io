9144,0.11381,0.11047,0.11168,0.10897,0.09914,0.083895,0.070349,0.060221,0.049715],"unified_progress":[0.036563,0.072073,0.091009,0.10783,0.10739,0.10312,0.099815,0.092762,0.093981,0.07634,0.064158,0.054956]},{"section":11,"text":"Retinal detachment is when the retina separates from the underlying tissue, which can lead to vision loss.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.02675,0.049481,0.070325,0.085054,0.1036,0.11216,0.11467,0.11548,0.10753,0.088367,0.068186,0.058388],"unified_progress":[0.028385,0.05636,0.080695,0.096138,0.10081,0.13447,0.10957,0.10156,0.093345,0.084467,0.065601,0.048593]},{"section":12,"text":"The presence of subretinal yellowish exudates adds to this.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.032687,0.058618,0.080564,0.097737,0.10811,0.11309,0.11383,0.10668,0.092816,0.076912,0.065067,0.053885],"unified_progress":[0.036105,0.068884,0.088393,0.1008,0.10776,0.10649,0.10341,0.097164,0.095705,0.07845,0.064419,0.052425]},{"section":13,"text":"Exudates are usually seen in conditions like Coats' disease or maybe even something like a choroidal effusion.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.028138,0.052118,0.074375,0.090397,0.1017,0.10761,0.11262,0.10954,0.10219,0.091933,0.072007,0.057371],"unified_progress":[0.031239,0.062076,0.084123,0.098119,0.10248,0.11553,0.10805,0.10166,0.094768,0.086438,0.067526,0.047998]},{"section":14,"text":"Telangiectatic vessels are wide, dilated blood vessels, which I think are more commonly associated with Coats' disease.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.029714,0.049601,0.070468,0.085401,0.10081,0.1091,0.11227,0.11247,0.10587,0.090528,0.074056,0.059709],"unified_progress":[0.032937,0.061127,0.082458,0.096141,0.10327,0.1099,0.10751,0.10283,0.097143,0.087369,0.068975,0.050344]},{"section":15,"text":"Coats' disease, also known as Coat's Retinal Disease or Coats' Retinal Vasodilatation and Exudative Vitreoretin