63,0.10917,0.11024,0.1012,0.091977,0.081257,0.068709,0.054963],"unified_progress":[0.040736,0.072951,0.089094,0.098589,0.10355,0.10334,0.1021,0.095691,0.091529,0.081914,0.068069,0.052438]},{"section":16,"text":"Von Willebrand's is caused by a deficiency or dysfunction of von Willebrand factor, which is needed for platelet adhesion.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.023654,0.046197,0.067625,0.081693,0.1011,0.11074,0.11348,0.11661,0.11111,0.092876,0.072939,0.061972],"unified_progress":[0.029888,0.058605,0.082696,0.095635,0.10171,0.12049,0.10844,0.10335,0.095069,0.087007,0.067702,0.049417]},{"section":17,"text":"If the ristocetin cofactor is normal, that suggests that von Willebrand's isn't the problem here.","dimension":7,"group":7,"is_degenerate":false,"model_progress":[0.035149,0.051755,0.07199,0.084345,0.096401,0.10277,0.10537,0.10465,0.10133,0.09277,0.082857,0.070606],"unified_progress":[0.04027,0.064343,0.079899,0.089857,0.09719,0.10099,0.10009,0.099456,0.095983,0.091742,0.077837,0.062342]},{"section":18,"text":"So putting it all together: he has a knee joint bleed, no prior history, normal platelets, normal PT, elevated PTT, normal factor VIII, low factor IX, and normal ristocetin cofactor.","dimension":7,"group":7,"is_degenerate":false,"model_progress":[0.030219,0.053526,0.072786,0.08332,0.090736,0.093716,0.095792,0.090938,0.089548,0.089542,0.096644,0.11323],"unified_progress":[0.034335,0.059283,0.071906,0.080251,0.086326,0.088952,0.091144,0.091765,0.093936,0.09176,0.10023,0.11011]},{"section":19,"text":"This points towards a hereditary bleeding disorder.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.027335,0.052603,0.070232,0.082489,0.085714,0.088641,0.093291,0.095094,0.094914,0.10332,0.098841,0.10752],"unified_progress":[0.029109,0.05694,0.07132,0.082104,0.085827,0.089727,0.093526,0.097635,0.098387,0.098149,0.098273,0.099003]},{"section":20,"text":"Since factor IX is reduced, it's likely hereditary factor 