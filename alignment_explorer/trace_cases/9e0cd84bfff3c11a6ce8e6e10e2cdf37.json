.095506,0.081697,0.07777,0.067839,0.057905,0.046538],"unified_progress":[0.056449,0.094174,0.084593,0.11232,0.11431,0.10036,0.10848,0.083933,0.076937,0.068122,0.058651,0.041671]},{"section":7,"text":"PT is normal, which is the prothrombin time, so that's the extrinsic pathway.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.048757,0.093739,0.1083,0.11307,0.11103,0.098508,0.094287,0.084513,0.07486,0.06813,0.059451,0.045353],"unified_progress":[0.046763,0.085025,0.099095,0.10731,0.11415,0.10522,0.12072,0.086326,0.075428,0.065407,0.055323,0.039236]},{"section":8,"text":"PTT is elevated, which is the partial thromboplastin time, indicating a problem in the intrinsic pathway or common pathway.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.04735,0.092133,0.10571,0.10936,0.10636,0.098621,0.095222,0.08621,0.07796,0.071121,0.061095,0.04886],"unified_progress":[0.048856,0.081103,0.097253,0.10553,0.11024,0.10653,0.11478,0.089987,0.078976,0.068351,0.056865,0.04153]},{"section":9,"text":"Bleeding time is normal, so that rules out platelet function issues.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.046211,0.092042,0.10551,0.10731,0.1034,0.096407,0.094299,0.087248,0.079419,0.072983,0.064416,0.050751],"unified_progress":[0.046143,0.08231,0.097006,0.10388,0.10847,0.10331,0.11076,0.090564,0.080743,0.072188,0.06062,0.043991]},{"section":10,"text":"Factor VIII is normal, but Factor IX is reduced.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.046419,0.093869,0.10983,0.11136,0.10575,0.0963,0.093978,0.085684,0.077521,0.069567,0.062394,0.04733],"unified_progress":[0.054963,0.085289,0.10047,0.10633,0.11115,0.10304,0.11421,0.087018,0.076098,0.065551,0.055777,0.040093]},{"section":11,"text":"Oh, Factor IX is part of the intrinsic pathway, specifically.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.042773,0.083705,0.097865,0.10389,0.10372,0.098793,0.096668,0.089408,0.082705,0.077216,0.066453,0.056807],"unified_progress":[0.057812,0.076885,0.092104,0.10179,0.10503,0.10403,0.10594,0.091072,0.082179,0.073518,0.061618,0.04802]},{"section":12,"text":"Wait, the ristocetin cofactor assay is normal.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.048236,0.089295,0.099826,0.10238,0.10063,0.095961,0.094434,0.088395,0.081768,0.075635,0.067138,0.056307],"unified_progress":[0.051506,0.081323,0.095762,0.10294,0.10678,0.1024,0.10512,0.090143,0.081744,0.07281,0.062038,0.047422]},{"section":13,"text":"That's for von Willebrand factor, right?","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.040171,0.079925,0.095053,0.10187,0.10313,0.099644,0.098596,0.091669,0.084538,0.079814,0.068793,0.056797],"unified_progress":[0.045844,0.076576,0.093441,0.10262,0.10632,0.10552,0.10712,0.092603,0.08407,0.076107,0.0628,0.046989]},{"section":14,"text":"So that would rule out von Willebrand disease.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.040696,0.079749,0.092934,0.098485,0.09908,0.096579,0.09579,0.090814,0.085921,0.081752,0.072322,0.065877],"unified_progress":[0.045873,0.074602,0.089326,0.098173,0.10192,0.10068,0.10195,0.092439,0.086413,0.079192,0.070084,0.059343]},{"section":15,"text":"Since Factor IX is low and Factor VIII is normal, that makes me think of Hemophilia B.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.042189,0.082496,0.096447,0.10088,0.099685,0.095083,0.094781,0.089152,0.083737,0.079753,0.071696,0.064096],"unified_progress":[0.046143,0.07562,0.090952,0.099071,0.10309,0.10036,0.1033,0.090989,0.08486,0.077742,0.069706,0.058162]},{"section":16,"text":"Because Hemophilia A is Factor VIII deficiency, and that's usually associated with von Willebrand (but here the ristocetin is normal).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.036064,0.072537,0.086094,0.095456,0.10024,0.10035,0.10043,0.094402,0.087086,0.085752,0.073928,0.067655],"unified_progress":[0.040951,0.067142,0.083886,0.093275,0.098912,0.10491,0.10291,0.096634,0.090268,0.084925,0.073934,0.062253]},{"section":17,"text":"Hemophilia B is also called Christmas disease, and it's an X-linked recessive disorder.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.036823,0.068603,0.079574,0.09069,0.09833,0.10093,0.10116,0.095857,0.088265,0.090751,0.075775,0.073241],"unified_progress":[0.050758,0.064701,0.07876,0.088518,0.093053,0.10136,0.098102,0.098043,0.092205,0.088106,0.077643,0.068754]},{"section":18,"text":"Since the patient is male, that fits.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.040685,0.074437,0.082186,0.088412,0.093698,0.099989,0.097103,0.095797,0.091214,0.088486,0.079502,0.068492],"unified_progress":[0.095592,0.10317,0.090455,0.085884,0.085274,0.086143,0.08194,0.087694,0.079493,0.075613,0.068698,0.060049]},{"section":19,"text":"The presentation with joint bleeding (hemarthrosis) after an injury is classic for hemophilia.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.036413,0.071467,0.080182,0.087272,0.09289,0.096663,0.098327,0.096414,0.091883,0.090645,0.082547,0.0753],"unified_progress":[0.050358,0.069277,0.083181,0.085837,0.091238,0.096443,0.094434,0.094425,0.092598,0.091043,0.082039,0.069126]},{"section":20,"text":"The labs all point to Factor IX deficiency.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.034501,0.071836,0.087349,0.09297,0.093134,0.091006,0.093068,0.090288,0.089668,0.089034,0.083718,0.083429],"unified_progress":[0.043308,0.066472,0.07921,0.087947,0.092949,0.09358,0.094257,0.092353,0.091896,0.090309,0.086987,0.080732]},{"section":21,"text":"The PTT is prolonged because Factor IX is part of the intrinsic pathway which the PTT tests.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.031688,0.06817,0.082828,0.092084,0.097448,0.098175,0.102,0.097841,0.09469,0.087284,0.081393,0.066404],"unified_progress":[0.098172,0.071514,0.080491,0.086883,0.093013,0.092756,0.094737,0.090178,0.084901,0.079079,0.070232,0.058044]},{"section":22,"text":"The normal bleeding time and platelets rule out other causes.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.034128,0.072856,0.087293,0.093447,0.095934,0.095661,0.09852,0.095364,0.092013,0.086337,0.080922,0.067523],"unified_progress":[0.050601,0.076025,0.087737,0.096108,0.10127,0.098442,0.10094,0.091425,0.087122,0.081316,0.072195,0.056818]},{"section":23,"text":"So putting it all together, the most likely diagnosis is Hemophilia B. <answer> Hemophilia B </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.031424,0.053392,0.058979,0.065027,0.072149,0.078137,0.084256,0.088642,0.09411,0.096951,0.10897,0.16796],"unified_progress":[0.03605,0.040266,0.047619,0.057163,0.061357,0.072059,0.074614,0.087017,0.097129,0.10335,0.13759,0.18579]}]}}