259,0.080844,0.071553,0.064311]},{"section":9,"text":"In the biliary system, stones or tumors can cause obstruction.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.043432,0.058486,0.07581,0.088622,0.097652,0.10103,0.10475,0.10171,0.096389,0.087803,0.077173,0.067142],"unified_progress":[0.040914,0.066819,0.08526,0.09768,0.10301,0.10566,0.10206,0.096462,0.093525,0.082628,0.069338,0.056645]},{"section":10,"text":"But since the pancreatic duct is also involved, it might be something that affects both systems.","dimension":12,"group":4,"is_degenerate":false,"model_progress":[0.030504,0.052491,0.07111,0.084138,0.094463,0.10061,0.10604,0.10683,0.10577,0.097851,0.08466,0.065537],"unified_progress":[0.033545,0.062917,0.081305,0.092609,0.10002,0.1029,0.10276,0.10116,0.098223,0.093133,0.075715,0.055706]},{"section":11,"text":"I remember that the ampulla of Vater is where the common bile duct and the pancreatic duct meet.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.031991,0.060583,0.079613,0.093799,0.10168,0.10375,0.10662,0.10051,0.094389,0.085141,0.075319,0.066611],"unified_progress":[0.034471,0.069349,0.089473,0.10293,0.10847,0.10537,0.10252,0.095502,0.096777,0.078266,0.064779,0.0521]},{"section":12,"text":"Tumors in this area, like ampullary carcinomas, can cause obstruction of both ducts.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.033915,0.058401,0.076706,0.091259,0.10029,0.10341,0.10841,0.10429,0.097461,0.086345,0.074811,0.0647],"unified_progress":[0.033845,0.065127,0.086588,0.10171,0.10684,0.1133,0.10523,0.097209,0.094396,0.079439,0.063889,0.052435]},{"section":13,"text":"That would explain the dilation of both the CBD and the pancreatic duct.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.037177,0.058296,0.074756,0.086786,0.093768,0.09668,0.099737,0.097963,0.095499,0.090636,0.085954,0.082747],"unified_progress":[0.034205,0.062648,0.080668,0.092851,0.099398,0.10114,0.10001,0.096704,0.09