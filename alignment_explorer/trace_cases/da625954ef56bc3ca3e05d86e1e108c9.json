98173,0.098092,0.095767,0.095103,0.089777,0.083874,0.080634,0.071431,0.064039],"unified_progress":[0.046149,0.072275,0.085738,0.091427,0.096966,0.09927,0.097975,0.094038,0.090586,0.086674,0.076752,0.062151]},{"section":11,"text":"The elevated conjugated bilirubin (direct hyperbilirubinemia) along with high transaminases is typical of hepatitis, especially acute viral hepatitis.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.043094,0.083122,0.093704,0.09772,0.097873,0.095516,0.095483,0.090345,0.084886,0.081268,0.072975,0.064015],"unified_progress":[0.045901,0.072858,0.086448,0.093018,0.098531,0.099651,0.1,0.093746,0.089878,0.084633,0.075188,0.060144]},{"section":12,"text":"Now, looking at the serology.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.045218,0.081419,0.095173,0.099077,0.097296,0.091465,0.090066,0.086836,0.083683,0.084561,0.075048,0.070158],"unified_progress":[0.059797,0.070758,0.081859,0.092149,0.094829,0.093913,0.095389,0.09231,0.088677,0.089064,0.07812,0.063135]},{"section":13,"text":"The presence of IgM anti-HAV is diagnostic for acute hepatitis A. IgM antibodies indicate a recent infection.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.039374,0.078568,0.092606,0.097824,0.098824,0.096188,0.096654,0.091357,0.086491,0.082089,0.074783,0.065243],"unified_progress":[0.067695,0.075593,0.086778,0.092411,0.09709,0.095846,0.096568,0.090535,0.085046,0.080127,0.071787,0.060525]},{"section":14,"text":"The positive IgG anti-HBsAg means she has immunity to hepatitis B, either from vaccination or past infection.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.042682,0.08137,0.091365,0.096244,0.098152,0.098569,0.09689,0.092471,0.086648,0.08168,0.072757,0.061174],"unified_progress":[0.071696,0.093026,0.095049,0.095831,0.097158,0.095277,0.094705,0.087958,0.079917,0.072537,0.064214,0.052632]},{"section":15,"text":"Since IgG anti-HBs is positive, that's protective, so hepatitis B isn't the cause here.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.043446,0.084708,0.097577,0.101,0.099254,0.095742,0.094624,0.089182,0.083488,0.078804,0.070882,0.061295],"unified_progress":[0.05724,0.087503,0.096026,0.10057,0.10294,0.098029,0.099878,0.087053,0.07989,0.072868,0.064768,0.053238]},{"section":16,"text":"The absence of anti-HCV antibodies rules out hepatitis C in the acute setting, though it's a chronic issue usually.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.038462,0.078857,0.092598,0.097886,0.098654,0.097842,0.096867,0.092571,0.087392,0.082912,0.074291,0.061669],"unified_progress":[0.050803,0.085861,0.093705,0.098012,0.10094,0.098242,0.10039,0.090405,0.083664,0.077846,0.067419,0.052714]},{"section":17,"text":"The recent travel to Mexico is a clue because hepatitis A is common in areas with poor sanitation, and travelers can acquire it through contaminated food or water.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.036946,0.072893,0.082231,0.089744,0.096772,0.10607,0.099913,0.09791,0.091371,0.089034,0.076986,0.060131],"unified_progress":[0.09996,0.12204,0.10093,0.093304,0.086964,0.088016,0.080523,0.083859,0.074047,0.068015,0.057863,0.044478]},{"section":18,"text":"The time frame of 2 weeks is also consistent with the incubation period for hepatitis A, which is typically 2-6 weeks.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.041032,0.077793,0.084761,0.089677,0.093481,0.099706,0.096266,0.096,0.088551,0.088037,0.077828,0.066869],"unified_progress":[0.083079,0.10288,0.097548,0.095586,0.090123,0.092928,0.084703,0.087663,0.07662,0.073817,0.063087,0.051968]},{"section":19,"text":"Other possibilities to consider: Could it be another type of hepatitis?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.030805,0.068685,0.087694,0.095292,0.098117,0.09483,0.09598,0.094831,0.091337,0.094663,0.081034,0.066731],"unified_progress":[0.039272,0.077077,0.092465,0.10721,0.10211,0.096877,0.098861,0.092293,0.086902,0.086749,0.069219,0.050967]},{"section":20,"text":"Hepatitis B would require positive HBsAg, which isn't mentioned here.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.032102,0.069413,0.083822,0.091119,0.095592,0.097093,0.1,0.097919,0.093974,0.08974,0.082221,0.067001],"unified_progress":[0.050685,0.075444,0.088344,0.092447,0.099319,0.098225,0.09657,0.095233,0.08984,0.084676,0.073182,0.056035]},{"section":21,"text":"Since her IgG anti-HBs is positive, that's actually immunity, so not B. Hep C is negative.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.035124,0.073726,0.08846,0.095131,0.097714,0.097383,0.09927,0.095439,0.090845,0.08501,0.07844,0.063458],"unified_progress":[0.074597,0.083656,0.090923,0.094509,0.098644,0.09532,0.097199,0.08865,0.08203,0.075552,0.066493,0.052426]},{"section":22,"text":"Hepatitis E is another possibility, but it's more common in the developing world and in outbreaks, but the IgM anti-HEV would be needed to confirm, which isn't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025583,0.060118,0.075942,0.086838,0.094263,0.099656,0.10419,0.10326,0.099504,0.096506,0.0874,0.066748],"unified_progress":[0.043541,0.073925,0.084147,0.089756,0.096722,0.098498,0.098982,0.098839,0.093698,0.093008,0.076067,0.052816]},{"section":23,"text":"However, the positive IgM for HAV makes that the most likely.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.030384,0.064542,0.078569,0.085776,0.089721,0.091869,0.095357,0.094903,0.094501,0.092704,0.089577,0.092098],"unified_progress":[0.04384,0.066916,0.076951,0.08407,0.088822,0.090157,0.092188,0.091424,0.090295,0.090026,0.091747,0.093564]},{"section":24,"text":"Also, the normal albumin and immunoglobulins don't point to chronic liver disease, which fits with acute hepatitis.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.033442,0.0716,0.086312,0.09224,0.094205,0.094218,0.097111,0.094853,0.093,0.088748,0.083668,0.070604],"unified_progress":[0.038391,0.072153,0.086524,0.093556,0.099464,0.097762,0.10152,0.093825,0.091204,0.086845,0.078053,0.060705]},{"section":25,"text":"The combination of the symptoms, the serology, and the travel history all point to acute hepatitis A.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.027481,0.060183,0.076712,0.084613,0.088933,0.089984,0.093572,0.093291,0.094833,0.098727,0.097154,0.094518],"unified_progress":[0.036131,0.056791,0.070981,0.079918,0.086504,0.092408,0.094557,0.097759,0.098938,0.10176,0.097978,0.086278]},{"section":26,"text":"The IgM anti-HAV is the key here.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.028276,0.060691,0.075046,0.081942,0.086007,0.087844,0.092354,0.09285,0.095483,0.095452,0.097308,0.10675],"unified_progress":[0.041128,0.055603,0.067113,0.075066,0.081674,0.087189,0.090124,0.093118,0.096711,0.097842,0.1047,0.10973]},{"section":27,"text":"So the diagnosis should be acute hepatitis A.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.019483,0.03998,0.049762,0.057184,0.065332,0.073229,0.081643,0.088482,0.099306,0.10484,0.12302,0.19774],"unified_progress":[0.018244,0.028912,0.036487,0.045677,0.050744,0.063668,0.067916,0.085142,0.10094,0.11271,0.15981,0.22975]}]}}