.099303,0.095833,0.10155,0.080421,0.053506]},{"section":35,"text":"So putting it all together: post-infectious, ascending weakness (though here it's more leg-focused but maybe still ascending), absent reflexes, high CSF protein, normal glucose.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.025843,0.054862,0.067071,0.076032,0.084659,0.091547,0.097143,0.099243,0.1033,0.10263,0.10311,0.094562],"unified_progress":[0.037182,0.056787,0.070251,0.079594,0.08825,0.094938,0.097287,0.099679,0.10116,0.10033,0.094837,0.079704]},{"section":36,"text":"GBS/AIDP seems the most likely.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.018956,0.042791,0.056085,0.064761,0.072507,0.078484,0.086438,0.09131,0.099383,0.10446,0.1166,0.16822],"unified_progress":[0.023287,0.035785,0.045221,0.055021,0.060649,0.074601,0.078361,0.092491,0.10304,0.10987,0.1405,0.18118]},{"section":37,"text":"The slightly elevated cells might be in the early phase before the dissociation becomes prominent.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.027539,0.059609,0.071808,0.079476,0.085673,0.090503,0.096744,0.098568,0.10059,0.098821,0.097657,0.093011],"unified_progress":[0.044273,0.055687,0.066915,0.075194,0.082495,0.08787,0.09126,0.096147,0.10007,0.10199,0.10244,0.095658]},{"section":38,"text":"Yeah, I think that's it.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30244,0.050684,0.05168,0.060553,0.061891,0.064887,0.062318,0.072001,0.073255,0.070052,0.074041,0.056199],"unified_progress":[0.20456,0.078012,0.062374,0.063732,0.07208,0.073781,0.087818,0.083407,0.081464,0.068053,0.063285,0.061438]}]}}