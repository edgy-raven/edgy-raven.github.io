91812,0.09117,0.092,0.086846,0.085268,0.079557,0.071159],"unified_progress":[0.05571,0.081337,0.082679,0.086082,0.08982,0.095916,0.092316,0.094587,0.091278,0.088093,0.079001,0.06318]},{"section":9,"text":"The hypertension could also be due to excess cortisol.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.036912,0.072206,0.084251,0.091241,0.094471,0.094546,0.096721,0.093701,0.089757,0.089865,0.081434,0.074895],"unified_progress":[0.042229,0.059473,0.071789,0.080155,0.088716,0.094425,0.096649,0.097529,0.098155,0.10009,0.092955,0.077832]},{"section":10,"text":"Now, looking at the lab results.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.044308,0.077208,0.087733,0.092674,0.093996,0.091843,0.091833,0.090458,0.088645,0.088252,0.07945,0.0736],"unified_progress":[0.0581,0.069084,0.079399,0.090112,0.093232,0.092522,0.094911,0.092972,0.090448,0.092758,0.081063,0.065399]},{"section":11,"text":"The serum cortisol level is elevated at 32 \u03bcg/dL (normal is 5-25).","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.048499,0.092636,0.10469,0.10366,0.099188,0.093398,0.093193,0.087577,0.081467,0.073653,0.068044,0.053993],"unified_progress":[0.049772,0.085316,0.098148,0.10179,0.10702,0.10019,0.10267,0.088729,0.082135,0.072496,0.064045,0.047688]},{"section":12,"text":"The 24-hour urinary free cortisol is also high at 200 \u03bcg/24h (normal <50).","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.052278,0.1002,0.11223,0.11099,0.10395,0.094172,0.091218,0.083516,0.074838,0.068021,0.060981,0.047614],"unified_progress":[0.047585,0.086594,0.10043,0.1064,0.11055,0.10346,0.11762,0.086004,0.076519,0.065949,0.057048,0.041843]},{"section":13,"text":"The low ACTH level (1 pg/mL, normal 10-60) suggests that the high cortisol is causing feedback inhibition on the pituitary, which is typical in cases of ectopic ACTH production or an adrenal adenoma.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.046474,0.091918,0.10532,0.10862,0.10526,0.098497,0.094942,0.086336,0.078585,0.071821,0.061798,0.050437],"unified_progress":[0.044613,0.079495,0.096152,0.10426,0.10909,0.1068,0.11397,0.090799,0.080863,0.070045,0.059179,0.044735]},{"section":14,"text":"Since ACTH is low, it's more likely an adrenal source, like an adrenal adenoma causing cortisol overproduction.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.038447,0.079395,0.092218,0.099194,0.10038,0.099509,0.097392,0.09063,0.088013,0.080356,0.069685,0.064786],"unified_progress":[0.040966,0.071356,0.087367,0.097606,0.10189,0.10375,0.10148,0.094187,0.090305,0.079302,0.070306,0.061489]},{"section":15,"text":"Alternatively, an ectopic ACTH tumor might also suppress ACTH, but those usually have higher ACTH.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032858,0.0706,0.084365,0.093716,0.099015,0.10087,0.10165,0.097068,0.092411,0.087809,0.07605,0.063578],"unified_progress":[0.039821,0.068108,0.084847,0.094652,0.10015,0.10465,0.10204,0.098084,0.093305,0.086478,0.072109,0.055755]},{"section":16,"text":"The dexamethasone suppression test: after 1 mg overnight, cortisol was 10 \u03bcg/dL. Normally, cortisol should suppress below 1.8 \u03bcg/dL. Since it didn't suppress, that supports Cushing's.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.046807,0.088923,0.098141,0.099558,0.097271,0.093855,0.094242,0.089641,0.083523,0.077197,0.070683,0.06016],"unified_progress":[0.048378,0.082018,0.095042,0.099633,0.10453,0.1,0.10038,0.090513,0.084124,0.074857,0.067021,0.053503]},{"section":17,"text":"The low ACTH and high cortisol with lack of suppression point to an adrenal cause, so maybe an adrenal adenoma.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.036551,0.076839,0.09087,0.09696,0.097451,0.096105,0.096021,0.090685,0.091023,0.081926,0.075443,0.070126],"unified_progress":[0.043041,0.071351,0.087483,0.096822,0.10177,0.10024,0.10258,0.091405,0.089271,0.078759,0.072506,0.064772]},{"section":18,"text":"But the main diagnosis here is Cushing's syndrome, and the underlying cause would need further testing like a CT scan of the adrenal glands or petrosal sinus sampling.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031417,0.070111,0.083465,0.091034,0.092735,0.095351,0.095046,0.091372,0.096595,0.086453,0.080845,0.085576],"unified_progress":[0.035134,0.066119,0.080974,0.09178,0.096428,0.096437,0.095376,0.092646,0.094514,0.084309,0.082544,0.083739]},{"section":19,"text":"But the question is asking for the most likely diagnosis, which is Cushing's syndrome.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028443,0.051347,0.059192,0.065524,0.072227,0.077785,0.084192,0.08882,0.09516,0.099227,0.11056,0.16752],"unified_progress":[0.030483,0.036557,0.043911,0.053129,0.058338,0.066871,0.073719,0.08629,0.096976,0.10787,0.14727,0.19859]},{"section":20,"text":"<answer> Cushing's syndrome </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.030514,0.051803,0.054286,0.059028,0.066259,0.074214,0.081852,0.089013,0.097925,0.10323,0.11632,0.17556],"unified_progress":[0.028916,0.034251,0.039672,0.046539,0.052037,0.062654,0.067029,0.082711,0.096494,0.10943,0.15266,0.22762]}]}}