0.041895],"unified_progress":[0.10492,0.11615,0.079644,0.10707,0.094883,0.10918,0.079206,0.075616,0.069402,0.063923,0.056157,0.043846]},{"section":10,"text":"The key points are the intrusive thoughts, the compulsion to clean despite knowing it's unnecessary, and the resulting anxiety and impairment.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.085156,0.14076,0.1187,0.092478,0.08672,0.085678,0.077656,0.080906,0.065603,0.061659,0.054693,0.049993],"unified_progress":[0.087908,0.1078,0.097879,0.089908,0.087544,0.089249,0.082488,0.089643,0.075515,0.072315,0.064817,0.054935]},{"section":11,"text":"So, the symptoms fit into obsessive-compulsive disorder (OCD).","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.072301,0.10339,0.1063,0.10392,0.094785,0.083878,0.080804,0.077148,0.069658,0.07701,0.062605,0.068213],"unified_progress":[0.086638,0.071978,0.078919,0.087603,0.088515,0.088039,0.088559,0.088093,0.082097,0.088391,0.077834,0.073334]},{"section":12,"text":"OCD typically involves obsessions (recurrent, intrusive thoughts) and compulsions (repetitive behaviors aimed at reducing anxiety).","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.052603,0.086617,0.08836,0.092849,0.096768,0.095869,0.096191,0.092352,0.084215,0.080105,0.071637,0.062434],"unified_progress":[0.097032,0.073608,0.080613,0.08235,0.087177,0.091224,0.089563,0.093316,0.085378,0.083455,0.073109,0.063174]},{"section":13,"text":"The patient's awareness that the thoughts are irrational (insight) is also a point here.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.060091,0.1012,0.095916,0.090981,0.089225,0.089656,0.087249,0.087886,0.080271,0.079536,0.070932,0.067058],"unified_progress":[0.071492,0.089872,0.087326,0.087508,0.087788,0.090153,0.086562,0.091147,0.08395,0.083458,0.075004,0.065739]},{"section":14,"text":"The compulsions (like cleaning) take up a lot of time and interfere with daily life, which matches the case description.","di