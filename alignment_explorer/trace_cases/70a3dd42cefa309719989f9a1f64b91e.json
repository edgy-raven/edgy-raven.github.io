unified_progress":[0.044265,0.06471,0.083787,0.092566,0.099937,0.10545,0.10293,0.099585,0.093687,0.087274,0.071622,0.054196]},{"section":17,"text":"Sickle cell anemia would show sickle-shaped cells on a blood smear.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.033987,0.071309,0.083488,0.093113,0.09919,0.10157,0.10307,0.09768,0.090877,0.089585,0.074372,0.061753],"unified_progress":[0.040244,0.066592,0.084494,0.094421,0.10051,0.10545,0.10352,0.10003,0.09446,0.087809,0.070436,0.052034]},{"section":18,"text":"G6PD deficiency causes oxidative stress-induced hemolysis, but that's usually triggered by certain medications or foods.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026716,0.060984,0.076199,0.089475,0.099459,0.10412,0.10765,0.103,0.095489,0.094579,0.079721,0.062608],"unified_progress":[0.048747,0.061091,0.078103,0.088214,0.095922,0.10461,0.10249,0.10235,0.096822,0.093959,0.074858,0.052835]},{"section":19,"text":"The timing of the dark urine in the morning could be because during the night, when the body is at rest, there's accumulation of free hemoglobin which then appears in the urine upon voiding in the morning.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.042233,0.078517,0.081162,0.085594,0.091571,0.096804,0.098858,0.097797,0.093167,0.087014,0.079592,0.067689],"unified_progress":[0.072499,0.074164,0.078434,0.082639,0.088905,0.094686,0.092886,0.094818,0.09196,0.087337,0.078659,0.063012]},{"section":20,"text":"That's a classic presentation for PNH as well.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035276,0.069499,0.084688,0.092072,0.094342,0.092569,0.094172,0.091873,0.089885,0.092568,0.082199,0.080859],"unified_progress":[0.046654,0.064029,0.075355,0.086222,0.089403,0.092045,0.093415,0.093869,0.092889,0.096815,0.088576,0.080727]},{"section":21,"text":"So putting it all together: anemia, hemoglobinuria, positive Ham's test.","dimension":4,"group":9,"is_degenerate":false,"mod