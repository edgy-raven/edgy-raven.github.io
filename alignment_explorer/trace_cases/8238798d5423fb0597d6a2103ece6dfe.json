,0.086669,0.092059,0.09803,0.10095,0.098008,0.10309,0.091872,0.085825,0.077265],"unified_progress":[0.042207,0.05819,0.074461,0.085844,0.094572,0.096935,0.099087,0.097558,0.10036,0.092712,0.084364,0.073709]}]}}