rate":false,"model_progress":[0.04797,0.099337,0.12298,0.12214,0.10623,0.088032,0.080447,0.07316,0.067531,0.07358,0.059893,0.0587],"unified_progress":[0.041708,0.076102,0.088614,0.10119,0.09883,0.094527,0.096178,0.091193,0.087053,0.09132,0.074513,0.05877]},{"section":10,"text":"Facial pain could point to sinus involvement.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.044034,0.089317,0.10404,0.10783,0.10269,0.095637,0.090742,0.083879,0.079959,0.075973,0.065826,0.06008],"unified_progress":[0.043633,0.071142,0.086062,0.10123,0.09949,0.098443,0.0974,0.09355,0.090671,0.085929,0.072458,0.059995]},{"section":11,"text":"The middle meatus is part of the nasal anatomy, and pus there suggests an infection in the sinuses.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.036796,0.085321,0.10049,0.10704,0.10252,0.10058,0.095525,0.086215,0.09163,0.074069,0.063652,0.05615],"unified_progress":[0.041263,0.073754,0.094613,0.11381,0.11252,0.10468,0.10074,0.091195,0.090903,0.071481,0.056686,0.04835]},{"section":12,"text":"The middle meatus drains the maxillary, frontal, and ethmoid sinuses.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.039449,0.083382,0.094429,0.10208,0.10143,0.10142,0.097318,0.089213,0.091622,0.076963,0.065254,0.057436],"unified_progress":[0.043391,0.073871,0.093933,0.10791,0.11184,0.10899,0.10256,0.092712,0.089725,0.071956,0.056184,0.046933]},{"section":13,"text":"So maybe a sinusitis?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.038883,0.081744,0.098668,0.10391,0.10092,0.095013,0.092619,0.086451,0.084362,0.084026,0.068614,0.064795],"unified_progress":[0.042751,0.072595,0.088378,0.10046,0.10233,0.098909,0.098612,0.093135,0.089561,0.084529,0.06991,0.058822]},{"section":14,"text":"Since it's been going on for three weeks, could it be acute bacterial rhinosinusitis?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.045618,0.085176,0.093096,0.096745,0.096696,0.095412,0.092736,0.088836,0.084033,0.082539,0.07156,0.067553],"unified_progress":[0.052776,0.072987,0.083303,0.092125,0.094539,0.096771,0.095248,0.093614,0.090069,0.086488,0.076397,0.065684]},{"section":15,"text":"Anosmia is interesting.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.039821,0.082339,0.097164,0.10023,0.097706,0.092847,0.091378,0.087877,0.084185,0.085471,0.074384,0.066601],"unified_progress":[0.049204,0.074409,0.084322,0.093943,0.095804,0.095244,0.095822,0.093754,0.090268,0.090633,0.076508,0.060091]},{"section":16,"text":"Loss of smell can occur with nasal congestion, but in this case, they used a decongestant, so maybe the congestion is relieved, but the smell is still gone.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.041408,0.081346,0.087182,0.0909,0.094249,0.097342,0.09724,0.094611,0.089631,0.084463,0.076656,0.064972],"unified_progress":[0.055489,0.071389,0.078801,0.084035,0.090292,0.094842,0.094492,0.096105,0.094134,0.091511,0.082411,0.0665]},{"section":17,"text":"That might indicate some inflammation or blockage in the olfactory area, or maybe the infection is affecting the sinuses near the olfactory region, like the ethmoid sinuses, which are close to the cribriform plate.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033526,0.077754,0.091408,0.098714,0.098032,0.099637,0.097811,0.090742,0.10064,0.079897,0.07052,0.061322],"unified_progress":[0.04122,0.072169,0.091059,0.10263,0.10706,0.10352,0.10007,0.092389,0.095494,0.077917,0.063812,0.052655]},{"section":18,"text":"The cough could be due to postnasal drip from the sinus infection.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.031178,0.066713,0.077958,0.087691,0.09462,0.099807,0.10287,0.099121,0.097299,0.090314,0.082288,0.070142],"unified_progress":[0.040042,0.059248,0.072714,0.08205,0.092222,0.095927,0.099303,0.10011,0.10104,0.096185,0.088406,0.072746]},{"section":19,"text":"The high fever and purulent discharge are classic signs of bacterial infection.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.026799,0.060997,0.076104,0.085645,0.092248,0.095854,0.1001,0.098576,0.09748,0.096284,0.090421,0.07949],"unified_progress":[0.034893,0.055593,0.067916,0.077958,0.088014,0.094585,0.098057,0.10065,0.10275,0.10413,0.096765,0.078693]},{"section":20,"text":"Viral sinusitis usually doesn't cause high fever beyond the first week or so.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.03256,0.0676,0.077054,0.08451,0.09106,0.095974,0.099984,0.1002,0.096328,0.095244,0.086521,0.07297],"unified_progress":[0.036552,0.060879,0.072915,0.080109,0.089577,0.095547,0.098866,0.10245,0.10098,0.10297,0.090771,0.068384]},{"section":21,"text":"So putting this together: prolonged symptoms beyond viral expectations, pus in the middle meatus after decongestion, facial pain, fever, and anosmia.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.029555,0.061941,0.0734,0.080218,0.086252,0.091038,0.094801,0.095776,0.09888,0.098962,0.098796,0.09038],"unified_progress":[0.03508,0.05706,0.068378,0.077485,0.086348,0.09522,0.097249,0.099815,0.10288,0.1027,0.097681,0.080103]},{"section":22,"text":"The most likely diagnosis is acute bacterial rhinosinusitis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.025619,0.053564,0.065641,0.072976,0.077852,0.08123,0.086556,0.088984,0.094961,0.099192,0.10596,0.14747],"unified_progress":[0.025253,0.041372,0.052117,0.062259,0.068066,0.079918,0.083199,0.093968,0.10248,0.10717,0.1285,0.1557]},{"section":23,"text":"Let me check if there's anything else.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.28483,0.046125,0.04718,0.056772,0.058957,0.063118,0.062006,0.073286,0.07905,0.078466,0.08649,0.063718],"unified_progress":[0.18261,0.069411,0.05939,0.060914,0.069866,0.073145,0.10145,0.086555,0.087669,0.074668,0.070559,0.06377]},{"section":24,"text":"Could it be something like nasal polyps?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.021107,0.051786,0.055248,0.088766,0.1019,0.096981,0.1067,0.10787,0.10596,0.10059,0.094355,0.068736],"unified_progress":[0.0308,0.069912,0.072098,0.098574,0.10747,0.10241,0.10319,0.10559,0.09963,0.089155,0.073934,0.047235]},{"section":25,"text":"But polyps might cause chronic symptoms and maybe not the acute fever and pus.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.015222,0.043524,0.060887,0.073996,0.086626,0.093782,0.10602,0.11227,0.11302,0.11156,0.10738,0.075707],"unified_progress":[0.027242,0.053983,0.070123,0.079061,0.094162,0.096832,0.10154,0.11102,0.10907,0.11262,0.090476,0.053878]},{"section":26,"text":"Maybe fungal sinusitis, but that's less common in otherwise healthy kids.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.016398,0.045203,0.061606,0.074124,0.084716,0.094466,0.1061,0.1127,0.11302,0.11301,0.10473,0.073931],"unified_progress":[0.030802,0.058375,0.071419,0.079275,0.090127,0.094753,0.10106,0.10851,0.1079,0.11395,0.090314,0.053512]},{"section":27,"text":"The key points all point to bacterial sinusitis.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.024507,0.056574,0.072667,0.080417,0.083984,0.085762,0.090516,0.092629,0.095431,0.10124,0.099009,0.11726],"unified_progress":[0.026932,0.050413,0.061875,0.07346,0.078267,0.083869,0.09263,0.093009,0.096134,0.10358,0.11286,0.12697]},{"section":28,"text":"Yeah, that's the call.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.2969,0.048074,0.048663,0.057988,0.060011,0.064173,0.062514,0.072707,0.07618,0.074221,0.079699,0.058875],"unified_progress":[0.18979,0.072309,0.062063,0.06221,0.071694,0.074269,0.096576,0.085922,0.08534,0.071755,0.067173,0.060897]}]}}