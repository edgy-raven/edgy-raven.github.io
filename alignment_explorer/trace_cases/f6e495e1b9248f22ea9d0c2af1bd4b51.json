735,0.08503,0.091421,0.093931,0.098565,0.096102,0.093994,0.094717,0.08951,0.07915,0.069252],"unified_progress":[0.05457,0.086511,0.089962,0.094647,0.096274,0.094365,0.092856,0.092606,0.089379,0.081532,0.069672,0.057627]},{"section":17,"text":"Urothelial carcinoma with mucinous differentiation is a thing, but adenocarcinoma is more definitively glandular and mucinous.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.027846,0.060738,0.07501,0.086198,0.093738,0.097032,0.099969,0.096641,0.094664,0.093245,0.085901,0.089017],"unified_progress":[0.033465,0.058183,0.077889,0.086608,0.091512,0.10147,0.09759,0.095591,0.094394,0.091365,0.08751,0.08442]},{"section":18,"text":"The key here is the gland-like structures and mucin, along with chronic cystitis as a predisposing factor.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.02866,0.06216,0.07681,0.084653,0.08876,0.091224,0.093798,0.09354,0.095874,0.097614,0.093991,0.092916],"unified_progress":[0.035222,0.058681,0.07056,0.081241,0.087463,0.094142,0.094693,0.097151,0.099141,0.099689,0.095962,0.086056]},{"section":19,"text":"So I think the most likely diagnosis is primary bladder adenocarcinoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.023242,0.046103,0.055823,0.063339,0.070361,0.076497,0.083474,0.088358,0.097251,0.102,0.11602,0.17753],"unified_progress":[0.023323,0.034103,0.043129,0.052831,0.058643,0.071556,0.075842,0.08932,0.10132,0.10991,0.14648,0.19355]}]}}