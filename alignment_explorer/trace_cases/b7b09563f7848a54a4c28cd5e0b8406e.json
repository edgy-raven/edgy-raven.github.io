76112],"unified_progress":[0.043068,0.06551,0.079836,0.090469,0.092911,0.095456,0.09493,0.092993,0.090552,0.092215,0.084043,0.078016]},{"section":11,"text":"Schizophrenia typically includes positive symptoms like hallucinations and delusions (like the conspiracy beliefs here).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037091,0.073509,0.084915,0.094673,0.1005,0.10043,0.099944,0.093963,0.085879,0.086908,0.073598,0.068592],"unified_progress":[0.040445,0.061003,0.077483,0.087118,0.094223,0.10328,0.10036,0.10035,0.096195,0.093481,0.079752,0.066299]},{"section":12,"text":"The age of onset for schizophrenia is usually in the late teens to early 30s, so that fits.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.045276,0.078832,0.083241,0.08867,0.093504,0.097547,0.096013,0.094041,0.088109,0.087672,0.076825,0.07027],"unified_progress":[0.067536,0.078469,0.081151,0.084581,0.088325,0.092581,0.091225,0.094391,0.089382,0.087211,0.077691,0.067458]},{"section":13,"text":"Another possibility could be a mood disorder with psychotic features, like bipolar disorder or schizoaffective disorder.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.029031,0.063004,0.07856,0.089036,0.097257,0.099083,0.10172,0.10014,0.094924,0.095429,0.083009,0.068811],"unified_progress":[0.03407,0.065321,0.085699,0.095849,0.097589,0.10016,0.10116,0.098577,0.094377,0.091817,0.076554,0.058831]},{"section":14,"text":"But the case doesn't mention any mood symptoms like depression or mania, so maybe less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021892,0.053453,0.069188,0.079089,0.087949,0.094045,0.10322,0.1074,0.10728,0.10478,0.099291,0.072413],"unified_progress":[0.027994,0.057639,0.073128,0.082001,0.093471,0.094881,0.10018,0.10705,0.10555,0.11255,0.089148,0.056405]},{"section":15,"text":"Substance-induced psychosis could be another thought, but since he's only an occasional drinker, unless there's another substance in