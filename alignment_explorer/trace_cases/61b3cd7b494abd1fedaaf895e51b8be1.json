[0.044296,0.067558,0.07884,0.086642,0.090398,0.092666,0.095628,0.095935,0.094417,0.090094,0.08521,0.078316],"unified_progress":[0.047573,0.070886,0.084595,0.091287,0.094342,0.098638,0.095857,0.095113,0.091578,0.086634,0.0773,0.066198]},{"section":9,"text":"The dry mouth, double vision, and drooping eyelids make me think of issues with the autonomic nervous system or cranial nerves.","dimension":14,"group":5,"is_degenerate":false,"model_progress":[0.039988,0.068985,0.081158,0.086978,0.09153,0.093137,0.095912,0.095803,0.093591,0.087744,0.085894,0.079279],"unified_progress":[0.054791,0.08349,0.088688,0.092007,0.094297,0.09687,0.09424,0.094572,0.089715,0.083773,0.071443,0.056114]},{"section":10,"text":"The muscle biopsy being normal is interesting because it rules out some muscle diseases like muscular dystrophy or myositis.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.03335,0.062495,0.079935,0.09082,0.095985,0.098203,0.1013,0.099934,0.096199,0.091181,0.080946,0.069655],"unified_progress":[0.035972,0.06521,0.0844,0.094139,0.0993,0.10154,0.10056,0.098023,0.096319,0.089695,0.075425,0.059416]},{"section":11,"text":"Since the weakness is widespread and there's evidence of autoantibodies, an autoimmune disorder seems likely.","dimension":13,"group":3,"is_degenerate":false,"model_progress":[0.035077,0.05751,0.072675,0.08274,0.090702,0.094973,0.099295,0.10011,0.099185,0.096079,0.089755,0.0819],"unified_progress":[0.034517,0.058999,0.074929,0.085731,0.092375,0.098541,0.097865,0.098954,0.097937,0.094685,0.087082,0.078386]},{"section":12,"text":"The key clue here is the IgG autoantibodies against voltage-sensitive calcium channels in motor nerve terminals.","dimension":1,"group":7,"is_degenerate":false,"model_progress":[0.031518,0.055092,0.071614,0.082691,0.09273,0.097436,0.10041,0.10042,0.098546,0.096131,0.089565,0.083844],"unified_progress":[0.035638,0.06431,0.079136,0.089035,0.09481,0.096252,0.097077,0.096146,0.095664,0.091799,0.084709,0.075425]},{"section":13,"text":"Voltage-sensitive calcium channels are crucial for the release of neurotransmitters at the neuromuscular junction.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.039121,0.057753,0.073817,0.085926,0.09547,0.099921,0.10483,0.10365,0.10012,0.09102,0.080375,0.067994],"unified_progress":[0.039945,0.06666,0.08387,0.095049,0.10119,0.10342,0.10181,0.097667,0.09604,0.085971,0.07238,0.056003]},{"section":14,"text":"When these channels are blocked, it affects the transmission of nerve impulses to the muscles, leading to weakness.","dimension":13,"group":3,"is_degenerate":false,"model_progress":[0.050529,0.059178,0.073573,0.08416,0.092939,0.097263,0.10191,0.10166,0.099077,0.090658,0.080688,0.068366],"unified_progress":[0.040125,0.062716,0.081,0.092035,0.099384,0.10609,0.10277,0.099624,0.097089,0.088504,0.074051,0.056618]},{"section":15,"text":"This presentation aligns with Lambert-Eaton Myasthenic Syndrome (LEMS).","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.031631,0.055685,0.072208,0.082368,0.091625,0.0963,0.10325,0.10468,0.10018,0.096549,0.086545,0.078981],"unified_progress":[0.030819,0.057454,0.077271,0.089725,0.095524,0.10626,0.10311,0.10147,0.097354,0.093209,0.080227,0.067582]},{"section":16,"text":"LEMS is an autoimmune disorder where the body produces antibodies that interfere with the normal functioning of the neuromuscular junction.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.038576,0.052145,0.066457,0.0784,0.090724,0.097669,0.10634,0.10864,0.10506,0.096611,0.085585,0.073786],"unified_progress":[0.037364,0.059946,0.078193,0.090326,0.097286,0.10525,0.10302,0.10127,0.097531,0.090293,0.077159,0.062356]},{"section":17,"text":"It often occurs in association with certain cancers, like small cell lung carcinoma, which is exactly the patient's history.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.035119,0.056481,0.068247,0.077963,0.088259,0.094678,0.10383,0.10726,0.1051,0.0