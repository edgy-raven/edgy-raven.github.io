ogress":[0.044224,0.087391,0.10166,0.10598,0.10368,0.096871,0.094938,0.087244,0.079278,0.07573,0.065777,0.057222],"unified_progress":[0.053075,0.076721,0.091464,0.09983,0.10347,0.10267,0.10623,0.091133,0.082251,0.075821,0.065303,0.052034]},{"section":13,"text":"The presence of lymphadenopathy in multiple regions (cervical, axillary, inguinal) is also typical for mono.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.037412,0.078547,0.088869,0.09459,0.096231,0.098268,0.097002,0.091994,0.09305,0.083023,0.075508,0.065504],"unified_progress":[0.043651,0.073306,0.088539,0.097894,0.10235,0.10254,0.098837,0.094383,0.093093,0.080698,0.069191,0.055518]},{"section":14,"text":"The right upper quadrant tenderness could be due to an inflamed liver or spleen, which are common in mono.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.03149,0.071069,0.083891,0.092586,0.09604,0.099499,0.10021,0.095284,0.097964,0.08642,0.077939,0.067608],"unified_progress":[0.036367,0.064776,0.081911,0.092816,0.10073,0.10158,0.10073,0.097068,0.098418,0.087217,0.076223,0.062155]},{"section":15,"text":"Splenomegaly is another classic finding.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.032084,0.071031,0.084332,0.092365,0.09563,0.097617,0.098645,0.094746,0.094701,0.088242,0.079237,0.071369],"unified_progress":[0.038159,0.066199,0.082442,0.092864,0.099131,0.10222,0.10063,0.096634,0.094962,0.087396,0.075949,0.063419]},{"section":16,"text":"Other possibilities to consider: maybe a different viral infection, like CMV (cytomegalovirus) or HIV, but those usually present differently.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.026062,0.060909,0.077585,0.088025,0.095332,0.098171,0.10171,0.10134,0.09742,0.097485,0.086025,0.069934],"unified_progress":[0.032906,0.065076,0.08052,0.090823,0.096158,0.10011,0.10117,0.10098,0.096923,0.096345,0.079759,0.059232]},{"section":17,"text":"Strep throat would have a higher neutrophil count and wouldn't have the atypical lymphocytes.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027373,0.061288,0.074841,0.083904,0.090658,0.095269,0.10225,0.10306,0.101,0.098643,0.091547,0.070154],"unified_progress":[0.033076,0.061569,0.077214,0.085275,0.095647,0.098774,0.10097,0.10394,0.10165,0.10243,0.08369,0.055758]},{"section":18,"text":"Lymphoma is a consideration with lymphadenopathy and atypical cells, but the acute presentation with fever and sore throat is less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021477,0.053447,0.068845,0.08003,0.088334,0.095294,0.10386,0.10633,0.10611,0.10464,0.097526,0.074105],"unified_progress":[0.027675,0.054778,0.070226,0.079792,0.091225,0.096823,0.10147,0.10707,0.1073,0.11182,0.092004,0.05983]},{"section":19,"text":"Also, lymphoma usually doesn't have such a high proportion of atypical lymphocytes in the blood.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028635,0.062358,0.074636,0.083104,0.089045,0.093766,0.099776,0.10081,0.10044,0.09814,0.091724,0.077566],"unified_progress":[0.033701,0.060325,0.074884,0.083926,0.092485,0.096796,0.099634,0.10174,0.10119,0.10067,0.088032,0.06662]},{"section":20,"text":"The combination of pharyngitis, lymphadenopathy, splenomegaly, and atypical lymphocytes points strongly to infectious mononucleosis.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.023337,0.051869,0.065331,0.075676,0.085163,0.092138,0.097813,0.099056,0.10315,0.10403,0.10522,0.097225],"unified_progress":[0.030653,0.050912,0.066053,0.075927,0.086162,0.097239,0.098463,0.10215,0.10517,0.10424,0.099775,0.08326]},{"section":21,"text":"The lab values support this, especially the atypical lymphocytes.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.027547,0.059982,0.074545,0.081978,0.086512,0.088916,0.094134,0.095073,0.09787,0.09879,0.098389,0.096264],"unified_progress":[0.034532,0.056655,0.069775,0.078852,0.087027,0.092236,0.095653,0.097178,0.099604,0.10002,0.098592,0.089879]},{"section":22,"text":"So I think that's the most likely diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028076,0.054669,0.066275,0.072529,0.076562,0.07893,0.083983,0.087765,0.093603,0.099404,0.10648,0.15172],"unified_progress":[0.029059,0.040025,0.048526,0.058786,0.063387,0.073177,0.077146,0.089774,0.099937,0.10894,0.1365,0.17475]}]}}