s_degenerate":false,"model_progress":[0.035823,0.064023,0.088036,0.107,0.11322,0.1132,0.10774,0.09672,0.086033,0.078796,0.065561,0.043855],"unified_progress":[0.041945,0.070133,0.087186,0.098265,0.10102,0.098626,0.1002,0.095757,0.092046,0.084037,0.072221,0.058562]},{"section":10,"text":"Oh, and wait, his trachea is shifted to the left.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.027225,0.06341,0.092337,0.11713,0.12632,0.1236,0.11305,0.097335,0.083035,0.073263,0.053776,0.029522],"unified_progress":[0.037713,0.073291,0.090573,0.10276,0.10688,0.10239,0.10034,0.094442,0.092288,0.080264,0.066233,0.052838]},{"section":11,"text":"That's interesting.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.12408,0.099713,0.092278,0.08175,0.083004,0.083189,0.081827,0.086387,0.075062,0.049769,0.04912,0.093819],"unified_progress":[0.21352,0.082175,0.069796,0.067744,0.077709,0.075259,0.086989,0.081612,0.07659,0.060942,0.05539,0.052277]},{"section":12,"text":"If the trachea shifts, it usually means there's something going on with the pressure inside the chest.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.043602,0.067649,0.090746,0.10828,0.11199,0.10978,0.10457,0.09306,0.083837,0.078709,0.063629,0.044138],"unified_progress":[0.053485,0.081615,0.070909,0.10298,0.10694,0.10516,0.098357,0.095078,0.087202,0.078966,0.067426,0.051877]},{"section":13,"text":"Like, if one side of the chest is more full than the other, the whole thing can shift over.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.042059,0.05749,0.079025,0.097616,0.10645,0.10901,0.10681,0.098668,0.091469,0.087992,0.073685,0.049723],"unified_progress":[0.047733,0.067052,0.083826,0.094247,0.099102,0.10087,0.099113,0.095772,0.092332,0.084371,0.073476,0.062103]},{"section":14,"text":"In this case, it looks like the right side is less full, which makes sense if the lung is collapsed.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.034