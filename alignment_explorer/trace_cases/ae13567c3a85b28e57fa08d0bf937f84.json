3,0.092609,0.090989,0.075834,0.056927]},{"section":8,"text":"The key here is the abnormal platelet features.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.040788,0.08312,0.09818,0.10139,0.096848,0.090433,0.08902,0.085404,0.083071,0.085753,0.074801,0.071188],"unified_progress":[0.041251,0.070092,0.081496,0.093246,0.095755,0.095519,0.097929,0.094474,0.092526,0.092896,0.080133,0.064683]},{"section":9,"text":"Primary thrombocythemia, like essential thrombocythemia (ET), is a myeloproliferative neoplasm.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034156,0.067891,0.08156,0.094657,0.10278,0.1031,0.10278,0.095302,0.086369,0.087526,0.073037,0.070845],"unified_progress":[0.037255,0.055523,0.076523,0.087329,0.096144,0.11032,0.1035,0.10164,0.09629,0.091836,0.077605,0.06604]},{"section":10,"text":"The absence of Philadelphia chromosome rules out CML.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.031162,0.068438,0.083907,0.092002,0.095658,0.097507,0.099086,0.096099,0.093185,0.091016,0.081311,0.070629],"unified_progress":[0.041964,0.068415,0.080483,0.089097,0.095238,0.097031,0.097254,0.098056,0.095348,0.092878,0.079722,0.064513]},{"section":11,"text":"Other MPNs like polycythemia vera or myelofibrosis might have different findings.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026039,0.060062,0.076327,0.09008,0.099258,0.10306,0.10581,0.10097,0.094343,0.095394,0.080055,0.068605],"unified_progress":[0.030499,0.058283,0.079047,0.089852,0.097378,0.10822,0.10461,0.10336,0.098791,0.094617,0.077219,0.058125]},{"section":12,"text":"ET typically has high platelets with megakaryocyte proliferation.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029307,0.06452,0.078653,0.089829,0.097311,0.1006,0.10383,0.099201,0.094267,0.093362,0.079717,0.069396],"unified_progress":[0.049357,0.062282,0.078526,0.089885,0.096817,0.10278,0.10172,0.10002,0.09575,0.088847,0.074751,0.059259]},{"section":13,"t