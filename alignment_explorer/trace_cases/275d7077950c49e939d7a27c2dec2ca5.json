:8,"group":3,"is_degenerate":false,"model_progress":[0.04426,0.080127,0.088723,0.096479,0.101,0.10181,0.098431,0.09247,0.084164,0.082484,0.069658,0.060396],"unified_progress":[0.067796,0.078302,0.084909,0.089222,0.092711,0.099921,0.094393,0.09456,0.087481,0.08341,0.070201,0.057094]},{"section":9,"text":"The fact that another child had similar lesions supports contagion.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.043877,0.083233,0.091073,0.094107,0.094489,0.096543,0.092794,0.09074,0.086794,0.084996,0.074659,0.066695],"unified_progress":[0.064657,0.089298,0.088579,0.091972,0.091858,0.092609,0.089296,0.09114,0.085902,0.083116,0.07175,0.059823]},{"section":10,"text":"Also, the brother had chickenpox, but chickenpox lesions are different\u2014more vesicular and itchy.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039567,0.077572,0.084629,0.090118,0.09453,0.098326,0.098546,0.096898,0.090109,0.088136,0.077304,0.064265],"unified_progress":[0.045236,0.071276,0.08563,0.089823,0.095759,0.10192,0.098316,0.098417,0.093497,0.090339,0.074504,0.055286]},{"section":11,"text":"Since the papules here are non-pruritic and the timing is a month later, maybe not directly related.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.0425,0.081737,0.087127,0.088777,0.09011,0.093329,0.093748,0.094568,0.090802,0.089105,0.080614,0.067584],"unified_progress":[0.047726,0.073956,0.081014,0.087281,0.09276,0.094308,0.095808,0.097449,0.094865,0.095626,0.079902,0.059306]},{"section":12,"text":"But molluscum can occur after varicella, though not necessarily connected.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.033759,0.068461,0.079917,0.088327,0.094644,0.10012,0.099331,0.097645,0.093337,0.092158,0.081701,0.070598],"unified_progress":[0.053526,0.079159,0.083655,0.087062,0.089993,0.095239,0.093829,0.095608,0.091245,0.089172,0.078241,0.063272]},{"section":13,"text":"The lesions are nontender and the child is otherwise healthy.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.053652,0.097,0.089441,0.083256,0.083524,0.089557,0.089084,0.095323,0.088877,0.084007,0.079084,0.067194],"unified_progress":[0.063042,0.09109,0.086418,0.086512,0.088386,0.090979,0.088802,0.093769,0.089249,0.087016,0.076127,0.058611]},{"section":14,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.034814,0.07503,0.09356,0.098341,0.096505,0.091079,0.091836,0.089738,0.087465,0.092622,0.079005,0.070005],"unified_progress":[0.03809,0.070763,0.081718,0.094312,0.096082,0.094192,0.099523,0.095028,0.092028,0.098013,0.08016,0.060092]},{"section":15,"text":"Like warts (verrucae), but they might have a rough surface.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028799,0.064286,0.078052,0.088593,0.096044,0.099115,0.10292,0.101,0.096215,0.094293,0.083434,0.067246],"unified_progress":[0.031998,0.060542,0.077883,0.08771,0.096789,0.10334,0.10261,0.10418,0.1004,0.098106,0.079763,0.056676]},{"section":16,"text":"Or maybe insect bites, but those are usually pruritic.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.020464,0.052121,0.0676,0.079008,0.087874,0.095272,0.10571,0.10952,0.10889,0.10639,0.098739,0.068407],"unified_progress":[0.025661,0.053977,0.070441,0.07988,0.092611,0.096846,0.10223,0.10978,0.10931,0.11713,0.089317,0.052812]},{"section":17,"text":"The umbilicated papules are classic for molluscum.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.027448,0.061222,0.074843,0.084215,0.089891,0.093964,0.097479,0.096904,0.1,0.096784,0.090857,0.086393],"unified_progress":[0.031617,0.056921,0.072575,0.084801,0.091989,0.099205,0.1007,0.10035,0.10196,0.09601,0.088605,0.075267]},{"section":18,"text":"Also, immunizations are up to date, so not a vaccine reaction.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.035259,0.072615,0.082378,0.087299,0.091478,0.097368,0.096636,0.097131,0.094247,0.0