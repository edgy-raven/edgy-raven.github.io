.086714,0.062425,0.08051,0.05,0.043242,0.036113,0.027874]},{"section":4,"text":"The X-ray shows a 'spilled teacup' sign.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.097532,0.1645,0.1461,0.10911,0.086574,0.082234,0.068801,0.06769,0.057454,0.046421,0.038948,0.034634],"unified_progress":[0.089076,0.11752,0.11059,0.10949,0.097668,0.093101,0.081295,0.080291,0.07394,0.057319,0.048714,0.040996]},{"section":5,"text":"Hmm, first, the mechanism of injury: high-speed fall on an outstretched hand.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.10185,0.13088,0.11494,0.1026,0.091436,0.084312,0.076202,0.074172,0.062637,0.062798,0.050413,0.047764],"unified_progress":[0.13138,0.088365,0.087729,0.089816,0.09051,0.088228,0.084387,0.085529,0.074771,0.072282,0.058736,0.048267]},{"section":6,"text":"That's a classic scenario for a Colles fracture.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.075576,0.10787,0.10941,0.10639,0.098186,0.087493,0.082627,0.078597,0.068243,0.072827,0.057013,0.055765],"unified_progress":[0.088855,0.078901,0.086558,0.094018,0.093497,0.092233,0.089759,0.089772,0.080856,0.082439,0.066672,0.056442]},{"section":7,"text":"Colles fractures are common wrist fractures, typically from falling onto the hand, especially with the wrist extended.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.052147,0.088822,0.091831,0.096256,0.099253,0.098558,0.096229,0.091095,0.082031,0.077807,0.067069,0.058901],"unified_progress":[0.079623,0.074344,0.086557,0.089335,0.092661,0.097073,0.092971,0.093767,0.085587,0.08099,0.068531,0.058561]},{"section":8,"text":"The 'dinner fork' deformity is often mentioned, but here they mention a 'spilled teacup' sign.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.052902,0.092094,0.092415,0.092709,0.093091,0.093718,0.091832,0.089633,0.083786,0.080489,0.070439,0.066891],"unified_progress":[0.059482,0.078102,0.087907,0.091461,0.094008,0.096704,0.093053,0.093076,0.088153,0.08228,0.072548,0.063226]},{"section":9,"text":"Wait, I need to recall what that X-ray sign means.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.030905,0.061537,0.079912,0.089533,0.097413,0.098775,0.098664,0.097306,0.097334,0.090525,0.083926,0.07417],"unified_progress":[0.042701,0.074401,0.085116,0.10144,0.099184,0.094136,0.09616,0.091423,0.087382,0.096042,0.074547,0.057472]},{"section":10,"text":"The spilled teacup sign refers to the direction of the fracture displacement.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.049196,0.081306,0.083126,0.088929,0.092085,0.093784,0.094783,0.09254,0.090611,0.08531,0.076555,0.071776],"unified_progress":[0.071673,0.070585,0.082937,0.098323,0.096337,0.096217,0.093865,0.091181,0.086852,0.078555,0.069198,0.064278]},{"section":11,"text":"In Colles fracture, the distal fragment is displaced posteriorly, so on the X-ray, the radius's distal end looks like it's spilling backward, hence the teacup image.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.047363,0.08408,0.08816,0.093009,0.09428,0.09535,0.095158,0.091108,0.090318,0.081304,0.072287,0.067582],"unified_progress":[0.059319,0.073654,0.089716,0.097843,0.10178,0.101,0.096494,0.092046,0.08875,0.076122,0.065244,0.058035]},{"section":12,"text":"The dinner fork deformity is the visible angular deformity when looking at the wrist from the side.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.046085,0.081716,0.085025,0.089727,0.093832,0.096,0.096994,0.094402,0.090436,0.083367,0.075739,0.066677],"unified_progress":[0.0798,0.075874,0.084568,0.090373,0.094173,0.097249,0.093329,0.092256,0.086624,0.079616,0.068167,0.057972]},{"section":13,"text":"Both signs point to Colles.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.037701,0.075247,0.090339,0.095705,0.094779,0.090644,0.091138,0.087667,0.085861,0.088972,0.078531,0.083417],"unified_progress":[0.048971,0.066785,0.078043,0.089315,0.0907,0.091899,0.091984,0.091107,0.090063,0.092101,0.085886,0.083147]},{"section":14,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.033671,0.075292,0.097593,0.10289,0.099294,0.091287,0.089323,0.086391,0.084497,0.088822,0.076703,0.074232],"unified_progress":[0.033979,0.068385,0.08138,0.095003,0.094986,0.093053,0.096032,0.09413,0.092609,0.098128,0.083784,0.068532]},{"section":15,"text":"Maybe a Smith's fracture, but that's from a fall on a flexed wrist, leading to anterior displacement, which would be a different X-ray appearance.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039272,0.07396,0.082287,0.091201,0.097101,0.099115,0.0995,0.095591,0.090339,0.087377,0.07649,0.067766],"unified_progress":[0.047111,0.062911,0.078065,0.089571,0.096028,0.10248,0.099779,0.099703,0.095724,0.090403,0.076034,0.062191]},{"section":16,"text":"Scaphoid fracture is another consideration, but it usually presents with tenderness over the anatomical snuffbox and maybe no obvious deformity.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.029107,0.065096,0.078102,0.08814,0.094738,0.09928,0.10308,0.10065,0.09857,0.093785,0.082792,0.066655],"unified_progress":[0.031138,0.060686,0.079026,0.08916,0.0977,0.10315,0.10255,0.10325,0.10141,0.098228,0.078022,0.055671]},{"section":17,"text":"The presence of deformity here makes me think it's a more displaced fracture.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.03215,0.069756,0.083369,0.090017,0.091879,0.093001,0.095018,0.093693,0.095325,0.092259,0.083979,0.079554],"unified_progress":[0.036926,0.06241,0.076023,0.08703,0.093035,0.094398,0.097633,0.097165,0.098162,0.095599,0.0863,0.075317]},{"section":18,"text":"Also, the spilled teacup is specific to Colles.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.032053,0.065232,0.078501,0.085698,0.089271,0.090241,0.092654,0.092195,0.09318,0.094227,0.090167,0.096581],"unified_progress":[0.035946,0.055445,0.068369,0.079127,0.084655,0.090079,0.092978,0.094981,0.097333,0.09919,0.10051,0.10139]},{"section":19,"text":"So putting it all together: high-speed fall, outstretched hand, swollen wrist with deformity, and the X-ray sign.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.031726,0.060741,0.070174,0.077047,0.083369,0.088311,0.092325,0.094631,0.099208,0.10132,0.10293,0.098216],"unified_progress":[0.038914,0.052097,0.063064,0.072453,0.081849,0.091083,0.094011,0.099285,0.10419,0.10714,0.10487,0.091042]},{"section":20,"text":"Definitely Colles fracture.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.024412,0.050185,0.062329,0.069231,0.074169,0.077452,0.083853,0.087788,0.095361,0.10199,0.1121,0.16113],"unified_progress":[0.023312,0.037186,0.046245,0.055914,0.061252,0.073912,0.078315,0.091736,0.10326,0.11108,0.14028,0.1775]}]}}