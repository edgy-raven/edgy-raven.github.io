,0.10642,0.10454,0.099377,0.090632,0.070016],"unified_progress":[0.032048,0.06567,0.084961,0.097222,0.099539,0.10086,0.10344,0.099768,0.095425,0.089598,0.074923,0.056552]},{"section":30,"text":"But I think Candida is more common.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.019844,0.049411,0.066901,0.077726,0.088119,0.094566,0.10088,0.10391,0.10548,0.10226,0.098673,0.092225],"unified_progress":[0.036692,0.060442,0.072911,0.08505,0.089112,0.091485,0.095498,0.097662,0.096752,0.10031,0.092271,0.081811]},{"section":31,"text":"Let me think of the prevalence.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.29403,0.048622,0.049897,0.059251,0.061436,0.065043,0.063897,0.073533,0.075796,0.072761,0.076547,0.059184],"unified_progress":[0.20471,0.07778,0.064579,0.064526,0.074201,0.074947,0.09412,0.084512,0.081915,0.066221,0.059504,0.052984]},{"section":32,"text":"In HIV patients with esophagitis, Candida is the most frequent cause, followed by CMV and HSV.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029878,0.065877,0.058006,0.098787,0.10813,0.10429,0.10602,0.098821,0.091083,0.08677,0.078584,0.07375],"unified_progress":[0.048683,0.075784,0.062915,0.093033,0.09926,0.097982,0.10023,0.098226,0.093324,0.088156,0.075947,0.066458]},{"section":33,"text":"Since he's not on ART, his CD4 is likely low enough for Candida to be a big player.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.034225,0.069291,0.079945,0.088179,0.095378,0.10374,0.10026,0.098449,0.093651,0.089465,0.080437,0.066975],"unified_progress":[0.090267,0.11058,0.095154,0.088194,0.086839,0.087151,0.082083,0.085755,0.078274,0.072747,0.066435,0.056522]},{"section":34,"text":"So the most likely diagnosis here is Candida esophagitis, even without oral lesions.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.024269,0.050416,0.061514,0.069498,0.076602,0.082367,0.088427,0.09021,0.096753,0.097811,0.10693,0.1552],"unified_progress":[0.030108,0.046937,0.057755,0.066112,0.070002,0.076481,0.08094,0.08503,0.092799,0.099424,0.12882,0.16559]},{"section":35,"text":"The exam being normal in the mouth doesn't exclude it because the infection is in the esophagus.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.028112,0.063104,0.074914,0.082765,0.087046,0.092324,0.096111,0.096039,0.10106,0.095202,0.093041,0.090285],"unified_progress":[0.046827,0.059896,0.072632,0.08333,0.089085,0.091375,0.092204,0.094256,0.096608,0.09418,0.092098,0.087508]},{"section":36,"text":"So the answer should be esophageal candidiasis, which is also called Candida esophagitis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.021937,0.044561,0.053815,0.062521,0.071622,0.079654,0.087156,0.09148,0.09919,0.10095,0.11415,0.17296],"unified_progress":[0.023023,0.035222,0.045849,0.055405,0.060651,0.071451,0.07684,0.086909,0.098966,0.107,0.1453,0.19338]}]}}