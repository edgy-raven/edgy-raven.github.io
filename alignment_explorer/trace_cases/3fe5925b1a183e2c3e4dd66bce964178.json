,0.091528,0.083055,0.080068,0.068558,0.057972,0.049807],"unified_progress":[0.052053,0.081836,0.096284,0.10463,0.10725,0.10481,0.10132,0.090238,0.085826,0.071071,0.058648,0.046033]},{"section":6,"text":"The bone marrow has 14% blasts.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.053019,0.097359,0.10303,0.10248,0.098154,0.094548,0.091171,0.085747,0.082001,0.072538,0.064572,0.055379],"unified_progress":[0.054301,0.083885,0.095386,0.10145,0.10535,0.10013,0.09981,0.090081,0.084875,0.072703,0.062243,0.049793]},{"section":7,"text":"Now, I remember that the threshold for diagnosing acute myeloid leukemia (AML) is usually 20% blasts in the bone marrow or blood.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.048125,0.084548,0.093382,0.09868,0.099229,0.095819,0.094672,0.088673,0.081059,0.080094,0.068996,0.066723],"unified_progress":[0.053814,0.069351,0.084725,0.093265,0.097311,0.10297,0.099764,0.093297,0.087094,0.082209,0.072761,0.063438]},{"section":8,"text":"But here it's 14%, which is below that.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.043761,0.083123,0.094098,0.096919,0.09651,0.094229,0.093392,0.090194,0.085537,0.081529,0.074212,0.066497],"unified_progress":[0.058755,0.077297,0.086196,0.093549,0.097086,0.09463,0.096105,0.091078,0.086102,0.082426,0.074067,0.06271]},{"section":9,"text":"However, there are other myelodysplastic or myeloproliferative disorders that might fit.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.03735,0.074246,0.087005,0.095288,0.098909,0.098581,0.098122,0.093479,0.087783,0.087337,0.074433,0.067466],"unified_progress":[0.041654,0.067003,0.084439,0.094191,0.098034,0.10297,0.10024,0.096931,0.092162,0.087657,0.07423,0.060493]},{"section":10,"text":"The cytogenetic finding is t(8;21), which I recall is a translocation associated with a specific type of AML, even if the blast percentage is a bit low.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.038585,0.074958,0.086154,0.093631,0.097454,0.098687,0.098249,0.093908,0.088373,0.086945,0.075042,0.068015],"unified_progress":[0.047439,0.071896,0.084996,0.092797,0.097452,0.10072,0.098617,0.095934,0.090858,0.084665,0.073453,0.061172]},{"section":11,"text":"Wait, maybe the World Health Organization (WHO) criteria have some exceptions.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.3095,0.051892,0.052974,0.062374,0.063468,0.064634,0.061822,0.07009,0.071091,0.066821,0.071254,0.054084],"unified_progress":[0.20565,0.080282,0.065192,0.064776,0.0747,0.074072,0.096633,0.082157,0.078716,0.063683,0.058993,0.055144]},{"section":12,"text":"Oh right, certain cytogenetic abnormalities like t(8;21)(q22;q22), inv(16)(p13.1q22), or t(16;16)(p13.1;q22) can classify a case as AML even if the blast percentage is between 10-19%.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.055959,0.11951,0.058197,0.099111,0.1011,0.10304,0.095194,0.086771,0.079248,0.074499,0.066447,0.060926],"unified_progress":[0.05931,0.079794,0.063464,0.098453,0.10028,0.10403,0.098334,0.095776,0.08987,0.083743,0.070032,0.056914]},{"section":13,"text":"So in this case, with t(8;21) and 14% blasts, it would still be AML.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.046247,0.078302,0.084865,0.086876,0.089217,0.089805,0.09023,0.088292,0.085881,0.084438,0.081191,0.094656],"unified_progress":[0.052143,0.06268,0.07156,0.079459,0.083416,0.088036,0.087248,0.090143,0.090275,0.089181,0.097797,0.10806]},{"section":14,"text":"The dysplasia mentioned in neutrophils might point towards a myelodysplastic syndrome, but the presence of the translocation and the blast count in the context of the cytogenetic criteria would push it towards AML.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.034467,0.070393,0.083264,0.090134,0.092819,0.093953,0.095561,0.09262,0.092587,0.089324,0.083532,0.081345],"unified_progress":[0.036225,0.062352,0.077086,0.086661,0.092097,0.09514,0.095935,0.094955,0.095821,0.092807,0.088642,0.082279]},{"section":15,"text":"The high WBC with myeloid precursors and the specific translocation are key here.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.033484,0.069714,0.082382,0.088658,0.091537,0.092984,0.095253,0.093522,0.094192,0.091384,0.087435,0.079454],"unified_progress":[0.036893,0.064468,0.078606,0.087573,0.09441,0.096805,0.098897,0.09633,0.096437,0.092564,0.085517,0.071499]},{"section":16,"text":"So the most likely diagnosis is AML with t(8;21)(q22;q22), which is also known as core-binding factor AML.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.030478,0.056565,0.064555,0.073051,0.080762,0.086279,0.090986,0.092029,0.094115,0.095959,0.099718,0.1355],"unified_progress":[0.033183,0.043928,0.055807,0.065526,0.071898,0.084109,0.085168,0.093089,0.098729,0.10126,0.12059,0.14672]},{"section":17,"text":"The old terminology might have called this AML M2, but now it's classified by the cytogenetic abnormality.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.029664,0.057262,0.067071,0.07596,0.083681,0.089468,0.094149,0.095493,0.097018,0.099526,0.0973,0.11341],"unified_progress":[0.035062,0.04936,0.060001,0.068863,0.075099,0.083591,0.086211,0.094296,0.098654,0.10258,0.11365,0.13264]}]}}