15,0.075684,0.073992],"unified_progress":[0.038134,0.06954,0.083371,0.095568,0.098149,0.096332,0.097343,0.093808,0.092346,0.092043,0.077464,0.065904]},{"section":13,"text":"But why didn't antibiotics work?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.03358,0.071804,0.089578,0.09594,0.09692,0.093916,0.09365,0.091959,0.089782,0.090462,0.08062,0.071788],"unified_progress":[0.044568,0.071399,0.083061,0.092252,0.094788,0.093037,0.096527,0.094979,0.091796,0.093707,0.079981,0.063906]},{"section":14,"text":"Maybe the infection is deep-seated or the bacteria is resistant.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029559,0.064878,0.079545,0.088973,0.095516,0.098497,0.1011,0.099146,0.096361,0.092373,0.084252,0.069798],"unified_progress":[0.061533,0.06818,0.077759,0.085322,0.090653,0.093328,0.095128,0.095962,0.093472,0.091517,0.081402,0.065744]},{"section":15,"text":"Or maybe it's actually a fungal infection, but malignant otitis externa is more common in diabetics.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.030427,0.062065,0.074513,0.084221,0.092092,0.096148,0.099373,0.099644,0.096989,0.096626,0.087748,0.080155],"unified_progress":[0.042243,0.064466,0.0781,0.087017,0.090819,0.094866,0.096484,0.097178,0.095327,0.094098,0.085531,0.073872]},{"section":16,"text":"The granulation tissue and the progression to facial nerve involvement point towards malignant external otitis.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.029438,0.06375,0.076073,0.084647,0.090019,0.094421,0.097688,0.096242,0.099142,0.094558,0.089544,0.084477],"unified_progress":[0.036227,0.060097,0.074772,0.085919,0.09252,0.097459,0.09727,0.097421,0.099371,0.094809,0.087726,0.076411]},{"section":17,"text":"Another possibility could be cholesteatoma, but that's more associated with chronic middle ear issues and maybe hearing loss, not so much the facial nerve palsy and bony erosion in the external canal.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023462,0.057329,0.072442,0.083719,0.091024,0.096817,0.10315,0.10341,0.10474,0.10007,0.091466,0.072376],"unified_progress":[0.027632,0.056275,0.074421,0.085925,0.096072,0.1001,0.10244,0.10451,0.10445,0.10361,0.085113,0.059456]},{"section":18,"text":"So putting it all together: diabetic, painful external ear lesion, non-responsive to antibiotics, granulation, bone erosion, facial nerve palsy.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.025238,0.053759,0.065488,0.07413,0.082585,0.089746,0.095191,0.098123,0.10355,0.10415,0.10745,0.10059],"unified_progress":[0.033239,0.052085,0.064091,0.074437,0.084508,0.093894,0.097498,0.10136,0.10521,0.10479,0.10215,0.086742]},{"section":19,"text":"Malignant otitis externa seems to fit best.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.021655,0.045685,0.05741,0.065965,0.073034,0.078568,0.085864,0.090102,0.098104,0.10397,0.11479,0.16485],"unified_progress":[0.022286,0.035569,0.046193,0.056194,0.062671,0.076722,0.080657,0.094157,0.10461,0.11047,0.13747,0.173]},{"section":20,"text":"The term \"malignant\" here refers to its aggressive nature, not a cancer.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.036431,0.062878,0.068825,0.076019,0.0818,0.085635,0.09059,0.093006,0.094552,0.10002,0.097664,0.11258],"unified_progress":[0.044287,0.046886,0.056129,0.065593,0.072985,0.081828,0.086491,0.095776,0.10157,0.10791,0.1153,0.12524]}]}}