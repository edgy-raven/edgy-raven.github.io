058,0.047831,0.038048]},{"section":5,"text":"Hmm, sore throat and mouth ulcers...","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.070819,0.11811,0.12306,0.11349,0.099093,0.086573,0.079104,0.073987,0.064967,0.068678,0.053323,0.048791],"unified_progress":[0.074886,0.091068,0.09322,0.10093,0.097115,0.093331,0.090701,0.086822,0.078475,0.081271,0.063042,0.049142]},{"section":6,"text":"I need to think about possible causes.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.053157,0.096035,0.11567,0.11689,0.10562,0.089553,0.083197,0.076291,0.070937,0.074983,0.059982,0.057682],"unified_progress":[0.06262,0.078565,0.087753,0.10159,0.0986,0.092741,0.094032,0.088445,0.082346,0.088642,0.069468,0.055202]},{"section":7,"text":"The presence of vesicles is important.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.045428,0.096406,0.12073,0.12138,0.10712,0.089244,0.082417,0.074837,0.069327,0.074872,0.060188,0.058046],"unified_progress":[0.046508,0.076038,0.08815,0.1015,0.098923,0.094558,0.095594,0.090942,0.086566,0.090515,0.072788,0.057916]},{"section":8,"text":"Vesicles could suggest a viral infection.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.041885,0.089145,0.11044,0.1146,0.10665,0.093844,0.088596,0.081408,0.074842,0.076671,0.063496,0.058425],"unified_progress":[0.050187,0.071445,0.085648,0.096908,0.097814,0.096487,0.097259,0.093318,0.088598,0.089767,0.073611,0.058957]},{"section":9,"text":"Herpes simplex virus (HSV) comes to mind because primary HSV infection can cause oral lesions.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034875,0.074816,0.091608,0.10224,0.1062,0.10332,0.099913,0.091744,0.08246,0.082933,0.067518,0.062361],"unified_progress":[0.037054,0.064543,0.082429,0.091896,0.097719,0.10628,0.10132,0.098942,0.093459,0.08997,0.07468,0.061707]},{"section":10,"text":"The ulcers with gray bases and inflamed borders are classic for HSV stomatitis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.043877,0.084962,0.09169,0.095648,0.096813,0.096647,0.094879,0.090407,0.084882,0.083269,0.070997,0.065929],"unified_progress":[0.045927,0.071771,0.083228,0.092279,0.096209,0.10016,0.097677,0.096758,0.093102,0.087577,0.074452,0.060858]},{"section":11,"text":"Wait, but there are also vesicles.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.039897,0.077619,0.09063,0.095086,0.095869,0.09382,0.092915,0.090977,0.088817,0.087466,0.078029,0.068877],"unified_progress":[0.047815,0.071711,0.082559,0.092716,0.095903,0.095345,0.09654,0.095113,0.092297,0.09275,0.07733,0.059922]},{"section":12,"text":"In primary herpetic stomatitis, you often see vesicles that rupture to form ulcers.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037096,0.073163,0.083246,0.093722,0.10057,0.10244,0.1021,0.095723,0.087834,0.085937,0.072359,0.065801],"unified_progress":[0.04124,0.063004,0.082177,0.091089,0.09775,0.10875,0.10238,0.10013,0.094425,0.087898,0.072465,0.058696]},{"section":13,"text":"The location on the soft palate and tonsillar areas fits.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.038477,0.082766,0.092145,0.096832,0.096019,0.098131,0.096387,0.090598,0.095512,0.07998,0.070839,0.062315],"unified_progress":[0.040427,0.074552,0.091515,0.10191,0.10762,0.10387,0.099998,0.094596,0.095654,0.076815,0.062713,0.050326]},{"section":14,"text":"Other possibilities might include aphthous ulcers, but those usually aren't associated with vesicles.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028146,0.063993,0.079445,0.089922,0.096398,0.098338,0.103,0.10089,0.095929,0.09553,0.082947,0.065465],"unified_progress":[0.031748,0.060983,0.078649,0.08924,0.097256,0.10634,0.10307,0.10328,0.098865,0.098283,0.077654,0.054625]},{"section":15,"text":"Aphthous ulcers are typically single or multiple painful ulcers without a viral exanthem.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032655,0.067516,0.077328,0.087584,0.095793,0.10036,0.10375,0.10099,0.094508,0.093584,0.079958,0.06598],"unified_progress":[0.037115,0.061272,0.07735,0.08802,0.095881,0.10505,0.10336,0.10427,0.099723,0.096172,0.077246,0.054534]},{"section":16,"text":"Another thought: hand, foot, and mouth disease, which is caused by Coxsackievirus.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028996,0.062794,0.077177,0.09007,0.099607,0.10357,0.10538,0.10083,0.093198,0.095547,0.07759,0.065238],"unified_progress":[0.035173,0.061634,0.081296,0.092866,0.098331,0.10656,0.10519,0.1034,0.097357,0.092104,0.072981,0.053106]},{"section":17,"text":"But that's more common in children and presents with ulcers in the mouth along with lesions on the hands and feet.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02529,0.058144,0.072086,0.084037,0.093539,0.10006,0.10632,0.10559,0.10149,0.10011,0.088109,0.065229],"unified_progress":[0.036047,0.057289,0.074643,0.084935,0.095466,0.10088,0.1031,0.1067,0.10345,0.10636,0.07978,0.05135]},{"section":18,"text":"The patient here doesn't mention a rash elsewhere, so maybe less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.019439,0.050198,0.066216,0.077407,0.086019,0.094218,0.10522,0.11023,0.11082,0.10819,0.10146,0.070588],"unified_progress":[0.027082,0.054759,0.069463,0.078692,0.09108,0.093998,0.10147,0.10928,0.10954,0.11978,0.091632,0.053227]},{"section":19,"text":"Candidiasis can cause oral lesions, but they are usually white plaques that can be scraped off, not vesicles turning into ulcers.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025492,0.057591,0.069652,0.080642,0.089421,0.096363,0.10421,0.10588,0.10458,0.10186,0.0924,0.071903],"unified_progress":[0.031214,0.056526,0.072472,0.083081,0.09274,0.10092,0.10258,0.10726,0.10632,0.10553,0.086027,0.055337]},{"section":20,"text":"So, putting it together: vesicles progressing to ulcers with gray bases in the oropharynx, along with dysphagia.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.034563,0.068473,0.07583,0.081264,0.085983,0.090996,0.093946,0.094645,0.098461,0.095285,0.092653,0.087901],"unified_progress":[0.041637,0.062459,0.073189,0.08234,0.089667,0.096294,0.096939,0.097963,0.10019,0.094779,0.088826,0.075718]},{"section":21,"text":"The key points are the vesicles and their evolution into ulcers.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.027091,0.059174,0.073824,0.081457,0.086397,0.088842,0.093204,0.094409,0.098402,0.10241,0.10092,0.093871],"unified_progress":[0.033725,0.054443,0.066475,0.076691,0.086054,0.092981,0.096667,0.10007,0.1033,0.10618,0.099672,0.083738]},{"section":22,"text":"That's very typical for herpetic gingivostomatitis, which is usually caused by HSV-1.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026876,0.057131,0.070809,0.083637,0.093161,0.09735,0.10052,0.097604,0.094023,0.09585,0.087921,0.095114],"unified_progress":[0.031333,0.049687,0.067737,0.078036,0.086655,0.09825,0.099163,0.10171,0.10075,0.098736,0.094881,0.09306]},{"section":23,"text":"I think the most likely diagnosis here is Herpes simplex virus infection, specifically primary herpetic gingivostomatitis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.025427,0.050844,0.060574,0.069646,0.078198,0.084711,0.090393,0.092384,0.096163,0.10006,0.10395,0.14765],"unified_progress":[0.025292,0.038093,0.049161,0.059898,0.065829,0.078914,0.080572,0.091674,0.098461,0.10467,0.13393,0.17351]}]}}