9,0.081835,0.080809,0.085823,0.07488,0.050145,0.050659,0.097447],"unified_progress":[0.20994,0.082532,0.067401,0.06643,0.076944,0.074499,0.089188,0.081632,0.077174,0.061999,0.057118,0.055138]},{"section":10,"text":"An audible click when pressing on the foot?","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.042983,0.07351,0.091128,0.1026,0.10501,0.10362,0.099155,0.090239,0.08535,0.083741,0.071866,0.050797],"unified_progress":[0.049258,0.083484,0.070782,0.099504,0.10466,0.10007,0.10091,0.093325,0.087121,0.081336,0.071742,0.057808]},{"section":11,"text":"That's a big clue.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.12035,0.096237,0.089318,0.079343,0.079188,0.080132,0.080264,0.08694,0.076885,0.051949,0.05388,0.10552],"unified_progress":[0.20593,0.080776,0.06588,0.064208,0.07511,0.074221,0.093249,0.082037,0.07801,0.063594,0.059184,0.057805]},{"section":12,"text":"It reminds me of Morton's neuroma, where you can feel a clicking sensation under the metatarsal heads due to nerve irritation.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.035074,0.052289,0.067744,0.083428,0.09237,0.10257,0.10884,0.10689,0.10799,0.11052,0.082445,0.049853],"unified_progress":[0.041699,0.069338,0.062878,0.098773,0.10482,0.10367,0.10333,0.10191,0.09542,0.088795,0.072481,0.056887]},{"section":13,"text":"And it's common in runners because of the repetitive impact and pressure on the feet.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.040862,0.047826,0.059144,0.070394,0.080617,0.08979,0.09813,0.10203,0.10814,0.11631,0.10894,0.077818],"unified_progress":[0.045915,0.059268,0.072774,0.082659,0.090332,0.098636,0.097485,0.099303,0.09771,0.095343,0.086756,0.073819]},{"section":14,"text":"So, putting all this together, the pain, the click, the fact that she's a runner, and the location of the pain all point towards Morton's neuroma.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.02549,0.036207,0.045331,0