,0.084722,0.088833,0.094315,0.096928,0.098433,0.095195,0.090913,0.083128,0.06733],"unified_progress":[0.050272,0.073952,0.07996,0.084335,0.090695,0.093751,0.095383,0.098733,0.096339,0.09652,0.080896,0.059163]},{"section":15,"text":"Could it be a hearing problem?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.028865,0.064511,0.08049,0.088904,0.096219,0.097459,0.099949,0.10146,0.097872,0.096653,0.084826,0.062787],"unified_progress":[0.035943,0.073003,0.089061,0.10152,0.10067,0.098709,0.10238,0.098204,0.092717,0.089618,0.070981,0.047192]},{"section":16,"text":"But if she's talking at home, hearing loss is less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.033273,0.069483,0.07886,0.084649,0.09079,0.095903,0.099425,0.10068,0.097833,0.09384,0.086634,0.068632],"unified_progress":[0.056175,0.07421,0.082289,0.086992,0.093837,0.094214,0.094986,0.097877,0.093446,0.091436,0.07763,0.056906]},{"section":17,"text":"Maybe she's just shy?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.030472,0.065002,0.077133,0.085003,0.09367,0.098293,0.10084,0.10304,0.099252,0.096307,0.086283,0.064697],"unified_progress":[0.051444,0.075677,0.087402,0.096331,0.097209,0.096515,0.098657,0.097046,0.091283,0.087952,0.071287,0.049199]},{"section":18,"text":"But selective mutism is more severe than shyness and is considered an anxiety condition.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028368,0.061534,0.074722,0.084537,0.0926,0.097023,0.10144,0.10095,0.097096,0.095851,0.087694,0.078186],"unified_progress":[0.050168,0.062064,0.075339,0.083576,0.090312,0.09574,0.096746,0.09848,0.095603,0.095179,0.085184,0.071607]},{"section":19,"text":"The child's ability to communicate non-verbally at school but not speak suggests anxiety about speaking in certain environments.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.043227,0.080876,0.08171,0.083505,0.088205,0.093364,0.095277,0.096402,0.092636,0.088506,0.083055,0.073237],"unified_progress":[0.078228,0.079871,0.079877,0.081872,0.085949,0.08992,0.089253,0.092559,0.089012,0.086791,0.079424,0.067245]},{"section":20,"text":"Another thought: could there be some trauma or fear associated with speaking in school?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.032565,0.066382,0.078094,0.086008,0.094245,0.097431,0.10017,0.10167,0.09832,0.09512,0.085436,0.064555],"unified_progress":[0.049241,0.074434,0.08824,0.0988,0.097558,0.096286,0.098211,0.095834,0.090944,0.087599,0.071704,0.051149]},{"section":21,"text":"But selective mutism is often linked to anxiety about social judgment, especially in children who are extremely shy or anxious.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.032439,0.065492,0.075953,0.085753,0.094536,0.099925,0.10279,0.10111,0.095851,0.092504,0.083458,0.07019],"unified_progress":[0.076851,0.070587,0.078528,0.083303,0.089345,0.094927,0.093799,0.095404,0.090379,0.087288,0.076778,0.062811]},{"section":22,"text":"The fact that she's been silent since school started and the parents note she only talks at home with close relatives points more towards selective mutism as the diagnosis.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.045951,0.083582,0.082631,0.082676,0.086326,0.09322,0.092072,0.094482,0.090617,0.088059,0.082456,0.077928],"unified_progress":[0.061697,0.084566,0.082663,0.082656,0.08454,0.089159,0.086727,0.091422,0.08808,0.086338,0.083748,0.078403]},{"section":23,"text":"I think that's the most likely.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31833,0.052388,0.053058,0.06175,0.062939,0.063149,0.062296,0.068502,0.06917,0.066216,0.069454,0.052749],"unified_progress":[0.21348,0.085833,0.065078,0.063956,0.074519,0.072958,0.090144,0.079703,0.07665,0.062969,0.058414,0.056299]},{"section":24,"text":"Let me check the criteria again.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30289,0.053145,0.26701,0.058707,0.040574,0.038604,0.035456,0.041277,0.044206,0.043981,0.042886,0.031259],"unified_progress":[0.18448,0.061722,0.24301,0.081852,0.056889,0.055242,0.054304,0.062516,0.061105,0.050617,0.045696,0.042563]},{"section":25,"text":"Selective mutism is an anxiety disorder where the child doesn't speak in specific social situations (like school) despite being able to speak in others.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.069729,0.13726,0.076122,0.10849,0.10276,0.096907,0.08782,0.078475,0.070408,0.063916,0.056989,0.051123],"unified_progress":[0.10147,0.11087,0.074235,0.098161,0.093126,0.10144,0.08452,0.079705,0.074314,0.068918,0.060648,0.0526]},{"section":26,"text":"It's usually present before age 5, which fits here.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.044364,0.083196,0.090409,0.094764,0.098107,0.10091,0.096516,0.092105,0.08516,0.080834,0.071679,0.061956],"unified_progress":[0.087103,0.093368,0.091803,0.089539,0.089206,0.091166,0.085726,0.08972,0.079671,0.076961,0.067845,0.057892]},{"section":27,"text":"The child's age is 6, so that's within the typical range.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.048496,0.083504,0.087291,0.090221,0.092863,0.097798,0.093093,0.092136,0.08641,0.08447,0.075536,0.068182],"unified_progress":[0.090825,0.10704,0.094421,0.089896,0.085841,0.087308,0.081362,0.086073,0.076389,0.073666,0.067368,0.059808]},{"section":28,"text":"No other symptoms mentioned like repetitive behaviors or sensory issues that would point elsewhere.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.030079,0.065133,0.078517,0.085979,0.091584,0.095141,0.10038,0.10062,0.098683,0.095333,0.088826,0.069726],"unified_progress":[0.04063,0.070488,0.081234,0.089744,0.096794,0.095735,0.097765,0.098096,0.095654,0.096339,0.080524,0.056997]},{"section":29,"text":"So yeah, selective mutism is the best fit here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0