.053107],"unified_progress":[0.042023,0.077601,0.096876,0.10923,0.10898,0.10418,0.098987,0.091317,0.090304,0.073275,0.059232,0.047997]},{"section":9,"text":"But the ECG findings are key here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.042024,0.087096,0.10805,0.11022,0.10275,0.091134,0.087946,0.08206,0.077402,0.083383,0.066548,0.061389],"unified_progress":[0.043509,0.074792,0.088453,0.10003,0.1006,0.094079,0.097005,0.093206,0.08847,0.0916,0.072302,0.055959]},{"section":10,"text":"The ECG shows a short P-R interval and a slurred upstroke of the QRS, which I remember is called a delta wave.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.057358,0.096397,0.098067,0.09918,0.096664,0.093673,0.090615,0.085378,0.081756,0.074421,0.066443,0.060048],"unified_progress":[0.066546,0.0786,0.090216,0.10031,0.10032,0.098052,0.095423,0.090504,0.085606,0.075642,0.064836,0.05394]},{"section":11,"text":"Oh right, that's classic for Wolff-Parkinson-White (WPW) syndrome.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.044763,0.080091,0.091239,0.098579,0.1008,0.097574,0.096224,0.089608,0.082323,0.082318,0.068978,0.0675],"unified_progress":[0.050298,0.066107,0.084859,0.094085,0.096609,0.10552,0.098461,0.094476,0.088873,0.084633,0.072786,0.06329]},{"section":12,"text":"WPW is an accessory pathway that bypasses the AV node, leading to pre-excitation.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037946,0.074578,0.086308,0.096225,0.10154,0.10181,0.10143,0.094193,0.087376,0.084874,0.070408,0.063314],"unified_progress":[0.053068,0.065298,0.083499,0.094077,0.098647,0.10392,0.10039,0.097306,0.091777,0.084131,0.070023,0.05786]},{"section":13,"text":"The short P-R interval because the impulse takes a shortcut through the accessory pathway, so the atrial depolarization starts the ventricular depolarization early.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.047792,0.085197,0.089009,0.094073,0.096596,0.097636,0.097146,0.092111,0.08757,0.081152,0.069766,0.061952],"unified_progress":[0.060036,0.074152,0.087585,0.095096,0.099397,0.10133,0.097295,0.094274,0.089725,0.0793,0.066855,0.054953]},{"section":14,"text":"The delta wave is that slow upstroke.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.050459,0.08571,0.090087,0.094144,0.095407,0.094669,0.094641,0.09056,0.087196,0.080741,0.071722,0.064664],"unified_progress":[0.066354,0.075405,0.087839,0.095063,0.098929,0.098837,0.095772,0.091873,0.087487,0.078636,0.067303,0.0565]},{"section":15,"text":"But wait, the murmur.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.03366,0.067033,0.083673,0.091302,0.096339,0.096813,0.096907,0.095163,0.09484,0.089956,0.082506,0.071807],"unified_progress":[0.044963,0.074604,0.085537,0.099201,0.098847,0.095265,0.095878,0.092608,0.088947,0.092057,0.074401,0.057692]},{"section":16,"text":"In WPW, sometimes the murmur is due to the rapid ventricular depolarization causing a systolic flow murmur.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.038747,0.075434,0.084109,0.092147,0.096226,0.098786,0.099189,0.094791,0.092982,0.085419,0.075571,0.0666],"unified_progress":[0.048881,0.068622,0.085019,0.099556,0.10048,0.1027,0.098707,0.094877,0.091484,0.081786,0.069255,0.058637]},{"section":17,"text":"A holosystolic murmur could be from the high heart rate causing turbulence, or maybe the accessory pathway isn't the cause of the murmur.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.040661,0.077773,0.085666,0.092321,0.095319,0.097473,0.097942,0.093836,0.093224,0.084546,0.075169,0.06607],"unified_progress":[0.050012,0.069331,0.084772,0.09443,0.10038,0.10101,0.098867,0.095051,0.093225,0.083044,0.071488,0.058386]},{"section":18,"text":"Alternatively, could there be a coexisting VSD?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.028466,0.064194,0.079496,0.089104,0.096783,0.099727,0.10169,0.10157,0.10072,0.093336,0.082958,0.061953],"unified_progress":[0.03955,0.073266,0.090891,0.10274,0.10384,0.10043,0.10232,0.096735,0.091995,0.083705,0.066749,0.04778]},{"section":19,"text":"But the key here is the ECG findings pointing to WPW.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.030753,0.066116,0.082689,0.089708,0.092086,0.091511,0.093533,0.092546,0.093022,0.094738,0.087203,0.086095],"unified_progress":[0.038595,0.063584,0.076129,0.088947,0.091665,0.093343,0.096036,0.094702,0.093926,0.095229,0.088138,0.079705]},{"section":20,"text":"Also, in WPW, patients can have episodes of tachycardia, like atrioventricular reentrant tachycardia (AVRT), which is a common arrhythmia in WPW.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032933,0.066358,0.077728,0.088921,0.097258,0.1005,0.10204,0.097605,0.091417,0.090754,0.079602,0.074881],"unified_progress":[0.038806,0.057403,0.07472,0.084701,0.092912,0.10385,0.10075,0.10093,0.0977,0.094003,0.083243,0.070981]},{"section":21,"text":"The high heart rate here might be such an episode.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.033918,0.067633,0.078159,0.08623,0.092715,0.096373,0.099537,0.097658,0.094404,0.091401,0.084903,0.077069],"unified_progress":[0.04709,0.05751,0.067919,0.077201,0.085556,0.095239,0.094996,0.098195,0.099875,0.099743,0.095643,0.081032]},{"section":22,"text":"The fact that the ECG was done after the heart rate was reduced might explain why the delta wave is visible now.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.041534,0.07814,0.083565,0.086842,0.090204,0.093242,0.095104,0.094571,0.092595,0.08743,0.082904,0.073869],"unified_progress":[0.06656,0.074502,0.079612,0.084477,0.08948,0.091282,0.092304,0.092111,0.090296,0.087433,0.081405,0.070539]},{"section":23,"text":"So putting it all together: the tachycardia episode, the ECG with short P-R and delta wave, and the holosystolic murmur (possibly due to the high flow from tachycardia or the pre-excitation).","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.038651,0.069701,0.076696,0.083039,0.088102,0.091741,0.09479,0.09393,0.09541,0.092316,0.089668,0.085954],"unified_progress":[0.054011,0.064065,0.075556,0.082545,0.089129,0.092667,0.093347,0.094004,0.095053,0.091695,0.08793,0.079998]},{"section":24,"text":"The most likely diagnosis is Wolff-Parkinson-White syndrome.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.022403,0.046149,0.057301,0.065262,0.072828,0.078806,0.085769,0.089688,0.097263,0.10114,0.11338,0.17001],"unified_progress":[0.021868,0.035748,0.046081,0.055965,0.060642,0.073554,0.077359,0.089633,0.10168,0.10837,0.14261,0.18648]},{"section":25,"text":"I don't think it's a VSD because the murmur in VSD is typically best heard at the left sternal border, maybe.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.029917,0.062144,0.071144,0.078782,0.084932,0.091237,0.096716,0.098986,0.10161,0.099708,0.095889,0.088932],"unified_progress":[0.032898,0.054282,0.067224,0.077565,0.08563,0.091048,0.095194,0.10077,0.10378,0.10754,0.099123,0.084944]},{"section":26,"text":"But the ECG findings are the strongest clue here.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.024384,0.055121,0.07163,0.081081,0.088153,0.092047,0.097814,0.099604,0.10181,0.10134,0.097771,0.089249],"unified_progress":[0.041022,0.05619,0.06777,0.077856,0.085339,0.08885,0.09521,0.098872,0.10054,0.10679,0.09807,0.083483]},{"section":27,"text":"So yeah, WPW.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.021305,0.045416,0.058205,0.066972,0.075434,0.082059,0.088503,0.093043,0.10039,0.10244,0.11139,0.15484],"unified_progress":[0.023627,0.03939,0.048862,0.059295,0.063744,0.073128,0.078627,0.087216,0.097972,0.10836,0.1389,0.18088]}]}}