2,0.31656,0.077337,0.11496,0.067489,0.067457,0.04682,0.038566,0.032192,0.027451,0.023526,0.021021],"unified_progress":[0.19621,0.16892,0.088695,0.11691,0.085226,0.089177,0.061899,0.053262,0.045427,0.038441,0.031931,0.023899]},{"section":3,"text":"That already makes me think of conditions that can cause rapidly progressive glomerulonephritis (RPGN).","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.084096,0.12736,0.13937,0.12108,0.10656,0.085015,0.076582,0.0669,0.05514,0.055439,0.042418,0.040042],"unified_progress":[0.079633,0.091283,0.10301,0.11006,0.10265,0.097155,0.089857,0.082646,0.072497,0.071302,0.055682,0.044224]},{"section":4,"text":"The differential for RPGN includes things like anti-glomerular basement membrane (anti-GBM) disease, pauci-immune crescentic glomerulonephritis (often associated with ANCA vasculitis), or immune complex-mediated like lupus nephritis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.042446,0.082482,0.098196,0.10942,0.11279,0.10687,0.101,0.088451,0.076303,0.073833,0.057605,0.050606],"unified_progress":[0.039473,0.065495,0.092514,0.10017,0.10469,0.11206,0.10325,0.097085,0.089302,0.08175,0.064194,0.050018]},{"section":5,"text":"But then there's the other symptoms: intermittent hemoptysis and chest pain.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.064093,0.1115,0.10102,0.092074,0.089457,0.091562,0.086386,0.087244,0.078686,0.074284,0.066375,0.057317],"unified_progress":[0.066531,0.096812,0.091437,0.090582,0.092124,0.092709,0.088909,0.091446,0.085723,0.081042,0.069231,0.053455]},{"section":6,"text":"The chest X-ray showing multiple opacities with cavitation is a big clue.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.046593,0.095805,0.10115,0.099008,0.093927,0.094609,0.090813,0.08697,0.093823,0.074131,0.066576,0.056594],"unified_progress":[0.045733,0.083587,0.094013,0.10369,0.10487,0.099694,0.095687,0.090758,0.096539,0.074901,0.061837,0.048691]},{"section":7,"text":"Cavitated lung lesions can be seen in infections like tuberculosis, fungal infections, or even some malignancies.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.029558,0.067862,0.083351,0.093677,0.099041,0.10111,0.10214,0.097878,0.095489,0.089887,0.077803,0.062205],"unified_progress":[0.036416,0.0676,0.084083,0.094088,0.099777,0.1048,0.10189,0.099004,0.0962,0.089425,0.072761,0.053959]},{"section":8,"text":"However, combined with the renal findings, I should consider vasculitis.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.034325,0.075994,0.09557,0.10137,0.098431,0.092279,0.091479,0.087945,0.084856,0.091295,0.076096,0.070363],"unified_progress":[0.037679,0.068723,0.081645,0.094536,0.096619,0.095512,0.099828,0.096237,0.093167,0.095884,0.079254,0.060916]},{"section":9,"text":"The combination of renal and pulmonary symptoms makes me think of ANCA-associated vasculitis, like granulomatosis with polyangiitis (GPA, formerly Wegener's).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031395,0.064759,0.079308,0.093083,0.10235,0.10387,0.1037,0.096988,0.088544,0.089426,0.07514,0.071441],"unified_progress":[0.037796,0.057005,0.076286,0.087194,0.096158,0.10919,0.10319,0.10199,0.096674,0.092103,0.077435,0.064974]},{"section":10,"text":"GPA typically presents with upper and lower respiratory tract involvement, renal disease, and can have granulomas and necrosis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.025746,0.058746,0.074017,0.088443,0.099358,0.10455,0.10782,0.10197,0.095071,0.097105,0.079735,0.067442],"unified_progress":[0.034114,0.053565,0.074177,0.087229,0.095742,0.10634,0.10604,0.10527,0.10181,0.097916,0.079094,0.058706]},{"section":11,"text":"The cavitary lung lesions are classic for GPA.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.029006,0.065977,0.08018,0.089343,0.093626,0.097317,0.099299,0.096125,0.098683,0.09191,0.082957,0.075579],"unified_progress":[0.032974,0.061919,0.079518,0.091494,0.098843,0.10123,0.1006,0.099032,0.099699,0.091181,0.078476,0.065037]},{"section":12,"text":"The chronic cold-like nasal symptoms might indicate chronic sinusitis, which is common in GPA.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.031695,0.067881,0.07817,0.086315,0.093059,0.099409,0.10028,0.098909,0.096806,0.093109,0.083134,0.071236],"unified_progress":[0.043536,0.071729,0.080473,0.087785,0.093343,0.099306,0.097803,0.098024,0.095953,0.090442,0.078595,0.063012]},{"section":13,"text":"The renal biopsy findings of crescentic glomerulonephritis without immune complex deposition (pauci-immune) would support ANCA vasculitis.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031092,0.067513,0.080461,0.089311,0.093953,0.096971,0.099339,0.095624,0.097436,0.090204,0.082612,0.075484],"unified_progress":[0.036177,0.065141,0.082941,0.092241,0.098812,0.10249,0.10052,0.096718,0.096513,0.086849,0.076807,0.064792]},{"section":14,"text":"The presence of c-ANCA (PR3-ANCA) is often seen in GPA.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.035727,0.073306,0.087418,0.094785,0.097529,0.096928,0.098792,0.094442,0.089338,0.086225,0.077642,0.067869],"unified_progress":[0.041085,0.071169,0.087493,0.095363,0.10111,0.10295,0.10274,0.094795,0.089482,0.082337,0.072642,0.058836]},{"section":15,"text":"Other possibilities to rule out: TB could cause cavitary lesions and maybe glomerulonephritis as a complication, but the crescentic pattern is less typical.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025523,0.058421,0.073174,0.084395,0.09247,0.097844,0.10312,0.10214,0.10078,0.097716,0.090017,0.0744],"unified_progress":[0.031655,0.056638,0.073719,0.083358,0.093339,0.099411,0.10023,0.10295,0.1021,0.10268,0.087851,0.066061]},{"section":16,"text":"Also, the combination of sinus issues and vasculitis points more towards GPA.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02319,0.054202,0.069467,0.080286,0.088529,0.09458,0.10085,0.10262,0.10339,0.10324,0.097468,0.082181],"unified_progress":[0.033103,0.05795,0.071014,0.080807,0.089604,0.094979,0.099086,0.10276,0.10324,0.10585,0.092385,0.069229]},{"section":17,"text":"The anti-GBM disease usually has linear deposits on immunofluorescence, and might present with rapidly declining renal function and pulmonary hemorrhage, but the cavitary lung lesions are more suggestive of granulomatous disease.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.022949,0.055152,0.069856,0.08189,0.090931,0.097526,0.10381,0.10349,0.10336,0.10044,0.092589,0.077996],"unified_progress":[0.027492,0.05462,0.072966,0.083951,0.09382,0.10148,0.10252,0.10477,0.10462,0.10205,0.087194,0.064524]},{"section":18,"text":"Putting it all together: RPGN with pulmonary cavitary lesions and sinus symptoms.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.023844,0.053385,0.067047,0.076625,0.084256,0.0907,0.095743,0.09746,0.10409,0.10309,0.10425,0.099509],"unified_progress":[0.030455,0.050945,0.065369,0.076831,0.086611,0.095912,0.097801,0.10079,0.10525,0.10301,0.10005,0.086967]},{"section":19,"text":"Most likely diagnosis is Granulomatosis with Polyangiitis (Wegener's).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.023866,0.049418,0.060687,0.072586,0.083134,0.090163,0.096114,0.09671,0.097928,0.10087,0.10154,0.12699],"unified_progress":[0.027402,0.041405,0.056396,0.067097,0.075135,0.09005,0.091627,0.099061,0.1029,0.1039,0.11478,0.13025]}]}}