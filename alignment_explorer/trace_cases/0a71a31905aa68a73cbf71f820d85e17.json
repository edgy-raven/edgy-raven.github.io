83,0.099412,0.094679,0.092987,0.07717,0.057803]},{"section":8,"text":"One of them is called hereditary angioedema (HAE).","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.027392,0.05268,0.068271,0.080481,0.093833,0.10091,0.11228,0.11423,0.10672,0.097229,0.080619,0.065354],"unified_progress":[0.028934,0.057197,0.081068,0.093744,0.10105,0.11261,0.10827,0.10534,0.098147,0.091201,0.070958,0.051494]},{"section":9,"text":"HAE is a condition where there's swelling in various parts of the body due to fluid leakage from blood vessels.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.044259,0.063007,0.074297,0.08457,0.092996,0.097468,0.1049,0.10465,0.099366,0.089043,0.078573,0.066868],"unified_progress":[0.039278,0.064993,0.08258,0.09479,0.1013,0.10549,0.10354,0.10073,0.097384,0.08628,0.070234,0.053409]},{"section":10,"text":"It's caused by a deficiency of C1 inhibitor, which leads to the activation of the complement system and the release of bradykinin, causing vasodilation and increased permeability of blood vessels.","dimension":1,"group":7,"is_degenerate":false,"model_progress":[0.048559,0.059353,0.072642,0.082673,0.092704,0.097288,0.10268,0.10262,0.099266,0.090069,0.081159,0.070986],"unified_progress":[0.04201,0.064836,0.081651,0.091117,0.098452,0.10389,0.10127,0.097901,0.095321,0.08654,0.07578,0.061223]},{"section":11,"text":"In this case, the patient has shortness of breath and wheezing.","dimension":14,"group":5,"is_degenerate":false,"model_progress":[0.045879,0.08159,0.078733,0.074192,0.080598,0.082646,0.085719,0.089453,0.089822,0.088285,0.099228,0.10386],"unified_progress":[0.07705,0.10779,0.093095,0.087823,0.085958,0.087025,0.083774,0.087387,0.080835,0.077023,0.070485,0.061759]},{"section":12,"text":"Those symptoms could be due to angioedema in the airways.","dimension":17,"group":6,"is_degenerate":false,"model_progress":[0.040783,0.065888,0.07786,0.087308,0.089384,0.091882,0.095837,0.096923,0.096166,0.091698,0.086984,0.079287],"unified_progress":[0.050952,0.076515,0.087601,0.093925,0.094776,0.095492,0.094014,0.093738,0.091266,0.085035,0.075044,0.061641]},{"section":13,"text":"When the airways swell, it can obstruct airflow, leading to wheezing and difficulty breathing.","dimension":14,"group":5,"is_degenerate":false,"model_progress":[0.049674,0.066859,0.076275,0.080704,0.08784,0.090891,0.095175,0.096744,0.095767,0.088952,0.088654,0.082464],"unified_progress":[0.064902,0.088862,0.089834,0.090698,0.092738,0.095378,0.09165,0.092792,0.08776,0.081227,0.069821,0.054337]},{"section":14,"text":"So, recurrent episodes of this would align with HAE.","dimension":12,"group":4,"is_degenerate":false,"model_progress":[0.039854,0.060122,0.072171,0.080119,0.085894,0.0897,0.093698,0.096478,0.097057,0.09791,0.094879,0.092117],"unified_progress":[0.040438,0.063142,0.077044,0.084908,0.089564,0.093945,0.094838,0.09609,0.094322,0.094747,0.08938,0.081583]},{"section":15,"text":"I should also consider other possibilities, but C1 inhibitor deficiency is pretty specific.","dimension":6,"group":8,"is_degenerate":false,"model_progress":[0.025452,0.050581,0.070875,0.079677,0.091794,0.096912,0.095633,0.099242,0.097635,0.11233,0.095248,0.08462],"unified_progress":[0.031655,0.064409,0.078089,0.093465,0.094743,0.094604,0.10058,0.096856,0.094968,0.10084,0.084879,0.064911]},{"section":16,"text":"Other causes of wheezing include asthma, but that's usually not associated with complement deficiencies.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.026222,0.047555,0.064888,0.076848,0.08944,0.097356,0.10625,0.11051,0.11005,0.10489,0.092315,0.073678],"unified_progress":[0.034695,0.05953,0.075777,0.085728,0.095436,0.10424,0.1023,0.10369,0.099563,0.097113,0.080199,0.061739]},{"section":17,"text":"Anaphylaxis is another possibility, but it's typically acute and involves other symptoms like hives, and it's not due to a chronic deficiency.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.027122,