32]},{"section":8,"text":"The M spike is present but small.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.045947,0.090018,0.099485,0.099884,0.096938,0.094022,0.093345,0.089445,0.084409,0.078017,0.071011,0.05748],"unified_progress":[0.055137,0.083501,0.093669,0.097781,0.10244,0.097622,0.09691,0.091429,0.085725,0.078282,0.067123,0.050378]},{"section":9,"text":"So putting this together: monoclonal plasma cells in a bone lesion, but low plasma cell percentage in the marrow, and only a single lesion.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.046195,0.086617,0.095568,0.097796,0.095271,0.092485,0.090882,0.086758,0.086242,0.080872,0.073189,0.068125],"unified_progress":[0.050393,0.074774,0.087211,0.095783,0.099341,0.09787,0.098634,0.091613,0.089278,0.081661,0.072502,0.060941]},{"section":10,"text":"Oh right, there's also the term \"plasmacytoma.\"","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.050568,0.084576,0.090769,0.09427,0.09429,0.091834,0.090656,0.088079,0.085034,0.084026,0.074605,0.071293],"unified_progress":[0.063052,0.069822,0.081822,0.091294,0.094842,0.095847,0.095693,0.093218,0.089511,0.085547,0.075239,0.064112]},{"section":11,"text":"Solitary plasmacytoma presents as a single plasma cell tumor, either in bone (which would be this case) or extramedullary.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.036852,0.07262,0.08346,0.093618,0.099528,0.10134,0.10084,0.0945,0.088859,0.085945,0.073123,0.069306],"unified_progress":[0.039376,0.061837,0.083596,0.092671,0.097897,0.10693,0.10156,0.098577,0.094417,0.08678,0.073482,0.062882]},{"section":12,"text":"The key points are the solitary lesion and the absence of other myeloma features like high plasma cell percentage, anemia, renal issues, or other bone lesions.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032679,0.069831,0.081779,0.089516,0.094651,0.097756,0.1,0.097064,0.092929,0.091244,0.081302,0.071244],"unified_