e":false,"model_progress":[0.043011,0.080949,0.094899,0.10408,0.10546,0.099974,0.095695,0.087184,0.079414,0.079233,0.065432,0.064661],"unified_progress":[0.045521,0.062712,0.08223,0.095137,0.099259,0.10551,0.10024,0.096832,0.091769,0.086956,0.071868,0.061963]},{"section":10,"text":"These tumors often have cystic components and enhance with contrast.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034816,0.073782,0.088163,0.097873,0.10155,0.10127,0.10064,0.093322,0.088958,0.084672,0.071477,0.063475],"unified_progress":[0.045072,0.064405,0.082785,0.095305,0.10025,0.10468,0.10109,0.097979,0.094149,0.086168,0.070756,0.057373]},{"section":11,"text":"The location in the cerebellum is also a common site for pilocytic astrocytomas, especially in younger patients.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037193,0.075256,0.088218,0.096438,0.098753,0.098707,0.097068,0.091491,0.087609,0.08694,0.072749,0.06958],"unified_progress":[0.046141,0.069874,0.083274,0.093208,0.096644,0.10146,0.097853,0.095779,0.092044,0.086416,0.073803,0.0635]},{"section":12,"text":"Another possibility could be a hemangioblastoma, which can also present with cystic components.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030938,0.066867,0.082052,0.093365,0.10019,0.10137,0.10238,0.097569,0.092656,0.091185,0.076354,0.06508],"unified_progress":[0.03499,0.062738,0.083829,0.095894,0.10043,0.10702,0.10401,0.10021,0.095672,0.089333,0.071588,0.054285]},{"section":13,"text":"But hemangioblastomas typically don't have mural nodules as prominently as pilocytic astrocytomas.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030456,0.064168,0.077676,0.090448,0.099129,0.10247,0.10448,0.099123,0.092247,0.093065,0.077027,0.069717],"unified_progress":[0.034657,0.057032,0.077181,0.090335,0.097536,0.1076,0.10467,0.10288,0.098079,0.092667,0.076341,0.061031]},{"section":14,"text":"They might have a more vascular appearance and can be associated with von Hippel-Lindau disease.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.023976,0.057838,0.07466,0.089098,0.09933,0.10462,0.10782,0.103,0.096708,0.098129,0.079961,0.06486],"unified_progress":[0.02984,0.058277,0.077781,0.090624,0.09811,0.10689,0.10587,0.10555,0.10088,0.097965,0.075301,0.052911]},{"section":15,"text":"A metastasis is less likely here because the patient is 35 and there's no mention of a primary cancer.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.027264,0.061798,0.074911,0.083821,0.091191,0.1002,0.10208,0.10357,0.10183,0.098475,0.088922,0.06594],"unified_progress":[0.054649,0.086402,0.085412,0.086098,0.091328,0.092049,0.092812,0.097545,0.093978,0.094706,0.074333,0.050686]},{"section":16,"text":"Plus, metastases usually don't have mural nodules in the same way.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023336,0.056071,0.071263,0.082282,0.089459,0.095154,0.10355,0.10421,0.10718,0.10192,0.093846,0.071733],"unified_progress":[0.031865,0.059283,0.076352,0.08552,0.096395,0.098854,0.10171,0.10399,0.10501,0.10279,0.083476,0.054747]},{"section":17,"text":"Cysts like arachnoid cysts are usually non-enhancing and don't have mural nodules.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.026258,0.061813,0.076111,0.086955,0.093003,0.0982,0.10226,0.10081,0.10439,0.095429,0.085307,0.06947],"unified_progress":[0.031193,0.061227,0.080495,0.093129,0.10077,0.10509,0.1034,0.1025,0.10285,0.092594,0.074676,0.052079]},{"section":18,"text":"A dermoid or epidermoid might have different imaging characteristics, maybe more T2 hyperintensity and not enhancing as much.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024922,0.05937,0.074272,0.085681,0.09292,0.098269,0.1041,0.1034,0.10356,0.098219,0.087601,0.067686],"unified_progress":[0.029624,0.059573,0.07835,0.090065,0.09943,0.10439,0.10404,0.10454,0.10264,0.098877,0.076849,0.051612]},{"section":19,"text":"The combination of the cystic component with a enhancing nodule in the cerebellum in a younger patient really points towards pilocytic astrocytoma.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031358,0.06561,0.078304,0.086636,0.090106,0.092907,0.094791,0.093058,0.098471,0.093914,0.088456,0.086389],"unified_progress":[0.038003,0.059044,0.074922,0.087457,0.094366,0.098835,0.099414,0.097719,0.099728,0.091586,0.084749,0.074178]},{"section":20,"text":"The enhancement and the location all align with that.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.029816,0.067586,0.086839,0.093565,0.093375,0.090012,0.091766,0.08992,0.090551,0.095472,0.086476,0.084623],"unified_progress":[0.042689,0.060935,0.073651,0.085338,0.090364,0.091841,0.095034,0.096251,0.096492,0.099591,0.089934,0.077879]},{"section":21,"text":"I think that's the most likely diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028575,0.058199,0.072118,0.078739,0.081796,0.08254,0.085818,0.087884,0.092232,0.09631,0.10002,0.13577],"unified_progress":[0.029117,0.043553,0.053316,0.063759,0.068105,0.076151,0.080787,0.088603,0.098281,0.10734,0.13107,0.15993]}]}}