652]},{"section":14,"text":"But in OI, you might see blue sclera, hearing loss, or family history.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027487,0.062461,0.07695,0.088655,0.0972,0.1022,0.10592,0.10278,0.096668,0.095558,0.081378,0.062738],"unified_progress":[0.039082,0.062994,0.08138,0.090083,0.097865,0.10267,0.10262,0.103,0.098116,0.097339,0.074427,0.050425]},{"section":15,"text":"The case doesn't mention those.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31157,0.051203,0.052494,0.061599,0.063117,0.064537,0.062665,0.071211,0.07124,0.06655,0.069542,0.054277],"unified_progress":[0.20623,0.07833,0.065289,0.065463,0.075361,0.074896,0.098695,0.084151,0.080459,0.063411,0.056266,0.051453]},{"section":16,"text":"Also, OI fractures can heal with callus, but the presence of different healing stages and the social history (alcoholic father) makes me think abuse is more likely.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.053628,0.11064,0.063138,0.099938,0.098308,0.096936,0.092256,0.087933,0.08241,0.077966,0.072007,0.064842],"unified_progress":[0.070627,0.098043,0.067432,0.090958,0.094274,0.095873,0.091749,0.090421,0.086084,0.081716,0.073151,0.05967]},{"section":17,"text":"The social history is important.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.040426,0.077289,0.091785,0.095744,0.096554,0.09419,0.091777,0.088908,0.086289,0.087628,0.07814,0.071271],"unified_progress":[0.059543,0.081539,0.084167,0.090761,0.091468,0.091768,0.092552,0.091474,0.08726,0.088774,0.077739,0.062953]},{"section":18,"text":"An alcoholic parent might be more prone to neglect or abuse.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.039301,0.074399,0.081631,0.088241,0.094727,0.10275,0.098814,0.097578,0.091745,0.089011,0.078671,0.063129],"unified_progress":[0.10113,0.10969,0.09387,0.087106,0.084167,0.086191,0.081654,0.087091,0.076958,0.073356,0.06527,0.053513]},{"section":19,"text":"The mother's explanation (falling off stairs) might not fit the severity or number of injuries.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.050753,0.089829,0.087335,0.086108,0.088223,0.094829,0.091797,0.095807,0.088262,0.084186,0.076275,0.066596],"unified_progress":[0.075324,0.094341,0.091338,0.091187,0.089385,0.091612,0.086421,0.090046,0.083,0.0789,0.06997,0.058477]},{"section":20,"text":"For a 3-year-old, falls usually don't cause multiple fractures unless they're severe.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.044791,0.082491,0.085875,0.088847,0.092845,0.097967,0.096587,0.096246,0.089808,0.08551,0.076459,0.062574],"unified_progress":[0.092762,0.085627,0.086696,0.087679,0.089562,0.091679,0.088544,0.091035,0.083501,0.080381,0.068393,0.054141]},{"section":21,"text":"The combination of findings points more towards physical abuse rather than an accident or a bone disorder.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.037009,0.075899,0.089241,0.094179,0.094356,0.092541,0.093092,0.090874,0.087995,0.090072,0.079235,0.075505],"unified_progress":[0.042274,0.070108,0.080799,0.091444,0.09323,0.094046,0.094999,0.093141,0.091857,0.093537,0.083093,0.071474]},{"section":22,"text":"So, the most likely diagnosis here is non-accidental trauma, which is part of child abuse.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.034848,0.06253,0.070793,0.076119,0.079501,0.081309,0.0848,0.086653,0.089745,0.093878,0.098442,0.14138],"unified_progress":[0.03616,0.04489,0.05382,0.063701,0.068178,0.078024,0.080912,0.088643,0.09635,0.10326,0.12734,0.15872]},{"section":23,"text":"The term for this in medical terms is Child Abuse, specifically physical abuse leading to fractures.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.031244,0.05936,0.067284,0.072671,0.077293,0.081196,0.085851,0.088819,0.093026,0.097902,0.10258,0.14277],"unified_progress":[0.02784,0.040662,0.048985,0.057561,0.063082,0.073