":true,"model_progress":[0.32929,0.060028,0.46848,0.027603,0.022524,0.019388,0.015274,0.014883,0.013284,0.011493,0.010092,0.0076579],"unified_progress":[0.20449,0.054865,0.55554,0.036107,0.030277,0.026363,0.022121,0.020164,0.017076,0.012842,0.010636,0.0095121]},{"section":2,"text":"The patient is a 30-year-old man who has been suspicious for two months that his wife is having an affair with his boss and that his friend is involved from abroad using technology.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.16633,0.31586,0.077552,0.11491,0.067557,0.06748,0.046854,0.038882,0.032387,0.027646,0.023584,0.020957],"unified_progress":[0.20052,0.17793,0.089075,0.11604,0.082589,0.086548,0.059504,0.051524,0.044066,0.037319,0.031252,0.023631]},{"section":3,"text":"He believes people are talking ill about him.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.12641,0.21239,0.15742,0.085468,0.072426,0.080144,0.056719,0.066209,0.043545,0.038309,0.032427,0.028536],"unified_progress":[0.11449,0.14914,0.12279,0.10072,0.084968,0.089343,0.069782,0.08011,0.057571,0.051418,0.043948,0.035719]},{"section":4,"text":"His friends tried to convince him otherwise, but he remains unconvinced.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.11384,0.18736,0.14811,0.095618,0.074586,0.080054,0.06172,0.071828,0.050557,0.044899,0.037988,0.033444],"unified_progress":[0.10416,0.13691,0.1113,0.10618,0.085922,0.088546,0.073695,0.081539,0.063863,0.058801,0.049423,0.039661]},{"section":5,"text":"Otherwise, he's functioning normally without thought disorder or inappropriate behavior.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.11644,0.19324,0.14974,0.094416,0.071431,0.080992,0.058966,0.072348,0.049673,0.0435,0.037061,0.032194],"unified_progress":[0.10221,0.1385,0.11009,0.1043,0.085098,0.089905,0.073156,0.083316,0.065407,0.058264,0.050271,0.039474]},{"section":6,"text":"Hmm, so the key points here are the persistent, unfounded 