83865,0.077261]},{"section":11,"text":"The beliefs here are plausible but untrue\u2014like infidelity and people conspiring, which are considered non-bizarre.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.050577,0.087754,0.088657,0.089751,0.091442,0.092871,0.091843,0.091084,0.084408,0.085053,0.074858,0.071703],"unified_progress":[0.057282,0.071502,0.079006,0.084796,0.088633,0.09365,0.092858,0.095633,0.092155,0.091107,0.081934,0.071444]},{"section":12,"text":"The patient is otherwise functioning normally, which fits because in delusional disorder, aside from the delusions, other mental functions are intact.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.047468,0.085302,0.086263,0.086007,0.087538,0.090343,0.090259,0.091319,0.086315,0.085911,0.080262,0.083014],"unified_progress":[0.049527,0.069372,0.075123,0.079861,0.083718,0.089399,0.08926,0.093734,0.092536,0.093887,0.092802,0.090781]},{"section":13,"text":"Unlike schizophrenia, there's no hallucinations, disorganized speech, or negative symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.03936,0.076894,0.082678,0.086076,0.090032,0.093737,0.0966,0.09724,0.092721,0.090244,0.083156,0.071263],"unified_progress":[0.040331,0.067277,0.078013,0.083634,0.090411,0.095166,0.096145,0.099549,0.097684,0.098559,0.085951,0.067279]},{"section":14,"text":"Another possibility could be paranoia related to another condition, but since there's no mention of other psychotic symptoms, delusional disorder seems more likely.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.031086,0.063599,0.076746,0.084107,0.088446,0.089967,0.094016,0.095347,0.094549,0.097138,0.091378,0.093622],"unified_progress":[0.033468,0.055686,0.068478,0.079427,0.084633,0.088971,0.093771,0.096928,0.097512,0.10281,0.10045,0.097868]},{"section":15,"text":"Paranoid personality disorder might have similar traits, but that's more about a pervasive distrust and suspicion that's been long-standing, not a sudden two-month onset of specific delusions.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.032849,0.064659,0.073002,0.081108,0.088774,0.094385,0.098928,0.10033,0.09725,0.097879,0.090246,0.080587],"unified_progress":[0.037639,0.056211,0.068744,0.077294,0.086283,0.09382,0.096791,0.10247,0.10231,0.10562,0.094484,0.078326]},{"section":16,"text":"Also, personality disorders develop earlier and are more ingrained.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027146,0.058656,0.070663,0.079554,0.087473,0.094379,0.10019,0.10292,0.1019,0.1013,0.095,0.080814],"unified_progress":[0.03455,0.058983,0.069848,0.077945,0.086306,0.091548,0.096303,0.10238,0.10258,0.10922,0.095041,0.075293]},{"section":17,"text":"So putting it all together: persistent, specific, non-bizarre delusions without other psychotic symptoms or thought disorder.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.035221,0.06371,0.070304,0.076227,0.081545,0.085683,0.090246,0.092954,0.094672,0.097899,0.097985,0.11355],"unified_progress":[0.041895,0.051889,0.06106,0.069863,0.076245,0.084087,0.088105,0.093259,0.096715,0.10177,0.11154,0.12357]},{"section":18,"text":"That points to delusional disorder, paranoid type.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.027014,0.049344,0.057758,0.065602,0.073056,0.078689,0.085683,0.08983,0.096326,0.10191,0.1114,0.16338],"unified_progress":[0.027615,0.034872,0.044481,0.053589,0.059428,0.071292,0.075426,0.087732,0.098837,0.10849,0.14285,0.19539]}]}}