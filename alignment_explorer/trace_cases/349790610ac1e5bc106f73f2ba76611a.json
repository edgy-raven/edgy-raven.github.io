_degenerate":false,"model_progress":[0.047895,0.059967,0.066384,0.073459,0.079763,0.085209,0.090695,0.093156,0.099614,0.10844,0.11095,0.084473],"unified_progress":[0.05049,0.06677,0.07547,0.082323,0.089296,0.094761,0.094598,0.09625,0.095783,0.093536,0.087549,0.073174]},{"section":10,"text":"Xeroderma pigmentosum is known for causing lots of skin issues after sun exposure because people with this condition can't fix the DNA damage caused by UV rays properly.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.032312,0.04131,0.053742,0.067918,0.082097,0.095537,0.10805,0.11248,0.11973,0.12971,0.10131,0.055798],"unified_progress":[0.036977,0.055989,0.078235,0.086206,0.094051,0.10586,0.10293,0.10235,0.097853,0.093279,0.079804,0.066463]},{"section":11,"text":"So, yeah, that fits pretty well.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.10635,0.086327,0.080925,0.073748,0.075603,0.07892,0.082627,0.092168,0.083455,0.058057,0.06171,0.12011],"unified_progress":[0.19947,0.075928,0.062685,0.063824,0.073158,0.073042,0.10618,0.082809,0.080476,0.064284,0.060121,0.058015]},{"section":12,"text":"Also, there's something else to consider.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.027415,0.064231,0.091419,0.1012,0.10322,0.10325,0.10115,0.099925,0.096852,0.094323,0.075024,0.041996],"unified_progress":[0.046461,0.094117,0.072886,0.093357,0.099386,0.095393,0.09216,0.095338,0.090239,0.08619,0.077056,0.057416]},{"section":13,"text":"People with xeroderma pigmentosum don't just have skin problems; they also have an increased risk of developing cancers, especially skin cancer.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.040668,0.048982,0.062261,0.076552,0.089221,0.099381,0.10805,0.10951,0.11225,0.11528,0.088738,0.049106],"unified_progress":[0.044467,0.063441,0.079497,0.088469,0.095608,0.10597,0.09997,0.099343,0.094713,0.089869,0.075846,0.062804]},{"section":14,"text":"So if this kid has a bunch of skin lesion