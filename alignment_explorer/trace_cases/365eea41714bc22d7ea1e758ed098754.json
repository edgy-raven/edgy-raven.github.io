_progress":[0.098223,0.099597,0.10511,0.10521,0.098032,0.093508,0.084964,0.083657,0.069596,0.066291,0.053087,0.042722]},{"section":4,"text":"Now, the skin lesions described are pruritic, grouped papules or vesicles on elbows, knees, sacrum, and shoulders.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.1168,0.183,0.13191,0.093846,0.078063,0.080568,0.065566,0.072245,0.053356,0.047837,0.040683,0.036127],"unified_progress":[0.10058,0.13316,0.111,0.094862,0.087647,0.088278,0.077097,0.08444,0.068244,0.061005,0.052159,0.041527]},{"section":5,"text":"The key points here are the distribution (extensor surfaces) and the fact that scratching the vesicles relieves the itching.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.098183,0.16341,0.13687,0.1002,0.082224,0.083159,0.067734,0.072821,0.057579,0.05377,0.044349,0.039696],"unified_progress":[0.087414,0.11819,0.10405,0.10194,0.090218,0.091664,0.081014,0.08489,0.073368,0.067283,0.055807,0.044168]},{"section":6,"text":"Hmm, I remember that dermatitis herpetiformis is associated with celiac disease.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.052836,0.090507,0.10397,0.11069,0.10753,0.096985,0.092808,0.082663,0.072865,0.074401,0.058832,0.055913],"unified_progress":[0.054015,0.067862,0.093896,0.096632,0.098755,0.1051,0.0984,0.092129,0.08483,0.083928,0.067931,0.056518]},{"section":7,"text":"It's an autoimmune blistering skin disease.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034454,0.071938,0.0882,0.10087,0.10733,0.10546,0.10324,0.093421,0.082991,0.085081,0.066496,0.060518],"unified_progress":[0.034434,0.059766,0.083105,0.095127,0.10012,0.10849,0.10479,0.10102,0.09472,0.08936,0.071957,0.057121]},{"section":8,"text":"The lesions are typically very itchy, and they do appear on extensor areas like elbows, knees, etc.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.041922,0.080657,0.085475,0.091037,0.096438,0.099529,0.099505,0.095496,0.087992,0.086443,0.073118,0.062387],"unified_progress":[0.054273,0.071728,0.08193,0.089915,0.095447,0.10101,0.098873,0.098885,0.093588,0.088207,0.071645,0.054502]},{"section":9,"text":"The intense pruritus and the relief after scratching by removing the vesicle top sounds classic for DH.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.053119,0.096002,0.092708,0.089623,0.090086,0.092923,0.091337,0.090948,0.083922,0.081065,0.07209,0.066177],"unified_progress":[0.056993,0.082155,0.085237,0.087812,0.090725,0.096063,0.092719,0.094325,0.090078,0.085492,0.075873,0.062527]},{"section":10,"text":"Also, the connection to gluten sensitivity makes sense because DH is linked to celiac, even if the gut isn't symptomatic.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.042522,0.080918,0.091665,0.096093,0.096344,0.096073,0.093148,0.089608,0.084328,0.08646,0.073871,0.068969],"unified_progress":[0.056239,0.079842,0.085164,0.090175,0.091285,0.094203,0.09241,0.09268,0.087894,0.087589,0.076985,0.065535]},{"section":11,"text":"Another thought: the vesicles are grouped and papular.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.04539,0.083254,0.08747,0.089068,0.09032,0.091799,0.091393,0.091227,0.090591,0.085845,0.080587,0.073055],"unified_progress":[0.053389,0.075038,0.082921,0.089717,0.093079,0.095304,0.094027,0.093927,0.09241,0.087823,0.078245,0.064123]},{"section":12,"text":"In DH, the blisters are small and often grouped.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.036609,0.0734,0.08256,0.090212,0.096112,0.098453,0.10033,0.096784,0.092274,0.08744,0.078591,0.067237],"unified_progress":[0.070082,0.069712,0.082018,0.087686,0.093305,0.099575,0.096361,0.095596,0.090441,0.085162,0.072093,0.057968]},{"section":13,"text":"The itching is so severe that patients often scratch until they rupture, which aligns with the case here.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.053429,0.092322,0.087411,0.085582,0.08803,0.092159,0.092169,0.092927,0.086467,0.083808,0.076324,0.069371],"unified_progress":[0.065826,0.083249,0.083578,0.083857,0.087476,0.093078,0.090253,0.094115,0.089102,0.086489,0.078118,0.064858]},{"section":14,"text":"The diagnosis would be supported by a skin biopsy showing deposits of IgA in the dermal papillae.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.041132,0.08276,0.092361,0.096031,0.095402,0.095366,0.094864,0.090007,0.091545,0.080617,0.072882,0.067034],"unified_progress":[0.043188,0.074616,0.090506,0.097272,0.10137,0.10041,0.097543,0.09208,0.092796,0.079871,0.070135,0.060212]},{"section":15,"text":"Also, the patient might have anti-tTG antibodies, which are present in both celiac and DH.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.036147,0.074676,0.087985,0.094969,0.097929,0.098195,0.098262,0.093792,0.088467,0.085528,0.076242,0.067809],"unified_progress":[0.050806,0.075745,0.087076,0.093246,0.097162,0.10008,0.097841,0.093004,0.087775,0.082296,0.07329,0.061684]},{"section":16,"text":"Are there other possibilities?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31457,0.053245,0.053958,0.062711,0.063522,0.06479,0.061429,0.069521,0.069477,0.065524,0.069005,0.052249],"unified_progress":[0.21072,0.082187,0.066426,0.065361,0.074865,0.074214,0.092952,0.081166,0.077203,0.062827,0.057775,0.054305]},{"section":17,"text":"Maybe atopic dermatitis, but that's more on flexor surfaces.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028995,0.066071,0.055698,0.097066,0.10505,0.10146,0.10702,0.10414,0.097862,0.090853,0.082792,0.062991],"unified_progress":[0.041613,0.067252,0.061752,0.091519,0.10213,0.10066,0.10065,0.10727,0.10295,0.096781,0.078022,0.0494]},{"section":18,"text":"Scabies could cause itching but the distribution and vesicles don't fit.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018102,0.04785,0.063954,0.077757,0.0879,0.095772,0.10758,0.11176,0.11109,0.10827,0.10067,0.069286],"unified_progress":[0.024502,0.0521,0.068091,0.078451,0.092722,0.096674,0.10259,0.11133,0.11146,0.11913,0.091102,0.051846]},{"section":19,"text":"Pemphigus or bullous pemphigoid?","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.022752,0.054625,0.070346,0.085237,0.09689,0.10286,0.10781,0.10607,0.10001,0.099145,0.085056,0.069193],"unified_progress":[0.027346,0.055002,0.075155,0.089909,0.097394,0.10927,0.10663,0.10812,0.1032,0.097247,0.078353,0.052383]},{"section":20,"text":"Those are different; pemphigus is intraepithelial, and bullous pemphigoid is more in elderly with different locations.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.022283,0.054304,0.070864,0.086213,0.097723,0.10388,0.10899,0.1052,0.098628,0.1026,0.08268,0.066636],"unified_progress":[0.026271,0.053223,0.07457,0.089391,0.098336,0.10713,0.1083,0.10829,0.10366,0.10144,0.076795,0.052585]},{"section":21,"text":"So putting it all together: celiac disease plus the skin findings point to dermatitis herpetiformis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.031544,0.058853,0.068517,0.076395,0.081973,0.0854,0.089681,0.090905,0.093339,0.097113,0.098038,0.12824],"unified_progress":[0.036541,0.045452,0.056275,0.067964,0.073728,0.084269,0.085844,0.092919,0.095997,0.10032,0.11909,0.14161]},{"section":22,"text":"The association is well-known, and the clinical features match.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.028605,0.061048,0.077295,0.08381,0.085583,0.08518,0.088519,0.089613,0.092568,0.099121,0.097046,0.11161],"unified_progress":[0.030975,0.049582,0.059006,0.069791,0.074885,0.082161,0.08596,0.093939,0.10045,0.10939,0.11742,0.12643]}]}}