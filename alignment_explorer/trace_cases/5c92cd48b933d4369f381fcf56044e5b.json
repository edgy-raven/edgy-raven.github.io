,"model_progress":[0.15669,0.1523,0.12753,0.11118,0.078469,0.074761,0.063821,0.058976,0.053183,0.048079,0.04132,0.033698],"unified_progress":[0.074809,0.10455,0.09918,0.098987,0.094455,0.095059,0.087503,0.087733,0.079948,0.070706,0.059029,0.048042]},{"section":6,"text":"This sounds like retinitis pigmentosa (RP).","dimension":6,"group":6,"is_degenerate":false,"model_progress":[0.068156,0.10071,0.14816,0.12708,0.10184,0.10611,0.082699,0.07066,0.061334,0.051774,0.045448,0.036033],"unified_progress":[0.036977,0.062165,0.088686,0.097243,0.097825,0.10384,0.10096,0.096335,0.091106,0.086506,0.075193,0.063171]},{"section":7,"text":"Night blindness, tunnel vision, attenuated arterioles, bone spicule pigmentation, waxy optic disc pallor, ring scotomas.","dimension":16,"group":9,"is_degenerate":false,"model_progress":[0.057502,0.089629,0.11161,0.11598,0.1083,0.10361,0.091566,0.083789,0.075428,0.067129,0.056997,0.038465],"unified_progress":[0.02984,0.055694,0.073854,0.085239,0.094313,0.10443,0.10184,0.10168,0.10177,0.09618,0.086455,0.068701]},{"section":8,"text":"So diagnosis: Retinitis pigmentosa.","dimension":8,"group":0,"is_degenerate":false,"model_progress":[0.032769,0.053004,0.067841,0.084306,0.084667,0.094215,0.10436,0.10038,0.09617,0.090249,0.098051,0.093984],"unified_progress":[0.01483,0.030351,0.041372,0.052517,0.05831,0.075561,0.079233,0.095136,0.1047,0.11076,0.14659,0.19064]},{"section":9,"text":"Could also be congenital stationary night blindness?","dimension":6,"group":6,"is_degenerate":false,"model_progress":[0.041269,0.075824,0.090777,0.098409,0.098619,0.10071,0.098444,0.10067,0.093092,0.084025,0.072522,0.045642],"unified_progress":[0.020434,0.047399,0.062763,0.074575,0.0829,0.09109,0.098083,0.10631,0.11071,0.11451,0.10546,0.085763]},{"section":10,"text":"But the features of bone spicules and ring scotomas strongly suggest RP.","dimension":8,"group":0,"is_degenerate":false,"model_progress":[0.042942,0.067749,0.08137,0.089865,0.093984,0.09542,0.095722,0.097459,0.0