9]},{"section":10,"text":"That can be seen in hypertensive retinopathy or maybe other vascular issues, but combined with the pigmentation?","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034489,0.073945,0.08887,0.097412,0.10041,0.099876,0.10003,0.094701,0.090161,0.086834,0.073465,0.059816],"unified_progress":[0.038563,0.06951,0.086811,0.096634,0.10144,0.1063,0.10199,0.097766,0.09308,0.087347,0.069825,0.050726]},{"section":11,"text":"The key here is the \"bony corpuscles like spicules of pigmentation\" in the mid-peripheral retina.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.043774,0.086771,0.093405,0.097022,0.095708,0.096859,0.094202,0.089068,0.093658,0.07842,0.069262,0.06185],"unified_progress":[0.048209,0.077169,0.09197,0.10322,0.10598,0.10262,0.098738,0.092545,0.091784,0.075098,0.062174,0.050485]},{"section":12,"text":"Those spicules are classic for retinitis pigmentosa.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037573,0.076579,0.089048,0.098219,0.1014,0.10067,0.099679,0.09221,0.087938,0.082896,0.06963,0.064154],"unified_progress":[0.04032,0.066321,0.086651,0.098014,0.10173,0.11354,0.10271,0.096033,0.091282,0.081632,0.066962,0.054798]},{"section":13,"text":"Also, ring scotomas on perimetry\u2014usually in RP, you get a constriction of the visual field leading to tubular vision, which matches the tubular vision mentioned.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.046873,0.088151,0.08996,0.091975,0.093768,0.096038,0.095023,0.091658,0.087688,0.081348,0.072099,0.065418],"unified_progress":[0.052487,0.07835,0.087371,0.094026,0.097762,0.10086,0.096479,0.094244,0.090196,0.080769,0.069512,0.057942]},{"section":14,"text":"But ring scotomas are sometimes associated with glaucoma.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037462,0.073707,0.084835,0.092692,0.097219,0.097968,0.099097,0.095151,0.091014,0.087173,0.07649,0.067193],"unified_progress":[0.044041,0.06