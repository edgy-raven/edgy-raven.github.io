3,0.094387,0.097798,0.10095,0.097168,0.093428,0.090244,0.083246,0.07009,0.058677]},{"section":12,"text":"The hilar lymphadenopathy is also a common finding.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.034541,0.074215,0.087017,0.09407,0.095736,0.096757,0.097506,0.093265,0.093375,0.087805,0.077078,0.068637],"unified_progress":[0.039338,0.068981,0.085286,0.095978,0.101,0.10142,0.099098,0.095919,0.094595,0.087138,0.073077,0.058168]},{"section":13,"text":"The yeast forms inside macrophages are a key feature.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.037462,0.078548,0.093379,0.098417,0.096993,0.093261,0.09283,0.088597,0.086501,0.086742,0.075745,0.071525],"unified_progress":[0.04403,0.069932,0.08372,0.094157,0.097594,0.098184,0.098005,0.094271,0.091576,0.088303,0.076364,0.063864]},{"section":14,"text":"In histoplasmosis, the yeast is usually 2-4 microns, which fits the \"tiny\" description.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.043065,0.081975,0.090372,0.095349,0.097179,0.096414,0.095493,0.090925,0.085703,0.082588,0.072599,0.068338],"unified_progress":[0.046911,0.071545,0.085267,0.093372,0.097554,0.10183,0.098468,0.094726,0.090105,0.084019,0.073461,0.06274]},{"section":15,"text":"Another possibility could be cryptococcosis, but that's more common in immunocompromised patients, and the case doesn't mention HIV or other immune issues.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028924,0.064299,0.078889,0.088544,0.095141,0.10028,0.10236,0.10123,0.096894,0.095233,0.084229,0.063983],"unified_progress":[0.044073,0.075507,0.083058,0.088103,0.094151,0.097016,0.096999,0.10001,0.095249,0.096374,0.076626,0.05283]},{"section":16,"text":"Also, cryptococcus might present with different symptoms like meningitis.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018227,0.049169,0.066452,0.079222,0.08891,0.096173,0.10751,0.1103,0.10891,0.10747,0.099273,0.068384],"unified_progress":[0.0256,0.053721,0.07137,0.080653,0.094066,0.098065,0.10328,0.10971,0.10858,0.11464,0.088915,0.051399]},{"section":17,"text":"Blastomycosis is another fungal infection that can cause pulmonary lesions and yeast forms, but the location (hilar lymphadenopathy) and the farming exposure still lean towards histoplasmosis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.024223,0.056658,0.071373,0.083388,0.091498,0.097436,0.10288,0.1029,0.103,0.10053,0.090422,0.075697],"unified_progress":[0.031071,0.056546,0.073565,0.0862,0.094435,0.10213,0.10335,0.10501,0.10436,0.10035,0.083651,0.059347]},{"section":18,"text":"Tuberculosis can cause granulomas and lymphadenopathy, but the acid-fast bacilli wouldn't be yeast forms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02578,0.059639,0.073963,0.085087,0.092653,0.097909,0.10333,0.10218,0.10133,0.098357,0.088148,0.071625],"unified_progress":[0.030355,0.058765,0.077069,0.088558,0.097373,0.10335,0.10348,0.10408,0.10234,0.098759,0.079683,0.056194]},{"section":19,"text":"So that's probably not it.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30677,0.050454,0.05176,0.060989,0.062176,0.064661,0.062837,0.072208,0.072611,0.068081,0.071498,0.055957],"unified_progress":[0.19989,0.075277,0.065586,0.065586,0.075347,0.075545,0.095397,0.085589,0.081972,0.065343,0.058629,0.055834]},{"section":20,"text":"So putting it all together: farmer exposed to soil/bird droppings, chronic cough, mass with lymph nodes on X-ray, and yeast in macrophages.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.037888,0.081118,0.056293,0.091223,0.095166,0.093903,0.096036,0.09296,0.092083,0.092541,0.088599,0.082191],"unified_progress":[0.048057,0.072701,0.059382,0.083305,0.092817,0.093535,0.10388,0.095674,0.094126,0.093009,0.08848,0.075029]},{"section":21,"text":"The most likely diagnosis is histoplasmosis, specifically chronic pulmonary histoplasmosis or possibly disseminated, but giv