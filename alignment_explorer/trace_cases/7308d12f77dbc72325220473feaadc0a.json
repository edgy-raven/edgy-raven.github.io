15,0.062656],"unified_progress":[0.05746,0.076735,0.085333,0.093462,0.095569,0.092497,0.094708,0.09234,0.087788,0.089532,0.074541,0.060036]},{"section":7,"text":"The uterosacral ligament involvement with nodularity and tenderness is a big clue.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.043431,0.090376,0.10286,0.10579,0.099832,0.095758,0.090785,0.083464,0.08497,0.074852,0.065723,0.062161],"unified_progress":[0.040977,0.074297,0.091657,0.10886,0.10522,0.10148,0.097717,0.090797,0.0901,0.077772,0.064778,0.056349]},{"section":8,"text":"The posterior cul-de-sac issues and adnexal masses...","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.038588,0.086728,0.098888,0.10452,0.10024,0.099167,0.094271,0.086121,0.092837,0.075287,0.065061,0.058293],"unified_progress":[0.037374,0.075271,0.095103,0.11084,0.11359,0.10466,0.10186,0.092139,0.0921,0.071705,0.057011,0.048347]},{"section":9,"text":"Wait, endometriosis comes to mind.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.040553,0.081846,0.10049,0.10434,0.10085,0.092266,0.089778,0.084537,0.080067,0.085616,0.069805,0.06985],"unified_progress":[0.045653,0.07068,0.085126,0.096535,0.09719,0.096896,0.09659,0.092409,0.087786,0.089902,0.075555,0.065677]},{"section":10,"text":"Let me think through the symptoms again.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.030634,0.06254,0.080534,0.090211,0.09768,0.098823,0.098128,0.096488,0.097024,0.090279,0.083436,0.074222],"unified_progress":[0.041574,0.074037,0.087237,0.10197,0.098685,0.093643,0.096131,0.091438,0.087429,0.093685,0.075292,0.058882]},{"section":11,"text":"Endometriosis is when endometrial-like tissue grows outside the uterus, causing inflammation and scarring.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034068,0.068984,0.080838,0.092255,0.099523,0.1022,0.10294,0.096942,0.090301,0.089209,0.075403,0.067332],"unified_progress":[0.05223,0.064112,0.080428,0.091381,0.098181,0.10719,0.099963,0.097851,0.091496,0.086133,0.070648,0.060383]},{"section":12,"text":"It's a common cause of infertility.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035388,0.071052,0.085029,0.094098,0.098203,0.098311,0.098537,0.094081,0.088003,0.090881,0.076388,0.07003],"unified_progress":[0.050646,0.068768,0.080289,0.089205,0.093071,0.098536,0.096639,0.096976,0.092315,0.091755,0.077757,0.064043]},{"section":13,"text":"The cyclical pain aligns because endometriosis lesions can bleed with menstruation, leading to pain around periods (dysmenorrhea).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.038539,0.075857,0.082615,0.089694,0.096035,0.099655,0.10043,0.096805,0.089197,0.087899,0.07601,0.067266],"unified_progress":[0.046487,0.066366,0.079183,0.085352,0.092157,0.10103,0.098475,0.099206,0.095681,0.092161,0.080013,0.06389]},{"section":14,"text":"Dyspareunia is typical if there's involvement of the uterosacral ligaments, which are near the vagina.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.037349,0.077879,0.08752,0.094261,0.096351,0.099054,0.098586,0.093132,0.095625,0.083224,0.072925,0.064094],"unified_progress":[0.045737,0.070127,0.087011,0.096886,0.10242,0.10253,0.099711,0.095203,0.095857,0.081532,0.067743,0.055246]},{"section":15,"text":"The nodular lesions on the uterosacral ligaments are classic for endometriosis implants.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.035667,0.078923,0.090843,0.098169,0.097513,0.098793,0.096709,0.089865,0.09641,0.080918,0.070711,0.065478],"unified_progress":[0.03778,0.070597,0.090671,0.10298,0.10844,0.10568,0.10186,0.093988,0.094457,0.076199,0.062908,0.054439]},{"section":16,"text":"The cul-de-sac scarring and adnexal masses might be due to ovarian endometriomas (chocolate cysts) or adhesions from chronic inflammation.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033534,0.076603,0.089798,0.098845,0.099253,0.10088,0.098701,0.09128,0.096685,0.081187,0.070109,0.063122],"unified_progress":[0.035756,0.068964,0.090124,0.10415,0.11018,0.10791,0.10376,0.095112,0.094523,0.075966,0.061586,0.051964]},{"section":17,"text":"The vaginal fornix scarring could be from deep infiltrating endometriosis affecting that area.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033542,0.077048,0.090125,0.098889,0.099154,0.10099,0.098334,0.09117,0.097112,0.081162,0.069932,0.062542],"unified_progress":[0.035626,0.070332,0.091468,0.10543,0.11155,0.10804,0.10404,0.094857,0.093961,0.074648,0.059782,0.050264]},{"section":18,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.031153,0.071578,0.094004,0.099739,0.099541,0.093912,0.093076,0.090299,0.087588,0.091538,0.077037,0.070536],"unified_progress":[0.034601,0.071488,0.086424,0.098345,0.099027,0.093929,0.098277,0.094924,0.090468,0.094281,0.076457,0.061779]},{"section":19,"text":"Pelvic inflammatory disease (PID) could cause adnexal tenderness and infertility, but PID usually presents with more acute symptoms like fever, abnormal discharge, and maybe a history of STDs.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023224,0.05709,0.072159,0.083125,0.092063,0.097562,0.10543,0.10609,0.10293,0.10028,0.091874,0.068175],"unified_progress":[0.029147,0.056248,0.072688,0.080879,0.093796,0.09903,0.10172,0.10743,0.10562,0.10743,0.08762,0.058387]},{"section":20,"text":"The nodular lesions and specific ligament involvement aren't typical for PID.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.0224,0.055269,0.070676,0.081039,0.087817,0.094037,0.10202,0.10444,0.10743,0.10303,0.096692,0.075155],"unified_progress":[0.030003,0.055286,0.071282,0.081629,0.092461,0.096594,0.10135,0.10574,0.10744,0.10876,0.089851,0.059615]},{"section":21,"text":"Adenomyosis is when endometrial tissue invades the uterine muscle, but that's more about menorrhagia and a bulky uterus, not the pelvic findings here.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.025357,0.059856,0.074359,0.086965,0.095454,0.101,0.10502,0.10259,0.10067,0.095989,0.083764,0.068977],"unified_progress":[0.03042,0.057491,0.076966,0.0899,0.097923,0.10812,0.10511,0.10499,0.10268,0.095583,0.077095,0.053718]},{"section":22,"text":"Ovarian cysts can cause pain but not the ligament nodularity.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.025485,0.060785,0.07499,0.085636,0.092589,0.098354,0.10303,0.10169,0.10331,0.096238,0.087105,0.070793],"unified_progress":[0.031118,0.060027,0.07776,0.089336,0.098249,0.10237,0.10258,0.10282,0.10273,0.096953,0.078755,0.057302]},{"section":23,"text":"Fibroids might cause bulk symptoms but not the same pain pattern.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.01965,0.050801,0.066678,0.078699,0.088151,0.095608,0.10576,0.10918,0.10888,0.10665,0.098833,0.071099],"unified_progress":[0.02846,0.05366,0.07015,0.07995,0.0926,0.096924,0.10202,0.10879,0.10818,0.11339,0.089942,0.055929]},{"section":24,"text":"So endometriosis fits best with the given symptoms and exam findings.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.025332,0.056631,0.071612,0.078771,0.082079,0.083917,0.088489,0.090935,0.094136,0.10031,0.10027,0.12753],"unified_progress":[0.025313,0.046223,0.057018,0.068331,0.073469,0.080695,0.08934,0.092083,0.096644,0.10501,0.12104,0.14484]}]}}