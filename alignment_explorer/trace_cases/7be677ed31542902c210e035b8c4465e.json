3745,0.069798,0.067042,0.075652,0.075643,0.084353,0.080872,0.075527,0.062219,0.056508,0.052786]},{"section":14,"text":"Hereditary angioedema type I is characterized by low C1 inhibitor quantity.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.038742,0.083343,0.062795,0.10652,0.11229,0.10546,0.10388,0.093285,0.084235,0.078162,0.069078,0.062213],"unified_progress":[0.056702,0.07793,0.063808,0.099231,0.10163,0.10316,0.10002,0.095758,0.089926,0.08372,0.070198,0.057919]},{"section":15,"text":"Type II is where the protein is present but dysfunctional.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.029202,0.065787,0.081704,0.094088,0.10233,0.10374,0.10657,0.10012,0.092908,0.087345,0.076354,0.059851],"unified_progress":[0.10064,0.072333,0.081847,0.088152,0.093839,0.094925,0.093767,0.093209,0.084797,0.079142,0.065742,0.051611]},{"section":16,"text":"Since the level is so low, it's more likely type I.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.03808,0.076686,0.090512,0.095778,0.095911,0.093215,0.093982,0.09049,0.086844,0.085083,0.077248,0.076169],"unified_progress":[0.056711,0.076508,0.084081,0.094037,0.095004,0.093058,0.092198,0.088743,0.085455,0.083622,0.078022,0.072562]},{"section":17,"text":"The fact that the episodes started in childhood also points towards a hereditary condition rather than something acquired.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.042857,0.080963,0.09196,0.096064,0.095785,0.094288,0.091955,0.089653,0.085094,0.087051,0.075884,0.068446],"unified_progress":[0.064433,0.087095,0.087786,0.092469,0.091457,0.091105,0.08979,0.090929,0.085606,0.085537,0.074069,0.059723]},{"section":18,"text":"Acquired C1 inhibitor deficiency is usually associated with lymphoproliferative disorders or autoimmune diseases, which might not fit here unless there's more info, but the history since childhood suggests it's genetic.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.032623,0.06833,0.081069,0.089707,0.095855,0.10144,0.10067,0.098522,0.093579,0.091842,0.080986,0.06538],"unified_progress":[0.056553,0.086513,0.089568,0.089984,0.09249,0.095736,0.092513,0.095157,0.088518,0.085641,0.072525,0.054803]},{"section":19,"text":"Other causes of angioedema like allergic reactions (which are more immediate and associated with hives) or angioedema from ACE inhibitors (but she's young, maybe not on those).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029667,0.064281,0.077094,0.087805,0.095916,0.10093,0.10443,0.10205,0.095463,0.094981,0.082711,0.06467],"unified_progress":[0.038695,0.065152,0.083496,0.089476,0.09682,0.10317,0.10146,0.10158,0.096874,0.094933,0.076417,0.051923]},{"section":20,"text":"The submucosal involvement in GI and respiratory tracts is classic for HAE, as it can cause abdominal pain from GI swelling and upper airway obstruction which is dangerous.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.031346,0.06696,0.077458,0.08613,0.093073,0.098268,0.10143,0.099072,0.097856,0.091976,0.084061,0.072376],"unified_progress":[0.044393,0.062616,0.075637,0.084701,0.092695,0.10016,0.098811,0.099389,0.099544,0.094062,0.083386,0.064608]},{"section":21,"text":"So putting it all together: recurrent swelling episodes since childhood, very low C1 inhibitor, and the sites involved.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.027905,0.058117,0.072262,0.080356,0.086111,0.089276,0.093474,0.094545,0.098196,0.10209,0.10181,0.095856],"unified_progress":[0.034441,0.052162,0.064248,0.074825,0.085017,0.093774,0.096942,0.10028,0.10363,0.10619,0.1019,0.086594]},{"section":22,"text":"The most likely diagnosis is Hereditary Angioedema, specifically Type I because of the low level.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.02291,0.046546,0.057305,0.065935,0.073909,0.080078,0.08703,0.090865,0.097623,0.10243,0.11356,0.16181],"unified_progress":[0.023422,0.035632,0.045982,0.054961,0.062007,0.077077,0.080546,0.094427,0.105,0.11009,0.13775,0.1731]},{"section":23,"text":"Type III is another type but is more related to hormonal factors and might have normal or near normal C1 inhibitor levels, so probably not here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023683,0.053515,0.067088,0.077188,0.085699,0.092185,0.099133,0.10156,0.10247,0.10374,0.099416,0.094319],"unified_progress":[0.026179,0.050764,0.0641,0.073563,0.082343,0.089323,0.094578,0.10176,0.10509,0.11167,0.10525,0.095365]},{"section":24,"text":"I don't think it's another complement deficiency because the key here is C1 inhibitor.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.033073,0.065725,0.077779,0.084308,0.087911,0.089547,0.093124,0.094009,0.094523,0.095255,0.091179,0.093567],"unified_progress":[0.038172,0.058871,0.070956,0.080282,0.085835,0.08946,0.093399,0.094974,0.096145,0.097503,0.097907,0.096494]},{"section":25,"text":"So yeah, Hereditary Angioedema Type I.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.019706,0.041091,0.052135,0.060833,0.069897,0.077655,0.08539,0.090557,0.09916,0.10319,0.1177,0.18268],"unified_progress":[0.018799,0.030398,0.039306,0.049038,0.054578,0.067338,0.071456,0.084947,0.099042,0.11057,0.15523,0.2193]}]}}