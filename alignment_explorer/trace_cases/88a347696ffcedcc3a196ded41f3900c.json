103]},{"section":23,"text":"Hmm, that's another possibility.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018583,0.044773,0.058486,0.070878,0.082593,0.096728,0.10991,0.12125,0.13033,0.12803,0.094026,0.044415],"unified_progress":[0.030397,0.060069,0.077719,0.087008,0.096499,0.099974,0.10184,0.1044,0.10157,0.10228,0.082901,0.055346]},{"section":24,"text":"Boys with Fragile X can have social challenges and sometimes exhibit repetitive behaviors.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.034565,0.041218,0.052511,0.065291,0.078864,0.092498,0.10572,0.11249,0.12055,0.12824,0.106,0.062054],"unified_progress":[0.042234,0.058582,0.074251,0.085668,0.093362,0.10377,0.10135,0.10278,0.099007,0.095142,0.081214,0.062645]},{"section":25,"text":"But, they often have distinct physical features like a long face and large ears.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.035332,0.043953,0.057415,0.071252,0.083519,0.09532,0.10566,0.11311,0.1198,0.12166,0.097524,0.055451],"unified_progress":[0.043513,0.061727,0.076308,0.08544,0.093846,0.098306,0.099009,0.10082,0.099318,0.097704,0.081682,0.06233]},{"section":26,"text":"Are those mentioned here?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.11135,0.089957,0.083526,0.074848,0.076925,0.079461,0.082981,0.091904,0.083867,0.057523,0.056633,0.11103],"unified_progress":[0.21009,0.080145,0.064844,0.065547,0.074967,0.07454,0.092346,0.083148,0.079578,0.063668,0.056984,0.054142]},{"section":27,"text":"Nope, not in this case.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.11828,0.10689,0.095065,0.078797,0.078183,0.078698,0.07823,0.088472,0.081417,0.053782,0.052578,0.089608],"unified_progress":[0.18498,0.061488,0.24031,0.080471,0.05733,0.055741,0.055007,0.063469,0.062035,0.05112,0.045737,0.042305]},{"section":28,"text":"So, back to autism spectrum disorder.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.025189,0.05537,0.07