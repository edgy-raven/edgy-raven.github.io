"unified_progress":[0.055444,0.093761,0.074282,0.10047,0.10408,0.10116,0.094276,0.094949,0.088292,0.079821,0.06736,0.046101]},{"section":11,"text":"That's more common in girls, though.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.029727,0.064287,0.07944,0.090317,0.097589,0.10054,0.10279,0.1008,0.096282,0.092645,0.082253,0.063328],"unified_progress":[0.050011,0.075389,0.084763,0.090281,0.096663,0.097456,0.097601,0.099035,0.093108,0.091976,0.073382,0.050336]},{"section":12,"text":"The child here is a boy, so maybe less likely.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.034693,0.069745,0.080478,0.087344,0.093288,0.099376,0.098831,0.098883,0.095357,0.092147,0.082555,0.067303],"unified_progress":[0.06786,0.094568,0.090053,0.090178,0.090439,0.090405,0.090588,0.091343,0.085267,0.084853,0.070724,0.053721]},{"section":13,"text":"Rett typically has regression in development, hand-wringing, and other neurological signs.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.02897,0.06461,0.07793,0.089328,0.097737,0.10211,0.10591,0.10223,0.09481,0.09304,0.080207,0.063118],"unified_progress":[0.039867,0.065779,0.087891,0.09137,0.098795,0.10648,0.10201,0.10092,0.094877,0.091313,0.071855,0.048846]},{"section":14,"text":"Not sure.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31894,0.052118,0.053111,0.061991,0.063012,0.064105,0.061749,0.070152,0.070112,0.064804,0.067462,0.052444],"unified_progress":[0.21104,0.079885,0.066794,0.066175,0.075763,0.074551,0.099617,0.082378,0.0783,0.06125,0.054372,0.049876]},{"section":15,"text":"What about childhood disintegrative disorder?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.044211,0.092543,0.062801,0.099812,0.10329,0.098764,0.09769,0.09362,0.087975,0.082228,0.07485,0.062214],"unified_progress":[0.051921,0.084846,0.070289,0.098513,0.10341,0.10135,0.097328,0.097698,0.09125,0.082952,0.069566,0.050872]},{"section":16,"text":"That's rare and involves a loss of skills, which might not be mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024985,0.058403,0.073586,0.085473,0.093932,0.098201,0.10506,0.10541,0.10213,0.098313,0.089651,0.064854],"unified_progress":[0.035023,0.060704,0.075991,0.084723,0.096707,0.098619,0.10124,0.10586,0.10263,0.10523,0.081828,0.051447]},{"section":17,"text":"The case doesn't say he lost skills, just not developing appropriately.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.037824,0.07415,0.079391,0.083003,0.087585,0.092944,0.097416,0.10016,0.097578,0.094574,0.086823,0.068546],"unified_progress":[0.048437,0.071492,0.078008,0.082959,0.090179,0.09225,0.097083,0.10007,0.097911,0.10134,0.083074,0.057195]},{"section":18,"text":"Then there's the chin-banging.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.037567,0.073625,0.084856,0.089418,0.092393,0.092769,0.093537,0.093724,0.092734,0.09231,0.083742,0.073325],"unified_progress":[0.046821,0.071247,0.081601,0.091076,0.093751,0.095116,0.098801,0.095956,0.093591,0.092171,0.079251,0.060618]},{"section":19,"text":"That might be a stereotypic movement.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.034198,0.070061,0.081571,0.089788,0.09619,0.098157,0.1008,0.098409,0.094198,0.089765,0.080776,0.066084],"unified_progress":[0.077968,0.070819,0.080753,0.087912,0.092573,0.095136,0.095182,0.094582,0.08932,0.085523,0.072775,0.057457]},{"section":20,"text":"In ASD, repetitive behaviors are common, like flapping, spinning, or head-banging.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030643,0.066323,0.078922,0.089661,0.098214,0.10174,0.10473,0.10089,0.094403,0.090699,0.079315,0.064464],"unified_progress":[0.072223,0.069582,0.083614,0.088204,0.093484,0.098513,0.096725,0.096569,0.089753,0.085804,0.070917,0.054611]},{"section":21,"text":"So chin-banging could fit under that category.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035128,0.072259,0.085828,0.092901,0.095648,0.095268,0.096241,0.093352,0.090825,0.088888,0.079145,0.074516],"unified_progress":[0.05389,0.070042,0.081653,0.091311,0.093923,0.095005,0.094203,0.093061,0.09029,0.088453,0.078837,0.069334]},{"section":22,"text":"The self-confinement, meaning he stays to himself, also aligns with social withdrawal seen in ASD.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.053203,0.094484,0.089992,0.087493,0.088305,0.091418,0.090515,0.090899,0.085662,0.082017,0.075457,0.070554],"unified_progress":[0.061578,0.085459,0.085396,0.08654,0.088482,0.091469,0.089262,0.091784,0.087921,0.084684,0.078434,0.068991]},{"section":23,"text":"Are there other genetic disorders?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.03391,0.07277,0.091659,0.098181,0.099017,0.094834,0.094756,0.092182,0.089124,0.090498,0.077739,0.065331],"unified_progress":[0.04461,0.076252,0.087877,0.099666,0.098169,0.095378,0.097444,0.093641,0.089054,0.090053,0.07331,0.054546]},{"section":24,"text":"Like Fragile X syndrome?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.028955,0.065496,0.082186,0.092219,0.099592,0.10124,0.10218,0.099667,0.094139,0.091109,0.079417,0.063807],"unified_progress":[0.042118,0.073057,0.088829,0.096773,0.10024,0.1017,0.10084,0.097284,0.090914,0.085566,0.070186,0.052496]},{"section":25,"text":"That can present with developmental delays and autism-like features.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026112,0.05996,0.075564,0.088042,0.097444,0.10201,0.10579,0.10274,0.096516,0.095549,0.083231,0.06704],"unified_progress":[0.04077,0.061762,0.078487,0.087574,0.095673,0.10271,0.10171,0.10245,0.097812,0.095975,0.078409,0.056672]},{"section":26,"text":"But Fragile X might have physical features like large ears or macroorchidism, which aren't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025098,0.059316,0.074676,0.086351,0.094874,0.1005,0.10571,0.10447,0.10001,0.097809,0.0857,0.065475],"unified_progress":[0.032052,0.061888,0.079201,0.088603,0.097137,0.10112,0.10269,0.10422,0.10039,0.10103,0.079109,0.052555]},{"section":27,"text":"Also, the main symptoms here point more towards social and behavioral aspects.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026534,0.060144,0.074951,0.083671,0.089383,0.093287,0.099344,0.10092,0.1002,0.099854,0.093461,0.07825],"unified_progress":[0.036159,0.058483,0.071722,0.081245,0.089989,0.093997,0.098806,0.10239,0.10172,0.10681,0.090736,0.06794]},{"section":28,"text":"Another thought: global developmental delay.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.029565,0.065463,0.081582,0.089158,0.09421,0.094912,0.096801,0.097789,0.095987,0.096396,0.086079,0.072058],"unified_progress":[0.034832,0.067116,0.082027,0.093453,0.096273,0.097282,0.10199,0.098894,0.095656,0.094235,0.07945,0.058798]},{"section":29,"text":"But that's more of a descriptive term.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30898,0.050672,0.050767,0.060401,0.061452,0.064566,0.062963,0.071138,0.073367,0.068853,0.072249,0.054594],"unified_progress":[0.20886,0.078689,0.066368,0.065581,0.074888,0.074709,0.092767,0.082488,0.078899,0.063164,0.05835,0.05524]},{"section":30,"text":"The key here is the combination of social deficits, lack of eye contact, not playing with peers, and repetitive movements.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.043217,0.085924,0.056978,0.088875,0.093447,0.092139,0.09628,0.093299,0.092278,0.091681,0.087374,0.07851],"unified_progress":[0.066172,0.086765,0.059108,0.080174,0.087829,0.090834,0.098868,0.092568,0.092093,0.090666,0.085135,0.069787]},{"section":31,"text":"All those are core features of autism spectrum disorder.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.030765,0.064566,0.079919,0.087739,0.09138,0.090173,0.093333,0.091662,0.091065,0.093675,0.089097,0.096627],"unified_progress":[0.055531,0.059014,0.06899,0.078237,0.082597,0.087912,0.090054,0.092825,0.093685,0.096125,0.096857,0.098171]},{"section":32,"text":"I don't think it's something like cerebral palsy, since that's more about motor impairments, though some with CP can have developmental delays.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027985,0.060944,0.074094,0.083737,0.091146,0.096014,0.10161,0.10279,0.10061,0.098928,0.090287,0.07186],"unified_progress":[0.035536,0.060207,0.074353,0.082618,0.091484,0.095411,0.098832,0.10307,0.10217,0.10547,0.087937,0.062906]},{"section":33,"text":"But the social aspects are more prominent here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021749,0.052686,0.068594,0.079188,0.087263,0.093344,0.10318,0.10684,0.107,0.10549,0.099377,0.075291],"unified_progress":[0.033654,0.053744,0.06805,0.07727,0.089062,0.092828,0.099782,0.10698,0.10732,0.11502,0.094247,0.062047]},{"section":34,"text":"So putting it all together: the social interaction issues, lack of eye contact, repetitive behavior (chin-banging), and self-isolation are all pointing towards autism spectrum disorder.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.029603,0.058475,0.068178,0.075493,0.08275,0.088438,0.093456,0.096149,0.099352,0.10191,0.1033,0.10289],"unified_progress":[0.03843,0.053474,0.063493,0.073005,0.081225,0.090389,0.095088,0.098677,0.1017,0.10397,0.10441,0.096142]},{"section":35,"text":"The age is also typical for when these symptoms become noticeable.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035946,0.068798,0.078303,0.084465,0.088754,0.091884,0.094,0.094792,0.093788,0.095586,0.08912,0.084563],"unified_progress":[0.067852,0.072708,0.074104,0.07851,0.082708,0.086744,0.08857,0.092843,0.091746,0.093819,0.089419,0.080976]}]}}