95599,0.098839,0.096942,0.093644,0.093069,0.080281,0.064793]},{"section":10,"text":"Maybe it's a specific learning disability, like a writing disorder.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.034254,0.060675,0.079508,0.091499,0.095349,0.097437,0.10213,0.099389,0.095994,0.098473,0.079554,0.065741],"unified_progress":[0.034743,0.065963,0.083805,0.094692,0.09772,0.099199,0.10197,0.099915,0.095726,0.091266,0.076571,0.058426]},{"section":11,"text":"But I'm not sure if that's a standard diagnosis.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.045838,0.078703,0.080227,0.086503,0.086635,0.088125,0.092035,0.09277,0.094454,0.098846,0.089507,0.066356],"unified_progress":[0.035546,0.067171,0.080778,0.096181,0.096528,0.095803,0.10034,0.097612,0.094037,0.096483,0.079661,0.059861]},{"section":12,"text":"Alternatively, could it be something like a developmental delay or a speech and language disorder?","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.029996,0.057684,0.07643,0.086373,0.09353,0.09784,0.10267,0.1045,0.10369,0.10287,0.083771,0.060652],"unified_progress":[0.034128,0.067277,0.08489,0.095465,0.099315,0.099886,0.10357,0.10123,0.096345,0.091072,0.074324,0.052493]},{"section":13,"text":"Wait, another thought: sometimes, when kids have trouble expressing themselves in writing, it might be due to a condition like a learning disability that affects written language more than spoken.","dimension":8,"group":6,"is_degenerate":false,"model_progress":[0.037589,0.058506,0.070073,0.079485,0.088218,0.095397,0.10082,0.10523,0.10714,0.10461,0.088576,0.064353],"unified_progress":[0.040905,0.068144,0.083684,0.095147,0.097878,0.099879,0.10209,0.099659,0.094296,0.090981,0.073701,0.053643]},{"section":14,"text":"Or maybe it's a motor planning issue, but that usually affects handwriting more than spelling.","dimension":8,"group":6,"is_degenerate":false,"model_progress":[0.032078,0.049862,0.065612,0.075516,0.087375,0.096715,0.102