s":[0.038177,0.067203,0.086859,0.095437,0.10107,0.10795,0.10311,0.098987,0.0927,0.087075,0.070237,0.051201]},{"section":10,"text":"The symmetric involvement of joints in hands, feet, elbows, and ankles suggests a systemic issue, not just localized to the hands.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.047514,0.07017,0.080308,0.090547,0.092627,0.096103,0.097946,0.096183,0.090744,0.084806,0.079396,0.073655],"unified_progress":[0.050202,0.073479,0.082842,0.090541,0.094742,0.096221,0.094064,0.09434,0.092985,0.084944,0.076832,0.068808]},{"section":11,"text":"Rheumatoid arthritis can present like that, but it's more about the small joints.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.035955,0.050876,0.068877,0.079511,0.091597,0.099245,0.10337,0.10793,0.10688,0.098828,0.086294,0.070637],"unified_progress":[0.035097,0.056575,0.077745,0.087195,0.095188,0.10677,0.1029,0.10269,0.098808,0.09704,0.079974,0.060018]},{"section":12,"text":"However, the presence of lgG anti-bodies is more concerning for something like systemic lupus erythematosus (SLE) or maybe another systemic autoimmune condition.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.033825,0.052331,0.07136,0.083099,0.090276,0.095518,0.10005,0.10188,0.10082,0.1011,0.089883,0.079854],"unified_progress":[0.035969,0.06153,0.07758,0.088234,0.093792,0.097094,0.098958,0.10023,0.097556,0.094918,0.084077,0.070063]},{"section":13,"text":"Wait, but SLE often presents with joint pain, fatigue, and systemic symptoms.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.036491,0.059074,0.069018,0.076649,0.085217,0.092828,0.098144,0.10462,0.1074,0.1026,0.092926,0.075028],"unified_progress":[0.039818,0.066121,0.079588,0.088526,0.093741,0.098372,0.09969,0.10076,0.096782,0.094557,0.080083,0.061963]},{"section":14,"text":"The tender joints and morning worsening fit.","dimension":9,"group":5,"is_degenerate":false,"model_progress":[0.060081,0.078771,0.078238,0