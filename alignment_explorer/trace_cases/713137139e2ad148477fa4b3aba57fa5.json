063965,0.073373,0.07401,0.095806,0.084411,0.082359,0.06748,0.062985,0.058907]},{"section":20,"text":"Maybe gout, but that's more about uric acid crystals and would present with sudden, severe pain, especially at night.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.047895,0.066123,0.0928,0.09922,0.10134,0.1002,0.10062,0.097506,0.091746,0.085264,0.069214,0.04807],"unified_progress":[0.035942,0.062471,0.061636,0.092231,0.10329,0.10124,0.10308,0.10964,0.10513,0.098576,0.077935,0.048833]},{"section":21,"text":"She doesn't mention that.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.02855,0.059043,0.077682,0.085423,0.088842,0.094804,0.098026,0.10439,0.10519,0.10452,0.095413,0.058119],"unified_progress":[0.028003,0.055272,0.069452,0.079083,0.092101,0.094681,0.10109,0.1097,0.10944,0.1185,0.089803,0.052882]},{"section":22,"text":"Osteoarthritis is less likely because it's more about joint degeneration, not inflammation.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.027069,0.047639,0.068348,0.078989,0.08679,0.095615,0.099835,0.10965,0.11232,0.11082,0.10033,0.062593],"unified_progress":[0.02811,0.052154,0.069187,0.079524,0.091518,0.09764,0.10302,0.11076,0.11036,0.11505,0.090843,0.051836]},{"section":23,"text":"So putting it all together: systemic joint pain, morning worsening, systemic symptoms, and anti-lgG positive.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.02763,0.044897,0.049749,0.054635,0.057543,0.063257,0.071247,0.080592,0.09307,0.10934,0.14339,0.20465],"unified_progress":[0.026831,0.041184,0.046805,0.054613,0.059724,0.070163,0.074756,0.085673,0.093716,0.10415,0.14289,0.19949]},{"section":24,"text":"That points towards systemic lupus erythematosus.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.020225,0.034732,0.045771,0.054086,0.059313,0.065546,0.073211,0.083705,0.095703,0.11537,0.14468,0.20765],"unified_progress":[0.019039,0.034372,0.044346,0.05318,0.059321,0.0695