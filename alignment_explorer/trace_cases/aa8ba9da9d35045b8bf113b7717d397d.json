5554,0.036107,0.030277,0.026363,0.022121,0.020164,0.017076,0.012842,0.010636,0.0095121]},{"section":2,"text":"The patient has gluten-sensitive enteropathy, which is another term for celiac disease.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.17942,0.34783,0.073665,0.10912,0.058353,0.064222,0.040355,0.033404,0.028286,0.0243,0.021065,0.019985],"unified_progress":[0.22801,0.14749,0.079275,0.11487,0.080114,0.096373,0.060113,0.052502,0.045293,0.038833,0.032305,0.02483]},{"section":3,"text":"So that's an autoimmune condition triggered by gluten ingestion, leading to intestinal damage.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.099528,0.14077,0.13845,0.11146,0.099114,0.08408,0.074364,0.068398,0.054067,0.051471,0.040973,0.037322],"unified_progress":[0.099088,0.097742,0.10356,0.10379,0.097525,0.093416,0.085258,0.084868,0.07015,0.067126,0.053874,0.043611]},{"section":4,"text":"Now, the skin lesions described are pruritic, grouped papules or vesicles on elbows, knees, sacrum, and shoulders.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.11375,0.18063,0.13089,0.093457,0.078027,0.081313,0.066098,0.073849,0.054235,0.048846,0.041678,0.03722],"unified_progress":[0.097817,0.13121,0.11007,0.094031,0.087359,0.08872,0.077506,0.085851,0.069207,0.062116,0.053345,0.042764]},{"section":5,"text":"The key points here are the distribution of the rash and the fact that scratching the vesicles relieves the itching.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.095744,0.16078,0.13656,0.10041,0.082315,0.083135,0.067795,0.073629,0.057649,0.055512,0.045363,0.041108],"unified_progress":[0.086205,0.11655,0.1022,0.10113,0.089272,0.091117,0.081091,0.085788,0.073579,0.069549,0.057597,0.045916]},{"section":6,"text":"Hmm, the classic condition that comes to mind with celiac disease and skin manifestations is dermatitis herpetiformis.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.057368,0.098969,0.11434,0.11575,0.10451,0.089069,0.084273,0.075806,0.067827,0.075427,0.057847,0.058815],"unified_progress":[0.055957,0.071094,0.087508,0.095953,0.0965,0.097517,0.09579,0.090232,0.084243,0.089703,0.072997,0.062505]},{"section":7,"text":"I remember that dermatitis herpetiformis is associated with celiac disease, and it's an autoimmune blistering disorder.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032102,0.068693,0.0871,0.10262,0.11098,0.10824,0.10499,0.093451,0.081835,0.083464,0.065138,0.061384],"unified_progress":[0.030781,0.054987,0.081318,0.09234,0.10036,0.11233,0.10612,0.10254,0.096178,0.09061,0.072749,0.05969]},{"section":8,"text":"The lesions are typically very itchy, and they often appear symmetrically on extensor surfaces like the elbows, knees, scalp, etc.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.042461,0.080747,0.084105,0.089236,0.095218,0.09923,0.099595,0.096264,0.088983,0.086707,0.074169,0.063284],"unified_progress":[0.061887,0.072373,0.080104,0.087716,0.093441,0.098483,0.097144,0.098279,0.093463,0.088196,0.07255,0.056365]},{"section":9,"text":"The fact that scratching the vesicles relieves the itching is a big clue because DH is characterized by that phenomenon.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.041553,0.080984,0.089373,0.092422,0.093531,0.093118,0.093659,0.09186,0.086895,0.087901,0.077572,0.071133],"unified_progress":[0.058388,0.073678,0.081008,0.087656,0.091088,0.094538,0.093846,0.094913,0.09059,0.091106,0.078319,0.064871]},{"section":10,"text":"The vesicles are usually filled with a specific type of antibody, IgA deposits in the skin.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.040204,0.079678,0.088334,0.093745,0.096399,0.097403,0.097663,0.093426,0.089686,0.083651,0.074321,0.065489],"unified_progress":[0.056943,0.073963,0.08746,0.093966,0.097873,0.10005,0.096942,0.094277,0.090116,0.081605,0.069522,0.057286]},{"section":11,"text":"Also, the patient's history of celiac disease makes this connection stronger since about 15-25% of celiac patients have DH.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.03935,0.075457,0.08485,0.090349,0.093788,0.096907,0.094574,0.092456,0.087705,0.089366,0.078666,0.076532],"unified_progress":[0.058869,0.083059,0.084876,0.087834,0.088535,0.093124,0.0897,0.091885,0.086683,0.084933,0.078525,0.071975]},{"section":12,"text":"Other possibilities might include atopic dermatitis, but that's usually more on flexural areas and not as associated with celiac.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023602,0.055574,0.07109,0.082771,0.091179,0.096365,0.10487,0.10521,0.10291,0.10229,0.093979,0.070174],"unified_progress":[0.029851,0.055984,0.073666,0.082241,0.094342,0.098304,0.10169,0.10574,0.10445,0.10924,0.087143,0.057347]},{"section":13,"text":"Scabies could cause itching but the distribution and the vesicles being relieved by scratching are more specific.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02135,0.051878,0.06561,0.076292,0.085178,0.093167,0.10388,0.10838,0.10877,0.10794,0.102,0.075553],"unified_progress":[0.028792,0.053442,0.068081,0.077301,0.089337,0.095229,0.10117,0.10891,0.10964,0.11661,0.09384,0.057639]},{"section":14,"text":"Pemphigus or bullous pemphigoid are blistering diseases but not linked to gluten.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.021961,0.052795,0.068731,0.084055,0.095774,0.10192,0.10773,0.10595,0.10025,0.10117,0.087221,0.072438],"unified_progress":[0.026022,0.051563,0.07293,0.086586,0.095352,0.10789,0.10668,0.10871,0.10474,0.10097,0.082203,0.056364]},{"section":15,"text":"The grouped vesicles and the relief upon scratching are classic for DH.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.025221,0.055916,0.068205,0.077316,0.08583,0.092548,0.098322,0.10012,0.10258,0.10232,0.10085,0.090768],"unified_progress":[0.035028,0.054874,0.067282,0.077794,0.087127,0.098213,0.098345,0.10185,0.10372,0.10328,0.095332,0.077157]},{"section":16,"text":"Also, the lifelong periodic crops suggest a chronic relapsing condition, which fits DH.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.030466,0.06357,0.073556,0.080787,0.087054,0.092455,0.096164,0.097489,0.097373,0.098307,0.093087,0.089691],"unified_progress":[0.035413,0.057964,0.068978,0.077919,0.085381,0.0927,0.095578,0.099134,0.10069,0.10193,0.097276,0.087036]},{"section":17,"text":"So putting it all together, the most likely diagnosis is dermatitis herpetiformis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.027415,0.049743,0.057777,0.065124,0.071982,0.077498,0.084355,0.088784,0.095719,0.10098,0.11198,0.16864],"unified_progress":[0.028948,0.035333,0.04417,0.053664,0.05966,0.071932,0.076219,0.08858,0.099028,0.10818,0.14341,0.19088]},{"section":18,"text":"<answer> Dermatitis Herpetiformis </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.030708,0.052632,0.055457,0.061061,0.068711,0.076427,0.083821,0.089936,0.097427,0.1029,0.11364,0.16728],"unified_progress":[0.029928,0.035508,0.042236,0.049516,0.055741,0.066686,0.071048,0.085839,0.097781,0.10883,0.14645,0.21043]}]}}