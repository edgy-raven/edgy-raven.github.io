14,0.082276,0.088934,0.076251,0.069265,0.057369,0.042101]},{"section":11,"text":"In terms of lab findings, Lyme can cause leukopenia and elevated liver enzymes, though I'm not sure about the inclusion bodies in monocytes.","dimension":1,"group":7,"is_degenerate":false,"model_progress":[0.034272,0.062445,0.078602,0.0879,0.095436,0.097718,0.099494,0.097925,0.095982,0.091033,0.084316,0.074877],"unified_progress":[0.048308,0.083067,0.096787,0.10036,0.1043,0.10083,0.096294,0.089717,0.08812,0.075963,0.065236,0.051021]},{"section":12,"text":"Rocky Mountain Spotted Fever is caused by Rickettsia rickettsii, also transmitted by ticks.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.028964,0.05334,0.070782,0.082458,0.095266,0.10105,0.11103,0.11177,0.10468,0.095207,0.079667,0.065775],"unified_progress":[0.032244,0.061298,0.086764,0.098966,0.10345,0.12012,0.10709,0.10104,0.092531,0.083945,0.065198,0.047367]},{"section":13,"text":"It presents with fever, headache, rash, and sometimes nausea.","dimension":14,"group":5,"is_degenerate":false,"model_progress":[0.040458,0.087959,0.080386,0.071789,0.078526,0.07959,0.084566,0.089501,0.090986,0.079473,0.10416,0.11261],"unified_progress":[0.10499,0.14085,0.10778,0.090649,0.08664,0.083549,0.076772,0.081431,0.071216,0.06257,0.05276,0.040793]},{"section":14,"text":"Lab findings can include leukopenia and elevated liver enzymes.","dimension":1,"group":7,"is_degenerate":false,"model_progress":[0.035817,0.067291,0.081622,0.088918,0.09626,0.097148,0.09714,0.094385,0.091879,0.084879,0.084321,0.080339],"unified_progress":[0.067774,0.10669,0.10695,0.10561,0.10404,0.097959,0.088551,0.082841,0.080144,0.062764,0.054202,0.042471]},{"section":15,"text":"Inclusion bodies in monocytes are a classic finding in Rocky Mountain Spotted Fever.","dimension":1,"group":7,"is_degenerate":false,"model_progress":[0.03556,0.060651,0.076273,0.087341,0.094858,0.097883,0.10069,0.099464,0.096088,0.090163,0.083681,0.077344],"unified_progress":[0.045654