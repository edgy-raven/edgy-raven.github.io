61,0.10379,0.099114,0.074248,0.038349],"unified_progress":[0.035846,0.067603,0.082541,0.095033,0.096983,0.096728,0.099832,0.096389,0.092939,0.095988,0.078805,0.061314]},{"section":9,"text":"Maybe it's insulinoma, which is a tumor that produces too much insulin.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.02512,0.044121,0.062483,0.07999,0.094106,0.10619,0.11518,0.11601,0.11646,0.11684,0.083293,0.040202],"unified_progress":[0.03191,0.058989,0.078839,0.09078,0.098569,0.10824,0.10486,0.10325,0.097832,0.092216,0.075367,0.059151]},{"section":10,"text":"Or maybe it's something like non-islet cell tumor hypoglycemia, where another type of tumor causes high insulin-like activity.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.02285,0.03856,0.056202,0.074037,0.090058,0.10478,0.11627,0.11993,0.12334,0.12511,0.088543,0.040325],"unified_progress":[0.030882,0.056841,0.078051,0.091893,0.09894,0.10658,0.10708,0.1054,0.10039,0.094495,0.074735,0.054713]},{"section":11,"text":"There's also reactive hypoglycemia, but that usually happens after eating, not before meals.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.024594,0.036542,0.050713,0.065436,0.08057,0.096871,0.11156,0.1221,0.131,0.1326,0.09841,0.049606],"unified_progress":[0.032668,0.055788,0.073394,0.085412,0.094361,0.10148,0.10304,0.10541,0.10254,0.1026,0.082529,0.060776]},{"section":12,"text":"Hmm, let's see.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.10403,0.084357,0.079702,0.072931,0.076009,0.079693,0.084613,0.094762,0.087332,0.060259,0.05959,0.11672],"unified_progress":[0.19737,0.074584,0.063413,0.064435,0.074431,0.074885,0.099969,0.085971,0.083166,0.066248,0.059652,0.055876]},{"section":13,"text":"Insulinoma seems like a strong contender here.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.026124,0.051476,0.066324,0.075437,0.080237,0.085403,0.089715,0.092026,0.095573,0.10103,0.11285,0.1238],"unified_progress":[0.034