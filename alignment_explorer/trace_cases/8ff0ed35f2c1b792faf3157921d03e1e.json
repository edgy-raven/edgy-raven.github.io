097904,0.095956,0.093775,0.088113,0.080234,0.069576],"unified_progress":[0.042551,0.073092,0.086135,0.09612,0.099312,0.097558,0.09919,0.09422,0.090465,0.087613,0.074802,0.058941]},{"section":16,"text":"Another possibility is prolymphocytic leukemia (PLL), but that's usually CD5 negative in most cases.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029182,0.063687,0.078959,0.092226,0.10128,0.10415,0.10604,0.10059,0.092712,0.091854,0.07651,0.062808],"unified_progress":[0.034102,0.061648,0.082839,0.093945,0.10112,0.11102,0.10531,0.10253,0.095598,0.089891,0.070917,0.051087]},{"section":17,"text":"Or maybe a mantle cell lymphoma (MCL)?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.031919,0.065228,0.078219,0.089544,0.098296,0.10156,0.10349,0.10072,0.095178,0.093432,0.078604,0.063806],"unified_progress":[0.041453,0.066075,0.084594,0.096654,0.10118,0.10382,0.10347,0.1006,0.094567,0.087154,0.069602,0.050824]},{"section":18,"text":"MCL typically expresses CD5 and is CD23 negative.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029235,0.063575,0.079315,0.09212,0.10081,0.1034,0.10635,0.10061,0.093322,0.090973,0.077195,0.063093],"unified_progress":[0.057318,0.064382,0.082341,0.092502,0.098976,0.10447,0.10212,0.099138,0.092334,0.0856,0.069164,0.051657]},{"section":19,"text":"Oh, that's important.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31409,0.052199,0.053685,0.06277,0.063788,0.065048,0.061485,0.070467,0.070896,0.064934,0.068643,0.051997],"unified_progress":[0.22185,0.084582,0.064057,0.065565,0.073898,0.072735,0.097908,0.079155,0.075435,0.059637,0.054419,0.050755]},{"section":20,"text":"MCL cells are CD5+, CD23-, and often have cyclin D1 overexpression due to the t(11;14) translocation.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.042889,0.090283,0.063146,0.10768,0.11241,0.10732,0.10383,0.092503,0.082739,0.076139,0.065696,0.055359],"unified_progress":[0.049934,0.077688,0.068077,0.10472,0.1084,0.10517,0.10376,0.098263,0.090232,0.081833,0.064668,0.047268]},{"section":21,"text":"The presence of splenomegaly and lymphadenopathy along with leukocytosis fits MCL.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.036788,0.075332,0.085394,0.091214,0.095453,0.097876,0.097852,0.093722,0.091982,0.086633,0.079217,0.068539],"unified_progress":[0.043003,0.070043,0.083587,0.092221,0.098305,0.10272,0.098454,0.096477,0.094458,0.086602,0.07539,0.058743]},{"section":22,"text":"Also, the monoclonal B-cells with kappa light chain restriction (monoclonal) supports a clonal process.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.038941,0.078419,0.089426,0.094855,0.096161,0.096146,0.096515,0.092009,0.090236,0.083747,0.07615,0.067394],"unified_progress":[0.044201,0.073014,0.088269,0.096356,0.10129,0.10144,0.099791,0.093554,0.090462,0.081741,0.071328,0.058547]},{"section":23,"text":"The high percentage (80%) in peripheral blood is significant.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.043145,0.08445,0.094333,0.096508,0.09543,0.09356,0.093347,0.089687,0.087184,0.081571,0.075624,0.065162],"unified_progress":[0.046557,0.078857,0.091246,0.097214,0.10177,0.098932,0.10044,0.091488,0.087469,0.079771,0.070508,0.055753]},{"section":24,"text":"Wait, but in CLL, CD5 and CD23 are both usually positive.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.034649,0.068195,0.081381,0.090748,0.097378,0.098402,0.10117,0.097518,0.09305,0.08843,0.081575,0.067501],"unified_progress":[0.078801,0.070353,0.081829,0.088584,0.094377,0.096476,0.096684,0.092879,0.086782,0.083517,0.072362,0.057357]},{"section":25,"text":"Since here CD23 is negative, that points away from CLL.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.03076,0.065548,0.08076,0.08952,0.09522,0.096308,0.10038,0.097759,0.095356,0.089957,0.084829,0.073599],"unified_progress":[0.088039,0.072869,0.079951,0.086477,0.091117,0.090821,0.09159,0.09057,0.085286,0.082591,0.075306,0.065383]},{"section":26,"text":"So the combination of CD5+ and CD23- is more indicative of mantle cell lymphoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.034554,0.066039,0.077114,0.085323,0.090496,0.092597,0.095347,0.093699,0.092953,0.092638,0.087716,0.091526],"unified_progress":[0.045458,0.061705,0.076935,0.08532,0.089333,0.093606,0.093347,0.092505,0.092889,0.090952,0.089759,0.088192]},{"section":27,"text":"Additionally, mantle cell lymphoma can present with leukemic involvement, meaning the lymphoma cells are in the blood, leading to high WBC counts.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.034366,0.068082,0.07836,0.087233,0.093789,0.097414,0.10008,0.096948,0.093665,0.091073,0.082945,0.076047],"unified_progress":[0.04206,0.060579,0.075868,0.084657,0.091906,0.099002,0.098021,0.098067,0.097174,0.093749,0.085953,0.072965]},{"section":28,"text":"Splenomegaly is common in MCL as well.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029759,0.063492,0.076976,0.087176,0.094395,0.098464,0.10112,0.098388,0.096059,0.09382,0.085255,0.075095],"unified_progress":[0.052087,0.06473,0.077062,0.085309,0.091849,0.097754,0.09721,0.097817,0.095438,0.092418,0.081447,0.066879]},{"section":29,"text":"So putting it all together: CD5+, CD23-, monoclonal B cells with kappa light chain restriction, splenomegaly, lymphadenopathy, and high WBC count.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.028038,0.057404,0.069127,0.077963,0.086014,0.091925,0.096719,0.097388,0.10131,0.1001,0.10133,0.092684],"unified_progress":[0.037559,0.055686,0.069452,0.078284,0.088182,0.097036,0.09739,0.098962,0.10155,0.099469,0.095676,0.080757]},{"section":30,"text":"The most likely diagnosis is mantle cell lymphoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.022461,0.045238,0.055502,0.063533,0.071251,0.077649,0.085103,0.089823,0.09809,0.103,0.11618,0.17217],"unified_progress":[0.023275,0.034824,0.044397,0.053962,0.059785,0.075069,0.078056,0.093677,0.10421,0.10951,0.14088,0.18235]},{"section":31,"text":"<answer> Mantle Cell Lymphoma </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.030726,0.05199,0.055086,0.060891,0.068569,0.076307,0.083832,0.090014,0.098276,0.10321,0.11396,0.16714],"unified_progress":[0.031562,0.03583,0.042402,0.050097,0.056268,0.067158,0.071356,0.086765,0.098213,0.10885,0.14547,0.20603]}]}}