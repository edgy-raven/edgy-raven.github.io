0.059292,0.46273,0.027264,0.022248,0.019151,0.015086,0.0147,0.013121,0.011352,0.0099684,0.007564],"unified_progress":[0.21058,0.054445,0.55129,0.03583,0.030045,0.026161,0.021952,0.02001,0.016946,0.012744,0.010555,0.0094393]},{"section":2,"text":"The patient is a 36-year-old man with a week-long right scrotal swelling.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.1891,0.35538,0.073042,0.10636,0.0561,0.061278,0.038613,0.031885,0.02686,0.023003,0.019872,0.018507],"unified_progress":[0.23543,0.16409,0.082054,0.1125,0.077324,0.090654,0.056982,0.049525,0.042543,0.036191,0.030101,0.022602]},{"section":3,"text":"He noticed it after moving furniture, which makes me think of some sort of strain or physical exertion causing the issue.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.11816,0.18811,0.15222,0.098496,0.083778,0.08287,0.062332,0.063555,0.046162,0.04195,0.033691,0.028677],"unified_progress":[0.1089,0.1327,0.1172,0.1007,0.092592,0.090899,0.076146,0.081579,0.061644,0.056342,0.045637,0.035665]},{"section":4,"text":"He doesn't have nausea, vomiting, abdominal pain, or urinary symptoms, so maybe it's not something systemic.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.098969,0.16335,0.13422,0.099157,0.08273,0.083143,0.07072,0.075777,0.059024,0.052702,0.044555,0.03565],"unified_progress":[0.086486,0.11975,0.10518,0.099902,0.091988,0.090785,0.082089,0.086418,0.073617,0.067669,0.055703,0.040411]},{"section":5,"text":"On exam, the right hemi-scrotum is enlarged with a mass starting at the external inguinal ring.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.073336,0.13211,0.124,0.10734,0.09259,0.089838,0.079651,0.075298,0.077954,0.056672,0.048746,0.042472],"unified_progress":[0.067999,0.099472,0.10334,0.10888,0.10515,0.097942,0.08967,0.084388,0.088189,0.062198,0.051195,0.04157]},{"section":6,"text":"The key point here is that the mass can be reduced by pushing it back through the ring when he's relaxed.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.07463,0.1285,0.11625,0.102,0.091834,0.090775,0.081394,0.079182,0.074368,0.061778,0.05262,0.04667],"unified_progress":[0.074201,0.10197,0.10161,0.10357,0.10153,0.095377,0.08966,0.086087,0.081688,0.065929,0.053515,0.044873]},{"section":7,"text":"Then, when he does a Valsalva, the protrusion comes back.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.081341,0.13328,0.11489,0.096985,0.088061,0.08934,0.079869,0.081054,0.072067,0.061967,0.053575,0.047569],"unified_progress":[0.083311,0.1049,0.10011,0.09994,0.095908,0.093605,0.086713,0.086332,0.079254,0.067609,0.056156,0.046154]},{"section":8,"text":"That sounds like a hernia, specifically an inguinal hernia.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.059412,0.10056,0.10707,0.10621,0.09862,0.09067,0.086549,0.080375,0.077283,0.073939,0.060135,0.059181],"unified_progress":[0.064513,0.077702,0.090525,0.099155,0.099584,0.096963,0.093754,0.088622,0.086102,0.078928,0.066029,0.058123]},{"section":9,"text":"Wait, but the testicle looks normal after reduction.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.053248,0.095826,0.098149,0.096882,0.094807,0.09416,0.089694,0.087304,0.084308,0.076341,0.068174,0.061107],"unified_progress":[0.05611,0.084679,0.092357,0.10078,0.099785,0.095245,0.093432,0.090369,0.085714,0.080261,0.06654,0.054729]},{"section":10,"text":"So maybe it's not a testicular issue like torsion or hydrocele.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.038524,0.080807,0.093241,0.098809,0.098781,0.097354,0.095749,0.091038,0.090972,0.082529,0.070979,0.061218],"unified_progress":[0.039605,0.072892,0.090452,0.10352,0.10387,0.10209,0.099847,0.094053,0.091847,0.081326,0.066673,0.053831]},{"section":11,"text":"Since the mass is reducible and comes back with Valsalva, that's classic for a hernia.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.0