053,0.11154,0.10975,0.10477,0.073973],"unified_progress":[0.02614,0.055664,0.072437,0.080934,0.094529,0.095938,0.10147,0.10975,0.1077,0.11191,0.090025,0.053509]},{"section":23,"text":"The leukocytosis and fever are more infection-related.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022762,0.053712,0.068362,0.078512,0.086788,0.093506,0.10195,0.10475,0.10502,0.10423,0.099933,0.080477],"unified_progress":[0.030489,0.056546,0.071488,0.08046,0.090772,0.095906,0.10025,0.10477,0.10487,0.10677,0.092986,0.0647]},{"section":24,"text":"So putting it all together: prosthetic valve endocarditis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.031284,0.057907,0.066962,0.074074,0.07925,0.083117,0.087834,0.090369,0.095084,0.097883,0.10125,0.13498],"unified_progress":[0.037864,0.046313,0.055984,0.066154,0.071326,0.080165,0.083761,0.091073,0.096992,0.101,0.12039,0.14898]},{"section":25,"text":"The symptoms, time frame after surgery, and signs like friction rub (which can occur if the infection leads to pericarditis) all align.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.025993,0.056335,0.069484,0.078918,0.086264,0.091808,0.09733,0.097771,0.10011,0.10088,0.099159,0.095957],"unified_progress":[0.031577,0.048785,0.060875,0.071066,0.079951,0.089467,0.092894,0.099418,0.10602,0.11103,0.11024,0.098673]},{"section":26,"text":"The JVP could be from some cardiac issue related to the infection, maybe some heart failure or pericardial involvement.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.021919,0.052125,0.066123,0.078575,0.089322,0.09773,0.1043,0.10371,0.1045,0.099736,0.096373,0.085588],"unified_progress":[0.026922,0.042772,0.056249,0.067436,0.080567,0.092469,0.097367,0.10396,0.11194,0.11487,0.11217,0.093278]},{"section":27,"text":"I think that's the most likely diagnosis here.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.030991,0.05802,0.069108,0.076292,0.082203,0.085394,0.089859,0.