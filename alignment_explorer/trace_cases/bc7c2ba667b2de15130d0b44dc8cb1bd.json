8464,0.080995,0.055761,0.060577,0.11404],"unified_progress":[0.19455,0.074833,0.065333,0.064023,0.073404,0.075091,0.094346,0.085108,0.081666,0.069482,0.063997,0.058164]},{"section":12,"text":"Could it be a heart issue?","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.028928,0.055716,0.075888,0.091257,0.097214,0.10258,0.10929,0.11146,0.11057,0.10498,0.07479,0.037318],"unified_progress":[0.035837,0.069315,0.067293,0.093772,0.10404,0.10021,0.10103,0.10647,0.10204,0.093592,0.077229,0.04918]},{"section":13,"text":"Like maybe a heart arrhythmia?","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02623,0.045619,0.063323,0.079126,0.091203,0.10297,0.1124,0.11776,0.11941,0.11702,0.085191,0.039747],"unified_progress":[0.033423,0.061437,0.078274,0.089034,0.09682,0.10079,0.10296,0.10462,0.10081,0.098399,0.079365,0.054065]},{"section":14,"text":"But again, those usually have more ongoing symptoms, not just a quick burst of feeling bad and then okay.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.044276,0.050683,0.057405,0.065366,0.074288,0.084607,0.095374,0.10432,0.11323,0.1203,0.1129,0.077252],"unified_progress":[0.047207,0.063001,0.072277,0.079171,0.087963,0.094466,0.095785,0.10015,0.099689,0.10033,0.089687,0.070277]},{"section":15,"text":"Plus, there's nothing here about any physical signs of a heart problem, like chest pain or shortness of breath.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.045711,0.049899,0.059989,0.070586,0.079827,0.089859,0.099737,0.10917,0.11693,0.12024,0.10056,0.05748],"unified_progress":[0.049926,0.064411,0.073982,0.081267,0.089658,0.093113,0.096205,0.10002,0.099844,0.10042,0.087157,0.063992]},{"section":16,"text":"So, I'm leaning towards a panic attack being the most likely explanation.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.018468,0.035369,0.046025,0.054956,0.061192,0.067684,0.073259,0.077738,0.085703,0.10177,0.1606,0.21723],"unified_progress":[0.019213,0.036447,0.046408,0.056757,0.061851,0.07196,0.078301,0.088059,0.098446,0.10876,0.14359,0.19021]},{"section":17,"text":"It matches up with the sudden onset and the way everything resolves quickly.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.020875,0.028983,0.03435,0.040504,0.048502,0.057961,0.070632,0.082103,0.10087,0.13266,0.18469,0.19787],"unified_progress":[0.027028,0.03897,0.048196,0.056689,0.067379,0.081814,0.086104,0.098147,0.11025,0.12096,0.13231,0.13216]},{"section":18,"text":"Yeah, that makes sense.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.087334,0.070685,0.066418,0.060592,0.063676,0.069294,0.075821,0.090811,0.088086,0.066546,0.079185,0.18155],"unified_progress":[0.17494,0.066981,0.056707,0.05932,0.068223,0.072638,0.088402,0.08699,0.087818,0.07616,0.074358,0.08746]},{"section":19,"text":"Panic attacks are pretty common when someone feels overwhelmed by anxiety, and this seems to check all the boxes for that.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.038257,0.04702,0.051036,0.055476,0.058714,0.062983,0.06716,0.069439,0.076519,0.0921,0.15177,0.22952],"unified_progress":[0.040093,0.056764,0.046339,0.065221,0.072454,0.07734,0.087783,0.086037,0.091332,0.099721,0.11788,0.15903]},{"section":20,"text":"Alright, I'm confident that this is probably a panic attack.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.015919,0.025751,0.030924,0.036458,0.041046,0.046257,0.051972,0.056691,0.068463,0.09741,0.20745,0.32166],"unified_progress":[0.012258,0.021893,0.028477,0.037199,0.042309,0.056866,0.061315,0.080583,0.10016,0.11342,0.17173,0.27379]},{"section":21,"text":"It fits the pattern perfectly, and there's nothing here suggesting otherwise.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.016671,0.025443,0.031237,0.037381,0.04344,0.050721,0.059427,0.067965,0.083567,0.11374,0.19794,0.27247],"unified_progress":[0.015325,0.023878,0.030695,0.038041,0.045548,0.05