se,"model_progress":[0.067272,0.11758,0.13315,0.12152,0.10641,0.085513,0.078785,0.06906,0.060279,0.065245,0.049252,0.045939],"unified_progress":[0.071666,0.092487,0.095425,0.10878,0.10108,0.094295,0.091317,0.083122,0.075058,0.079426,0.06066,0.046682]},{"section":6,"text":"But wait, could it be something cardiac?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.050864,0.1015,0.12352,0.12246,0.10763,0.089861,0.082253,0.075125,0.068234,0.071031,0.056564,0.05096],"unified_progress":[0.046735,0.081682,0.093992,0.10634,0.10246,0.095633,0.096568,0.089988,0.083838,0.085637,0.067079,0.050045]},{"section":7,"text":"Like a heart attack or arrhythmia?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.04166,0.087712,0.10492,0.10838,0.10435,0.096009,0.091855,0.086474,0.07967,0.078184,0.065665,0.055109],"unified_progress":[0.039628,0.074508,0.089275,0.099576,0.10029,0.098867,0.099807,0.095162,0.089816,0.087628,0.071451,0.053993]},{"section":8,"text":"The duration is important here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.041314,0.087419,0.10692,0.10961,0.10249,0.092141,0.088625,0.083596,0.078507,0.081175,0.067709,0.060488],"unified_progress":[0.047092,0.07349,0.085153,0.097552,0.097449,0.094171,0.097752,0.094,0.08933,0.0929,0.075134,0.055978]},{"section":9,"text":"Panic attacks usually peak around 10 minutes and then start to subside, which matches the 10-15 minutes mentioned.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.074761,0.11737,0.10187,0.093295,0.089045,0.088301,0.083988,0.08336,0.074644,0.071335,0.063435,0.058591],"unified_progress":[0.085153,0.096352,0.089956,0.087212,0.087938,0.08923,0.086855,0.089442,0.081676,0.078841,0.069524,0.057822]},{"section":10,"text":"Cardiac events can vary, but they might not resolve so quickly on their own.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.038327,0.075426,0.086319,0.092091,0.095153,0.095876,0.099158,0.097193,0.092371,0.0882,0.079598,0.060288],"unified_progress":[0.050275,0.06816,0.078706,0.085653,0.094605,0.09568,0.097499,0.099966,0.096466,0.098403,0.080067,0.054521]},{"section":11,"text":"Also, the \"impending doom\" is a key symptom of panic attacks.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.046527,0.084549,0.09134,0.094157,0.093923,0.091973,0.091882,0.08968,0.084636,0.086185,0.075752,0.069395],"unified_progress":[0.054851,0.071509,0.079856,0.08792,0.091388,0.094445,0.097983,0.095271,0.091638,0.092446,0.079751,0.062942]},{"section":12,"text":"But I should consider other possibilities.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.32603,0.053102,0.053274,0.062118,0.062681,0.063818,0.061013,0.068182,0.068858,0.064252,0.0669,0.049778],"unified_progress":[0.21561,0.084342,0.064488,0.064367,0.074096,0.073635,0.091883,0.080468,0.077214,0.062306,0.057263,0.054326]},{"section":13,"text":"Maybe a supraventricular tachycardia (SVT) or atrial fibrillation?","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.048855,0.10009,0.063897,0.10348,0.10659,0.1012,0.099658,0.091853,0.083781,0.077166,0.068622,0.054813],"unified_progress":[0.055585,0.087935,0.070201,0.0996,0.10438,0.10107,0.099183,0.096272,0.089543,0.081402,0.067034,0.047797]},{"section":14,"text":"Those can cause palpitations and chest discomfort.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.032286,0.067727,0.079801,0.090188,0.098205,0.10097,0.1043,0.099978,0.093831,0.088469,0.079798,0.064447],"unified_progress":[0.071128,0.064247,0.07427,0.080838,0.089523,0.096921,0.095487,0.097501,0.094177,0.092592,0.080991,0.062326]},{"section":15,"text":"However, SVT often has a sudden onset and offset, and the patient might not necessarily have the fear of dying.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.032198,0.067369,0.076667,0.084428,0.091372,0.096802,0.10271,0.10344,0.099192,0.094985,0.086395,0.064446],"unified_progress":[0.049532,0.065847,0.076404,0.082418,0.091891,0.095092,0.097819,0.1019,0.098922,0.1013,0.083724,0.055148]},{"section":16,"text":"But some arrhythmias can cause anxiety-like symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026306,0.059522,0.073802,0.084624,0.093533,0.098397,0.10437,0.10416,0.10035,0.097306,0.088544,0.069085],"unified_progress":[0.052237,0.059892,0.072439,0.081167,0.089884,0.095684,0.09882,0.10195,0.1,0.10134,0.086194,0.06039]},{"section":17,"text":"How do I differentiate?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30839,0.050301,0.051551,0.060693,0.062624,0.06505,0.063485,0.07198,0.07228,0.068041,0.070733,0.054877],"unified_progress":[0.2111,0.08107,0.062121,0.064304,0.073508,0.073811,0.090653,0.082591,0.079524,0.064085,0.058371,0.058861]},{"section":18,"text":"The absence of other symptoms like prolonged chest pain, diaphoresis, or shortness of breath that doesn't settle quickly might lean towards panic.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.058204,0.11136,0.065453,0.096761,0.095654,0.092666,0.09405,0.09028,0.084925,0.078976,0.072745,0.058928],"unified_progress":[0.071517,0.10505,0.06874,0.086672,0.093908,0.090345,0.092623,0.092726,0.089411,0.084643,0.072963,0.051405]},{"section":19,"text":"Also, the fact that he's back to normal afterward suggests it's not a\u6301\u7eed\u6027 cardiac issue.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.049877,0.091706,0.09308,0.089912,0.090141,0.092137,0.090354,0.090425,0.085904,0.083293,0.075471,0.0677],"unified_progress":[0.055154,0.080158,0.082546,0.088298,0.090412,0.091308,0.092486,0.092781,0.090017,0.089676,0.080324,0.066841]},{"section":20,"text":"But I can't rule out cardiac causes completely without an ECG or other tests.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.033412,0.071029,0.087313,0.093538,0.095372,0.094499,0.096091,0.094061,0.092172,0.089904,0.081553,0.071055],"unified_progress":[0.037634,0.069486,0.081131,0.090434,0.094933,0.09407,0.09745,0.095822,0.093921,0.095626,0.083466,0.066029]},{"section":21,"text":"However, given the information here, the classic triad of symptoms points more towards panic attack.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.036616,0.073322,0.087567,0.092088,0.090915,0.087394,0.088355,0.087264,0.086111,0.090863,0.08483,0.094675],"unified_progress":[0.038228,0.05891,0.069746,0.080637,0.083817,0.087038,0.092069,0.093072,0.094294,0.10018,0.10057,0.10143]},{"section":22,"text":"The \"sensation of impending doom\" is a hallmark of panic disorder.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.040508,0.073611,0.078917,0.083985,0.088754,0.091553,0.093453,0.093038,0.09106,0.090843,0.087087,0.087191],"unified_progress":[0.048856,0.061524,0.069691,0.076506,0.082733,0.090106,0.091158,0.095468,0.09643,0.097878,0.096725,0.092927]},{"section":23,"text":"Another thought: could it be a mitral valve prolapse with palpitations?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.030292,0.064331,0.077375,0.08599,0.09439,0.097378,0.1004,0.10174,0.099529,0.095941,0.086268,0.066373],"unified_progress":[0.036109,0.068219,0.085138,0.096418,0.098038,0.098671,0.10117,0.099367,0.096251,0.091026,0.075464,0.054126]},{"section":24,"text":"Or maybe a panic attack triggered by an underlying anxiety disorder.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.024194,0.055939,0.071038,0.082366,0.094267,0.10055,0.10499,0.1067,0.10386,0.099454,0.089789,0.066863],"unified_progress":[0.045566,0.068767,0.082415,0.091893,0.095388,0.097784,0.099812,0.099263,0.095127,0.092315,0.076406,0.055262]},{"section":25,"text":"The suddenness and self-limiting nature support panic.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029017,0.062768,0.074823,0.082738,0.089647,0.09434,0.098996,0.099565,0.09846,0.097295,0.091649,0.080702],"unified_progress":[0.058756,0.065567,0.073517,0.081782,0.087927,0.092739,0.094039,0.096486,0.094883,0.095833,0.086768,0.071703]},{"section":26,"text":"Also, the term \"impending doom\" is more commonly associated with anxiety episodes rather than cardiac events, though some heart issues can cause similar feelings.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02905,0.060031,0.071642,0.081346,0.089638,0.094911,0.10051,0.10144,0.099592,0.09884,0.092341,0.080657],"unified_progress":[0.03917,0.057454,0.071262,0.07997,0.08843,0.094417,0.097389,0.10085,0.10077,0.10283,0.092754,0.074704]},{"section":27,"text":"I think the most likely diagnosis here is a panic attack.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.026624,0.052253,0.06347,0.070272,0.075566,0.079272,0.084928,0.088772,0.094501,0.099848,0.10736,0.15713],"unified_progress":[0.026953,0.038318,0.046854,0.057473,0.061809,0.073363,0.077883,0.088187,0.097413,0.10685,0.1395,0.18539]},{"section":28,"text":"But I should make sure there's no life-threatening condition first.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.025867,0.055957,0.071183,0.079064,0.085324,0.08912,0.093521,0.096808,0.10087,0.10254,0.099553,0.10019],"unified_progress":[0.029663,0.054101,0.064893,0.07613,0.080544,0.085653,0.09079,0.09705,0.10206,0.11036,0.10838,0.10037]},{"section":29,"text":"Since the case says he's all right afterward, maybe it's more likely panic.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.033469,0.064182,0.071335,0.076692,0.082935,0.089125,0.092646,0.096251,0.097711,0.097845,0.096366,0.10144],"unified_progress":[0.044088,0.062572,0.066709,0.072251,0.076673,0.081629,0.085805,0.092175,0.095648,0.10191,0.10786,0.11269]},{"section":30,"text":"So the answer is panic attack.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.023971,0.045779,0.055107,0.062314,0.069995,0.076771,0.08422,0.089738,0.098368,0.1028,0.11592,0.17501],"unified_progress":[0.024398,0.033477,0.040584,0.049405,0.054516