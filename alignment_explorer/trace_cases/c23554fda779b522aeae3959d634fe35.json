"unified_progress":[0.039767,0.063442,0.076305,0.085589,0.093016,0.097666,0.097105,0.096946,0.099171,0.093352,0.085827,0.071815]},{"section":16,"text":"The normal complement levels also fit because in IgA nephropathy, complement isn't typically consumed like in some other glomerulonephritides.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.035823,0.070051,0.082202,0.091025,0.095963,0.0969,0.099222,0.095643,0.090717,0.089503,0.079949,0.073002],"unified_progress":[0.040952,0.061977,0.07909,0.088164,0.095177,0.10167,0.10124,0.098164,0.094775,0.091008,0.080744,0.067041]},{"section":17,"text":"The ANA is negative, so lupus is less likely.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.029901,0.066645,0.08341,0.091087,0.094254,0.095421,0.10009,0.098888,0.096246,0.092191,0.085791,0.066077],"unified_progress":[0.035259,0.068855,0.083012,0.090546,0.098632,0.097563,0.10199,0.098575,0.095285,0.095031,0.079194,0.056056]},{"section":18,"text":"The mesangial deposits with IgA and C3 are pathognomonic for IgA nephropathy.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031036,0.065505,0.079334,0.088731,0.093577,0.095606,0.097908,0.094676,0.094504,0.091318,0.084901,0.082903],"unified_progress":[0.035229,0.059895,0.077331,0.088089,0.094848,0.10071,0.10039,0.097193,0.095975,0.08975,0.08436,0.076234]},{"section":19,"text":"So putting it all together, the most likely diagnosis is IgA nephropathy.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.026936,0.051467,0.061775,0.068712,0.074234,0.078219,0.084162,0.087694,0.094067,0.098889,0.10891,0.16493],"unified_progress":[0.027313,0.037622,0.04679,0.057489,0.062297,0.073483,0.076443,0.089214,0.098504,0.10653,0.14007,0.18425]}]}}