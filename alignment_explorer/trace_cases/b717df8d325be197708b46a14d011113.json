10022,0.10061,0.0977,0.096863,0.090096,0.078199,0.063424]},{"section":20,"text":"Or maybe an injury during surgery caused a biliary-enteric anastomosis issue, leading to infection.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031542,0.073007,0.086457,0.095255,0.097402,0.10076,0.099637,0.094443,0.098942,0.08464,0.074415,0.0635],"unified_progress":[0.037421,0.071767,0.09019,0.10222,0.10703,0.10436,0.10182,0.095063,0.093713,0.079059,0.064896,0.052461]},{"section":21,"text":"Also, the term \"toxic\" suggests systemic infection, so sepsis from a biliary source.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029024,0.06345,0.076878,0.08665,0.093792,0.098173,0.10216,0.099409,0.096804,0.09293,0.085628,0.075107],"unified_progress":[0.03684,0.057977,0.071765,0.081073,0.090722,0.094581,0.098699,0.099936,0.10052,0.098539,0.092258,0.077094]},{"section":22,"text":"The patient is hemodynamically stable now, but the toxic appearance is concerning.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.038534,0.075872,0.080783,0.083674,0.088371,0.093415,0.096091,0.097142,0.094607,0.090903,0.085859,0.074748],"unified_progress":[0.043127,0.070071,0.075389,0.080401,0.0875,0.091614,0.094258,0.097051,0.097066,0.098672,0.091336,0.073514]},{"section":23,"text":"So putting it together: post-op cholecystectomy, Charcot's triad (fever, jaundice, RUQ pain), so acute cholangitis.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.040863,0.07101,0.076267,0.081918,0.086726,0.09007,0.092905,0.09265,0.093263,0.092678,0.089965,0.091683],"unified_progress":[0.051644,0.05865,0.069408,0.076973,0.084353,0.091199,0.092705,0.095612,0.097229,0.096564,0.095248,0.090415]},{"section":24,"text":"But after surgery, maybe from a retained stone or injury leading to obstruction and infection.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027347,0.060436,0.074149,0.084593,0.092136,0.097548,0.10132,0.099209,0.10037,0.09414,0.088991,0.079765],"unified_progress":[0.051284,0.060129,0.070902,0.0794,0.087148,0.092926,0.094269,0.096816,0.099178,0.096712,0.091759,0.079476]},{"section":25,"text":"The most likely diagnosis here would be acute cholangitis, perhaps post-cholecystectomy.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.025292,0.052601,0.063079,0.071343,0.078287,0.084577,0.089885,0.092071,0.098453,0.097464,0.1037,0.14325],"unified_progress":[0.026982,0.04203,0.05382,0.063786,0.06929,0.079726,0.083241,0.09174,0.10157,0.10414,0.12737,0.15631]},{"section":26,"text":"Alternatively, could it be a liver abscess?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.018097,0.046763,0.063348,0.075257,0.088866,0.096096,0.10309,0.11015,0.11195,0.1094,0.10287,0.074095],"unified_progress":[0.025411,0.059575,0.078137,0.090529,0.095378,0.097773,0.10378,0.10519,0.10425,0.10018,0.083741,0.056059]},{"section":27,"text":"But the timing and the triad make cholangitis more likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.01684,0.045503,0.062475,0.073172,0.083671,0.090699,0.10172,0.10771,0.11062,0.11086,0.10852,0.088223],"unified_progress":[0.026238,0.051846,0.067333,0.077051,0.088862,0.093175,0.098791,0.10703,0.10751,0.1124,0.098135,0.071629]},{"section":28,"text":"Also, the upper abdominal fullness might indicate distension from bile duct obstruction.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.028362,0.06619,0.078023,0.08599,0.089784,0.096016,0.0983,0.097023,0.10671,0.09208,0.086272,0.075253],"unified_progress":[0.033565,0.064722,0.081061,0.09321,0.099566,0.10132,0.10041,0.098007,0.10313,0.087939,0.077387,0.059686]},{"section":29,"text":"Another point: the patient had a cholecystectomy, so the common bile duct isn't directly connected anymore unless there was an injury.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.034177,0.074558,0.085468,0.092905,0.09515,0.10074,0.097473,0.093828,0.099006,0.087256,0.075269,0.064173],"unified_progress":[0.056954,0.09006,0.095421,0.10127,0.10326,0.098391,0.096101,0.09024,0.088518,0.072541,0.058742,0.048504]},{"section":30,"text":"But even so, the key symptoms align with cholangitis.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.029075,0.063295,0.077748,0.086559,0.092149,0.09493,0.098529,0.097164,0.096984,0.095019,0.088019,0.080529],"unified_progress":[0.049196,0.067182,0.078673,0.08711,0.092865,0.092713,0.09511,0.095247,0.09358,0.092303,0.08335,0.072669]},{"section":31,"text":"So I think the answer is acute cholangitis, maybe specifically post-cholecystectomy cholangitis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.022035,0.043904,0.053153,0.061695,0.070733,0.078992,0.086327,0.091143,0.099611,0.10123,0.1149,0.17628],"unified_progress":[0.023928,0.034509,0.04435,0.054355,0.059349,0.071835,0.075236,0.086452,0.098595,0.10599,0.1456,0.19981]}]}}