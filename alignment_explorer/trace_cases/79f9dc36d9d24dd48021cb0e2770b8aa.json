.054093,0.080732,0.092671,0.098704,0.10024,0.10118,0.095577,0.091418,0.086406,0.077458,0.066505,0.05501]},{"section":11,"text":"Ptosis is usually due to weakness in the eye muscles, often related to a neurological issue.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.034315,0.058618,0.078866,0.093045,0.10144,0.1052,0.10774,0.10509,0.098214,0.088962,0.069934,0.058577],"unified_progress":[0.035396,0.065239,0.088954,0.099275,0.10211,0.1105,0.10519,0.099736,0.092777,0.084866,0.06727,0.048686]},{"section":12,"text":"The pupil being smaller on the left could indicate something affecting the parasympathetic nervous system, which controls pupil size.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.037058,0.057166,0.076422,0.090237,0.10151,0.10687,0.10876,0.10577,0.098431,0.08639,0.072015,0.05938],"unified_progress":[0.038679,0.066061,0.085367,0.096832,0.1028,0.10593,0.10372,0.099606,0.094716,0.084949,0.069128,0.052216]},{"section":13,"text":"Chronic smoking can affect the nervous system, maybe leading to conditions like Horner's syndrome.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.032802,0.057954,0.076831,0.089728,0.097579,0.10216,0.10675,0.10489,0.099585,0.094641,0.075325,0.061756],"unified_progress":[0.037931,0.068255,0.085927,0.097247,0.1005,0.10541,0.10364,0.10009,0.093849,0.086153,0.069561,0.051442]},{"section":14,"text":"Horner's is characterized by ptosis, miosis (smaller pupil), and sometimes anhidrosis ( inability to sweat).","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.024336,0.046502,0.06524,0.079214,0.098006,0.1086,0.1129,0.11718,0.11321,0.094595,0.076111,0.064116],"unified_progress":[0.029756,0.058634,0.083123,0.09558,0.10241,0.11305,0.10978,0.10459,0.097222,0.087776,0.068178,0.049897]},{"section":15,"text":"The patient's symptoms align with that.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.050966,0.067749,0.072851,0.079226,0.082128,0.086069,0.090777,0.09