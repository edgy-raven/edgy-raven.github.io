018646],"unified_progress":[0.13909,0.17726,0.13442,0.085143,0.077293,0.084856,0.061465,0.084326,0.048739,0.043469,0.036051,0.027886]},{"section":4,"text":"On exam, there's an inset left eyeball, drooping upper left eyelid, and a reduced left pupil size.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.12093,0.20025,0.16028,0.10304,0.07609,0.075884,0.058583,0.062758,0.047337,0.037493,0.03096,0.026392],"unified_progress":[0.10259,0.137,0.11827,0.11125,0.091946,0.090393,0.075008,0.079417,0.066802,0.051152,0.042495,0.033684]},{"section":5,"text":"Hmm, those eye signs stand out.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.06944,0.12053,0.13461,0.12568,0.10485,0.085236,0.076588,0.068045,0.060433,0.064544,0.046762,0.043284],"unified_progress":[0.068316,0.091908,0.095849,0.10809,0.10218,0.093693,0.091926,0.084285,0.076869,0.081776,0.059271,0.045836]},{"section":6,"text":"Inset eyeball, ptosis, and miosis... that combination makes me think of Horner's syndrome.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.063754,0.10544,0.11055,0.11021,0.10298,0.092911,0.085981,0.078513,0.070296,0.068465,0.056637,0.054251],"unified_progress":[0.067182,0.078464,0.090366,0.098793,0.098616,0.098853,0.094257,0.090246,0.083419,0.079182,0.065553,0.055069]},{"section":7,"text":"Wait, Horner's syndrome is due to a disruption in the sympathetic pathway.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.047358,0.084884,0.096552,0.10304,0.10343,0.098009,0.095632,0.088148,0.080518,0.078354,0.065592,0.058484],"unified_progress":[0.068898,0.070633,0.085438,0.094327,0.096888,0.099846,0.096083,0.093189,0.086658,0.082871,0.068446,0.056722]},{"section":8,"text":"The three key signs are ptosis (drooping eyelid), miosis (constricted pupil), and anhidrosis (lack of sweating on the same side of the face).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.051194,0.091953,0.092529,0.094993,0.097247,0.098148,0.095567,0.090921,0.081887,0.079235,0.0663,0.060026],"unified_progress":[0.054396,0.07813,0.090532,0.09421,0.097153,0.10251,0.096908,0.095276,0.088236,0.08065,0.067188,0.054808]},{"section":9,"text":"The patient has the first two.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.042873,0.084391,0.09595,0.098312,0.096918,0.093201,0.092297,0.088852,0.083996,0.083701,0.073717,0.065791],"unified_progress":[0.079383,0.076933,0.081614,0.088942,0.09163,0.091501,0.090735,0.091366,0.086122,0.086653,0.07405,0.061072]},{"section":10,"text":"The eyeball might appear sunken or inset because of the ptosis and miosis making the eye look smaller compared to the other side.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.052007,0.093756,0.094729,0.095403,0.093646,0.094456,0.091716,0.087946,0.087141,0.076908,0.068579,0.063713],"unified_progress":[0.059901,0.081268,0.091955,0.099467,0.098947,0.097357,0.09337,0.090575,0.087401,0.076146,0.065911,0.057703]},{"section":11,"text":"Now, considering he's a chronic smoker, that's a risk factor for lung cancer.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.046191,0.083653,0.090446,0.093838,0.096065,0.10314,0.093211,0.090972,0.084942,0.086815,0.071233,0.059496],"unified_progress":[0.095229,0.12155,0.10193,0.09413,0.087804,0.086181,0.080788,0.084797,0.073715,0.068982,0.058094,0.046807]},{"section":12,"text":"But Horner's syndrome can be caused by a Pancoast tumor, which is a type of lung cancer that occurs in the apex of the lung.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034718,0.072197,0.085447,0.095944,0.10042,0.10342,0.10101,0.093285,0.094616,0.084349,0.07095,0.063639],"unified_progress":[0.055297,0.082951,0.10184,0.10129,0.10005,0.10369,0.09431,0.090075,0.086808,0.073479,0.06032,0.049894]},{"section":13,"text":"These tumors can compress the cervical sympathetic chain, leading to Horner's.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030608,0.068263,0.082218,0.093089,0.099079,0.10204,0.10253,0.096088,0.094398,0.08802,0.075013,0.068648],"unified_progress":[0.044362,0.066397,0.086268,0.095874,0.10017,0.10632,0.10001,0.095371,0.092635,0.082503,0.070539,0.059558]},{"section":14,"text":"The chest pain might also be related to the tumor in the lung.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.030069,0.066807,0.07975,0.089247,0.09476,0.09977,0.1013,0.09773,0.098631,0.089859,0.081441,0.070638],"unified_progress":[0.045218,0.067412,0.079386,0.088176,0.095502,0.098389,0.097236,0.096459,0.096881,0.089422,0.080192,0.065725]},{"section":15,"text":"Alternatively, other causes of Horner's could be a carotid artery dissection, but that's less common in a smoker with these additional symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026613,0.061886,0.07694,0.087189,0.094108,0.098446,0.10229,0.10165,0.099506,0.097243,0.085955,0.068175],"unified_progress":[0.034772,0.065396,0.080483,0.089796,0.096481,0.10002,0.10097,0.10096,0.09816,0.096455,0.079781,0.056721]},{"section":16,"text":"Since he's a smoker, malignancy is a big concern here.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.034474,0.070632,0.082853,0.089276,0.093223,0.098672,0.095429,0.095048,0.091748,0.093654,0.082032,0.07296],"unified_progress":[0.07064,0.099202,0.090127,0.088517,0.087369,0.087576,0.087782,0.088454,0.083295,0.082049,0.07299,0.061999]},{"section":17,"text":"The combination of Horner's with chest pain and smoking points towards a Pancoast tumor.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030199,0.066069,0.080513,0.088676,0.091985,0.094306,0.095507,0.092627,0.097174,0.092694,0.086322,0.083928],"unified_progress":[0.04442,0.071443,0.081904,0.090667,0.092849,0.093733,0.093423,0.09175,0.093794,0.089174,0.082163,0.074679]},{"section":18,"text":"Let me make sure there's no other obvious causes.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.025