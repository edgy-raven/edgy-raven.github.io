.097675,0.096314,0.091755,0.085328,0.085947,0.072562,0.066961],"unified_progress":[0.048374,0.068008,0.079806,0.089662,0.093874,0.10053,0.097218,0.09674,0.092614,0.090789,0.077576,0.064809]},{"section":9,"text":"Acoustic neuromas are often associated with unilateral hearing loss, tinnitus, and maybe imbalance because the vestibular part of the nerve is involved.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034047,0.072206,0.084478,0.094441,0.10034,0.10203,0.10183,0.095567,0.089125,0.08743,0.072846,0.065671],"unified_progress":[0.037704,0.062675,0.081769,0.09153,0.097347,0.1061,0.10225,0.10003,0.096082,0.089735,0.074675,0.060102]},{"section":10,"text":"The patient doesn't have other cranial nerve deficits, which is possible because the tumor might be small or just affecting the nerve.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033151,0.073803,0.085511,0.09183,0.094171,0.097784,0.098567,0.095994,0.097072,0.088002,0.078855,0.065261],"unified_progress":[0.039951,0.068639,0.082502,0.092319,0.099194,0.098795,0.098556,0.098226,0.098173,0.091411,0.074918,0.057314]},{"section":11,"text":"The location in the cerebello-pontine angle is classic for these tumors.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.032359,0.075189,0.089695,0.097565,0.096617,0.097813,0.095893,0.089765,0.10099,0.083056,0.072923,0.068134],"unified_progress":[0.03572,0.069802,0.088611,0.10255,0.10671,0.10344,0.10106,0.093899,0.097238,0.078155,0.065771,0.057043]},{"section":12,"text":"Extra-axial also fits since schwannomas grow outside the brain's parenchyma.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.034232,0.077306,0.090618,0.098668,0.098061,0.098919,0.096575,0.090051,0.096402,0.082282,0.070944,0.065942],"unified_progress":[0.035793,0.069539,0.089816,0.10453,0.10944,0.10587,0.1028,0.094535,0.094352,0.076535,0.06248,0.054314]},{"section":13,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.031996,0.073338,0.096197,0.10151,0.099735,0.092565,0.091515,0.088454,0.085551,0.09186,0.076144,0.071139],"unified_progress":[0.033339,0.07049,0.085514,0.097915,0.098578,0.093778,0.098368,0.095168,0.091063,0.095714,0.077505,0.062568]},{"section":14,"text":"Maybe a meningioma, but those are more common in different locations like convexity or sphenoid ridge.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026079,0.062539,0.078609,0.089899,0.096609,0.10027,0.10311,0.10061,0.098499,0.093461,0.083008,0.067306],"unified_progress":[0.031657,0.062477,0.080174,0.093711,0.099584,0.10297,0.10178,0.10228,0.099316,0.093628,0.076011,0.056417]},{"section":15,"text":"Also, meningiomas might present with different symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.019975,0.051288,0.067936,0.080528,0.089983,0.096835,0.10603,0.1083,0.10693,0.10551,0.096307,0.070372],"unified_progress":[0.02605,0.053796,0.071383,0.081917,0.093644,0.099477,0.10288,0.10877,0.10744,0.11219,0.087227,0.05522]},{"section":16,"text":"Another thought: vestibular schwannoma is another term for acoustic neuroma.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.024567,0.056283,0.071247,0.084089,0.093835,0.098953,0.1027,0.10141,0.09812,0.098399,0.086931,0.083461],"unified_progress":[0.028872,0.054037,0.071909,0.085828,0.092053,0.10213,0.10169,0.10252,0.09999,0.096041,0.087229,0.077705]},{"section":17,"text":"Since the MRI with gadolinium shows a tumor there, that's the likely diagnosis.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031472,0.069805,0.083519,0.090141,0.091193,0.093126,0.094578,0.091944,0.096163,0.088629,0.083454,0.085976],"unified_progress":[0.03343,0.063934,0.079286,0.090231,0.095781,0.095942,0.095114,0.094428,0.095731,0.087692,0.085159,0.083273]},{"section":18,"text":"The gradual onset and unilateral symptoms are key here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.029769