070477],"unified_progress":[0.052723,0.071516,0.083553,0.091535,0.094645,0.098019,0.09536,0.094361,0.090429,0.088579,0.076655,0.062625]},{"section":11,"text":"Hmm, I remember that bleomycin is a chemotherapy drug known to cause pulmonary toxicity.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.040301,0.072545,0.083755,0.092985,0.098549,0.098675,0.098385,0.094158,0.088184,0.088158,0.075395,0.06891],"unified_progress":[0.054346,0.06787,0.08326,0.092105,0.096133,0.10038,0.098581,0.096313,0.090503,0.088,0.07326,0.059253]},{"section":12,"text":"It can lead to interstitial lung disease, which presents with dyspnea, cough, crackles, and even pulmonary fibrosis.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.031756,0.065706,0.076118,0.086242,0.095222,0.10039,0.10386,0.10016,0.0945,0.091793,0.082242,0.072016],"unified_progress":[0.037654,0.057241,0.072279,0.080394,0.089758,0.10137,0.09943,0.10104,0.10081,0.09876,0.089501,0.071762]},{"section":13,"text":"Clubbing can occur in chronic lung diseases, so that fits.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.02884,0.06132,0.075211,0.086133,0.093926,0.09756,0.10214,0.10012,0.096733,0.095321,0.086573,0.076132],"unified_progress":[0.043838,0.053256,0.067056,0.077229,0.087212,0.095724,0.098149,0.10116,0.1019,0.10326,0.094557,0.076659]},{"section":14,"text":"But wait, is bleomycin part of the standard regimen for testicular cancer?","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.0405,0.070419,0.077359,0.084552,0.091102,0.096585,0.096141,0.096334,0.093705,0.09294,0.083538,0.076826],"unified_progress":[0.071839,0.084656,0.082586,0.08436,0.086428,0.08872,0.089263,0.091702,0.087241,0.086511,0.078482,0.068212]},{"section":15,"text":"Wait, testicular cancer regimens like BEP (bleomycin, etoposide, cisplatin) are commonly used for germ cell tumors, including embryonal carcinoma.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039243,0.06948