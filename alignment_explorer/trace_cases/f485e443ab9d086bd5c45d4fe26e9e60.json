ified_progress":[0.038428,0.073592,0.090624,0.10347,0.10554,0.10194,0.099917,0.093804,0.091317,0.080602,0.066798,0.053964]},{"section":12,"text":"Clubbing usually means there's been long-term hypoxia or some chronic lung issue.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.030224,0.059486,0.082714,0.10167,0.11003,0.1137,0.11189,0.10329,0.094335,0.08839,0.067893,0.036385],"unified_progress":[0.037804,0.069434,0.088204,0.10005,0.10282,0.10501,0.10397,0.098295,0.092409,0.083871,0.068125,0.050009]},{"section":13,"text":"Hmm, that's definitely not good.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.12138,0.096677,0.090554,0.081072,0.080903,0.080921,0.081146,0.087333,0.076957,0.051077,0.052317,0.099662],"unified_progress":[0.2114,0.079106,0.066687,0.066632,0.075713,0.074005,0.095269,0.08144,0.077188,0.061224,0.056681,0.054657]},{"section":14,"text":"Let's look at those pulmonary function tests.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.01948,0.070462,0.10754,0.1179,0.11675,0.11171,0.10289,0.095572,0.086674,0.080724,0.060953,0.029344],"unified_progress":[0.046221,0.10514,0.079713,0.098995,0.10356,0.096168,0.089718,0.092436,0.085392,0.080288,0.071177,0.051189]},{"section":15,"text":"The FVC is 78%, which isn't too bad, but the FEV1/FVC ratio is 92%.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.028658,0.065047,0.099542,0.12809,0.13719,0.12996,0.11374,0.091054,0.072919,0.061358,0.045675,0.026763],"unified_progress":[0.042403,0.074326,0.093929,0.12771,0.10847,0.10199,0.096906,0.08835,0.08561,0.069166,0.057708,0.053432]},{"section":16,"text":"That's actually normal, so it doesn't suggest any obstructive lung disease.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.041829,0.0695,0.09461,0.11572,0.12194,0.11852,0.10931,0.09313,0.079899,0.068301,0.05347,0.033765],"unified_progress":[0.0504,0.074279,0.092338,0.10351,0.10863,0.1001,0.1,0.092059,0.088126,0.075009,0.063308,0.05223]},{"section":17,"text":"But wait, if it were restrictive, that could mean something like interstitial lung disease or fibrosis.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.031785,0.05414,0.078535,0.098381,0.10812,0.1127,0.11248,0.10714,0.10017,0.092795,0.068546,0.035199],"unified_progress":[0.04148,0.066678,0.085407,0.096579,0.10225,0.10237,0.10216,0.098822,0.094366,0.087583,0.070854,0.051449]},{"section":18,"text":"That fits with the crackles and clubbing.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.020062,0.046761,0.058518,0.068421,0.077073,0.085127,0.093383,0.097502,0.10621,0.11858,0.12931,0.099053],"unified_progress":[0.032878,0.056985,0.072594,0.081716,0.091847,0.099255,0.098977,0.099875,0.10068,0.098118,0.092272,0.0748]},{"section":19,"text":"So, back to the chemo.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.015193,0.049973,0.076574,0.092185,0.099098,0.10387,0.10467,0.10656,0.10839,0.10834,0.087297,0.047861],"unified_progress":[0.033049,0.065473,0.079229,0.093244,0.094936,0.094814,0.097153,0.096602,0.094877,0.098486,0.085456,0.066681]},{"section":20,"text":"Certain types of chemotherapy are notorious for causing lung problems.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.027678,0.042229,0.059392,0.07612,0.090756,0.1033,0.11382,0.11609,0.11916,0.12195,0.08775,0.041745],"unified_progress":[0.036415,0.0589,0.07774,0.08938,0.098387,0.10924,0.10426,0.10249,0.097006,0.092032,0.074818,0.059334]},{"section":21,"text":"Bleomycin comes to mind.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.020833,0.038337,0.054878,0.07175,0.088589,0.10422,0.11667,0.12081,0.12661,0.12988,0.08869,0.038742],"unified_progress":[0.030213,0.056754,0.079687,0.093985,0.10055,0.10933,0.10788,0.10437,0.098125,0.092097,0.072219,0.054787]},{"section":22,"text":"It's known for causing pulmonary toxicity, leading to conditions like pulmonary fibrosis.","dimension":7,"group":3,"is_degene