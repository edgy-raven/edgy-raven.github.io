mension":5,"group":1,"is_degenerate":false,"model_progress":[0.046486,0.084752,0.090122,0.094591,0.095704,0.096861,0.095094,0.09065,0.088383,0.081693,0.070774,0.064891],"unified_progress":[0.053842,0.070003,0.083955,0.093223,0.098274,0.09998,0.097408,0.095116,0.093012,0.083405,0.071555,0.060224]},{"section":11,"text":"The opposing tooth might be causing some trauma or making it harder to clean that area, contributing to the infection.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.039314,0.077875,0.085822,0.091448,0.094335,0.097642,0.097356,0.094015,0.093395,0.085314,0.076255,0.06723],"unified_progress":[0.044187,0.066212,0.079367,0.088595,0.095482,0.097784,0.097797,0.096837,0.097313,0.08994,0.080008,0.06648]},{"section":12,"text":"Trismus is a symptom that can occur because the infection spreads to the surrounding muscles, causing swelling and pain that limits movement.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.030227,0.064613,0.075999,0.08559,0.093276,0.098546,0.10234,0.099743,0.098291,0.091642,0.085436,0.074298],"unified_progress":[0.044448,0.056328,0.068233,0.077181,0.087691,0.094806,0.097315,0.099939,0.10213,0.10036,0.093617,0.07795]},{"section":13,"text":"The fever and increased pulse rate indicate that this is a more severe infection, possibly a cellulitis.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027405,0.05967,0.071998,0.081994,0.090429,0.096277,0.10158,0.10084,0.099345,0.09639,0.09141,0.082663],"unified_progress":[0.031917,0.049279,0.060926,0.070621,0.082576,0.092282,0.096767,0.10188,0.10703,0.10969,0.10661,0.090424]},{"section":14,"text":"Other possibilities might include a dental abscess, but that's more likely to be a localized abscess around the tooth, maybe with a draining fistula.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026279,0.059828,0.073415,0.083686,0.090873,0.096246,0.10152,0.10195,0.10232,0.098531,0.090062,0.075292],"unified_progress":[0.029379,0.054497,0.070795,0.081976,0.091158,0.096274,0.10051,0.10329,0.10438,0.10532,0.09256,0.069872]},{"section":15,"text":"But the presence of a gum flap over the impacted tooth and the signs of pericoronitis fit better here.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030231,0.067553,0.080397,0.087621,0.090303,0.093697,0.095452,0.09414,0.099601,0.093458,0.086903,0.080645],"unified_progress":[0.032805,0.061326,0.076318,0.088316,0.09505,0.097597,0.099429,0.098286,0.10121,0.094143,0.084387,0.071133]},{"section":16,"text":"Also, since the opposing tooth is impinging, that could be causing some mechanical irritation, leading to the inflammation and subsequent infection.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029711,0.063984,0.075491,0.084457,0.090788,0.096645,0.099401,0.097992,0.099442,0.094425,0.087864,0.079799],"unified_progress":[0.038314,0.0594,0.07098,0.080982,0.089245,0.09377,0.097051,0.099064,0.10191,0.098306,0.091977,0.078996]},{"section":17,"text":"I don't think it's something like osteomyelitis, which is a bone infection, but that's more severe and might have different symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.020951,0.05174,0.067873,0.079509,0.088542,0.094568,0.10368,0.10666,0.10641,0.10551,0.098388,0.076163],"unified_progress":[0.025892,0.052194,0.068802,0.079108,0.090605,0.09475,0.1006,0.10651,0.10674,0.11237,0.096362,0.066064]},{"section":18,"text":"Plus, in a young person with these dental issues, pericoronitis is much more common.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.028349,0.059583,0.071541,0.079971,0.086521,0.092847,0.096636,0.099332,0.099217,0.10149,0.094791,0.089725],"unified_progress":[0.046505,0.068356,0.071886,0.076968,0.082421,0.087196,0.092485,0.095925,0.09632,0.10065,0.094872,0.086414]},{"section":19,"text":"So putting it all together, the most likely diagnosis is pericoronitis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.030617,0.054607,0.06314,0.069517,0.073961,0.077159,0.082936,0.086731,0.092617,0.099794,0.10778,0.16114],"unified_progress":[0.034254,0.039676,0.047921,0.057661,0.062685,0.070938,0.077212,0.085097,0.093846,0.10582,0.13865,0.18625]}]}}