e":false,"model_progress":[0.14811,0.17857,0.10708,0.08635,0.07578,0.070251,0.063831,0.058846,0.057409,0.061212,0.053709,0.038852],"unified_progress":[0.043961,0.097356,0.075631,0.096852,0.10226,0.096391,0.092258,0.095403,0.089382,0.084064,0.073523,0.052917]},{"section":11,"text":"There's also something called \"demonomania,\" which is a type of delusional disorder where the person believes they're being persecuted by demons or the devil.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.044529,0.07091,0.088592,0.090592,0.10444,0.1057,0.10346,0.10095,0.094317,0.080793,0.06339,0.052311],"unified_progress":[0.031742,0.060526,0.082031,0.092677,0.10233,0.11476,0.10626,0.10253,0.095567,0.088971,0.069061,0.053546]},{"section":12,"text":"That fits because he feels compelled to think the devil is after him even after he's cleaned, which he knows logically isn't true.","dimension":0,"group":5,"is_degenerate":false,"model_progress":[0.059477,0.081473,0.084802,0.087077,0.087502,0.089496,0.092091,0.090871,0.089325,0.086451,0.079244,0.072189],"unified_progress":[0.057201,0.073064,0.078415,0.084506,0.08923,0.094485,0.092871,0.095639,0.091962,0.089476,0.08147,0.071681]},{"section":13,"text":"Alternatively, could it be something else?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.33005,0.14611,0.067568,0.053048,0.061933,0.062428,0.056563,0.060802,0.055019,0.040867,0.04157,0.024045],"unified_progress":[0.20987,0.08328,0.063267,0.063765,0.073906,0.073063,0.094423,0.08082,0.07808,0.063598,0.059161,0.056765]},{"section":14,"text":"Maybe a dissociative identity disorder, but that usually involves switching identities or alter personas, which doesn't quite fit here.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.059918,0.077835,0.095319,0.098993,0.098796,0.096774,0.09622,0.09226,0.087555,0.082316,0.067761,0.046253],"unified_progress":[0.038536,0.06711,0.062966,0.093001,0.10343,0.101,0.1015,0.10716,0.10249,0.095854,0.077401,0.049554]},{"section":15,"text":"Or perhaps a persecutory delusional disorder, where the person believes they're being harmed or followed.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.041032,0.06044,0.074629,0.083291,0.093529,0.099885,0.10189,0.10508,0.10322,0.093877,0.080096,0.06302],"unified_progress":[0.038419,0.062449,0.079171,0.090119,0.096419,0.10344,0.10253,0.10252,0.09801,0.092913,0.076925,0.057091]},{"section":16,"text":"That's a possibility too.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.041652,0.067015,0.074801,0.082589,0.087554,0.091911,0.096569,0.098259,0.099495,0.099674,0.089581,0.0709],"unified_progress":[0.036059,0.063598,0.078753,0.091233,0.095373,0.097465,0.099926,0.099214,0.09618,0.096741,0.081647,0.063812]},{"section":17,"text":"But demonomania seems more specific to the content of the delusion involving demons or the devil.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.045515,0.05745,0.066516,0.073874,0.081409,0.087405,0.092422,0.097064,0.10033,0.10099,0.098771,0.098258],"unified_progress":[0.038646,0.057107,0.071294,0.082417,0.087968,0.094575,0.095875,0.097312,0.096657,0.096883,0.092734,0.088532]},{"section":18,"text":"The fact that he's compelled to think this despite knowing it's not true points towards a delusional disorder rather than a more general persecutory delusion.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.043909,0.050631,0.062111,0.069431,0.077095,0.084112,0.08988,0.096727,0.10194,0.10508,0.10779,0.11129],"unified_progress":[0.039116,0.052056,0.064296,0.073651,0.081435,0.089273,0.091942,0.098012,0.10015,0.10401,0.1037,0.10236]},{"section":19,"text":"So, I think demonomania is the most accurate diagnosis here.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.032825,0.056749,0.059736,0.065215,0.067381,0.071286,0.07867,0.083893,0.092914,0.10921,0.12594,0.15618],"unified_progress":[0.024649,0.045953,0.056667,0.068202,0.072458,0.080147