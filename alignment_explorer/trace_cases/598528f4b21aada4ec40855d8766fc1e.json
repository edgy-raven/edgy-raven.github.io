183,0.061147,0.075311,0.083539,0.090589,0.096865,0.10048,0.10267,0.10115,0.099573,0.091335,0.070155],"unified_progress":[0.048127,0.079771,0.083448,0.086141,0.091982,0.092306,0.094479,0.0988,0.094768,0.095652,0.079681,0.054845]},{"section":17,"text":"However, the gradual onset is less typical for substance-induced, which is usually more acute.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.020808,0.051029,0.066183,0.07758,0.086727,0.09408,0.10529,0.10901,0.10818,0.1076,0.10103,0.072487],"unified_progress":[0.035588,0.056859,0.070683,0.078785,0.091672,0.09479,0.10059,0.10723,0.10619,0.11145,0.090291,0.055867]},{"section":18,"text":"Delusional disorder?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.025512,0.057482,0.071262,0.081811,0.091568,0.096918,0.10175,0.10417,0.10156,0.10144,0.091372,0.075149],"unified_progress":[0.034009,0.062647,0.078724,0.090093,0.094784,0.099537,0.10225,0.10205,0.098376,0.095925,0.081031,0.060579]},{"section":19,"text":"But thought insertion is a hallucinatory type of first-rank symptom, which is more characteristic of schizophrenia.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029757,0.061057,0.073247,0.084892,0.094094,0.098686,0.10258,0.10055,0.095822,0.096541,0.085019,0.077763],"unified_progress":[0.038004,0.057336,0.075046,0.086249,0.093847,0.10208,0.10217,0.10214,0.098614,0.094865,0.081985,0.067664]},{"section":20,"text":"Delusional disorder typically has non-bizarre delusions without the other symptoms like thought insertion.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030471,0.062289,0.073231,0.084528,0.093822,0.099076,0.10359,0.10157,0.096302,0.097767,0.084413,0.07294],"unified_progress":[0.036658,0.057328,0.074816,0.085691,0.09368,0.1017,0.10232,0.10406,0.10049,0.099441,0.081535,0.062279]},{"section":21,"text":"So putting it all together: first-rank symptoms, negative symptoms, gradual course, and the age all point to schizophrenia.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.032565,0.063979,0.077104,0.083845,0.086943,0.087664,0.090639,0.090994,0.092672,0.097454,0.094828,0.10131],"unified_progress":[0.037743,0.053658,0.065167,0.07664,0.083077,0.091445,0.093564,0.096434,0.098438,0.10178,0.1029,0.09915]},{"section":22,"text":"The thought insertion is a big clue here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.033487,0.068045,0.083798,0.089287,0.089068,0.086134,0.087665,0.087475,0.089008,0.09472,0.090574,0.10074],"unified_progress":[0.035154,0.05423,0.065387,0.07667,0.081417,0.086917,0.09029,0.094646,0.098537,0.10447,0.10612,0.10616]},{"section":23,"text":"I think that's the most likely diagnosis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.029565,0.056966,0.069047,0.075503,0.079446,0.081325,0.085276,0.088066,0.093485,0.097395,0.1028,0.14112],"unified_progress":[0.029714,0.039566,0.048255,0.057768,0.062961,0.072438,0.076967,0.087653,0.09884,0.10945,0.13874,0.17765]}]}}