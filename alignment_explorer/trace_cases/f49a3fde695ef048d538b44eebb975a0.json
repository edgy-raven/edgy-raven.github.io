0.20624,0.054744,0.55432,0.036028,0.03021,0.026305,0.022072,0.02012,0.017039,0.012814,0.010613,0.0094912]},{"section":2,"text":"The patient is a 2-year-old with recurrent abdominal pain, failure to thrive, and iron deficiency anemia that doesn't respond to iron therapy.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.16384,0.30445,0.0807,0.12085,0.070904,0.066613,0.048367,0.03976,0.032765,0.027728,0.023608,0.020412],"unified_progress":[0.19067,0.19778,0.094559,0.1157,0.082478,0.080138,0.058023,0.049949,0.042586,0.035825,0.03012,0.022177]},{"section":3,"text":"The anti-TTG antibodies are elevated at 300 U/L, which is a big clue.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.091205,0.14712,0.14475,0.11617,0.098438,0.086632,0.074408,0.066618,0.054701,0.047558,0.040227,0.032184],"unified_progress":[0.083746,0.12394,0.1139,0.10982,0.11026,0.097325,0.086077,0.075228,0.06402,0.055355,0.046153,0.034177]},{"section":4,"text":"First, the symptoms: abdominal pain and failure to thrive are common in gastrointestinal issues.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.064004,0.11167,0.1211,0.11542,0.1022,0.089134,0.081938,0.075061,0.06615,0.067444,0.055071,0.050804],"unified_progress":[0.064435,0.088644,0.094192,0.10596,0.098925,0.09481,0.090332,0.087392,0.079964,0.079955,0.0653,0.050096]},{"section":5,"text":"Iron deficiency anemia that's refractory to treatment might suggest either continued blood loss, poor absorption, or maybe the patient isn't adhering to treatment.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.045381,0.087709,0.095507,0.098374,0.099247,0.098943,0.095792,0.090621,0.082767,0.078237,0.069213,0.058209],"unified_progress":[0.055043,0.072055,0.081036,0.085703,0.092129,0.095949,0.094882,0.09513,0.091846,0.09034,0.08085,0.065037]},{"section":6,"text":"But since they mentioned it's refractory, absorption issues are more likely here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.042064,0.084176,0.0979,0.10074,0.097193,0.09223,0.090625,0.087498,0.082422,0.085611,0.072872,0.066665],"unified_progress":[0.04243,0.070324,0.079818,0.090229,0.093387,0.093384,0.095298,0.094972,0.092667,0.096477,0.083913,0.0671]},{"section":7,"text":"The anti-TTG antibodies (anti-tissue transglutaminase) are a key test for celiac disease.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.042432,0.080432,0.092827,0.099314,0.10014,0.096652,0.09577,0.089643,0.083244,0.081828,0.071397,0.06632],"unified_progress":[0.044666,0.067011,0.083867,0.092132,0.098263,0.10155,0.099995,0.095486,0.09112,0.08638,0.075939,0.063587]},{"section":8,"text":"High titres like 300 U/L (normal is usually <10, I think) are strongly indicative.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.045758,0.089871,0.10469,0.10628,0.10171,0.09451,0.094064,0.087065,0.08019,0.073886,0.067283,0.054694],"unified_progress":[0.044285,0.080669,0.096169,0.10227,0.10751,0.10153,0.10675,0.08959,0.082969,0.073613,0.065102,0.049534]},{"section":9,"text":"Then the duodenal biopsy would confirm it.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.04166,0.086498,0.099479,0.10264,0.098861,0.095286,0.092198,0.086132,0.088446,0.076509,0.068552,0.063738],"unified_progress":[0.039743,0.076097,0.09122,0.10207,0.10536,0.10143,0.10367,0.090741,0.088995,0.075542,0.067171,0.057954]},{"section":10,"text":"What does celiac disease do?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.036769,0.077334,0.096571,0.10302,0.10128,0.093968,0.093253,0.08789,0.082884,0.085778,0.072659,0.068589],"unified_progress":[0.068026,0.069769,0.080849,0.092281,0.093732,0.093595,0.093987,0.092236,0.087279,0.088449,0.07575,0.064048]},{"section":11,"text":"It causes an immune response to gluten, leading to villous atrophy in the small intestine.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.029743,0.06658,0.081851,0.093534,0.10086,0.10259,0.10406,0.098158,0.092071,0.08804,0.077015,0.065494],"unified_progress":[0.07452,0.065215,0.079416,0.08667,0.092822,0.098325,0.09598,0.095996,0.090179,0.086129,0.073332,0.061418]},{"section":12,"text":"That atrophy impairs nutrient absorption, so iron isn't absorbed well, leading to anemia.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.028046,0.062164,0.075638,0.086331,0.094882,0.099394,0.10382,0.10094,0.096819,0.092418,0.085505,0.074044],"unified_progress":[0.063242,0.060457,0.070342,0.077829,0.086342,0.094381,0.094241,0.096964,0.09632,0.09569,0.089517,0.074675]},{"section":13,"text":"The failure to thrive makes sense because the child isn't getting enough nutrients.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.031158,0.064227,0.073994,0.082723,0.091078,0.097057,0.10134,0.10084,0.097823,0.094251,0.088577,0.076933],"unified_progress":[0.063841,0.059622,0.066157,0.072638,0.08224,0.090395,0.09247,0.097446,0.098508,0.10043,0.095601,0.080653]},{"section":14,"text":"The abdominal pain could be from the inflammation in the gut.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027382,0.059314,0.071071,0.081561,0.090697,0.097265,0.10256,0.10172,0.1008,0.096333,0.091245,0.080053],"unified_progress":[0.041752,0.051466,0.062558,0.071166,0.08286,0.09234,0.095735,0.10054,0.10534,0.10754,0.10285,0.085853]},{"section":15,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.030051,0.069231,0.089911,0.096466,0.095748,0.090903,0.091902,0.090889,0.089452,0.09714,0.081961,0.076347],"unified_progress":[0.030817,0.063611,0.076816,0.090593,0.09303,0.093508,0.096985,0.097189,0.096645,0.10208,0.08855,0.070182]},{"section":16,"text":"Well, maybe another cause of malabsorption like tropical sprue, but that's less common in a 2-year-old not from an endemic area.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027546,0.061797,0.075627,0.085155,0.093037,0.098982,0.10157,0.10237,0.098911,0.098512,0.087901,0.068586],"unified_progress":[0.046684,0.076818,0.081445,0.084535,0.090774,0.09414,0.095494,0.1001,0.095892,0.095546,0.080177,0.058392]},{"section":17,"text":"Or maybe Crohn's disease, but the anti-TTG and biopsy findings would point more towards celiac.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023784,0.057386,0.073848,0.084067,0.090269,0.09432,0.10083,0.10146,0.10247,0.1009,0.093142,0.077521],"unified_progress":[0.030175,0.059953,0.075659,0.085752,0.093736,0.096179,0.099932,0.10148,0.10146,0.10235,0.087286,0.066037]},{"section":18,"text":"Also, the iron deficiency being refractory to treatment is classic in celiac because even if you give iron, the gut can't absorb it properly until gluten is removed.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029184,0.061659,0.073419,0.083033,0.091372,0.097137,0.10162,0.10083,0.098028,0.095773,0.089751,0.078194],"unified_progress":[0.054953,0.061399,0.070348,0.0774,0.085833,0.093451,0.095113,0.098085,0.098166,0.097607,0.091913,0.075732]},{"section":19,"text":"So putting it all together: the antibodies, the symptoms, and the biopsy (which I assume shows villous atrophy) all point to celiac disease.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.033182,0.06471,0.07673,0.082801,0.084717,0.08511,0.088391,0.088866,0.092093,0.096167,0.09439,0.11284],"unified_progress":[0.036963,0.052597,0.063383,0.07429,0.079491,0.085976,0.088638,0.093348,0.098369,0.10195,0.10869,0.11631]}]}}