8,0.11369,0.10654,0.10196,0.095915,0.08981,0.065108,0.030172],"unified_progress":[0.035127,0.072702,0.084989,0.10225,0.099084,0.094577,0.097622,0.093049,0.08943,0.096412,0.076543,0.058213]},{"section":10,"text":"A common thing with these symptoms would be a dentigerous cyst.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.026711,0.046438,0.065722,0.083106,0.096972,0.10735,0.11483,0.11421,0.11387,0.11312,0.079504,0.03816],"unified_progress":[0.034795,0.060723,0.079181,0.090665,0.099375,0.10966,0.10321,0.10083,0.095126,0.091014,0.074154,0.061266]},{"section":11,"text":"Those are pretty typical when you've got a tooth stuck under a layer of bone, like an unerupted molar.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.038636,0.043345,0.055781,0.070203,0.085421,0.099326,0.11072,0.11402,0.11907,0.12402,0.091617,0.047838],"unified_progress":[0.042627,0.058508,0.076878,0.089217,0.096214,0.10618,0.10416,0.10252,0.09688,0.091061,0.075075,0.060681]},{"section":12,"text":"They're also known as odontogenic keratocysts sometimes, but I'm getting ahead of myself.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.021373,0.034902,0.050297,0.066371,0.083424,0.10063,0.11529,0.12296,0.1315,0.13588,0.09441,0.042972],"unified_progress":[0.030036,0.053917,0.077383,0.090751,0.097941,0.1067,0.1067,0.10517,0.10005,0.096785,0.076273,0.05829]},{"section":13,"text":"The biopsy results came back, and they say the lining of the cyst is stratified squamous epithelium.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.030244,0.047797,0.069882,0.09099,0.10374,0.10952,0.10986,0.10436,0.099935,0.098899,0.080957,0.053819],"unified_progress":[0.040281,0.06223,0.079732,0.092843,0.098886,0.10128,0.099731,0.098108,0.097334,0.086636,0.075949,0.066985]},{"section":14,"text":"That's interesting because it's a type of epithelial lining that's often seen in certain types of cysts.","dimension":0,"group":7,"is_degenerate":false,"model_progr