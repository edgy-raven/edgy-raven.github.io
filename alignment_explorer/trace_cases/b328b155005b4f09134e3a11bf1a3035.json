":false,"model_progress":[0.045987,0.084801,0.085388,0.086526,0.091089,0.095174,0.096199,0.096264,0.089206,0.085541,0.077513,0.066311],"unified_progress":[0.079329,0.080865,0.084724,0.087026,0.089913,0.093782,0.091238,0.093512,0.086464,0.083411,0.071509,0.058226]},{"section":24,"text":"Since he has multiple symptoms from both categories and it's impairing his functioning, yeah, that fits.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.044819,0.081521,0.087214,0.089315,0.090687,0.091029,0.092025,0.09133,0.087477,0.086714,0.079983,0.077885],"unified_progress":[0.068886,0.075801,0.079637,0.085155,0.087328,0.089373,0.088634,0.090789,0.086924,0.087881,0.082521,0.077073]},{"section":25,"text":"<answer> Attention Deficit Hyperactivity Disorder (ADHD) </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.046845,0.071998,0.071004,0.074031,0.078824,0.082668,0.085923,0.088451,0.088903,0.090399,0.093765,0.12719],"unified_progress":[0.054625,0.053784,0.060835,0.066905,0.070653,0.078735,0.080047,0.08716,0.091642,0.096026,0.11602,0.14357]}]}}