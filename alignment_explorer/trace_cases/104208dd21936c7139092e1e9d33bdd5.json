541,0.065058],"unified_progress":[0.047233,0.06712,0.07373,0.078756,0.086895,0.09713,0.094737,0.097512,0.097801,0.096028,0.090317,0.072741]},{"section":8,"text":"Anaphylaxis typically presents with multiple systems involved.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.042353,0.078985,0.090461,0.096358,0.097084,0.093722,0.094097,0.090104,0.084383,0.087809,0.074549,0.070094],"unified_progress":[0.048814,0.064117,0.077404,0.086285,0.091449,0.095536,0.097032,0.096736,0.093783,0.095282,0.083718,0.069843]},{"section":9,"text":"The tachycardia (high heart rate) is a common compensatory response as the body goes into shock, trying to maintain blood pressure.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.040755,0.07709,0.083239,0.088406,0.093392,0.096389,0.098403,0.09571,0.090282,0.086108,0.079633,0.070592],"unified_progress":[0.046911,0.062803,0.071578,0.077281,0.086295,0.094999,0.095091,0.098028,0.098679,0.098182,0.093111,0.077041]},{"section":10,"text":"The BP here is a bit low for him, maybe he's starting to go into anaphylactic shock.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.044557,0.082507,0.087362,0.089608,0.092045,0.094369,0.095147,0.093814,0.089433,0.084508,0.078016,0.068635],"unified_progress":[0.048729,0.069214,0.077029,0.082493,0.089641,0.093532,0.095861,0.095226,0.095039,0.093242,0.087336,0.072656]},{"section":11,"text":"The X-ray might show something like pulmonary edema if there's fluid in the lungs, but I'm not sure.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.037665,0.078355,0.089424,0.094145,0.094662,0.096099,0.095757,0.092598,0.096498,0.084018,0.075776,0.065003],"unified_progress":[0.040004,0.071604,0.085333,0.095987,0.10058,0.098862,0.099053,0.094596,0.09541,0.08759,0.07377,0.057213]},{"section":12,"text":"But the key here is the history of exposure to a known allergen and the rapid onset of symptoms.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.045035,0.083099,0.091531,0.093793,0.092989,0.091317,0.089913,0.088239,0.084681,0.088916,0.077817,0.072671],"unified_progress":[0.057165,0.074862,0.081081,0.088315,0.090875,0.091086,0.093684,0.093341,0.090328,0.091791,0.080389,0.067084]},{"section":13,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035428,0.076356,0.097099,0.10212,0.099136,0.091771,0.090171,0.087153,0.084819,0.088998,0.076158,0.070794],"unified_progress":[0.03739,0.071391,0.08355,0.096607,0.096445,0.09409,0.097004,0.09374,0.090851,0.096004,0.079646,0.063281]},{"section":14,"text":"Maybe a panic attack could cause palpitations and breathlessness, but the context of the peanut ingestion makes anaphylaxis more likely.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.033559,0.069635,0.082403,0.089722,0.093633,0.09476,0.097364,0.095946,0.092389,0.092202,0.084304,0.074083],"unified_progress":[0.037981,0.059007,0.071363,0.079851,0.08831,0.093678,0.097027,0.10026,0.10044,0.10365,0.093215,0.075218]},{"section":15,"text":"Also, the blood pressure isn't extremely low yet, but it's on the lower side.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.038993,0.077122,0.085549,0.088768,0.090862,0.092922,0.095885,0.096082,0.093113,0.08932,0.083318,0.068065],"unified_progress":[0.041983,0.071088,0.081219,0.086558,0.09383,0.094268,0.097007,0.097403,0.095563,0.095141,0.083895,0.062046]},{"section":16,"text":"Anaphylaxis can present with hypotension, but sometimes early signs are tachycardia and other symptoms before the blood pressure drops more.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029175,0.062345,0.074501,0.084376,0.093168,0.098157,0.10284,0.10099,0.096991,0.093796,0.087875,0.075789],"unified_progress":[0.041165,0.056341,0.070318,0.076999,0.087059,0.095578,0.097408,0.1008,0.1011,0.10177,0.094982,0.076483]},{"section":17,"text":"I don't think it's a heart issue like arrhythmia because the trigger is the allergen.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035359,0.070543,0.08152,0.087727,0.0913,0.093117,0.095882,0.096418,0.094245,0.094538,0.085275,0.074076],"unified_progress":[0.041841,0.06456,0.075815,0.0855,0.091014,0.093588,0.09677,0.098238,0.097454,0.098908,0.087746,0.068566]},{"section":18,"text":"Asthma exacerbation could cause breathlessness, but again, the connection to the peanut allergy points more towards anaphylaxis.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.025623,0.058002,0.072468,0.082862,0.090961,0.096253,0.10178,0.10163,0.099941,0.099047,0.092478,0.078955],"unified_progress":[0.032757,0.055538,0.068336,0.077098,0.086914,0.094422,0.097757,0.10252,0.10397,0.10698,0.097072,0.076633]},{"section":19,"text":"The combination of respiratory symptoms and cardiovascular symptoms (tachycardia, hypotension) fits anaphylaxis.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.0255,0.056378,0.068614,0.078791,0.088234,0.095074,0.10099,0.1011,0.10086,0.099139,0.096783,0.088541],"unified_progress":[0.032345,0.050625,0.062386,0.071712,0.082681,0.093546,0.096744,0.10175,0.10594,0.10774,0.105,0.089531]},{"section":20,"text":"So the most likely diagnosis here is anaphylaxis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.025649,0.049593,0.05912,0.06578,0.071779,0.076613,0.083417,0.088365,0.09547,0.1016,0.11275,0.16986],"unified_progress":[0.025046,0.034812,0.042933,0.052125,0.058074,0.072575,0.076572,0.092334,0.10369,0.11139,0.14382,0.18663]},{"section":21,"text":"<answer> Anaphylaxis </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.033858,0.055766,0.057001,0.061363,0.068148,0.075344,0.08245,0.089066,0.096799,0.10199,0.11302,0.1652],"unified_progress":[0.033771,0.037129,0.042472,0.049268,0.055305,0.065651,0.070362,0.085544,0.097615,0.1092,0.1464,0.20728]}]}}