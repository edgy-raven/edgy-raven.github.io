ied_progress":[0.055024,0.074155,0.083701,0.087811,0.093207,0.099522,0.094303,0.094204,0.08999,0.086101,0.077689,0.064295]},{"section":10,"text":"The fact that she's worried about having more of these episodes suggests she's pretty anxious about them too.","dimension":6,"group":5,"is_degenerate":false,"model_progress":[0.083686,0.082911,0.078678,0.079318,0.080699,0.082435,0.084514,0.084796,0.087911,0.092625,0.091845,0.070582],"unified_progress":[0.069561,0.084373,0.083266,0.08493,0.087342,0.090087,0.0885,0.090943,0.08713,0.084747,0.079329,0.069791]},{"section":11,"text":"That's common with panic disorder, where people can become preoccupied with their next attack.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.062127,0.074069,0.077818,0.082151,0.085173,0.088127,0.090576,0.089632,0.092476,0.095879,0.09077,0.071203],"unified_progress":[0.055352,0.073096,0.082691,0.08628,0.090392,0.093818,0.092709,0.092544,0.089157,0.08699,0.082175,0.074795]},{"section":12,"text":"But wait, let's consider other possibilities.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.12251,0.098012,0.089383,0.077845,0.076753,0.077445,0.078669,0.086323,0.077445,0.052919,0.055455,0.10724],"unified_progress":[0.21109,0.082725,0.064589,0.064442,0.073871,0.073307,0.093242,0.080828,0.07773,0.063652,0.058804,0.055724]},{"section":13,"text":"Could it be something like a seizure?","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.036401,0.062295,0.081635,0.096498,0.10053,0.10357,0.10757,0.106,0.10242,0.095944,0.06963,0.037512],"unified_progress":[0.041547,0.075424,0.069044,0.096765,0.1055,0.10123,0.10009,0.10341,0.097889,0.088514,0.073012,0.047572]},{"section":14,"text":"Well, seizures usually have different characteristics, like convulsions or loss of consciousness, which aren't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.042771,0.051456,0.063006,0.074108,0.083987,0.093917,0.10282,0.1089,0.1138,0.11501,0.094673,0.055557],"unified_progress":[0.046758,0.064465,0.076696,0.084458,0.093529,0.098157,0.098417,0.10099,0.098307,0.095877,0.081859,0.06049]},{"section":15,"text":"Plus, there's no mention of any neurological issues or abnormal findings on tests, so that seems unlikely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02754,0.041137,0.055142,0.067805,0.079428,0.093188,0.10652,0.12052,0.12988,0.12877,0.099111,0.050949],"unified_progress":[0.036923,0.059395,0.072789,0.081435,0.092019,0.094558,0.098738,0.10348,0.10359,0.10645,0.089002,0.061618]},{"section":16,"text":"What about a cardiac issue?","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018067,0.040544,0.059251,0.074778,0.086438,0.099984,0.1116,0.12294,0.12754,0.12595,0.092115,0.040798],"unified_progress":[0.029007,0.060111,0.076099,0.08693,0.094423,0.096798,0.10267,0.10563,0.10361,0.10587,0.08519,0.053658]},{"section":17,"text":"Maybe something like arrhythmia could cause some of these symptoms, but again, we'd expect to see something unusual on an ECG or other tests, right?","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027967,0.03972,0.054835,0.06887,0.080744,0.093235,0.10461,0.11464,0.12147,0.12466,0.10594,0.063298],"unified_progress":[0.038509,0.057896,0.072093,0.081782,0.091184,0.096001,0.099342,0.10341,0.1033,0.10317,0.088757,0.064559]},{"section":18,"text":"Since all her investigations came back normal, that makes it less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024417,0.04023,0.056289,0.070775,0.081717,0.092332,0.10132,0.10951,0.11579,0.11737,0.1071,0.083144],"unified_progress":[0.033694,0.053884,0.068281,0.078141,0.087034,0.090776,0.094756,0.099582,0.10227,0.10351,0.098709,0.089361]},{"section":19,"text":"Alright, let's go back to the idea of panic attacks.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.01445,0.04274,0.065296,0.079949,0.088494,0.095992,0.10033,0.10655,0.11042,0.11394,0.10253,0.079308],"unified_progress":[0.027696,0.055617,0.068268,0.081192,0.085033,0.088163,0.096556,0.096802,0.098453,0.1066,0.10119,0.094425]},{"section":20,"text":"They fit well with the sudden onset and short duration of the episodes.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.018995,0.030479,0.037965,0.04581,0.055647,0.066635,0.081211,0.092786,0.10965,0.13648,0.17167,0.15268],"unified_progress":[0.02974,0.045369,0.056666,0.065451,0.077529,0.089966,0.094264,0.10184,0.10862,0.11436,0.11504,0.10116]},{"section":21,"text":"The physical symptoms match up too\u2014sweating, palpitations, and derealization are all classic.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.021983,0.033053,0.040521,0.048854,0.058809,0.069884,0.084019,0.095806,0.11457,0.14292,0.16863,0.12096],"unified_progress":[0.030928,0.045593,0.057265,0.066937,0.079861,0.091392,0.096705,0.10316,0.1097,0.11339,0.11091,0.094164]},{"section":22,"text":"And the fact that she's afraid of having more episodes aligns with how people experience panic disorder.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.038584,0.041396,0.047772,0.055297,0.063471,0.072918,0.083938,0.093855,0.10761,0.12597,0.14445,0.12474],"unified_progress":[0.041686,0.051111,0.059247,0.06697,0.076224,0.085977,0.090556,0.098829,0.10385,0.10798,0.11094,0.10663]},{"section":23,"text":"So, putting it all together, it really does seem like what she's describing is panic disorder.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.016905,0.028506,0.035183,0.041736,0.046869,0.052511,0.058362,0.062797,0.073948,0.099717,0.1955,0.28796],"unified_progress":[0.01452,0.025833,0.033701,0.042483,0.048241,0.062801,0.068471,0.085658,0.10183,0.11441,0.16508,0.23697]},{"section":24,"text":"It's the best explanation given everything we know.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.013784,0.023218,0.028644,0.034359,0.039724,0.046053,0.053419,0.060185,0.074569,0.10674,0.2