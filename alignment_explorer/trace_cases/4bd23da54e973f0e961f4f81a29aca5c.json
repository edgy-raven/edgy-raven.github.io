1,0.08487,0.070741,0.067216],"unified_progress":[0.040068,0.066787,0.088534,0.096724,0.099947,0.1075,0.10046,0.095459,0.089963,0.084029,0.070413,0.060112]},{"section":16,"text":"They often present with visual field defects because of pressure on the optic chiasm.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032345,0.071386,0.084711,0.094594,0.10011,0.10227,0.10227,0.095684,0.090992,0.086602,0.073609,0.065428],"unified_progress":[0.044713,0.06501,0.081972,0.093245,0.098508,0.10463,0.1004,0.097743,0.094232,0.086382,0.073453,0.059711]},{"section":17,"text":"They can have calcifications on imaging, which matches the CT finding.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033735,0.07441,0.088961,0.096069,0.097653,0.098044,0.098229,0.093675,0.092691,0.085829,0.075765,0.06494],"unified_progress":[0.046447,0.071662,0.086619,0.096132,0.10127,0.10011,0.098435,0.095059,0.092426,0.085209,0.070857,0.055775]},{"section":18,"text":"Also, craniopharyngiomas are more common in kids and adults over 50, so a 6-year-old fits that.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.037687,0.074251,0.083612,0.091257,0.097268,0.10279,0.099043,0.095749,0.089243,0.088281,0.074841,0.065974],"unified_progress":[0.068727,0.095493,0.091949,0.090981,0.090694,0.096463,0.090011,0.090566,0.083126,0.07787,0.067452,0.056667]},{"section":19,"text":"Another possibility could be a pituitary adenoma, but those are less common in children.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.028248,0.064172,0.080761,0.091236,0.097659,0.10007,0.10182,0.098627,0.095122,0.093589,0.081348,0.067352],"unified_progress":[0.041062,0.073884,0.08987,0.097367,0.098679,0.099709,0.098246,0.095802,0.090927,0.08761,0.071885,0.054958]},{"section":20,"text":"Also, pituitary adenomas might present with hormonal issues, but the kid isn't mentally retarded and school is okay, so maybe not growth hormone issues.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025371,0.059468,0.073588,0.083145,0.090987,0.097221,0.10382,0.10541,0.10281,0.099843,0.091435,0.066903],"unified_progress":[0.035866,0.06635,0.079163,0.085388,0.095225,0.097223,0.099202,0.1037,0.10063,0.10273,0.08157,0.052957]},{"section":21,"text":"But the key here is the suprasellar location with calcification.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.027567,0.062889,0.078373,0.086532,0.090462,0.093631,0.096355,0.095882,0.10063,0.096432,0.090966,0.08028],"unified_progress":[0.036412,0.064407,0.077654,0.087756,0.094351,0.097397,0.1001,0.098354,0.099984,0.095002,0.083977,0.06461]},{"section":22,"text":"Craniopharyngiomas often have calcifications, whereas adenomas might not.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.027003,0.060976,0.075994,0.087873,0.095647,0.099323,0.10164,0.097987,0.095864,0.092574,0.083533,0.081582],"unified_progress":[0.032632,0.058743,0.077302,0.088584,0.094585,0.10406,0.1007,0.099076,0.096692,0.090945,0.082341,0.074339]},{"section":23,"text":"Other options: optic glioma?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.024784,0.059937,0.077372,0.087577,0.095557,0.098385,0.10118,0.10161,0.099937,0.096776,0.086537,0.070351],"unified_progress":[0.029665,0.066194,0.084593,0.096815,0.10015,0.10072,0.10235,0.099994,0.096123,0.09063,0.075659,0.057106]},{"section":24,"text":"Those can occur in children, especially with neurofibromatosis, but they might present with more gradual vision loss.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.021821,0.055486,0.07302,0.087663,0.099001,0.10467,0.10877,0.10576,0.098515,0.09759,0.083256,0.064439],"unified_progress":[0.030551,0.060196,0.078599,0.089402,0.098855,0.10778,0.10617,0.1063,0.10039,0.096205,0.075212,0.050337]},{"section":25,"text":"Also, optic gliomas are usually infratentorial or in the chiasm, but maybe.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.025342,0.061643,0.077006,0.089025,0.096641,0.10209,0.1052,0.10175,0.10113,0.094693,0.080694,0.064789],"unified_progress":[0.030416,0.062445,0.082376,0.094753,0.10201,0.10541,0.10444,0.10291,0.10055,0.092382,0.071849,0.05047]},{"section":26,"text":"But the calcification is more typical of craniopharyngioma.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.027309,0.061425,0.075917,0.085695,0.091822,0.095761,0.098826,0.097381,0.098026,0.094322,0.08717,0.086347],"unified_progress":[0.033204,0.059549,0.074938,0.086083,0.092203,0.097488,0.097001,0.097717,0.097172,0.093682,0.0882,0.082762]},{"section":27,"text":"What about a Rathke's cleft cyst?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.027428,0.062531,0.077605,0.088087,0.095823,0.099834,0.10177,0.10082,0.1011,0.094,0.083539,0.067461],"unified_progress":[0.035214,0.067854,0.086373,0.098661,0.1022,0.10291,0.10279,0.098927,0.095619,0.086285,0.070793,0.052369]},{"section":28,"text":"They can be suprasellar but usually don't calcify as much.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022497,0.056041,0.072629,0.08476,0.093801,0.099369,0.10547,0.10511,0.10357,0.098946,0.089502,0.068296],"unified_progress":[0.033071,0.061338,0.079149,0.089544,0.098896,0.10256,0.10274,0.10408,0.10043,0.098084,0.077465,0.052638]},{"section":29,"text":"Maybe a meningioma?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.022177,0.056922,0.073951,0.085399,0.094679,0.10053,0.10417,0.10523,0.10609,0.097997,0.087534,0.065328],"unified_progress":[0.03138,0.068897,0.087389,0.098896,0.10323,0.10279,0.10344,0.10061,0.097263,0.088422,0.070115,0.04757]},{"section":30,"text":"But those are more common in adults.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.0191,0.050009,0.067015,0.07895,0.089599,0.096974,0.10576,0.10911,0.10815,0.10554,0.097928,0.071874],"unified_progress":[0.034975,0.062947,0.076896,0.084809,0.095026,0.097118,0.10034,0.10537,0.10197,0.10393,0.082795,0.053826]},{"section":31,"text":"So putting it all together: the bitemporal hemianopia from chiasmal compression, suprasellar mass with calcification in a child.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.028628,0.061523,0.073545,0.082087,0.087388,0.092855,0.095882,0.095579,0.10398,0.096325,0.094204,0.088004],"unified_progress":[0.038321,0.060342,0.07582,0.087301,0.094475,0.099258,0.098938,0.097781,0.10127,0.091159,0.084729,0.070602]},{"section":32,"text":"The most likely diagnosis is craniopharyngioma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.02298,0.04867,0.060032,0.068841,0.07644,0.082553,0.088619,0.091225,0.097746,0.099869,0.10849,0.15454],"unified_progress":[0.024422,0.040307,0.052098,0.062485,0.067896,0.080233,0.082947,0.092717,0.10105,0.1044,0.13026,0.16118]},{"section":33,"text":"The visual acuity being affected could be from direct pressure on the optic nerves or the chiasm.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.027285,0.061376,0.072668,0.081394,0.087535,0.093989,0.09846,0.097973,0.10129,0.09625,0.093361,0.088415],"unified_progress":[0.035144,0.053793,0.067173,0.078112,0.086386,0.093511,0.095183,0.098723,0.10346,0.10208,0.099458,0.086983]},{"section":34,"text":"The lack of mental retardation is good because craniopharyngioma doesn't directly cause cognitive issues unless there's significant hypothalamic involvement, which might present with other symptoms like hormonal imbalances.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.026931,0.060625,0.072671,0.082491,0.090907,0.097773,0.10231,0.1021,0.099937,0.097332,0.08976,0.07717],"unified_progress":[0.034513,0.057926,0.069607,0.077591,0.087171,0.095341,0.098005,0.10201,0.10314,0.10386,0.094823,0.076011]},{"section":35,"text":"But the key points all point to craniopharyngioma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.026979,0.056029,0.068357,0.075437,0.080332,0.08381,0.088648,0.0909,0.095051,0.098064,0.10157,0.13482],"unified_progress":[0.027289,0.043501,0.053446,0.063397,0.06918,0.078943,0.083133,0.092046,0.098933,0.10576,0.1277,0.15668]},{"section":36,"text":"<answer> Craniopharyngioma </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.032671,0.057081,0.061169,0.06722,0.07441,0.081032,0.086772,0.090671,0.095951,0.098454,0.1057,0.14887],"unified_progress":[0.032822,0.040278,0.04804,0.056035,0.062158,0.072598,0.075995,0.088143,0.097624,0.10572,0.13578,0.18481]}]}}