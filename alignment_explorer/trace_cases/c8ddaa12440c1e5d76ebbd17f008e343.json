91219,0.088599,0.087138,0.088522,0.08526,0.089852,0.083169,0.080354,0.071831,0.058455]},{"section":10,"text":"This makes me think about anxiety disorders.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.056885,0.087339,0.089609,0.093162,0.089566,0.087874,0.091224,0.085991,0.084475,0.089102,0.079371,0.065402],"unified_progress":[0.049269,0.07706,0.086377,0.097814,0.095898,0.093738,0.096114,0.091699,0.087007,0.090542,0.074932,0.05955]},{"section":11,"text":"People often get physically symptoms when they're anxious, like increased heart rate, palpitations, or digestive issues.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.052956,0.080642,0.08598,0.089314,0.093074,0.09546,0.096731,0.09564,0.092257,0.083715,0.072864,0.061367],"unified_progress":[0.053954,0.077188,0.087422,0.091218,0.095905,0.10222,0.097625,0.096895,0.089659,0.084347,0.069799,0.053765]},{"section":12,"text":"So maybe the patient has an anxiety disorder that's causing him to fixate on these health concerns.","dimension":0,"group":5,"is_degenerate":false,"model_progress":[0.058481,0.079661,0.087444,0.090526,0.089081,0.089757,0.092273,0.09038,0.088435,0.088168,0.077948,0.067846],"unified_progress":[0.062923,0.081035,0.085462,0.089983,0.091025,0.093251,0.091857,0.093658,0.088048,0.084738,0.075262,0.062758]},{"section":13,"text":"I should consider if this is a somatization disorder, where physical symptoms are a way of expressing psychological distress.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.048113,0.075408,0.082707,0.089175,0.089401,0.090812,0.094218,0.093351,0.09259,0.093825,0.082565,0.067835],"unified_progress":[0.044576,0.070753,0.084032,0.094376,0.0952,0.09614,0.09736,0.095259,0.091292,0.090999,0.077521,0.062493]},{"section":14,"text":"Alternatively, it could be generalized anxiety disorder, where the patient is excessively worried about their health.","dimension":8,"group":6,"is_degenerate":false,"model_progress":[0.045126,0.065556,0.0