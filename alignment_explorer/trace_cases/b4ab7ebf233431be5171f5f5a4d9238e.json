_progress":[0.065386,0.089451,0.10008,0.10306,0.10366,0.098951,0.093161,0.086134,0.081085,0.071039,0.0593,0.048693]},{"section":5,"text":"Hmm, that's quite specific.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.1322,0.10624,0.096721,0.083803,0.081924,0.080848,0.078739,0.082952,0.071432,0.047083,0.047369,0.090681],"unified_progress":[0.2201,0.088273,0.067791,0.066156,0.076484,0.073574,0.089522,0.078567,0.073927,0.05934,0.054565,0.051698]},{"section":6,"text":"Alright, so let's think about what could cause something like this.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.02085,0.071883,0.10873,0.11652,0.11378,0.10909,0.10099,0.095283,0.087676,0.081989,0.062256,0.030946],"unified_progress":[0.046647,0.10859,0.07895,0.096631,0.10141,0.094511,0.087899,0.091649,0.085725,0.081415,0.073015,0.053557]},{"section":7,"text":"When I hear 'rolled out' and 'feathery,' it makes me think of certain types of corneal ulcers.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.029846,0.051708,0.071138,0.087516,0.099627,0.10744,0.11263,0.11015,0.10932,0.1079,0.076306,0.03642],"unified_progress":[0.039615,0.066147,0.084531,0.093692,0.10081,0.10855,0.1016,0.097761,0.091896,0.087368,0.070561,0.057469]},{"section":8,"text":"Herpes simplex keratitis usually has dendritic ulcers, which look more branching and linear.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.026279,0.040903,0.05541,0.071387,0.088238,0.10326,0.11547,0.11917,0.12449,0.12803,0.088465,0.038893],"unified_progress":[0.032938,0.057528,0.079468,0.092589,0.099846,0.11058,0.10685,0.10386,0.097624,0.091548,0.072122,0.055046]},{"section":9,"text":"But wait, this doesn't sound like that at all.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02237,0.047323,0.060478,0.072103,0.083148,0.096003,0.10739,0.11762,0.12654,0.12192,0.09383,0.051276],"unified_progress":[0.031604,0.060197,0.075982,0.084969,0.095056,0.096721,0.099286,0.10265,0.1012,0.10556,0.085123,0.061645]},{"section":10,"text":"It's more like a bacterial infection, maybe? Fungal infections can have these kinds of presentations too.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.023138,0.046159,0.060897,0.07461,0.086533,0.098203,0.10861,0.11369,0.1197,0.1227,0.095281,0.050483],"unified_progress":[0.031959,0.059045,0.077056,0.088762,0.096234,0.10369,0.10412,0.10292,0.098919,0.096522,0.081353,0.05942]},{"section":11,"text":"Aspergillus keratitis often shows up with feathery or even nodular projections.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.017054,0.031693,0.047019,0.064227,0.083084,0.10122,0.11784,0.12455,0.13375,0.14214,0.09794,0.039482],"unified_progress":[0.026379,0.051833,0.075328,0.091093,0.099454,0.11294,0.10987,0.1081,0.10171,0.09513,0.074221,0.053943]},{"section":12,"text":"Yeah, that seems to fit better than herpes.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.021807,0.058486,0.069287,0.078515,0.085451,0.091815,0.096554,0.097866,0.10343,0.10218,0.10205,0.092556],"unified_progress":[0.029095,0.059667,0.075592,0.083781,0.091774,0.094119,0.093812,0.096738,0.095936,0.095518,0.094254,0.089714]},{"section":13,"text":"Plus, the fact that there's only a little bit of pus, just a small hypopyon, suggests it might not be as aggressive as something like bacterial keratitis.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.042196,0.049177,0.064351,0.079043,0.088941,0.096252,0.10123,0.10295,0.10513,0.10877,0.096531,0.065425],"unified_progress":[0.048137,0.060041,0.073036,0.082555,0.090819,0.095129,0.096725,0.099443,0.10014,0.09759,0.086912,0.069471]},{"section":14,"text":"So, putting it all together, the rolled-out margins, the feathery projections, and the minimal inflammation point towards fungal keratitis.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.020477,0.037268,0.050034,0.060609,0.068868,0.076292,0.083556,0.088471,0.097681,0.1152