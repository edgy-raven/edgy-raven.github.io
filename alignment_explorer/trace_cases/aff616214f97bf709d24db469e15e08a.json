,0.098459,0.096446,0.090493,0.087452,0.07787,0.063037],"unified_progress":[0.045828,0.067763,0.080013,0.086442,0.094388,0.098465,0.098042,0.10062,0.096535,0.095592,0.078719,0.057597]},{"section":13,"text":"Migraine?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.033789,0.072784,0.088117,0.095141,0.097688,0.096237,0.097494,0.095152,0.089898,0.090674,0.078024,0.065001],"unified_progress":[0.042456,0.067312,0.081256,0.091731,0.095521,0.097813,0.10076,0.098642,0.094478,0.094769,0.078015,0.057251]},{"section":14,"text":"Migraines can have triggers, but the association with chewing is less common.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028388,0.064372,0.079051,0.087835,0.093383,0.096191,0.1016,0.10167,0.097926,0.096685,0.086948,0.065948],"unified_progress":[0.037224,0.060347,0.074432,0.083314,0.093131,0.096756,0.10038,0.10431,0.10203,0.10566,0.085373,0.057037]},{"section":15,"text":"Wait, maybe it's related to the temporomandibular joint (TMJ) or the muscles involved in chewing.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.036257,0.074161,0.085937,0.093347,0.096258,0.097354,0.097139,0.094199,0.094478,0.08791,0.076424,0.066537],"unified_progress":[0.04328,0.067877,0.0838,0.095901,0.099303,0.10089,0.1013,0.097123,0.09583,0.086464,0.072371,0.055864]},{"section":16,"text":"Oh, temporomandibular disorder (TMD) comes to mind.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.041488,0.076078,0.087431,0.094657,0.097265,0.095339,0.094817,0.090619,0.085694,0.087066,0.074524,0.075022],"unified_progress":[0.050763,0.063591,0.078919,0.090289,0.093636,0.10029,0.097741,0.095334,0.091307,0.08889,0.078726,0.070517]},{"section":17,"text":"That's when there's pain in the jaw joint and muscles that control jaw movement.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039371,0.076206,0.084467,0.092007,0.097404,0.099482,0.099671,0.095159,0.089379,0.08584,0.074548,0.066466],"unified_progress":[0.059145,0.068168,0.081311,0.089543,0.094374,0.099842,0.097155,0.096632,0.091907,0.086491,0.073879,0.061554]},{"section":18,"text":"The tenderness over the temporal and mandibular regions, especially when moving the jaw, fits.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.046355,0.090537,0.092741,0.093181,0.092761,0.095375,0.093463,0.09049,0.09021,0.07972,0.071565,0.063602],"unified_progress":[0.05166,0.082546,0.092116,0.097294,0.10033,0.099462,0.095284,0.092572,0.090258,0.077714,0.066179,0.054581]},{"section":19,"text":"The temporalis muscle is a big one for chewing, so if that's inflamed or strained, it could cause pain during chewing.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.041676,0.081774,0.09065,0.095392,0.096356,0.096368,0.095584,0.091034,0.089307,0.082804,0.072651,0.066403],"unified_progress":[0.052426,0.071771,0.084563,0.093042,0.097254,0.098834,0.096522,0.093417,0.09198,0.084052,0.073433,0.062706]},{"section":20,"text":"Another thought: maybe a muscle spasm or myofascial pain.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.034799,0.071476,0.084214,0.091989,0.097257,0.097892,0.098772,0.096798,0.093272,0.089423,0.078452,0.065656],"unified_progress":[0.040639,0.069684,0.086532,0.097392,0.099318,0.10052,0.10044,0.096535,0.092419,0.086687,0.072842,0.056994]},{"section":21,"text":"Trigeminal neuralgia is another possibility, but that's usually sharp, shooting pain, not a dull ache.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025844,0.059961,0.074758,0.085884,0.094913,0.099348,0.10513,0.10457,0.099806,0.097498,0.086825,0.065464],"unified_progress":[0.03066,0.060172,0.078087,0.087331,0.097247,0.10244,0.10332,0.10556,0.10134,0.10097,0.080042,0.052828]},{"section":22,"text":"Plus, it's triggered by things like touching the face or chewing, but the distribution might be different.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027363,0.061007,0.072345,0.08124,0.088784,0.095647,0.10337,0.10602,0.10405,0.10102,0.092168,0.066975],"unified_progress":[0.032903,0.060123,0.074124,0.082475,0.093033,0.097344,0.10117,0.10674,0.10519,0.10946,0.08515,0.052294]},{"section":23,"text":"The physical exam shows pain and tenderness in those areas when moving the mouth.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.045629,0.087974,0.087735,0.086471,0.086767,0.091432,0.091179,0.091565,0.095865,0.084384,0.079607,0.071391],"unified_progress":[0.049906,0.080362,0.085754,0.09091,0.094972,0.096245,0.094964,0.093502,0.095262,0.083836,0.074318,0.05997]},{"section":24,"text":"That's classic for TMD or myofascial pain.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035115,0.070639,0.083624,0.091249,0.094363,0.093711,0.095413,0.091956,0.089756,0.089803,0.081082,0.083288],"unified_progress":[0.039118,0.061238,0.077223,0.086682,0.091029,0.097475,0.0964,0.095064,0.094069,0.092684,0.087128,0.081889]},{"section":25,"text":"Since she's young and otherwise healthy, maybe overuse or some trauma?","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.034777,0.071567,0.081707,0.087931,0.094136,0.10281,0.09833,0.097987,0.093647,0.09186,0.080733,0.064512],"unified_progress":[0.086177,0.11224,0.094963,0.087066,0.085675,0.085504,0.082744,0.08708,0.080085,0.07653,0.067895,0.054039]},{"section":26,"text":"Like clenching teeth, maybe stress?","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.033884,0.070674,0.080846,0.087994,0.094812,0.10239,0.10031,0.099788,0.094742,0.090377,0.08037,0.063819],"unified_progress":[0.080425,0.096203,0.09388,0.094543,0.090431,0.092468,0.087277,0.089999,0.081398,0.077153,0.065357,0.050867]},{"section":27,"text":"Alternatively, could it be a dental issue like an abscess, but then there might be more signs of infection, swelling, or tooth pain.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022804,0.056966,0.072741,0.083377,0.09158,0.097407,0.10514,0.10592,0.10629,0.09966,0.092372,0.065736],"unified_progress":[0.03301,0.065379,0.0811,0.090343,0.099893,0.098659,0.1011,0.10182,0.10046,0.098072,0.079522,0.050639]},{"section":28,"text":"The case doesn't mention that.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.3088,0.05043,0.051387,0.060451,0.061963,0.064578,0.064328,0.07239,0.071605,0.068325,0.069765,0.055978],"unified_progress":[0.20381,0.076587,0.067358,0.066756,0.077116,0.076686,0.089723,0.086466,0.08189,0.064648,0.056163,0.052801]},{"section":29,"text":"So putting it all together: the association with chewing, tenderness over the jaw and temple areas, and pain on mouth movement.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.037035,0.077575,0.052753,0.085602,0.091128,0.091697,0.09555,0.093748,0.094967,0.096972,0.093928,0.089044],"unified_progress":[0.046962,0.067017,0.054727,0.077598,0.088541,0.091205,0.10569,0.096643,0.097281,0.097636,0.094739,0.081963]},{"section":30,"text":"Temporomandibular disorder seems like the most likely diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.025385,0.050799,0.062262,0.069541,0.075483,0.079169,0.085273,0.088376,0.095449,0.10022,0.10988,0.15816],"unified_progress":[0.025113,0.038353,0.048119,0.058329,0.063424,0.077127,0.080556,0.092587,0.10585,0.10823,0.1339,0.16841]},{"section":31,"text":"<answer> Temporomandibular disorder (TMD) </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.033824,0.056231,0.058325,0.063643,0.070703,0.077677,0.084225,0.08949,0.096341,0.10061,0.10982,0.15911],"unified_progress":[0.034656,0.037785,0.044196,0.05173,0.057949,0.068766,0.072661,0.087102,0.098086,0.1076,0.14221,0.19726]}]}}