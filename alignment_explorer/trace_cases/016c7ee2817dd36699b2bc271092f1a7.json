.091803,0.087693,0.085356,0.07871,0.08205,0.072959,0.066367,0.06002,0.051547]},{"section":5,"text":"Rapid progression suggests it's not something like age-related macular degeneration, which tends to develop more slowly.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.04905,0.076608,0.092343,0.095791,0.098667,0.098074,0.096269,0.094596,0.089825,0.083605,0.07123,0.053941],"unified_progress":[0.046313,0.070831,0.091037,0.093732,0.099266,0.10152,0.098826,0.096846,0.091252,0.088,0.07178,0.050598]},{"section":6,"text":"It could be something acute, maybe an inflammatory condition or an optic nerve issue.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.031007,0.064861,0.087399,0.10258,0.10104,0.10061,0.10272,0.098369,0.09099,0.093719,0.071271,0.055439],"unified_progress":[0.032085,0.070985,0.090751,0.10311,0.10348,0.10117,0.10339,0.10072,0.094238,0.087746,0.068709,0.043613]},{"section":7,"text":"On examination, the fundi appearance is normal.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.03662,0.0749,0.091357,0.10488,0.10803,0.1081,0.10829,0.09698,0.082576,0.072083,0.063915,0.052276],"unified_progress":[0.039873,0.077496,0.093058,0.10254,0.10775,0.10258,0.098792,0.09394,0.090274,0.077033,0.064763,0.051902]},{"section":8,"text":"That's interesting because some conditions like glaucoma can have changes in the optic nerve, but if the fundus looks normal, maybe it's not that.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.040825,0.05762,0.077611,0.088703,0.09622,0.10108,0.10233,0.10324,0.099592,0.093466,0.082501,0.056812],"unified_progress":[0.03876,0.062123,0.078512,0.088046,0.098019,0.099942,0.10118,0.10273,0.099787,0.097702,0.078408,0.054784]},{"section":9,"text":"However, the afferent pupillary response is diminished.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.037094,0.066037,0.085632,0.10221,0.10712,0.1099,0.10949,0.10076,0.088192,0.07574,0.066049,0.051764],"unified_progress":[0.039089,0.071616,0.088401,0.09961,0.10461,0.10226,0.10069,0.095594,0.097465,0.081412,0.067654,0.0516]},{"section":10,"text":"The afferent pathway involves the optic nerve, so if that's diminished, it points towards an issue with the optic nerve itself.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.046926,0.059596,0.077505,0.091344,0.10072,0.10558,0.10674,0.10259,0.094818,0.083458,0.070851,0.059878],"unified_progress":[0.043668,0.065458,0.082986,0.094207,0.099609,0.10735,0.10215,0.097687,0.093834,0.08543,0.071253,0.056363]},{"section":11,"text":"Also, perimetry showing a large central scotoma indicates a central vision problem, which makes me think of optic atrophy or optic neuritis.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.041166,0.065241,0.083222,0.098344,0.10306,0.10624,0.10715,0.10045,0.089481,0.079034,0.068199,0.05841],"unified_progress":[0.043109,0.072244,0.08787,0.097982,0.10243,0.10186,0.099592,0.095412,0.093396,0.081166,0.068529,0.056409]},{"section":12,"text":"Wait, optic neuritis is an inflammation of the optic nerve, often caused by viral infections like measles, mumps, or herpes.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.027142,0.053727,0.073238,0.086296,0.098781,0.10553,0.10974,0.11014,0.10497,0.093667,0.074515,0.062258],"unified_progress":[0.032809,0.062934,0.084679,0.096116,0.099867,0.11607,0.10635,0.10092,0.093761,0.08625,0.068831,0.051416]},{"section":13,"text":"It can lead to vision loss, and if it's viral, it might be acute.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.035061,0.0495,0.066181,0.078124,0.09287,0.10201,0.10765,0.11223,0.11008,0.098371,0.080986,0.066929],"unified_progress":[0.03769,0.059956,0.079879,0.092766,0.098817,0.10737,0.1065,0.10367,0.096829,0.090871,0.071876,0.053771]},{"section":14,"text":"The fact that the fundus is normal but the afferent response is down makes sense because the optic nerve might not have had time to show structural changes yet, or maybe the inflammation is affecting the function without significant structural damage.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.052999,0.05256,0.069577,0.081422,0.090826,0.097493,0.10126,0.10198,0.099248,0.092478,0.086108,0.074043],"unified_progress":[0.049037,0.062416,0.076955,0.086698,0.094504,0.097704,0.097285,0.098434,0.097147,0.092693,0.080693,0.066436]},{"section":15,"text":"Another possibility is optic atrophy, which is usually due to degeneration, often from conditions like glaucoma.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.0264,0.048739,0.069363,0.082177,0.092908,0.10017,0.10557,0.10957,0.10841,0.10327,0.085347,0.06808],"unified_progress":[0.031522,0.060353,0.082058,0.093826,0.098379,0.10606,0.10469,0.10227,0.097354,0.091766,0.075461,0.056263]},{"section":16,"text":"But glaucoma can cause changes in the optic disc, which isn't mentioned here.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.031805,0.047785,0.065456,0.077561,0.090504,0.099753,0.10512,0.11071,0.11086,0.10235,0.090105,0.068],"unified_progress":[0.033082,0.058424,0.077612,0.089852,0.097925,0.10257,0.10409,0.10421,0.10031,0.097673,0.07831,0.055945]},{"section":17,"text":"Since the fundus is normal, maybe it's not glaucoma.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.035997,0.046535,0.064163,0.0746,0.083674,0.092592,0.098526,0.10658,0.11036,0.10911,0.10229,0.07557],"unified_progress":[0.036302,0.056987,0.072521,0.082524,0.091937,0.094828,0.099051,0.10377,0.10289,0.10582,0.088481,0.064894]},{"section":18,"text":"Optic neuritis seems more fitting because it can cause sudden vision loss and affect the afferent pathway.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.037605,0.043406,0.058378,0.069281,0.081501,0.091388,0.097807,0.10621,0.10988,0.10593,0.10037,0.098247],"unified_progress":[0.036579,0.052875,0.069623,0.081019,0.088015,0.097932,0.098225,0.10098,0.099579,0.09783,0.092007,0.085341]},{"section":19,"text":"Also, considering her age, optic neuritis is more common in younger individuals, especially if there's a history of viral infections.","dimension":0,"group":5,"is_degenerate":false,"model_progress":[0.033299,0.058738,0.070884,0.075559,0.081031,0.087087,0.093528,0.099367,0.10362,0.10679,0.10007,0.090021],"unified_progress":[0.04957,0.073576,0.076912,0.080493,0.085073,0.089606,0.090761,0.09626,0.094348,0.09501,0.088509,0.079882]},{"section":20,"text":"The rapid loss of vision supports this as well.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.041899,0.054405,0.061492,0.067351,0.071119,0.076784,0.082403,0.089246,0.096308,0.10397,0.1164,0.13862],"unified_progress":[0.042043,0.055615,0.063052,0.070003,0.075078,0.082304,0.084945,0.091565,0.094638,0.099863,0.11234,0.12855]},{"section":21,"text":"So putting it all together, the most likely diagnosis is optic neuritis.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.019317,0.036645,0.044432,0.051011,0.053998,0.05935,0.066752,0.078002,0.091965,0.11613,0.15338,0.22902],"unified_progress":[0.016498,0.032418,0.041983,0.052104,0.056712,0.067769,0.072926,0.086106,0.098439,0.11033,0.15042,0.2143]},{"section":22,"text":"The patient's presentation of rapid vision loss in one eye, diminished afferent pupillary response, and central scotoma on perimetry, along with a normal fundus, points towards optic neuritis.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.01804,0.030248,0.034429,0.038934,0.042515,0.048898,0.056389,0.070319,0.087825,0.11529,0.1724,0.28472],"unified_progress":[0.017688,0.02755,0.031803,0.038303,0.044118,0.056713,0.061261,0.079375,0.095782,0.11237,0.16776,0.26727]},{"section":23,"text":"This is likely due to a viral infection affecting the optic nerve, commonly seen in younger individuals.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.018348,0.029656,0.039608,0.047295,0.055255,0.063708,