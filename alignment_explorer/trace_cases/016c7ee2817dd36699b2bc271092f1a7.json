30797,0.025952,0.022205,0.019183,0.017917],"unified_progress":[0.24485,0.16517,0.081863,0.11031,0.075649,0.089289,0.055804,0.048493,0.041645,0.03541,0.029415,0.022104]},{"section":3,"text":"First, I need to think about possible causes of acute monocular vision loss.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.13361,0.15733,0.14973,0.11107,0.092642,0.07175,0.062852,0.060078,0.045258,0.046233,0.035069,0.034379],"unified_progress":[0.13776,0.10418,0.095921,0.1032,0.095313,0.087192,0.079871,0.081762,0.063794,0.063243,0.04885,0.038916]},{"section":4,"text":"The key symptoms here are pain with eye movement, a normal fundus exam, a diminished afferent pupillary defect (which is part of the Marcus Gunn pupil), and a central scotoma on perimetry.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.11301,0.17828,0.13196,0.099503,0.083057,0.082386,0.067156,0.070429,0.052903,0.046773,0.039554,0.03499],"unified_progress":[0.087517,0.12755,0.1151,0.099994,0.093661,0.092444,0.080365,0.084512,0.068117,0.05979,0.050335,0.040613]},{"section":5,"text":"Hmm, the presence of pain when moving the eye makes me think of optic neuritis.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.07429,0.12359,0.12683,0.11549,0.099591,0.086413,0.078315,0.071736,0.064434,0.064615,0.049415,0.045273],"unified_progress":[0.07189,0.091668,0.096951,0.10469,0.10047,0.095129,0.091333,0.08564,0.07951,0.076934,0.059345,0.04644]},{"section":6,"text":"Optic neuritis typically presents with sudden vision loss, often in young adults, and pain on eye movement is a classic symptom.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.048261,0.090922,0.098358,0.10325,0.10467,0.10136,0.096873,0.088346,0.077653,0.074225,0.061766,0.054314],"unified_progress":[0.048377,0.072468,0.089849,0.094032,0.098143,0.10799,0.098671,0.09565,0.088609,0.083273,0.068417,0.054515]},{"section":7,"text":"The afferent pupillary defect is also a sign of optic nerve dysfunction.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.043411,0.086496,0.096198,0.10019,0.099684,0.098033,0.095946,0.089186,0.084966,0.078373,0.067388,0.060128],"unified_progress":[0.043689,0.073996,0.088867,0.097166,0.10125,0.10215,0.098362,0.094259,0.091337,0.081858,0.070113,0.056949]},{"section":8,"text":"But wait, the fundi are normal.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.038281,0.079609,0.092761,0.096658,0.096561,0.09521,0.095119,0.092291,0.089934,0.084835,0.076109,0.06263],"unified_progress":[0.042351,0.074458,0.086766,0.094848,0.10003,0.097473,0.098436,0.09569,0.092566,0.089551,0.073753,0.054078]},{"section":9,"text":"In optic neuritis, the optic disc might look normal early on, but sometimes there's swelling later.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.034831,0.075405,0.088406,0.096614,0.099307,0.10026,0.10002,0.09446,0.092985,0.083987,0.072782,0.060947],"unified_progress":[0.044907,0.069621,0.086916,0.098001,0.10257,0.1053,0.10116,0.0966,0.093608,0.082886,0.067454,0.050976]},{"section":10,"text":"However, if the fundus is normal, maybe it's another condition?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.036044,0.07617,0.090291,0.096057,0.096615,0.095561,0.095959,0.093279,0.091818,0.087529,0.076517,0.064161],"unified_progress":[0.04107,0.07257,0.087056,0.09714,0.1014,0.098168,0.099313,0.096207,0.093011,0.088385,0.071683,0.054]},{"section":11,"text":"Another possibility is a retinal artery occlusion, but that usually causes a sudden, painless loss of vision.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.033346,0.070788,0.082296,0.091154,0.097068,0.099684,0.10158,0.098367,0.093914,0.089501,0.078233,0.064069],"unified_progress":[0.037628,0.066065,0.082411,0.092422,0.098507,0.10508,0.10179,0.10058,0.096469,0.090853,0.074141,0.054058]},{"section":12,"text":"Plus, the fundus would show a \"cherry red spot\" in central artery occlusion, which isn't mentioned here.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.032197,0.070569,0.082908,0.091677,0.096087,0.099313,0.10158,0.098005,0.09709,0.089281,0.078142,0.063153],"unified_progress":[0.0357,0.066236,0.084184,0.094524,0.10184,0.10427,0.10242,0.10037,0.098036,0.090263,0.071499,0.050645]},{"section":13,"text":"So maybe not that.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.32019,0.052884,0.0539,0.062472,0.062664,0.064127,0.061396,0.069631,0.069448,0.06424,0.067065,0.051982],"unified_progress":[0.21011,0.079621,0.068031,0.067055,0.076705,0.075349,0.092754,0.083227,0.07865,0.062063,0.055125,0.051314]},{"section":14,"text":"Amaurosis fugax is transient, so if this is persistent, that's less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.039878,0.083738,0.062175,0.10009,0.10297,0.097946,0.09962,0.096195,0.090448,0.0843,0.077347,0.065294],"unified_progress":[0.047988,0.081189,0.066865,0.092091,0.1005,0.096842,0.097267,0.10002,0.09536,0.089503,0.076078,0.056288]},{"section":15,"text":"Maybe a compressive lesion like a tumor?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.027192,0.065292,0.081286,0.091388,0.097539,0.10057,0.10157,0.10023,0.10158,0.091537,0.080898,0.060913],"unified_progress":[0.034675,0.073175,0.090107,0.10273,0.10413,0.10168,0.10164,0.097739,0.095296,0.084629,0.067513,0.046686]},{"section":16,"text":"But the patient is young, and tumors are less common.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02237,0.055146,0.070628,0.080868,0.09018,0.097756,0.10404,0.10706,0.10545,0.10355,0.094833,0.068123],"unified_progress":[0.047953,0.075743,0.081469,0.084168,0.093237,0.092833,0.09553,0.10203,0.097851,0.098494,0.07935,0.051338]},{"section":17,"text":"Plus, the scotoma is central, which points more towards the optic nerve or macula.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.028607,0.067509,0.081016,0.089303,0.091989,0.096126,0.098565,0.096107,0.10862,0.090135,0.082381,0.069642],"unified_progress":[0.042116,0.069961,0.086049,0.096528,0.10228,0.10091,0.099555,0.095731,0.10139,0.083459,0.070028,0.051994]},{"section":18,"text":"Since the fundus is normal, macular issues like a macular hole or detachment might cause a central scotoma, but those usually have other fundus findings.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.027494,0.066567,0.081129,0.090899,0.094847,0.098648,0.1011,0.098082,0.10151,0.091557,0.081192,0.066974],"unified_progress":[0.032662,0.066286,0.085456,0.097346,0.10423,0.10471,0.10282,0.098964,0.098139,0.087073,0.069827,0.052491]},{"section":19,"text":"Papilledema would show disc swelling, which isn't present here.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.029991,0.069323,0.083411,0.091777,0.095202,0.097795,0.10006,0.097306,0.098124,0.089944,0.080705,0.066359],"unified_progress":[0.034592,0.068323,0.085997,0.096398,0.10321,0.104,0.10216,0.098556,0.09617,0.086879,0.071054,0.052668]},{"section":20,"text":"Maybe retrobulbar optic neuritis, where the optic disc isn't swollen because the inflammation is behind the globe.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030582,0.074452,0.088864,0.097554,0.098138,0.10085,0.099122,0.092735,0.10127,0.082649,0.071856,0.061934],"unified_progress":[0.03585,0.071391,0.091856,0.10551,0.11062,0.1077,0.10301,0.094997,0.09602,0.074995,0.060316,0.04774]},{"section":21,"text":"That would explain the normal fundus and pain with movement.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030834,0.070112,0.083372,0.0915,0.095002,0.097802,0.099244,0.095926,0.097183,0.089243,0.080597,0.069185],"unified_progress":[0.042595,0.068818,0.084153,0.094232,0.10134,0.10011,0.099874,0.096876,0.095111,0.086002,0.072403,0.058479]},{"section":22,"text":"The afferent pupillary defect and central scotoma fit with optic nerve involvement.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033125,0.071125,0.082598,0.090035,0.093335,0.096208,0.097369,0.09393,0.096079,0.088119,0.081872,0.076203],"unified_progress":[0.039058,0.06762,0.083264,0.093533,0.09899,0.10065,0.098849,0.095057,0.094865,0.08501,0.076506,0.066597]},{"section":23,"text":"Another thought: multiple sclerosis is a common associated condition with optic neuritis, especially in young women.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.030659,0.065482,0.07935,0.088923,0.095797,0.10005,0.099775,0.097701,0.09291,0.094243,0.081996,0.073114],"unified_progress":[0.05191,0.080291,0.085015,0.089688,0.091599,0.097742,0.094461,0.094714,0.089431,0.086736,0.075653,0.062759]},{"section":24,"text":"The central scotoma is typical for optic neuritis affecting the optic nerve, which transmits central vision.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031988,0.068673,0.080176,0.089227,0.094539,0.098248,0.099813,0.095564,0.097446,0.088501,0.079939,0.075885],"unified_progress":[0.045193,0.065896,0.082684,0.091535,0.09653,0.10022,0.0972,0.094934,0.095345,0.084915,0.076894,0.068655]},{"section":25,"text":"So putting it all together: sudden vision loss with eye pain, afferent defect, central scotoma, normal fundus.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.026023,0.054828,0.067062,0.075857,0.084358,0.090627,0.095778,0.097574,0.10244,0.1024,0.10576,0.097287],"unified_progress":[0.034904,0.053621,0.06622,0.075416,0.085961,0.095455,0.097002,0.10013,0.10349,0.10313,0.10003,0.084632]},{"section":26,"text":"The most likely diagnosis is retrobulbar optic neuritis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.020927,0.047238,0.059101,0.067637,0.074472,0.080991,0.087495,0.090768,0.1001,0.10149,0.11196,0.15783],"unified_progress":[0.020927,0.038951,0.050661,0.060973,0.066986,0.080489,0.082691,0.094715,0.10446,0.10638,0.12991,0.16286]},{"section":27,"text":"I should confirm that other possibilities are 