_progress":[0.042754,0.085265,0.097852,0.10023,0.096595,0.090974,0.089044,0.08614,0.081235,0.085739,0.073538,0.070634],"unified_progress":[0.043158,0.069401,0.079308,0.089492,0.091703,0.093293,0.09914,0.095199,0.092591,0.095409,0.083483,0.067824]},{"section":12,"text":"Wait, there's a diagnosis called \"medically unexplained symptoms\" where physical symptoms can't be attributed to a physical cause.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.046579,0.083616,0.092046,0.09599,0.096012,0.093023,0.091504,0.088488,0.082932,0.084366,0.073894,0.071552],"unified_progress":[0.052108,0.067156,0.078901,0.087152,0.091585,0.094994,0.095705,0.095438,0.091997,0.092096,0.08197,0.070897]},{"section":13,"text":"But the question is asking for the most likely diagnosis.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.036254,0.06887,0.08205,0.087559,0.089957,0.089375,0.090167,0.089922,0.09008,0.090427,0.086808,0.098529],"unified_progress":[0.04036,0.058162,0.067152,0.078673,0.081005,0.084429,0.087499,0.09085,0.09339,0.10057,0.10517,0.11274]},{"section":14,"text":"Another possibility is hypochondriasis, but I think the current DSM-5 terms it as illness anxiety disorder.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.031359,0.063997,0.076933,0.084725,0.090569,0.092898,0.095098,0.095161,0.093987,0.09469,0.088757,0.091825],"unified_progress":[0.033387,0.056554,0.069404,0.07871,0.084018,0.089769,0.092285,0.095714,0.097399,0.10085,0.10051,0.1014]},{"section":15,"text":"Illness anxiety disorder is when a person is preoccupied with having a serious illness despite negative tests, they worry a lot about their health, and they might misinterpret bodily symptoms as signs of disease.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.048839,0.083244,0.081311,0.083894,0.088781,0.092971,0.094164,0.094522,0.088346,0.088002,0.07969,0.076237],"unified_progress":[0.057783,0.068417,0.074325,0.079413,0.085233,0.092448,0.092487