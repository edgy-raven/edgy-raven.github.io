39,0.012844,0.011113,0.0097581,0.0074044],"unified_progress":[0.22106,0.053722,0.54397,0.035355,0.029646,0.025814,0.02166,0.019744,0.016721,0.012575,0.010415,0.009314]},{"section":2,"text":"The patient is a 36-year-old man with swelling in the submandibular region, an elevated tongue, and dysphagia.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.19,0.34159,0.075447,0.10782,0.059981,0.060788,0.0409,0.033534,0.027867,0.023645,0.020238,0.018178],"unified_progress":[0.22258,0.18279,0.089628,0.11201,0.078773,0.083562,0.056356,0.048497,0.04121,0.034672,0.028754,0.021168]},{"section":3,"text":"He also has a high fever.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.15405,0.24933,0.16832,0.0803,0.06365,0.071957,0.046567,0.056592,0.034266,0.029816,0.024573,0.020577],"unified_progress":[0.1362,0.17347,0.12982,0.099083,0.081032,0.084847,0.062913,0.075315,0.050238,0.043575,0.036152,0.027356]},{"section":4,"text":"The intraoral exam shows a grossly destructed lower first molar.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.097624,0.16915,0.14689,0.11015,0.087172,0.083122,0.068883,0.065868,0.060188,0.043579,0.036652,0.03072],"unified_progress":[0.08529,0.12259,0.11523,0.11475,0.10316,0.094618,0.081906,0.077522,0.075914,0.052082,0.042789,0.034131]},{"section":5,"text":"Hmm, so first, the key points here are the location of the swelling (under the jaw), the affected tooth (lower first molar), the symptoms like fever and difficulty swallowing, and the elevated tongue.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.08631,0.13771,0.12891,0.11091,0.093981,0.084719,0.074591,0.070343,0.062414,0.059459,0.047247,0.04341],"unified_progress":[0.087182,0.1012,0.099396,0.10281,0.098668,0.091579,0.087386,0.083703,0.076682,0.070316,0.05599,0.045083]},{"section":6,"text":"I remember that infections in the oral cavity can spread into the surrounding areas.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.056236,0.098608,0.10937,0.11031,0.10326,0.093943,0.088756,0.080856,0.075972,0.071384,0.059181,0.052123],"unified_progress":[0.072301,0.08184,0.092523,0.10228,0.10067,0.095957,0.093053,0.087808,0.082908,0.077306,0.062314,0.051042]},{"section":7,"text":"The lower molar is part of the mandibular teeth.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.045806,0.091014,0.10084,0.10518,0.10147,0.09967,0.093951,0.085755,0.086176,0.072887,0.06241,0.054849],"unified_progress":[0.055105,0.083588,0.099451,0.11183,0.10865,0.10154,0.095978,0.088153,0.084324,0.068243,0.055298,0.047833]},{"section":8,"text":"If there's a dental infection, like a severe abscess, it might lead to cellulitis or space infections.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.041274,0.082935,0.094654,0.10071,0.10043,0.098644,0.096269,0.089428,0.087189,0.080569,0.067948,0.059947],"unified_progress":[0.048086,0.072731,0.088337,0.098559,0.10232,0.10137,0.098668,0.093292,0.090457,0.081665,0.068509,0.056005]},{"section":9,"text":"The submandibular region is part of the submandibular space.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.040442,0.084357,0.094727,0.10054,0.0991,0.099227,0.095848,0.088698,0.092063,0.077322,0.067228,0.060445],"unified_progress":[0.047696,0.075435,0.093599,0.107,0.10842,0.10394,0.099278,0.091081,0.089226,0.073145,0.059769,0.051409]},{"section":10,"text":"But the tongue being elevated is interesting.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.038085,0.081753,0.09529,0.099802,0.0986,0.096577,0.094687,0.089893,0.089806,0.082821,0.071476,0.06121],"unified_progress":[0.057011,0.078442,0.091118,0.10055,0.10382,0.097587,0.097091,0.092195,0.088532,0.079577,0.063649,0.050432]},{"section":11,"text":"Wait, the sublingual space is near there.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.035082,0.078241,0.092323,0.09963,0.099784,0.10021,0.097593,0.091377,0.09504,0.080288,0.070398,0.06004],"unified_progress":[0.050388,0.077219,0.095034,0.10916,0.10888,0.10224,0.09913,0.09067,0.088496,0.073706,0.057934,0.047147]},{"section":12,"text":"Maybe the infection is spreading into the sublingual or submandibular spaces?","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.035377,0.0816,0.095002,0.10279,0.10056,0.10089,0.097049,0.088964,0.095924,0.077451,0.066176,0.05822],"unified_progress":[0.038494,0.075772,0.098274,0.11466,0.11566,0.10616,0.10215,0.091148,0.089615,0.068398,0.05369,0.04598]},{"section":13,"text":"Wait, the \"elevated tongue\" could be a sign of Ludwig's angina, but Ludwig's is usually bilateral and involves the floor of the mouth.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.042489,0.081295,0.089131,0.095691,0.09829,0.099023,0.097671,0.09245,0.089711,0.081872,0.070594,0.061782],"unified_progress":[0.051592,0.073166,0.088848,0.099791,0.1035,0.10862,0.10054,0.094165,0.088763,0.078258,0.06285,0.049909]},{"section":14,"text":"But Ludwig's typically affects the sublingual and submandibular spaces, leading to swelling that can elevate the tongue.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.038472,0.077297,0.086805,0.09501,0.098656,0.10059,0.1,0.09385,0.092038,0.08269,0.071443,0.063145],"unified_progress":[0.044354,0.069414,0.088207,0.098769,0.10322,0.10739,0.10114,0.095689,0.09226,0.080155,0.065967,0.053437]},{"section":15,"text":"However, Ludwig's is usually associated with bilateral swelling and can cause airway obstruction.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027522,0.062635,0.077047,0.087859,0.09584,0.10019,0.10452,0.10215,0.098001,0.093757,0.08383,0.066655],"unified_progress":[0.043905,0.061352,0.076643,0.086083,0.094653,0.10117,0.1002,0.10154,0.098271,0.097747,0.079962,0.058474]},{"section":16,"text":"The patient here has a high fever, which points to an acute infection.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.035416,0.070672,0.080751,0.087162,0.091633,0.094781,0.097088,0.096366,0.093791,0.092796,0.085252,0.074292],"unified_progress":[0.04736,0.066987,0.075234,0.08303,0.089583,0.094205,0.096575,0.097591,0.096742,0.09748,0.087074,0.068141]},{"section":17,"text":"The presence of a destructed lower first molar suggests a dental source.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.035852,0.076621,0.087564,0.093435,0.094184,0.097497,0.095605,0.091666,0.097807,0.084817,0.076677,0.068275],"unified_progress":[0.048803,0.078997,0.089775,0.099987,0.10067,0.098854,0.096106,0.091307,0.092151,0.078772,0.067526,0.057054]},{"section":18,"text":"Dental caries leading to periapical abscess, which can spread into the surrounding tissues.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031706,0.071783,0.085291,0.094581,0.097747,0.10035,0.10013,0.094176,0.097357,0.085245,0.075158,0.06647],"unified_progress":[0.047267,0.069534,0.085937,0.096461,0.1017,0.10241,0.099323,0.094184,0.093877,0.081178,0.069495,0.058635]},{"section":19,"text":"The submandibular swelling could be from an infection spreading from the periapical area into the submandibular space.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033021,0.076659,0.090066,0.098499,0.098307,0.10034,0.098259,0.091066,0.098585,0.080922,0.070913,0.063367],"unified_progress":[0.040679,0.071834,0.092369,0.10521,0.11024,0.10466,0.10142,0.092644,0.092728,0.074627,0.06119,0.052397]},{"section":20,"text":"But the tongue elevation might indicate involvement of the sublingual space as well.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031168,0.075388,0.090416,0.099508,0.099469,0.10092,0.098573,0.091558,0.098003,0.081656,0.071055,0.062281],"unified_progress":[0.040559,0.072526,0.093588,0.10706,0.11237,0.10462,0.10273,0.093106,0.091674,0.073319,0.058746,0.049716]},{"section":21,"text":"Wait, another possibility is a parapharyngeal space infection, but that's more on the side.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.029619,0.068444,0.083611,0.093124,0.097777,0.1004,0.10053,0.09756,0.09911,0.088568,0.078045,0.063204],"unified_progress":[0.036393,0.071682,0.091113,0.1038,0.10768,0.10341,0.10298,0.0962,0.092147,0.082047,0.064015,0.048527]},{"section":22,"text":"The submandibular space infection can spread to the floor of the mouth.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.032555,0.073841,0.086716,0.095606,0.097335,0.10008,0.099046,0.09342,0.098917,0.083111,0.074157,0.06522],"unified_progress":[0.046127,0.072222,0.091343,0.10568,0.10884,0.10443,0.10038,0.093042,0.091606,0.073692,0.061064,0.05158]},{"section":23,"text":"The combination of a dental abscess leading to Ludwig's angina?","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029856,0.065432,0.078511,0.088559,0.094793,0.098927,0.10098,0.097337,0.09723,0.090462,0.083027,0.074885],"unified_progress":[0.046729,0.064497,0.079163,0.089255,0.095951,0.098441,0.098206,0.095977,0.094945,0.087624,0.079854,0.069359]},{"section":24,"text":"Let me think again.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.3173,0.051515,0.052675,0.061483,0.06239,0.064468,0.062026,0.070178,0.070685,0.065866,0.068945,0.052468],"unified_progress":[0.21355,0.082046,0.065116,0.065582,0.074305,0.073181,0.088601,0.080147,0.076347,0.062121,0.05797,0.061034]},{"section":25,"text":"Ludwig's angina is a bilateral cellulitis of the floor of the mouth, often from dental infections, leading to swelling, elevated tongue, difficulty swallowing (dysphagia), and possibly airway compromise.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.040035,0.084006,0.0581,0.099168,0.10536,0.10291,0.10386,0.096091,0.088048,0.082441,0.074876,0.065106],"unified_progress":[0.047307,0.0706,0.058993,0.087794,0.096689,0.09658,0.10415,0.098552,0.095489,0.092348,0.082863,0.068632]},{"section":26,"text":"The high fever is consistent with a systemic infection.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.026057,0.058923,0.073524,0.085729,0.095147,0.10002,0.1045,0.10145,0.097837,0.093381,0.087481,0.075941],"unified_progress":[0.033592,0.050154,0.062111,0.072366,0.08457,0.096292,0.098611,0.10208,0.10547,0.10735,0.10333,0.084079]},{"section":27,"text":"The presence of a severely decayed molar is a classic source for such an infection.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031374,0.067108,0.079048,0.087016,0.092009,0.097078,0.097594,0.095911,0.096689,0.092486,0.084954,0.078733],"unified_progress":[0.047349,0.07161,0.076609,0.083009,0.088202,0.092888,0.09359,0.094407,0.095513,0.092935,0.086806,0.077082]},{"section":28,"text":"Alternatively, maybe a peritonsillar abscess, but that's usually unilateral and on the tonsil area.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.027494,0.06279,0.076916,0.087625,0.094787,0.099306,0.10275,0.10085,0.10233,0.093868,0.084002,0.067275],"unified_progress":[0.034722,0.064151,0.083127,0.094208,0.099848,0.10209,0.10214,0.099776,0.098677,0.091389,0.074853,0.055015]},{"section":29,"text":"The submandibular region swelling might not be the primary site there.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.027808,0.064507,0.078231,0.087433,0.09251,0.097259,0.10071,0.099455,0.10321,0.092942,0.08555,0.070389],"unified_progress":[0.043238,0.065908,0.082039,0.092412,0.1001,0.09898,0.099497,0.098574,0.098167,0.089811,0.074554,0.056726]},{"section":30,"text":"The key here is the dental source.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.026674,0.059695,0.076821,0.085351,0.091104,0.093692,0.096011,0.096274,0.097808,0.09816,0.092581,0.085828],"unified_progress":[0.041619,0.065887,0.075408,0.084486,0.089503,0.091436,0.096146,0.096193,0.095986,0.097177,0.089335,0.076825]},{"section":31,"text":"So the most likely diagnosis is Ludwig's angina.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.02084,0.043591,0.054988,0.063332,0.070854,0.077453,0.084634,0.08948,0.098557,0.10278,0.11658,0.17691],"unified_progress":[0.021751,0.033944,0.043392,0.053391,0.058943,0.072341,0.076529,0.08866,0.10148,0.10999,0.14639,0.19319]},{"section":32,"text":"Let me confirm the typical presentation: bilateral swelling of the floor of the mouth, caused by bacterial infection (usually mixed, including strep and anaerobes), from a dental source.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026025,0.05562,0.066986,0.077777,0.087154,0.094039,0.099154,0.099419,0.099379,0.10139,0.096019,0.097035],"unified_progress":[0.029195,0.047241,0.060818,0.071555,0.080917,0.091332,0.094892,0.10214,0.10627,0.10874,0.10649,0.10041]},{"section":33,"text":"The patient's symptoms fit: fever, dysphagia, elevated tongue, and the dental issue.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.024007,0.052591,0.063448,0.072769,0.083334,0.092238,0.099002,0.10166,0.10494,0.10443,0.10654,0.095046],"unified_progress":[0.03466,0.051341,0.060715,0.069155,0.080028,0.09255,0.095191,0.10183,0.10763,0.11057,0.1078,0.088538]},{"section":34,"text":"So I think that's it.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30232,0.049196,0.050673,0.059816,0.06119,0.064866,0.064245,0.073707,0.074343,0.070424,0.072646,0.056579],"unified_progress":[0.19162,0.073694,0.06103,0.062424,0.07144,0.073771,0.086672,0.084315,0.082375,0.069203,0.065822,0.077632]},{"section":35,"text":"<answer> Ludwig's angina </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.061947,0.12018,0.047616,0.07633,0.076651,0.085541,0.079961,0.081982,0.083548,0.083213,0.084697,0.11834],"unified_progress":[0.061979,0.071437,0.049363,0.071042,0.073291,0.082443,0.082494,0.081422,0.084158,0.090332,0.10632,0.14572]}]}}