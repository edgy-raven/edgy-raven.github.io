,0.10147,0.105,0.10016,0.09434,0.085897,0.078364,0.070149,0.060203,0.046409]},{"section":8,"text":"Hmm, something else might be happening here.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.040664,0.085608,0.10277,0.11249,0.1121,0.10737,0.10007,0.089524,0.081945,0.072923,0.058202,0.036333],"unified_progress":[0.044357,0.081207,0.09599,0.10416,0.10589,0.099738,0.10371,0.09061,0.083593,0.076939,0.065124,0.048691]},{"section":9,"text":"She also has these enlarged lymph nodes in the back of her neck.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.073195,0.089627,0.097296,0.10721,0.10998,0.10631,0.098147,0.085933,0.076124,0.070145,0.054262,0.031763],"unified_progress":[0.061119,0.088578,0.093907,0.098829,0.10084,0.098357,0.093379,0.090856,0.087223,0.074673,0.062907,0.04933]},{"section":10,"text":"That could mean there's some kind of infection or inflammation going on.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.02449,0.067895,0.096291,0.11504,0.11891,0.11893,0.11238,0.10024,0.086248,0.076189,0.056326,0.027063],"unified_progress":[0.03295,0.074841,0.095693,0.10932,0.10629,0.1008,0.10462,0.097056,0.090214,0.082214,0.064183,0.041829]},{"section":11,"text":"And then we see leukopenia, which means her white blood cell count is low.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.031073,0.068207,0.096773,0.12291,0.13189,0.12795,0.11393,0.092854,0.07495,0.064576,0.047904,0.026981],"unified_progress":[0.041548,0.077294,0.095387,0.10505,0.11117,0.10517,0.099999,0.093633,0.089438,0.073554,0.060544,0.04722]},{"section":12,"text":"This can happen when the immune system is really active or if there's an underlying issue like an infection or even a type of cancer.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.02363,0.059369,0.088416,0.11064,0.11869,0.12176,0.11664,0.10486,0.090006,0.079617,0.058321,0.02805],"unified_progress":[0.033725,0.070997,0.091625,0.10469,0.10536,0.10261,0.10689,0.099283,0.091739,0.084153,0.06532,0.043612]},{"section":13,"text":"Oh, and there are low C4 complement levels too.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.020615,0.061649,0.092713,0.11978,0.13003,0.12811,0.11632,0.098913,0.082847,0.071768,0.051096,0.026162],"unified_progress":[0.034751,0.073637,0.092787,0.10469,0.11021,0.10463,0.10163,0.095434,0.091388,0.078467,0.063914,0.048458]},{"section":14,"text":"Complement proteins play a role in the immune response, so their depletion often indicates ongoing inflammation or immune activation.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.035554,0.057629,0.079784,0.099013,0.10835,0.11169,0.10988,0.10097,0.092997,0.087948,0.071612,0.044576],"unified_progress":[0.043016,0.066792,0.084572,0.09656,0.10104,0.10509,0.10214,0.096892,0.092568,0.083372,0.070777,0.057172]},{"section":15,"text":"In Sj\u00f6gren's, you'd expect to see low IgG levels more than low complement levels, but this combination of symptoms is making me think there's more to consider.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.032044,0.057817,0.075221,0.08918,0.097085,0.10229,0.10441,0.10277,0.10189,0.098706,0.083704,0.054893],"unified_progress":[0.040131,0.065322,0.08131,0.090874,0.097598,0.098377,0.099311,0.097662,0.094933,0.09119,0.079658,0.063634]},{"section":16,"text":"So, what could cause all these things together?","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.11657,0.091952,0.086149,0.077377,0.078226,0.079894,0.081829,0.089815,0.080928,0.054735,0.055076,0.10745],"unified_progress":[0.20628,0.078501,0.065734,0.06562,0.074926,0.074969,0.091007,0.083526,0.079798,0.064591,0.058769,0.056283]},{"section":17,"text":"One possibility is a lymphoma.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.025748,0.055789,0.07838,0.0948,0.10046,0.10543,0.10947,0.10707,0.10417,0.099917,0.074664,0.044103],"unified_progress":[0.036309,0.071083,0.068236,0.097919,0.10612,0.10172,0.10166,0.10339,0.097676,0.089196,0.074171,0.052515]},{"section":18,"text":"Specifically, a type called mucosa-associated lymphoid tissue, or MALT, lymphoma.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.017836,0.034143,0.051399,0.069788,0.088184,0.10568,0.12063,0.12395,0.12982,0.13349,0.089245,0.035844],"unified_progress":[0.026929,0.054419,0.078748,0.093236,0.10187,0.11334,0.11054,0.1068,0.099818,0.091,0.071162,0.052147]},{"section":19,"text":"It's known to develop in people with chronic inflammatory conditions like Sj\u00f6gren's syndrome.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.0207,0.032092,0.045778,0.06163,0.080377,0.099025,0.11541,0.123,0.13241,0.14043,0.10087,0.04828],"unified_progress":[0.029476,0.053303,0.075085,0.092524,0.098937,0.10976,0.10942,0.1068,0.10035,0.094209,0.074105,0.056029]},{"section":20,"text":"The parotid swelling and lymphadenopathy fit with this idea, as does the leukopenia and low complement levels due to systemic involvement.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.012994,0.025186,0.035081,0.045394,0.058134,0.071184,0.088306,0.10125,0.11907,0.14634,0.1688,0.12826],"unified_progress":[0.028554,0.045704,0.060951,0.073156,0.084762,0.10368,0.10049,0.10329,0.10754,0.10564,0.10328,0.082941]},{"section":21,"text":"Yeah, I'm leaning towards this being a case of MALT lymphoma.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.013464,0.026804,0.035654,0.044581,0.05226,0.060623,0.069482,0.075936,0.087821,0.11045,0.1814,0.24152],"unified_progress":[0.016092,0.031862,0.042501,0.052466,0.058913,0.076277,0.08005,0.098732,0.10843,0.1126,0.14199,0.18009]},{"section":22,"text":"It seems to explain the persistent parotid swelling, the lymph node enlargement, and the lab findings.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.0082728,0.017014,0.023042,0.029708,0.039164,0.050644,0.066685,0.08177,0.10565,0.14643,0.20958,0.22203],"uni