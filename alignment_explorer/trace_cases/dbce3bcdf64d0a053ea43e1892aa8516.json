083,0.10367,0.10004,0.093344,0.092735,0.083917,0.086923,0.075047,0.067618,0.057578,0.047532]},{"section":5,"text":"Often, when food isn't stored properly, bacteria can grow, and reheating might not kill all the toxins.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.052223,0.092891,0.09862,0.099818,0.098464,0.097684,0.092547,0.088728,0.080466,0.076929,0.064893,0.056737],"unified_progress":[0.061187,0.078076,0.089538,0.0942,0.095921,0.098626,0.094126,0.092221,0.08687,0.083033,0.06966,0.056542]},{"section":6,"text":"His vital signs: temperature is normal, which is interesting because sometimes infections can cause fever.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.050433,0.094625,0.097875,0.094826,0.092517,0.092551,0.09149,0.091573,0.083981,0.079709,0.072226,0.058196],"unified_progress":[0.05258,0.084979,0.089151,0.092012,0.096802,0.094864,0.0946,0.094015,0.088464,0.086173,0.07315,0.05321]},{"section":7,"text":"But in food poisoning, especially from preformed toxin ingestion, fever might not be present.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.03674,0.074506,0.086192,0.092723,0.095796,0.096488,0.09763,0.095144,0.089304,0.089655,0.078522,0.067301],"unified_progress":[0.039342,0.064243,0.078403,0.086647,0.093054,0.098576,0.099088,0.099638,0.096478,0.097606,0.083506,0.063421]},{"section":8,"text":"His pulse is a bit elevated (106) and his blood pressure is on the lower side (90/78), which could be due to dehydration from vomiting and diarrhea.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.054833,0.099814,0.098861,0.093931,0.090976,0.091377,0.090331,0.089992,0.083018,0.076901,0.071013,0.058955],"unified_progress":[0.053902,0.087276,0.091396,0.092638,0.096961,0.095265,0.094783,0.092087,0.087078,0.081458,0.072204,0.054954]},{"section":9,"text":"The physical exam is normal except for dehydration signs, which fits with acute gastroenteritis from a toxin rather than an infection that might cause more localized abdominal tenderness or other findings.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.044166,0.085606,0.088905,0.08855,0.089731,0.09318,0.093718,0.094272,0.090563,0.085651,0.078658,0.067002],"unified_progress":[0.044531,0.071725,0.079155,0.084163,0.090425,0.094237,0.094332,0.097879,0.096864,0.09552,0.084978,0.066193]},{"section":10,"text":"So, the timing of symptoms after eating, the presence of dehydration, and the history of eating possibly contaminated food point towards food poisoning.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.037855,0.075671,0.089008,0.093156,0.092161,0.090144,0.08965,0.088176,0.086813,0.093606,0.083752,0.080009],"unified_progress":[0.042712,0.065681,0.074203,0.084207,0.088575,0.091748,0.096359,0.09571,0.095539,0.10012,0.09006,0.075085]},{"section":11,"text":"The most common causes of this are bacterial toxins like Staphylococcus aureus, which produces a preformed toxin that acts quickly after ingestion.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032078,0.066996,0.080399,0.090967,0.097587,0.099297,0.099754,0.095343,0.089062,0.090954,0.079443,0.07812],"unified_progress":[0.033175,0.056103,0.074461,0.083325,0.091727,0.10201,0.10072,0.10102,0.098433,0.097005,0.086297,0.075733]},{"section":12,"text":"Other possibilities might include viral gastroenteritis, but the rapid onset is more typical of a bacterial toxin.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024394,0.058156,0.075292,0.085896,0.092141,0.09512,0.10061,0.10062,0.098583,0.10055,0.091209,0.077424],"unified_progress":[0.025728,0.05283,0.06885,0.080503,0.089717,0.095602,0.099576,0.10447,0.10492,0.11165,0.094259,0.071891]},{"section":13,"text":"Also, viral usually has a longer incubation period.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022913,0.054064,0.067687,0.078211,0.087167,0.094286,0.10297,0.10651,0.10541,0.10598,0.098641,0.076169],"unified_progress":[0.028458,0.05225,0.066932,0.07638,0.088246,0.094848,0.10066,0.10826,0.10865,0.11601,0.095747,0.063559]},{"section":14,"text":"So, Staphylococcal food poisoning seems likely here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028782,0.059027,0.071508,0.080323,0.086055,0.089125,0.093097,0.093983,0.093835,0.099073,0.094295,0.1109],"unified_progress":[0.031666,0.048803,0.061043,0.072198,0.078194,0.08697,0.091837,0.095223,0.097418,0.10246,0.11069,0.1235]}]}}