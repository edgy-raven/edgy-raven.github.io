0.10085,0.10239,0.10835,0.10402,0.097703,0.090734,0.084896,0.080007,0.067864,0.056051,0.042859]},{"section":5,"text":"That's interesting because that area can be linked to infections or even inflammation in the nearby structures like the parotid gland or maybe even the lymph nodes.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.047602,0.076917,0.096946,0.11084,0.11339,0.11177,0.10555,0.094026,0.083803,0.075983,0.055333,0.027834],"unified_progress":[0.048499,0.078809,0.096558,0.1052,0.10465,0.10413,0.10042,0.093153,0.086276,0.076473,0.061265,0.044569]},{"section":6,"text":"But let's keep going.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.12911,0.10271,0.095101,0.083808,0.082047,0.080915,0.079827,0.084623,0.073488,0.048158,0.04846,0.091758],"unified_progress":[0.21758,0.082904,0.067711,0.066974,0.076233,0.073591,0.093948,0.079773,0.075081,0.059462,0.054697,0.052042]},{"section":7,"text":"Oh, and he has a fever too.","dimension":6,"group":5,"is_degenerate":false,"model_progress":[0.096502,0.10649,0.10517,0.10548,0.10229,0.094986,0.087086,0.077926,0.070987,0.066475,0.053193,0.033412],"unified_progress":[0.077524,0.11934,0.078305,0.097835,0.10077,0.094348,0.089899,0.084964,0.077587,0.071086,0.062022,0.046328]},{"section":8,"text":"Fever often means there's an infection or inflammation happening somewhere.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.036891,0.073803,0.097628,0.11231,0.11364,0.11173,0.10498,0.093754,0.08262,0.075469,0.060931,0.036245],"unified_progress":[0.042703,0.078125,0.095266,0.10711,0.10315,0.098775,0.10009,0.093526,0.087414,0.079682,0.065919,0.048233]},{"section":9,"text":"So, I'm thinking we're dealing with something infectious or inflammatory.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.028434,0.069541,0.091134,0.1062,0.11052,0.11024,0.10555,0.097117,0.088081,0.08074,0.067543,0.044893],"unified_progress":[0.036289,0.07338,0.089801,0.10071,0.10115,0.097713,0.099573,0.095143,0.08989,0.086296,0.073054,0.057004]},{"section":10,"text":"And then there's the kicker - he's been having ear discharge for six whole years!","dimension":6,"group":5,"is_degenerate":false,"model_progress":[0.092521,0.10491,0.098224,0.097382,0.096548,0.093678,0.089037,0.082461,0.077205,0.073228,0.058833,0.03597],"unified_progress":[0.065589,0.097892,0.094179,0.094143,0.094315,0.092458,0.089315,0.089884,0.084613,0.077873,0.067201,0.052538]},{"section":11,"text":"That's a long time to be dealing with ear issues.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.062612,0.11078,0.11399,0.11202,0.10564,0.098964,0.090476,0.078181,0.073445,0.064973,0.054029,0.034886],"unified_progress":[0.054427,0.090934,0.099475,0.10114,0.10479,0.098853,0.095557,0.088056,0.081783,0.072563,0.063665,0.048753]},{"section":12,"text":"Chronic ear problems could mean chronic suppurative otitis media, where the middle ear gets infected over and over again.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.045938,0.064484,0.079557,0.093007,0.10131,0.10545,0.10692,0.10117,0.097434,0.095338,0.07123,0.038164],"unified_progress":[0.045668,0.070541,0.088143,0.097043,0.10011,0.10635,0.10001,0.097422,0.090645,0.083269,0.068484,0.052313]},{"section":13,"text":"This can lead to all sorts of complications if left unchecked.","dimension":0,"group":7,"is_degenerate":false,"model_progress":[0.036765,0.066232,0.079338,0.089707,0.095531,0.099422,0.10103,0.097941,0.097057,0.096238,0.084411,0.056332],"unified_progress":[0.040449,0.070372,0.085386,0.093752,0.098347,0.10004,0.098977,0.096561,0.092387,0.087244,0.07622,0.060264]},{"section":14,"text":"Let's think about those granulations in the ear canal.","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.017753,0.058528,0.089632,0.10803,0.11316,0.11335,0.10764,0.1021,0.096156,0.09106,0.068338,0.034249],"unified_progress":[0.035791,0.071021,0.085191,0.10195,0.10024,0.097567,0.099478,0.09429,0.090842,0.091679,0.074877,0.05707]},{"section":15,"text":"Granulations suggest some kind of ongoing irritation or infection.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.03139,0.058331,0.081781,0.099383,0.10642,0.11089,0.11001,0.10376,0.095678,0.091027,0.071602,0.039734],"unified_progress":[0.03959,0.067941,0.085628,0.096395,0.10057,0.10191,0.10332,0.099253,0.094111,0.086053,0.071348,0.05388]},{"section":16,"text":"It's like the body's way of trying to fight back against something persistent.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.041207,0.061986,0.080254,0.095349,0.10236,0.10533,0.10422,0.097652,0.091625,0.088364,0.077598,0.054055],"unified_progress":[0.046359,0.068236,0.083664,0.09323,0.097324,0.097938,0.098516,0.096414,0.092556,0.087008,0.076152,0.062602]},{"section":17,"text":"So, putting these pieces together - the torticollis, the swelling, the fever, and the long-term ear issue - they all seem to point towards something more than just a simple ear infection.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.022574,0.041329,0.053496,0.0635,0.072402,0.080977,0.089954,0.095774,0.10524,0.12233,0.13951,0.11292],"unified_progress":[0.033463,0.054237,0.068017,0.077393,0.086014,0.096127,0.096706,0.099736,0.10221,0.10319,0.098698,0.08421]},{"section":18,"text":"Hmm, what could tie them all together?","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.019688,0.048485,0.068249,0.082146,0.089897,0.096109,0.10003,0.1026,0.10645,0.10926,0.10188,0.075199],"unified_progress":[0.031322,0.059594,0.074085,0.08622,0.090071,0.092854,0.096522,0.097794,0.097938,0.099862,0.093008,0.080728]},{"section":19,"text":"Chronic suppurative otitis media could cause the ear discharge and might even affect the mastoid bone, leading to mastoiditis.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.02378,0.040221,0.055776,0.071024,0.084146,0.096309,0.10717,0.11123,0.11669,0.12476,0.10526,0.063641],"unified_progress":[0.032136,0.056345,0.074006,0.085437,0.093946,0.10346,0.10292,0.10392,0.10136,0.097746,0.083616,0.065101]},{"section":20,"text":"Mastoiditis can get serious and cause fever and even spread to other areas, causing things like torticollis due to muscle involvement from referred pain or inflammation.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.023959,0.039412,0.053572,0.067642,0.080255,0.092101,0.10323,0.10836,0.1154,0.12637,0.11599,0.073709],"unified_progress":[0.03307,0.056174,0.073294,0.085031,0.092877,0.10195,0.1027,0.10308,0.10162,0.097627,0.085592,0.066989]},{"section":21,"text":"Yeah, that makes sense.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.10457,0.084187,0.079117,0.071908,0.073951,0.077342,0.081187,0.091651,0.083969,0.059053,0.063678,0.12939],"unified_progress":[0.19881,0.074974,0.063236,0.064247,0.073313,0.07375,0.096564,0.083334,0.080554,0.065266,0.061316,0.06464]},{"section":22,"text":"The combination of symptoms fits well with mastoiditis as a complication of chronic ear issues.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.029796,0.045628,0.05713,0.067075,0.072237,0.077727,0.083349,0.084541,0.088927,0.10117,0.13485,0.15757],"unified_progress":[0.035573,0.05612,0.051039,0.074509,0.08433,0.086708,0.09802,0.095118,0.097078,0.099068,0.10456,0.11788]},{"section":23,"text":"It explains the fever, the swelling, and even the torticollis.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.012023,0.022756,0.029689,0.036914,0.047164,0.059235,0.075251,0.089143,0.11072,0.14606,0.1933,0.17774],"unified_progress":[0.024623,0.038724,0.050856,0.061282,0.075224,0.092694,0.095444,0.10354,0.11265,0.11908,0.12091,0.10497]},{"section":24,"text":"So, I'm feeling confident that mastoiditis is the most likely diagnosis here.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.011077,0.019454,0.024394,0.030036,0.035237,0.041323,0.048612,0.054398,0.068573,0.10119,0.22395,0.3