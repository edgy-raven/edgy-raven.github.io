ilities.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.27639,0.045035,0.046387,0.056288,0.058675,0.063073,0.062314,0.073938,0.080591,0.080897,0.090011,0.066399],"unified_progress":[0.18445,0.071311,0.05943,0.060609,0.069468,0.071765,0.10581,0.084832,0.085732,0.07455,0.070614,0.061434]},{"section":25,"text":"Maybe an ovarian cyst torsion, but that's usually more in the lower abdomen and the patient is postmenopausal.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027653,0.062875,0.05657,0.094147,0.10121,0.099643,0.10579,0.10545,0.10019,0.09398,0.086261,0.066238],"unified_progress":[0.040383,0.071073,0.065603,0.090398,0.10191,0.098489,0.10034,0.10653,0.10182,0.095973,0.077972,0.049512]},{"section":26,"text":"Appendicitis is right lower quadrant.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02557,0.059503,0.07286,0.084001,0.092036,0.097987,0.10384,0.10408,0.104,0.098158,0.088704,0.069256],"unified_progress":[0.031177,0.06047,0.07727,0.08743,0.096853,0.10176,0.10209,0.10452,0.10349,0.10009,0.080436,0.054405]},{"section":27,"text":"So yeah, sigmoid volvulus fits best.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.02175,0.048546,0.062118,0.070909,0.078408,0.084179,0.090285,0.093677,0.099128,0.10031,0.10607,0.14462],"unified_progress":[0.02246,0.040023,0.05069,0.06156,0.067192,0.076471,0.081472,0.090061,0.096873,0.1052,0.13427,0.17374]}]}}