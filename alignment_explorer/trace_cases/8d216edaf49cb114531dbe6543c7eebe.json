3084]},{"section":3,"text":"He has two attacks a day, each lasting about an hour, and they wake him from sleep.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.15841,0.27643,0.18632,0.072428,0.055376,0.066614,0.039146,0.05746,0.027196,0.023787,0.01953,0.017295],"unified_progress":[0.12588,0.18107,0.13871,0.086824,0.077294,0.087369,0.061275,0.085823,0.048764,0.042726,0.035991,0.028279]},{"section":4,"text":"The headaches are severe, unilateral (right side), and associated with tearing and reddening of the right eye, plus nasal stuffiness.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.1276,0.2151,0.17158,0.10051,0.069696,0.073154,0.05303,0.062513,0.041453,0.034048,0.027673,0.023637],"unified_progress":[0.10774,0.14378,0.11871,0.1123,0.08596,0.088982,0.071304,0.080978,0.062994,0.050777,0.042962,0.033514]},{"section":5,"text":"Neuro exam is normal.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.087338,0.15189,0.13667,0.10544,0.087375,0.08709,0.072519,0.073887,0.060453,0.053894,0.045797,0.037653],"unified_progress":[0.083094,0.11317,0.10126,0.10241,0.094043,0.092962,0.083201,0.08602,0.074769,0.068635,0.056985,0.043439]},{"section":6,"text":"Hmm, the key points here are the unilateral headache, the associated autonomic symptoms like tearing (lacrimation), eye redness (conjunctival injection), and nasal congestion.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.070957,0.12195,0.11537,0.10219,0.092929,0.090793,0.082361,0.080404,0.071312,0.065341,0.056294,0.050096],"unified_progress":[0.068825,0.093112,0.096553,0.097617,0.095499,0.09772,0.090442,0.08935,0.082832,0.074933,0.063153,0.049964]},{"section":7,"text":"The timing\u2014waking him from sleep and occurring twice daily for three weeks.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.082238,0.13875,0.11587,0.092569,0.083375,0.088289,0.077164,0.08186,0.068642,0.063999,0.056753,0.050492],"unified_progress":[0.080927,0.11224,0.098229,0.093559,0.088143,0.090713,0.083077,0.088052,0.078141,0.072373,0.063261,0.051282]},{"section":8,"text":"Cluster headaches are classic for this presentation.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.048084,0.091408,0.10864,0.11084,0.10203,0.089502,0.086529,0.07961,0.073061,0.081958,0.064243,0.064099],"unified_progress":[0.047978,0.071278,0.084572,0.095109,0.095317,0.095518,0.096048,0.090878,0.085915,0.094271,0.077104,0.066012]},{"section":9,"text":"They typically occur in cyclical patterns, hence \"cluster\" periods, which can last weeks.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037855,0.07615,0.086977,0.095477,0.10079,0.10129,0.099352,0.093691,0.085624,0.084477,0.072338,0.065982],"unified_progress":[0.047973,0.064164,0.07883,0.086664,0.093619,0.10228,0.098403,0.098841,0.093853,0.091112,0.078118,0.066145]},{"section":10,"text":"The side is usually consistent, so right side here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.038638,0.079107,0.088696,0.092583,0.093885,0.094932,0.095077,0.093127,0.090001,0.086527,0.077726,0.0697],"unified_progress":[0.05723,0.071376,0.079505,0.087065,0.091883,0.093512,0.093481,0.095389,0.092956,0.091489,0.079493,0.066622]},{"section":11,"text":"The symptoms on the same side as the headache (like ptosis or miosis might also occur but not mentioned here) are part of the cranial autonomic features.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.040657,0.08069,0.087374,0.091415,0.093671,0.095926,0.095859,0.093406,0.090729,0.085425,0.076039,0.068809],"unified_progress":[0.043926,0.072158,0.084528,0.091391,0.095437,0.099901,0.097107,0.096282,0.094046,0.087375,0.075576,0.062273]},{"section":12,"text":"The duration of an hour and the frequency (two times a day) fit cluster headache's typical attacks, which can happen up to eight times a day.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.047145,0.085726,0.086218,0.086899,0.089902,0.093712,0.093484,0.093397,0.08738,0.085734,0.077771,0.072632],"unified_progress":[0.054061,0.075169,0.080864,0.08524,0.088962,0.095829,0.093252,0.095275,0.091443,0.088997,0.080761,0.070147]},{"section":13,"text":"The fact that the neurological exam is normal is also important because it rules out other causes like tumors or strokes.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.03222,0.070769,0.086159,0.092151,0.092783,0.09269,0.095648,0.094599,0.094135,0.093363,0.084321,0.071162],"unified_progress":[0.032997,0.064585,0.077111,0.087496,0.094605,0.094913,0.098126,0.099215,0.099262,0.10222,0.08569,0.063778]},{"section":14,"text":"Migraines can have autonomic features but usually last longer and aren't as strictly unilateral with the same timing.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024249,0.056814,0.070451,0.081069,0.089382,0.095221,0.10367,0.10566,0.1032,0.10288,0.094793,0.072605],"unified_progress":[0.030438,0.05447,0.06944,0.07838,0.090235,0.09719,0.10093,0.10752,0.10668,0.11142,0.091893,0.061401]},{"section":15,"text":"Tension headaches don't have the autonomic symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.023647,0.055093,0.068666,0.079121,0.087198,0.093635,0.1024,0.10555,0.10472,0.10544,0.09759,0.07694],"unified_progress":[0.027757,0.053485,0.068651,0.078806,0.089324,0.09612,0.10151,0.10745,0.10756,0.11337,0.093278,0.062694]},{"section":16,"text":"Maybe trigeminal neuralgia, but that's more like sharp, electric shocks and not\u6301\u7eed an hour.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.0246,0.055818,0.068169,0.07919,0.088412,0.095642,0.10389,0.10651,0.10486,0.10472,0.094845,0.073349],"unified_progress":[0.02896,0.054044,0.070071,0.080566,0.091063,0.098724,0.10245,0.10825,0.1075,0.11083,0.089308,0.058237]},{"section":17,"text":"So cluster headache is the most likely.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.022667,0.050621,0.065344,0.072922,0.077154,0.079746,0.085615,0.089091,0.094192,0.10157,0.10686,0.15422],"unified_progress":[0.020642,0.038538,0.048537,0.059892,0.065025,0.074465,0.081268,0.088923,0.095776,0.10772,0.13815,0.18107]}]}}