944,0.091261,0.089442,0.086075,0.079292,0.083023,0.070353,0.061035]},{"section":5,"text":"I remember that sometimes people can have what's called \"functional neurological disorders\" where the symptoms don't match the imaging results.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.057824,0.091319,0.094544,0.098879,0.093094,0.089893,0.090921,0.085902,0.083115,0.083768,0.072991,0.057747],"unified_progress":[0.044288,0.073969,0.088571,0.09848,0.098871,0.09904,0.098057,0.093762,0.088388,0.088609,0.071993,0.055972]},{"section":6,"text":"These can include things like conversion disorders, where physical symptoms can't be explained by structural issues in the brain.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.037862,0.061134,0.077811,0.087848,0.097639,0.10204,0.1041,0.10426,0.10015,0.091058,0.075679,0.060419],"unified_progress":[0.034744,0.061257,0.081766,0.092701,0.099829,0.10725,0.10411,0.10195,0.096527,0.091927,0.073341,0.05459]},{"section":7,"text":"Another possibility is that he might be experiencing something like somatization disorder, where he's expressing physical symptoms as a way to deal with underlying psychological stress or emotional issues.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.040225,0.070053,0.081294,0.088542,0.091696,0.095009,0.099346,0.098859,0.096854,0.095518,0.079962,0.062642],"unified_progress":[0.045421,0.072723,0.084336,0.092685,0.096275,0.098497,0.099264,0.098823,0.093684,0.088788,0.074052,0.05545]},{"section":8,"text":"Alternatively, it could be something like anxiety or depression causing him to fixate on the idea of a brain tumor.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.0381,0.062996,0.077605,0.086862,0.090859,0.094846,0.099348,0.1003,0.099333,0.1003,0.084027,0.065424],"unified_progress":[0.045894,0.072379,0.084491,0.092887,0.095024,0.096417,0.097804,0.097935,0.093313,0.089921,0.076024,0.05791]},{"section":9,"text":"Wait, but he's been to the doctor multiple times, and the MRI was normal.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31313,0.13077,0.06696,0.05599,0.063062,0.065445,0.05989,0.064102,0.060453,0.045466,0.046815,0.027922],"unified_progress":[0.20811,0.079776,0.064461,0.064981,0.074831,0.073635,0.094334,0.082097,0.078735,0.063253,0.05891,0.056876]},{"section":10,"text":"That makes me think it's not something like a brain tumor, which would usually show up on imaging.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.070924,0.084917,0.096055,0.097532,0.094636,0.091294,0.090101,0.086964,0.08267,0.081205,0.071093,0.052608],"unified_progress":[0.044985,0.07122,0.061525,0.087695,0.097742,0.097307,0.097741,0.10384,0.10099,0.096753,0.082419,0.057785]},{"section":11,"text":"So maybe it's more about how he's perceiving his symptoms.","dimension":8,"group":6,"is_degenerate":false,"model_progress":[0.056703,0.075394,0.082661,0.086192,0.088068,0.089949,0.093089,0.092309,0.092018,0.091425,0.082768,0.069423],"unified_progress":[0.049303,0.067425,0.076802,0.085204,0.089475,0.092606,0.096457,0.096444,0.094059,0.094098,0.085491,0.072637]},{"section":12,"text":"He might be misinterpreting normal bodily sensations as signs of a serious condition.","dimension":0,"group":5,"is_degenerate":false,"model_progress":[0.051007,0.073865,0.081603,0.08556,0.087916,0.090787,0.093107,0.093745,0.093293,0.091042,0.084001,0.074074],"unified_progress":[0.053224,0.071079,0.078506,0.083965,0.088326,0.092879,0.093251,0.095569,0.093264,0.091583,0.084655,0.073698]},{"section":13,"text":"Functional neurological disorder (FND) comes to mind because it's characterized by physical symptoms that can't be explained by a structural brain issue.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.037304,0.054771,0.068825,0.078796,0.089465,0.096076,0.10026,0.10379,0.10359,0.097899,0.087957,0.081267],"unified_progress":[0.034986,0.057116,0.077765,0.086896,0.092971,0.10088,0.10047,0.099842,0.097257,0.094989,0.084048,0.07278]},{"section":14,"text":"Symptoms like headaches, dizziness, or numbness can be part of FND.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.040647,0.065818,0.072454,0.079655,0.086553,0.092676,0.097762,0.1011,0.10099,0.094987,0.086523,0.080835],"unified_progress":[0.044702,0.068041,0.078694,0.086633,0.091415,0.09881,0.097645,0.098869,0.094715,0.090852,0.080301,0.069323]},{"section":15,"text":"People with FND often have normal or negative MRI results but still experience significant disability because of their symptoms.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.041427,0.058045,0.070854,0.078393,0.088213,0.094761,0.099248,0.10285,0.10268,0.096469,0.087286,0.079769],"unified_progress":[0.045047,0.064591,0.07877,0.08594,0.091718,0.098976,0.097814,0.099008,0.095477,0.092371,0.081182,0.069107]},{"section":16,"text":"Alternatively, it could be a somatic delusion, where he's convinced he has a serious illness, like a brain tumor, but without a physical cause.","dimension":8,"group":6,"is_degenerate":false,"model_progress":[0.032734,0.05375,0.067759,0.075836,0.085547,0.093739,0.099446,0.10669,0.11026,0.10717,0.094802,0.07227],"unified_progress":[0.042363,0.068854,0.082155,0.090984,0.094065,0.09697,0.098367,0.099005,0.095316,0.091222,0.078998,0.061701]},{"section":17,"text":"This might be related to a mental health condition like schizophrenia or delusional disorder.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.03238,0.0538,0.069652,0.079339,0.088386,0.095569,0.10144,0.10584,0.10678,0.10512,0.089856,0.071843],"unified_progress":[0.04434,0.070063,0.083005,0.090731,0.09447,0.098383,0.098917,0.09902,0.094387,0.090626,0.076748,0.05931]},{"section":18,"text":"But considering the context, the doctor thinks he's misinterpreting his sensations, which points more towards a functional issue rather than a delusional disorder.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.