32,0.11213,0.076449,0.093264,0.056887,0.049491,0.04254,0.036203,0.029912,0.022305]},{"section":3,"text":"He had a throat infection three weeks ago.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.12942,0.21272,0.15549,0.087864,0.074679,0.084306,0.057171,0.062893,0.042289,0.037612,0.030756,0.024788],"unified_progress":[0.12405,0.16142,0.12976,0.092008,0.083132,0.087787,0.06707,0.082819,0.05365,0.047673,0.039629,0.031007]},{"section":4,"text":"Now he's feeling unwell, and in the last week, he's had nausea and vomiting.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.13432,0.21461,0.15905,0.092716,0.067171,0.073614,0.053158,0.069772,0.042681,0.036614,0.030097,0.026195],"unified_progress":[0.12183,0.1544,0.11842,0.10684,0.081343,0.085019,0.067629,0.079569,0.058282,0.050514,0.042912,0.033243]},{"section":5,"text":"The urine dipstick shows protein and blood, and his serum creatinine and urea are a bit off.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.09098,0.15213,0.14213,0.11358,0.09188,0.085482,0.073256,0.070012,0.057154,0.048535,0.041976,0.032892],"unified_progress":[0.079792,0.12086,0.11148,0.10813,0.10431,0.096324,0.085566,0.079592,0.06862,0.058453,0.050071,0.036802]},{"section":6,"text":"Hmm, so first, the timeline.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.35407,0.064664,0.062813,0.069055,0.065358,0.062568,0.056159,0.060484,0.057703,0.052893,0.053604,0.040629],"unified_progress":[0.22652,0.092906,0.073072,0.067235,0.078071,0.074513,0.082767,0.076776,0.070691,0.057264,0.051873,0.048313]},{"section":7,"text":"The throat infection three weeks ago might be a clue.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.064833,0.13285,0.068488,0.10854,0.1036,0.10037,0.087987,0.081927,0.07331,0.068053,0.060304,0.049729],"unified_progress":[0.12147,0.15924,0.079095,0.091722,0.087194,0.088299,0.075741,0.072487,0.067139,0.061553,0.054829,0.041224]},{"section":8,"text":"Throat infections, especially strep (Group A Streptococcus), can sometimes lead to post-infectious conditions.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.043561,0.081467,0.091192,0.098707,0.10341,0.10511,0.099579,0.091973,0.081871,0.080187,0.065895,0.05704],"unified_progress":[0.067525,0.090251,0.10696,0.098802,0.095989,0.10122,0.091276,0.088481,0.07878,0.073093,0.059996,0.047622]},{"section":9,"text":"The edema is around the eyes, which is common in nephrotic syndrome, but he also has protein and blood in the urine.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.044445,0.086437,0.093628,0.096026,0.096185,0.095757,0.094524,0.091165,0.085048,0.082338,0.071554,0.062893],"unified_progress":[0.05343,0.079882,0.088876,0.094742,0.097219,0.098837,0.094707,0.092601,0.088383,0.084102,0.071605,0.055618]},{"section":10,"text":"Wait, nephrotic syndrome typically has heavy proteinuria, hypoalbuminemia, but here there's also hematuria.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.038766,0.078685,0.090356,0.096735,0.099476,0.098695,0.099064,0.093745,0.086588,0.083815,0.072654,0.061421],"unified_progress":[0.049412,0.072062,0.087236,0.093008,0.098775,0.10255,0.099799,0.095673,0.090017,0.085143,0.071561,0.054758]},{"section":11,"text":"The elevated creatinine and urea suggest some kidney dysfunction, maybe acute kidney injury.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.034376,0.073468,0.087358,0.094187,0.097272,0.097761,0.099717,0.095244,0.091272,0.085068,0.078229,0.066049],"unified_progress":[0.038786,0.066052,0.080723,0.087982,0.096089,0.099676,0.1001,0.096064,0.095258,0.090523,0.083248,0.065502]},{"section":12,"text":"Putting this together, post-streptococcal glomerulonephritis comes to mind.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.04631,0.078564,0.086196,0.093457,0.09587,0.094141,0.094139,0.089762,0.084031,0.086938,0.074254,0.076338],"unified_progress":[0.057222,0.061785,0.075704,0.086155,0.091243,0.097362,0.096445,0.096398,0.092677,0.090373,0.081654,0.072983]},{"section":13,"text":"That's a common cause in kids after a strep infection.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.03722,0.071754,0.084186,0.092976,0.098123,0.10095,0.098453,0.094063,0.087811,0.089448,0.075754,0.069266],"unified_progress":[0.059746,0.082024,0.085205,0.087138,0.089526,0.094858,0.091927,0.094766,0.088617,0.086174,0.075526,0.064493]},{"section":14,"text":"The time frame is about three weeks, which fits because PSGN usually develops 1-2 weeks after the infection.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.039886,0.075767,0.083511,0.089964,0.095077,0.10041,0.097939,0.095871,0.089079,0.088567,0.077033,0.066891],"unified_progress":[0.072061,0.089424,0.089548,0.089513,0.089504,0.093759,0.089267,0.092349,0.084576,0.081449,0.070252,0.058298]},{"section":15,"text":"The symptoms: edema, hematuria (blood in urine), proteinuria, and elevated renal parameters.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.034769,0.070352,0.078372,0.084394,0.090902,0.09579,0.098927,0.098058,0.094321,0.091389,0.086974,0.075754],"unified_progress":[0.048189,0.071314,0.080906,0.084428,0.091217,0.097421,0.095199,0.095954,0.094314,0.091141,0.083425,0.066493]},{"section":16,"text":"The nausea and vomiting could be due to uremia from the kidney impairment.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.020676,0.050307,0.065074,0.078682,0.09126,0.099688,0.10678,0.10553,0.10339,0.099122,0.095959,0.08353],"unified_progress":[0.02743,0.043125,0.057762,0.0661,0.081749,0.095225,0.098495,0.10429,0.11029,0.11316,0.11121,0.09117]},{"section":17,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.027798,0.065903,0.086451,0.094005,0.094931,0.091733,0.093536,0.093389,0.092165,0.098764,0.084098,0.077227],"unified_progress":[0.029285,0.061216,0.075518,0.089078,0.092432,0.094042,0.096793,0.09857,0.098291,0.10262,0.091135,0.071017]},{"section":18,"text":"Maybe a nephrotic syndrome like minimal change disease, but that usually doesn't present with hematuria or acute kidney injury.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.027296,0.061153,0.075972,0.087369,0.095634,0.098894,0.10293,0.10103,0.096385,0.0962,0.085302,0.07184],"unified_progress":[0.031079,0.055983,0.073175,0.083746,0.093844,0.1017,0.10253,0.10437,0.10218,0.10122,0.085237,0.064932]},{"section":19,"text":"IgA nephropathy can have hematuria after infections, but the timing and the other symptoms might not fit as well.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.01989,0.050979,0.067766,0.080693,0.090527,0.097491,0.10639,0.10822,0.10636,0.10533,0.096072,0.070278],"unified_progress":[0.025048,0.052023,0.069692,0.080289,0.092471,0.09864,0.10318,0.10936,0.10843,0.11453,0.089849,0.056493]},{"section":20,"text":"Also, the presence of both protein and blood in the urine, along with the recent infection, points more towards PSGN.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.02586,0.058885,0.074112,0.082942,0.088562,0.092238,0.097066,0.09801,0.099356,0.10052,0.096199,0.086246],"unified_progress":[0.032325,0.056968,0.070852,0.08191,0.089688,0.095665,0.10066,0.10102,0.10197,0.10256,0.093079,0.073306]},{"section":21,"text":"The lab results with elevated creatinine and urea support acute kidney issues, which is part of PSGN.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027171,0.059791,0.073966,0.083191,0.089794,0.094043,0.099326,0.098569,0.098557,0.096482,0.093625,0.085484],"unified_progress":[0.033009,0.05464,0.06894,0.078002,0.087877,0.094327,0.097949,0.099381,0.10199,0.10195,0.098239,0.083689]},{"section":22,"text":"So I think the most likely diagnosis is post-streptococcal glomerulonephritis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.029964,0.055092,0.062972,0.070958,0.078