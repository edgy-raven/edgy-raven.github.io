progress":[0.04353,0.080282,0.093726,0.097569,0.096771,0.092508,0.090258,0.087662,0.084308,0.087269,0.075221,0.070897],"unified_progress":[0.06284,0.0762,0.083634,0.092388,0.093658,0.091469,0.094883,0.091831,0.087415,0.088338,0.0755,0.061844]},{"section":13,"text":"I think some appetite suppressants like fenfluramine or dexfenfluramine are associated with pulmonary hypertension.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.041889,0.074968,0.083559,0.093483,0.10021,0.10231,0.10021,0.094457,0.085796,0.085882,0.07172,0.065515],"unified_progress":[0.057343,0.07166,0.08682,0.0903,0.095603,0.104,0.098082,0.09693,0.089073,0.083722,0.069324,0.057139]},{"section":14,"text":"Primary pulmonary hypertension is a possibility, but the history of appetite suppressants makes me think of drug-induced pulmonary arterial hypertension.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.03512,0.070197,0.083789,0.09255,0.096776,0.098397,0.097506,0.09329,0.088181,0.090972,0.077556,0.075667],"unified_progress":[0.047659,0.071272,0.081875,0.089206,0.091754,0.096548,0.094494,0.095414,0.091257,0.089437,0.080036,0.071049]},{"section":15,"text":"The clinical findings: right heart signs (JVD, RV lift, loud P2), ECG changes, and the normal perfusion scan (so no PE) all fit with pulmonary hypertension.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.035093,0.074047,0.085098,0.090827,0.092494,0.09464,0.09583,0.092776,0.096478,0.087111,0.081689,0.073917],"unified_progress":[0.039645,0.070352,0.084645,0.094745,0.099468,0.099415,0.097589,0.094726,0.095576,0.085548,0.075702,0.062588]},{"section":16,"text":"Since the lung fields are clear on CXR, it's more about the vascular system rather than the lungs themselves.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033197,0.074304,0.087407,0.09423,0.094136,0.09571,0.095907,0.091972,0.098351,0.086592,0.077943,0.070251],"unified_progress":[0.035332,0.068214,0.085601,0.097977,0.10408,0.10057,0.10068,0.09546,0.097043,0.084509,0.071425,0.059099]},{"section":17,"text":"The normal perfusion scan rules out clots, so the obstruction is likely in the pulmonary arteries due to hypertension.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030798,0.071225,0.085087,0.093878,0.095457,0.098094,0.098213,0.093276,0.099856,0.086228,0.077601,0.070288],"unified_progress":[0.033176,0.064552,0.083424,0.096688,0.10375,0.10155,0.10177,0.096724,0.09865,0.084242,0.073272,0.062212]},{"section":18,"text":"Putting it all together, the most likely diagnosis is pulmonary arterial hypertension, possibly drug-induced from the appetite suppressants she used.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.031026,0.05698,0.065519,0.072315,0.078043,0.082297,0.086943,0.089202,0.093142,0.09664,0.10203,0.14586],"unified_progress":[0.035725,0.044274,0.052826,0.062395,0.067648,0.075923,0.08155,0.090571,0.098426,0.10394,0.12938,0.15734]}]}}