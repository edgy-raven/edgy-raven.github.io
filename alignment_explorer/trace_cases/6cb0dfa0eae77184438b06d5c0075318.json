37,0.089067,0.098855,0.10363,0.10497,0.10203,0.096326,0.086234,0.074128,0.060767],"unified_progress":[0.044724,0.065456,0.082278,0.092662,0.098983,0.10412,0.10186,0.098687,0.094422,0.088025,0.073246,0.055533]},{"section":10,"text":"But the indirect response, which is when you shine a light in one eye and the other pupil constricts, is normal.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.043117,0.060792,0.078423,0.089684,0.098411,0.10322,0.10433,0.10177,0.096041,0.085945,0.07604,0.062226],"unified_progress":[0.044539,0.067492,0.082533,0.09148,0.098176,0.10144,0.10001,0.097942,0.095081,0.088563,0.07478,0.057959]},{"section":11,"text":"That makes me think that the optic nerve itself isn't completely non-functional because the consensual response requires the optic nerve to signal to the brain, so if it were completely dead, the indirect response might also be absent.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.043756,0.053686,0.071936,0.083569,0.094457,0.10103,0.10318,0.10396,0.10098,0.092599,0.083263,0.067589],"unified_progress":[0.042769,0.061358,0.077366,0.086766,0.095074,0.10077,0.10031,0.10026,0.097956,0.095126,0.080769,0.061476]},{"section":12,"text":"So maybe it's not a complete optic nerve lesion.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.037932,0.057395,0.074569,0.085773,0.091209,0.09598,0.099971,0.10081,0.098897,0.098456,0.087985,0.071021],"unified_progress":[0.036926,0.061287,0.076863,0.087602,0.094299,0.096474,0.099586,0.10084,0.099522,0.098464,0.084218,0.063922]},{"section":13,"text":"The optic disc is edematous.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.027573,0.061467,0.08673,0.10921,0.11445,0.11751,0.11687,0.10485,0.086286,0.069447,0.058755,0.046845],"unified_progress":[0.032896,0.071549,0.092099,0.10577,0.11036,0.10585,0.10202,0.094688,0.096683,0.07581,0.062297,0.049984]},{"section":14,"text":"Edema in the optic disc is often seen in conditions like papillede