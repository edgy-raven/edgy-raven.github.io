79,0.040128,0.033614,0.02559]},{"section":4,"text":"The visual field exam shows significant defects.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.12671,0.20986,0.16696,0.10199,0.073009,0.073352,0.05524,0.060609,0.04365,0.035279,0.029104,0.024235],"unified_progress":[0.11297,0.14581,0.11794,0.11287,0.089011,0.088661,0.071576,0.076979,0.062255,0.049396,0.041023,0.031506]},{"section":5,"text":"The CT scan shows a suprasellar mass with calcification.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.073585,0.13904,0.13452,0.11593,0.096766,0.08996,0.078278,0.070343,0.070827,0.051028,0.043339,0.036392],"unified_progress":[0.063844,0.10508,0.10963,0.11459,0.11036,0.098566,0.089596,0.081009,0.084982,0.057486,0.046756,0.038105]},{"section":6,"text":"Hmm, first, the symptoms.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.068804,0.10578,0.11586,0.11286,0.10233,0.087714,0.081965,0.075397,0.068076,0.071488,0.056261,0.05346],"unified_progress":[0.097163,0.082223,0.088739,0.097663,0.096378,0.088587,0.090182,0.086001,0.078017,0.081349,0.063099,0.0506]},{"section":7,"text":"Headache is a common symptom of increased intracranial pressure, which can happen with a mass in the brain.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.047544,0.091005,0.10429,0.10739,0.10326,0.096003,0.091656,0.084182,0.07677,0.076039,0.063623,0.058242],"unified_progress":[0.047432,0.072733,0.085974,0.094638,0.096622,0.098405,0.095689,0.093197,0.089528,0.088678,0.075321,0.061783]},{"section":8,"text":"The visual issues are important here.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.045037,0.094433,0.11567,0.11649,0.10435,0.089395,0.084069,0.077186,0.071582,0.078789,0.062706,0.06029],"unified_progress":[0.041546,0.074807,0.086479,0.099013,0.09841,0.094981,0.095823,0.092487,0.088815,0.092885,0.075997,0.058756]},{"section":9,"text":"Ignoring objects on the sides suggests a bitemporal hemianopia, which is typical of a lesion compressing the optic chiasm.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.046758,0.092485,0.099689,0.10275,0.10061,0.098411,0.093296,0.086106,0.08194,0.074077,0.064011,0.059866],"unified_progress":[0.04595,0.075484,0.088713,0.10379,0.10084,0.10202,0.096851,0.092916,0.089183,0.078751,0.066793,0.058713]},{"section":10,"text":"The optic chiasm is where the optic nerves cross, so a mass there would affect the lateral fibers, leading to loss of peripheral vision in both eyes.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.040653,0.084867,0.094449,0.099992,0.1002,0.099998,0.097627,0.090397,0.089692,0.077283,0.0669,0.057938],"unified_progress":[0.061244,0.075068,0.089163,0.098834,0.10283,0.10273,0.097489,0.092295,0.089955,0.075757,0.062688,0.051948]},{"section":11,"text":"That's a classic presentation for a pituitary adenoma or a craniopharyngioma, maybe a Rathke's cleft cyst, but let's think about the location and calcification.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.036484,0.077996,0.093094,0.10144,0.10238,0.10033,0.097873,0.090408,0.086819,0.083083,0.067693,0.062412],"unified_progress":[0.039727,0.070215,0.090001,0.10062,0.10307,0.10803,0.10112,0.094573,0.090354,0.081536,0.066179,0.054574]},{"section":12,"text":"The CT shows a suprasellar mass.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.035446,0.080693,0.094369,0.10102,0.098923,0.099328,0.096038,0.088673,0.095436,0.078359,0.069213,0.062498],"unified_progress":[0.037246,0.073703,0.093707,0.10903,0.11111,0.10464,0.10076,0.092623,0.0926,0.072922,0.060296,0.051365]},{"section":13,"text":"The suprasellar region is above the sella turcica, which is where the pituitary gland is.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.3302,0.054731,0.05585,0.063635,0.062342,0.063824,0.060012,0.067432,0.067254,0.061262,0.064616,0.048845],"unified_progress":[0.21995,0.084082,0.071812,0.069518,0.078667,0.074704,0.083077,0.079814,0.0739,0.05867,0.053391,0.05242]},{"section":14,"text":"Common tumors in that area in a child could be craniopharyngioma, which often has calcifications.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.036542,0.080645,0.06477,0.11082,0.11537,0.10716,0.10442,0.09427,0.08339,0.077246,0.067563,0.057812],"unified_progress":[0.051458,0.086718,0.070688,0.10304,0.10783,0.10248,0.098931,0.096499,0.087983,0.080189,0.064942,0.049242]},{"section":15,"text":"Pituitary adenomas can occur, but they're less common in kids.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.027152,0.062764,0.079116,0.092825,0.10188,0.10556,0.10627,0.10039,0.092978,0.092089,0.076271,0.06271],"unified_progress":[0.043318,0.069675,0.084926,0.092452,0.097826,0.10454,0.099929,0.099287,0.093221,0.089788,0.071358,0.053679]},{"section":16,"text":"Craniopharyngiomas are more frequent in children and often present with visual field defects due to chiasmal compression.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.02682,0.062401,0.077881,0.091769,0.10107,0.10528,0.10652,0.099566,0.093169,0.092735,0.075275,0.067526],"unified_progress":[0.031175,0.059225,0.082229,0.09376,0.099525,0.10903,0.10471,0.10177,0.097218,0.089186,0.073628,0.058546]},{"section":17,"text":"The presence of calcification on CT is a key point.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.031156,0.07113,0.088494,0.095836,0.096833,0.095885,0.09668,0.09261,0.09257,0.088494,0.079889,0.070424],"unified_progress":[0.048946,0.069008,0.082749,0.092905,0.098506,0.098619,0.097232,0.095408,0.093506,0.08776,0.075493,0.059869]},{"section":18,"text":"Craniopharyngiomas typically have calcifications, while adenomas might not.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028397,0.064872,0.080647,0.092553,0.099338,0.10165,0.10255,0.09695,0.09282,0.089323,0.077747,0.073154],"unified_progress":[0.035315,0.061372,0.081444,0.092501,0.097988,0.10712,0.10163,0.098221,0.09456,0.087777,0.076138,0.06594]},{"section":19,"text":"Also, the age is important here.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31473,0.051752,0.052888,0.061913,0.062663,0.064235,0.061083,0.070145,0.071325,0.065906,0.070145,0.05322],"unified_progress":[0.20739,0.078271,0.066135,0.065815,0.07483,0.073894,0.10012,0.081893,0.078478,0.062584,0.057283,0.053308]},{"section":20,"text":"Another possibility could be a germinoma, but those are germ cell tumors and might present differently, maybe with other symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.02595,0.060123,0.056238,0.097896,0.1071,0.10275,0.10833,0.10534,0.098561,0.091537,0.082967,0.063212],"unified_progress":[0.037636,0.069208,0.065036,0.093414,0.10437,0.099954,0.1018,0.10698,0.10173,0.094504,0.076129,0.049238]},{"section":21,"text":"Or a glioma like a optic pathway glioma, but those might be associated with neurofibromatosis, and the child here doesn't have mental retardation, so maybe less likely.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022323,0.054966,0.070262,0.083143,0.092904,0.099986,0.10629,0.1073,0.10484,0.10092,0.090451,0.066611],"unified_progress":[0.032897,0.063454,0.077404,0.085958,0.095742,0.099502,0.10101,0.10548,0.10291,0.10311,0.08068,0.051862]},{"section":22,"text":"The fact that the mass is suprasellar and has calcification points more towards craniopharyngioma.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.0282,0.06394,0.077637,0.08603,0.089727,0.093868,0.095711,0.094132,0.10244,0.092634,0.087769,0.087911],"unified_progress":[0.035014,0.06262,0.077316,0.088315,0.094217,0.096893,0.096834,0.095247,0.098972,0.088701,0.085296,0.080575]},{"section":23,"text":"Wait, the visual acuity is diminished too.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.030035,0.061926,0.073731,0.080683,0.088177,0.093233,0.096442,0.098381,0.10035,0.097425,0.095978,0.083642],"unified_progress":[0.03958,0.066243,0.077173,0.086268,0.091704,0.093479,0.096699,0.097091,0.09673,0.098306,0.087401,0.069325]},{"section":24,"text":"Craniopharyngioma can cause visual loss by pressing on the optic nerves or chiasm.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.028111,0.06307,0.076272,0.087304,0.094606,0.099616,0.10241,0.0988,0.098647,0.092329,0.083721,0.07511],"unified_progress":[0.044973,0.060478,0.077482,0.089239,0.095408,0.10109,0.099601,0.098066,0.096999,0.089973,0.079054,0.067637]},{"section":25,"text":"The bitemporal hemianopia is the classic field defect.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.031669,0.066604,0.077313,0.085972,0.092506,0.096874,0.099915,0.097584,0.096957,0.092509,0.085904,0.076192],"unified_progress":[0.052546,0.065286,0.078366,0.086973,0.093765,0.099723,0.09791,0.09697,0.09504,0.089116,0.078931,0.065374]},{"section":26,"text":"The CT showing calcification is a strong indicator.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.0282,0.063231,0.079427,0.087786,0.091804,0.093426,0.096591,0.095025,0.097366,0.094308,0.090152,0.082685],"unified_progress":[0.049036,0.063579,0.076311,0.085954,0.092732,0.094777,0.095731,0.095092,0.095364,0.092466,0.085337,0.07362]},{"section":27,"text":"So putting it all together: suprasellar mass with calcification, bitemporal hemianopia, headache from increased ICP.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.029096,0.061547,0.073723,0.081399,0.086699,0.090791,0.094119,0.09437,0.098595,0.097816,0.097026,0.094818],"unified_progress":[0.035724,0.057149,0.07058,0.080412,0.087983,0.093798,0.095393,0.097247,0.10018,0.098997,0.095774,0.08676]},{"section":28,"text":"The most likely diagnosis is craniopharyngioma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.021643,0.046547,0.057822,0.066247,0.073656,0.080083,0.086685,0.090279,0.098433,0.10125,0.11257,0.16479],"unified_progress":[0.021216,0.0364