erate":false,"model_progress":[0.03512,0.071021,0.082157,0.089264,0.093487,0.096509,0.097688,0.096442,0.095508,0.090635,0.081924,0.070245],"unified_progress":[0.059934,0.076832,0.085275,0.092217,0.095919,0.095014,0.094342,0.093985,0.090029,0.084894,0.072944,0.058616]},{"section":30,"text":"They can vary in location.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.028368,0.063225,0.078426,0.088993,0.0968,0.10029,0.10349,0.10074,0.098147,0.091567,0.083193,0.066756],"unified_progress":[0.091812,0.074876,0.082188,0.088573,0.092387,0.093074,0.092673,0.092286,0.086016,0.08349,0.068936,0.053687]},{"section":31,"text":"Also, the mobility and well-defined edges fit.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.032543,0.069585,0.081683,0.088387,0.092032,0.094801,0.096963,0.095517,0.09655,0.091519,0.085078,0.075344],"unified_progress":[0.044682,0.071747,0.084611,0.09281,0.097012,0.097463,0.09625,0.094263,0.092882,0.088029,0.077128,0.063124]},{"section":32,"text":"Wait, the patient's LMP was a week ago.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.039451,0.075351,0.081934,0.08638,0.092168,0.10026,0.096162,0.096538,0.093336,0.090616,0.081286,0.066517],"unified_progress":[0.080407,0.10993,0.096694,0.091976,0.089522,0.087861,0.08586,0.085942,0.079269,0.075373,0.065508,0.051655]},{"section":33,"text":"Could hormonal changes be causing a fibroadenoma to become more noticeable?","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.036769,0.07278,0.081992,0.088913,0.094665,0.099227,0.099387,0.097724,0.093504,0.08886,0.079728,0.066453],"unified_progress":[0.074489,0.082957,0.088144,0.09121,0.092342,0.093365,0.0908,0.090887,0.08562,0.081469,0.071074,0.057644]},{"section":34,"text":"Since fibroadenomas are hormone-sensitive, maybe around menses they can change in size or become more palpable.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.036147,0.072159,0.081566,0.089907,0.096652,0.101,0.10163,0.098261,0.092309,0.088065,0.077275,0.065034],"unified_progress":[0.063613,0.074815,0.08658,0.089395,0.093884,0.098529,0.095337,0.094419,0.089057,0.084249,0.072505,0.057616]},{"section":35,"text":"That makes sense.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.32188,0.052755,0.053747,0.06247,0.063633,0.064199,0.06159,0.068881,0.068985,0.064074,0.066977,0.050815],"unified_progress":[0.22343,0.0871,0.064792,0.065216,0.074207,0.072329,0.092251,0.077936,0.074124,0.059452,0.054793,0.054375]},{"section":36,"text":"Alternatively, a radial scar or complex fibroadenoma might have a stellate appearance on imaging, but clinically, the exam findings still lean towards benign.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.046344,0.097079,0.066106,0.10729,0.10668,0.10083,0.098097,0.090972,0.083423,0.07694,0.068796,0.05743],"unified_progress":[0.051297,0.084554,0.074694,0.10679,0.11204,0.10554,0.099976,0.094322,0.08403,0.075845,0.063407,0.047508]},{"section":37,"text":"So putting it all together: young age, firm, mobile, well-circumscribed mass without skin changes or lymphadenopathy.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.035737,0.071543,0.080894,0.086612,0.091001,0.093775,0.095036,0.093459,0.094621,0.090075,0.087371,0.079876],"unified_progress":[0.041222,0.065864,0.078211,0.086729,0.0944,0.097306,0.097144,0.096546,0.096002,0.091037,0.084255,0.071283]},{"section":38,"text":"The most likely diagnosis is fibroadenoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.023195,0.049201,0.061089,0.068358,0.074414,0.079126,0.08531,0.088683,0.095812,0.09953,0.11062,0.16466],"unified_progress":[0.021684,0.037844,0.047411,0.05737,0.062301,0.075126,0.078723,0.091396,0.10132,0.10742,0.13885,0.18055]}]}}