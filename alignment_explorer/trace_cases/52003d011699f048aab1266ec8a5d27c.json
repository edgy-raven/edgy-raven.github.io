93232,0.078327,0.080322,0.072258,0.055324,0.046679,0.037277]},{"section":6,"text":"The abdomen is tender over the fundus without rebound.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.080222,0.14452,0.1306,0.1073,0.090778,0.088972,0.076698,0.073918,0.070256,0.053108,0.045441,0.03819],"unified_progress":[0.070177,0.10877,0.10658,0.10927,0.1042,0.096726,0.087819,0.083711,0.082509,0.06128,0.049583,0.039371]},{"section":7,"text":"Hmm, first, the key symptoms here are chills (which suggest infection), abdominal pain, and foul-smelling discharge.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.067964,0.11498,0.11941,0.11037,0.097391,0.085868,0.079625,0.075009,0.066973,0.071714,0.057075,0.053617],"unified_progress":[0.070809,0.088394,0.091175,0.097852,0.095942,0.091181,0.091491,0.088065,0.081071,0.083288,0.066995,0.053739]},{"section":8,"text":"The vaginal discharge being foul-smelling is a big clue.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.051197,0.10008,0.11539,0.1135,0.1019,0.089501,0.083893,0.077605,0.07244,0.074489,0.062102,0.057902],"unified_progress":[0.048268,0.080703,0.089766,0.10058,0.098876,0.095219,0.094743,0.090255,0.086062,0.086905,0.071623,0.057006]},{"section":9,"text":"The incision site isn't red, so maybe the infection isn't at the skin level.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.045468,0.092576,0.10356,0.10581,0.099981,0.096107,0.091047,0.084212,0.084819,0.073942,0.064369,0.058108],"unified_progress":[0.044414,0.076483,0.091818,0.10914,0.10496,0.099559,0.097038,0.090822,0.089802,0.076968,0.064309,0.054683]},{"section":10,"text":"The tenderness over the fundus makes me think of the uterus.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.042896,0.089196,0.10116,0.10491,0.099862,0.096237,0.091794,0.084718,0.088303,0.076635,0.065038,0.05925],"unified_progress":[0.044068,0.076281,0.09315,0.10704,0.10888,0.10083,0.099437,0.091578,0.090643,0.075807,0.061195,0.051088]},{"section":11,"text":"Wait, after a C-section, especially with risk factors like prolonged rupture of membranes (which increases infection risk because the membranes were ruptured longer, allowing more time for bacteria to ascend), the most common postpartum infections are endometritis.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.043108,0.083271,0.091302,0.096755,0.099381,0.1017,0.096907,0.09169,0.085447,0.082506,0.0687,0.059236],"unified_progress":[0.061222,0.086724,0.090665,0.094668,0.09583,0.10163,0.094474,0.092081,0.085754,0.078453,0.065637,0.052857]},{"section":12,"text":"Endometritis typically presents with fever, lower abdominal pain, foul lochia (vaginal discharge), and uterine tenderness.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.040384,0.079504,0.085516,0.091049,0.096116,0.099294,0.099337,0.095705,0.088941,0.084418,0.073981,0.065757],"unified_progress":[0.046392,0.072161,0.086577,0.090612,0.095323,0.10342,0.098043,0.096334,0.092066,0.085467,0.073874,0.059733]},{"section":13,"text":"The chills could be part of the systemic response to infection.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029299,0.062307,0.075619,0.086223,0.09454,0.098614,0.10322,0.10009,0.096033,0.092335,0.08602,0.075694],"unified_progress":[0.037334,0.052297,0.065243,0.074195,0.085756,0.097234,0.097755,0.10068,0.10339,0.10422,0.10025,0.081641]},{"section":14,"text":"The LSCS incision itself isn't showing signs of infection (no erythema, just serous drainage), so that's probably not the source.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.036234,0.076084,0.085936,0.091064,0.092248,0.095158,0.095739,0.093177,0.095925,0.086787,0.079796,0.071853],"unified_progress":[0.038588,0.067994,0.081914,0.091763,0.097385,0.098281,0.098726,0.094926,0.095494,0.089885,0.079057,0.065989]},{"section":15,"text":"The fundal tenderness points to the uterus.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.032777,0.075668,0.089386,0.0967,0.095979,0.097353,0.096162,0.090474,0.099961,0.08331,0.074754,0.067477],"unified_progress":[0.040298,0.070091,0.0884,0.10187,0.1068,0.10214,0.10079,0.093763,0.09618,0.078214,0.065659,0.055786]},{"section":16,"text":"The foul smell is important because it suggests anaerobic bacteria, which are common in genital tract infections.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.032047,0.070418,0.085458,0.093631,0.096864,0.097185,0.098304,0.094285,0.091569,0.089808,0.079063,0.071368],"unified_progress":[0.037796,0.064751,0.080248,0.090782,0.096512,0.10052,0.099733,0.097186,0.094958,0.091248,0.079831,0.066431]},{"section":17,"text":"Other possibilities might include a pelvic abscess or wound infection, but the wound doesn't look infected.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.026115,0.063914,0.080058,0.089127,0.093721,0.096894,0.099961,0.099115,0.10108,0.093768,0.085492,0.070752],"unified_progress":[0.028807,0.063625,0.081408,0.094166,0.099407,0.099091,0.10069,0.09956,0.098869,0.094093,0.079324,0.060963]},{"section":18,"text":"Also, if it were a wound infection, the tenderness might be more localized to the incision.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.030243,0.065573,0.076495,0.084754,0.090349,0.095481,0.10026,0.10064,0.10247,0.095138,0.087757,0.070841],"unified_progress":[0.03863,0.06348,0.078253,0.088135,0.096681,0.097518,0.099479,0.10117,0.10077,0.096084,0.08059,0.059209]},{"section":19,"text":"The absence of rebound tenderness suggests it's not a perforation or peritonitis, so more likely endometritis.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.028507,0.06649,0.079635,0.088136,0.091628,0.095998,0.099183,0.097535,0.10347,0.091975,0.084406,0.073037],"unified_progress":[0.031916,0.062983,0.080158,0.091295,0.099169,0.099492,0.10027,0.09914,0.10159,0.091742,0.079281,0.062967]},{"section":20,"text":"Risk factors here include prolonged PROM (since the membranes were ruptured for a long time before delivery), which is a known risk factor for endometritis.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.033293,0.069133,0.078975,0.086808,0.094369,0.10288,0.09995,0.098831,0.094273,0.093588,0.080794,0.067105],"unified_progress":[0.071133,0.10027,0.091285,0.088598,0.088911,0.092741,0.089555,0.09,0.084578,0.079306,0.068706,0.054915]},{"section":21,"text":"Cephalopelvic disproportion might have led to a longer labor or instrumentation, but the main issue here is the infection.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.035321,0.071115,0.080172,0.087384,0.093432,0.10354,0.098779,0.097848,0.095512,0.090786,0.080131,0.065976],"unified_progress":[0.080755,0.10865,0.096535,0.094162,0.088195,0.091396,0.08352,0.088339,0.080492,0.072701,0.063764,0.051493]},{"section":22,"text":"So putting it all together: endometritis is the most likely diagnosis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028591,0.056337,0.068994,0.075649,0.078804,0.079846,0.084828,0.085867,0.090251,0.09753,0.10261,0.15069],"unified_progress":[0.034196,0.048395,0.057596,0.068357,0.071599,0.076965,0.08274,0.086066,0.091518,0.10189,0.12512,0.15556]},{"section":23,"text":"The symptoms align with that, and the risk factors are present.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.028475,0.062494,0.079436,0.085936,0.087126,0.086182,0.089542,0.090482,0.092809,0.098884,0.096204,0.10243],"unified_progress":[0.03599,0.053249,0.063187,0.074179,0.078886,0.084789,0.088598,0.095309,0.10071,0.10909,0.11005,0.10596]},{"section":24,"text":"The foul discharge and fundal tenderness are classic signs.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.023266,0.053198,0.067608,0.076966,0.08461,0.090194,0.095802,0.097607,0.10222,0.10364,0.10556,0.099328],"unified_progress":[0.031249,0.049038,0.061176,0.071227,0.080882,0.089856,0.094283,0.10003,0.10624,0.11097,0.10908,0.095971]},{"section":25,"text":"I don't think it's a urinary tract infection because there's no mention of urinary symptoms.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027244,0.061115,0.072567,0.079974,0.086132,0.092037,0.09875,0.10196,0.10297,0.10065,0.095793,0.080805],"unified_progress":[0.029831,0.058189,0.070985,0.079573,0.088555,0.092305,0.097633,0.10207,0.10359,0.10721,0.096709,0.073355]},{"section":26,"text":"Also, the chills and fever (though not mentioned as fever, chills can be a sign of it) fit with systemic infection from endometritis.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.026914,0.058736,0.070846,0.080032,0.08833,0.094558,0.10124,0.1021,0.10096,0.098851,0.095192,0.082237],"unified_progress":[0.03252,0.053962,0.066803,0.07477,0.085469,0.09303,0.097145,0.10226,0.10466,0.10723,0.10108,0.081076]}]}}