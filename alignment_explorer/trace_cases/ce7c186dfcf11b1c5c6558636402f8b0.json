4417,0.092978,0.085392,0.081467,0.067829,0.053863]},{"section":10,"text":"Wait, the side effects here are restlessness, fidgeting, pacing.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.059262,0.098783,0.093878,0.089919,0.089559,0.090583,0.08817,0.089638,0.082202,0.079829,0.072351,0.065826],"unified_progress":[0.071296,0.08868,0.08893,0.091114,0.091704,0.093039,0.090028,0.090974,0.084193,0.081569,0.070963,0.05751]},{"section":11,"text":"That sounds like akathisia.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.048778,0.083827,0.091502,0.095682,0.096575,0.093437,0.093297,0.089776,0.083438,0.084052,0.072465,0.067171],"unified_progress":[0.060966,0.072309,0.085539,0.092115,0.094611,0.096953,0.095263,0.093079,0.087541,0.086096,0.073716,0.061812]},{"section":12,"text":"Akathisia is a common side effect of antipsychotics.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.040889,0.073464,0.083933,0.093784,0.099577,0.099242,0.099662,0.093851,0.086116,0.086972,0.073435,0.069076],"unified_progress":[0.050098,0.061623,0.080966,0.089485,0.094969,0.10229,0.099611,0.097748,0.092615,0.0889,0.076511,0.06518]},{"section":13,"text":"It's characterized by a subjective feeling of inner restlessness and an objective observation of inability to stay still.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.05232,0.091748,0.087394,0.087235,0.091146,0.094913,0.094538,0.093949,0.085481,0.082606,0.073044,0.065626],"unified_progress":[0.06848,0.080597,0.083445,0.086085,0.089641,0.094654,0.092022,0.094509,0.08886,0.08492,0.074718,0.062068]},{"section":14,"text":"The patient's description of not being able to sit and the fidgeting movements fit.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.072946,0.12041,0.1017,0.086294,0.082648,0.087198,0.082258,0.087172,0.077,0.073378,0.067108,0.061888],"unified_progress":[0.08328,0.10484,0.092487,0.088104,0.085351,0.088821,0.083081,0.089161,0.0805,0.076636,0.069165,0.058576]},{"section":15,"text":"Other EPS like parkinsonism would have more rigid movements, tremors, bradykinesia.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.042869,0.08237,0.09025,0.09519,0.098422,0.098674,0.09883,0.094208,0.086359,0.08177,0.07146,0.059597],"unified_progress":[0.047305,0.072708,0.09258,0.093028,0.097671,0.10305,0.09839,0.095917,0.090319,0.085136,0.070644,0.053254]},{"section":16,"text":"Tardive dyskinesia is more like involuntary movements, like lip smacking or choreiform movements, but that usually takes longer to develop.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030248,0.065548,0.079234,0.091962,0.1007,0.10396,0.10657,0.10108,0.092672,0.092393,0.075593,0.060041],"unified_progress":[0.033059,0.060464,0.082641,0.092533,0.099492,0.10758,0.10499,0.10375,0.097965,0.094634,0.073031,0.049861]},{"section":17,"text":"Dystonia is more sudden and severe muscle spasms, which might not fit here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026165,0.059898,0.073822,0.084675,0.092909,0.098658,0.10483,0.10476,0.10164,0.098685,0.087721,0.066238],"unified_progress":[0.030735,0.059236,0.075941,0.086511,0.095735,0.099969,0.10233,0.10542,0.10288,0.10602,0.081465,0.053761]},{"section":18,"text":"Since he started risperidone two months ago, and the symptoms started around then, the timing makes sense for akathisia.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.043447,0.077351,0.082485,0.08616,0.088967,0.092024,0.091769,0.092011,0.089648,0.091189,0.083843,0.081106],"unified_progress":[0.063251,0.076145,0.078245,0.08288,0.086348,0.089456,0.091885,0.092011,0.089803,0.089498,0.084406,0.076072]},{"section":19,"text":"The patient's main issue now is the restlessness, which is a classic presentation.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.043142,0.075463,0.080825,0.084023,0.086498,0.087735,0.089999,0.091295,0.08928,0.092809,0.089166,0.089762],"unified_progress":[0.056848,0.065424,0.071005,0.077915,0.082807,0.087583,0.089497,0.093514,0.093485,0.097963,0.095143,0.088817]},{"section":20,"text":"The parents noticed improvement in psychosis, so the treatment is working for that, but the side effect is now problematic.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.040104,0.074735,0.080708,0.084238,0.08754,0.091623,0.09216,0.092888,0.090843,0.091774,0.086824,0.086563],"unified_progress":[0.05051,0.067888,0.070597,0.075286,0.080334,0.086539,0.088169,0.093787,0.095292,0.098767,0.099007,0.093822]},{"section":21,"text":"I should also consider if it's part of his schizophrenia, like agitation, but the history of improvement and the specific movement symptoms point more to a drug side effect.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.036126,0.071497,0.085223,0.091135,0.092193,0.090531,0.09237,0.091697,0.089525,0.094471,0.084904,0.080327],"unified_progress":[0.041479,0.061964,0.072558,0.083169,0.087614,0.090666,0.094579,0.096653,0.097151,0.10251,0.093287,0.078369]},{"section":22,"text":"So the most likely diagnosis here is akathisia caused by risperidone.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028371,0.052168,0.060732,0.067397,0.073716,0.078667,0.084498,0.088335,0.094407,0.098231,0.10909,0.16439],"unified_progress":[0.028241,0.036926,0.0456,0.054958,0.06053,0.072472,0.076481,0.086695,0.09876,0.10805,0.14331,0.18797]}]}}