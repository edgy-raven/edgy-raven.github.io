.083132,0.082341,0.067225,0.061044],"unified_progress":[0.038699,0.062177,0.086576,0.093291,0.099077,0.10789,0.10295,0.099339,0.093866,0.087285,0.071485,0.057372]},{"section":17,"text":"Wait, the patient has all except maybe telangiectasias, but they might not be present here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.038215,0.075761,0.08489,0.089994,0.094179,0.097184,0.0978,0.096461,0.092581,0.087285,0.078961,0.066689],"unified_progress":[0.041984,0.07089,0.082324,0.090578,0.095856,0.096397,0.095963,0.097617,0.094322,0.094831,0.078339,0.060899]},{"section":18,"text":"The esophageal symptoms (dysphagia and heartburn) point to esophageal involvement.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.035628,0.073655,0.082866,0.089479,0.094279,0.097942,0.099057,0.095774,0.093775,0.0874,0.079855,0.070289],"unified_progress":[0.039952,0.066459,0.079759,0.088334,0.094338,0.10014,0.098092,0.097567,0.097136,0.090726,0.081483,0.06601]},{"section":19,"text":"The calcinosis is definitely there with the draining nodules.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.033356,0.069492,0.080283,0.087144,0.091238,0.094716,0.096607,0.094497,0.096981,0.090741,0.086305,0.078639],"unified_progress":[0.03967,0.064338,0.077871,0.087332,0.094476,0.09782,0.097561,0.096507,0.097765,0.09165,0.083701,0.071311]},{"section":20,"text":"The skin thickening (sclerodactyly) is also present.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.036296,0.070182,0.078239,0.085431,0.090985,0.09472,0.096734,0.094834,0.094307,0.091238,0.085922,0.081111],"unified_progress":[0.043314,0.062233,0.075896,0.0847,0.091734,0.099227,0.097883,0.097536,0.096778,0.092113,0.084744,0.073842]},{"section":21,"text":"Raynaud's is mentioned.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.034866,0.069284,0.079344,0.08612,0.091876,0.095384,0.097612,0.096446,0.094268,0.092538,0.08649,0.075773],"unified_progress":[0.0482,0.065686,0.077423,0.084895,0.091735,0.097307,0.097273,0.097334,0.095467,0.092987,0.083734,0.067961]},{"section":22,"text":"So CREST syndrome is a limited form of systemic sclerosis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.030367,0.061321,0.074636,0.083829,0.089345,0.091085,0.094003,0.092429,0.09138,0.094132,0.08983,0.10764],"unified_progress":[0.035081,0.052994,0.066648,0.076562,0.080912,0.089558,0.090196,0.094484,0.096062,0.09759,0.10448,0.11543]},{"section":23,"text":"Alternatively, could it be another condition?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.024358,0.057273,0.075466,0.085218,0.093662,0.095717,0.099416,0.10258,0.10188,0.10068,0.091777,0.07197],"unified_progress":[0.030505,0.064453,0.08166,0.093644,0.096573,0.096875,0.10136,0.10141,0.099036,0.096357,0.080795,0.057331]},{"section":24,"text":"Let's see.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.29735,0.048658,0.048923,0.059401,0.060825,0.064697,0.064323,0.072857,0.076456,0.071857,0.076109,0.058548],"unified_progress":[0.20736,0.076743,0.065779,0.065727,0.074855,0.074626,0.09433,0.083235,0.079914,0.063472,0.058991,0.054965]},{"section":25,"text":"The painful lumps that drain\u2014could they be rheumatoid nodules?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.037824,0.080127,0.05848,0.094544,0.1009,0.098483,0.10141,0.097854,0.093644,0.088853,0.081814,0.066063],"unified_progress":[0.048918,0.078936,0.069367,0.097963,0.10463,0.10155,0.10161,0.098073,0.091795,0.084208,0.071576,0.05138]},{"section":26,"text":"But rheumatoid nodules are usually found over joints and are more common in rheumatoid arthritis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.026289,0.058965,0.074056,0.088643,0.098897,0.10335,0.10766,0.10401,0.097324,0.094687,0.082087,0.064034],"unified_progress":[0.040031,0.060044,0.080011,0.089441,0.098534,0.10686,0.1043,0.10382,0.097844,0.094186,0.074429,0.050491]},{"section":27,"text":"However, the presence of calcinosis and skin thickening makes me lean away from RA.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024804,0.057278,0.072893,0.083364,0.091178,0.096508,0.1017,0.10219,0.10188,0.099122,0.092722,0.076371],"unified_progress":[0.036593,0.060158,0.074395,0.08419,0.092763,0.098093,0.09964,0.10214,0.10103,0.10218,0.085775,0.063047]},{"section":28,"text":"Also, the chalky substance in the nodules is more indicative of calcium deposits rather than the non-caseating granulomas in sarcoidosis or something else.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.031053,0.065424,0.077106,0.086359,0.092622,0.097066,0.10085,0.099737,0.099459,0.093966,0.085068,0.071288],"unified_progress":[0.038784,0.063613,0.080431,0.090715,0.097677,0.10085,0.10101,0.10029,0.098492,0.092816,0.077789,0.05753]},{"section":29,"text":"Another thought: dermatomyositis?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.024397,0.057121,0.074482,0.085515,0.095433,0.099192,0.10244,0.1033,0.10096,0.098332,0.088363,0.070463],"unified_progress":[0.031712,0.066088,0.08425,0.096723,0.099529,0.10156,0.10334,0.10015,0.095371,0.091783,0.07509,0.054401]},{"section":30,"text":"But that typically has a different rash and muscle weakness, which isn't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.015551,0.045428,0.063668,0.075871,0.087008,0.094538,0.10724,0.11257,0.11285,0.11013,0.10458,0.07056],"unified_progress":[0.02506,0.054166,0.071774,0.080036,0.094705,0.09664,0.10239,0.111,0.1089,0.11536,0.089332,0.050649]},{"section":31,"text":"The key points still point to CREST.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.023075,0.053031,0.068644,0.077631,0.084228,0.088565,0.094529,0.097875,0.10001,0.1034,0.10131,0.10771],"unified_progress":[0.028452,0.04954,0.061732,0.072606,0.079561,0.086346,0.095149,0.097259,0.099524,0.10604,0.10997,0.11383]},{"section":32,"text":"The joint pain could be part of the arthritis that sometimes accompanies scleroderma, though it's more common in the diffuse form.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.025863,0.056666,0.069193,0.080251,0.090133,0.096975,0.10233,0.1026,0.10059,0.099943,0.093102,0.08236],"unified_progress":[0.03904,0.055445,0.066896,0.075329,0.08471,0.093796,0.096673,0.10197,0.10316,0.10508,0.097271,0.080626]},{"section":33,"text":"But CREST can have some joint involvement too.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025664,0.056755,0.070886,0.081858,0.091301,0.097423,0.10283,0.10361,0.10176,0.099218,0.091897,0.076792],"unified_progress":[0.056249,0.063593,0.073007,0.080739,0.087631,0.092017,0.095235,0.09904,0.0972,0.099496,0.087104,0.068689]},{"section":34,"text":"So putting it all together: Calcinosis, Raynaud's, Esophageal issues, Sclerodactyly, and Telangiectasias (even if telangiectasias aren't mentioned, the other features are there).","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.030069,0.059341,0.069216,0.078405,0.08675,0.092788,0.097224,0.097526,0.098683,0.098291,0.095801,0.095906],"unified_progress":[0.03963,0.055552,0.070072,0.078424,0.086009,0.094636,0.094972,0.097365,0.09899,0.097562,0.096255,0.090532]},{"section":35,"text":"The most likely diagnosis is CREST syndrome, which is a subset of systemic sclerosis.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.018529,0.038654,0.049504,0.058698,0.06836,0.076596,0.085303,0.090957,0.10065,0.10513,0.12115,0.18647],"unified_progress":[0.019787,0.030419,0.039225,0.048816,0.0543,0.070078,0.073151,0.089528,0.10156,0.11034,0.15259,0.21021]}]}}