.12577,0.099901,0.05455],"unified_progress":[0.034024,0.058512,0.076501,0.087736,0.096096,0.1062,0.10334,0.10321,0.098872,0.094964,0.080062,0.060481]},{"section":13,"text":"However, asbestosis often shows up with pleural plaques or calcifications on an X-ray.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.020608,0.039547,0.057424,0.075718,0.091197,0.1035,0.1129,0.11525,0.11903,0.12314,0.093466,0.048226],"unified_progress":[0.031012,0.057893,0.078513,0.091797,0.099392,0.10645,0.10507,0.10315,0.10014,0.092691,0.075676,0.058215]},{"section":14,"text":"So, if those are there, it might point towards asbestosis.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024239,0.044989,0.060419,0.073669,0.083952,0.094667,0.10349,0.11042,0.11648,0.11519,0.1006,0.071887],"unified_progress":[0.034248,0.057532,0.073076,0.082628,0.091455,0.094146,0.096909,0.10046,0.099956,0.10172,0.091028,0.07684]},{"section":15,"text":"But I need to remember that these plaques take a while to develop, so maybe not immediately after just 15 years of exposure.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027051,0.037249,0.051141,0.063685,0.075981,0.091141,0.10636,0.12257,0.13365,0.13497,0.10309,0.053109],"unified_progress":[0.037064,0.055711,0.069457,0.078682,0.089345,0.09367,0.098896,0.10481,0.10496,0.11038,0.092743,0.064283]},{"section":16,"text":"Oh, and then there's chronic bronchitis.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.016418,0.037417,0.055259,0.070225,0.083061,0.097777,0.11123,0.12522,0.13387,0.13431,0.095384,0.039836],"unified_progress":[0.028536,0.057926,0.073581,0.084863,0.093001,0.097441,0.10356,0.10509,0.10399,0.10788,0.087194,0.056938]},{"section":17,"text":"This is more about inflammation in the airways due to irritation from dust and other particles.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.032978,0.041964,0.055744,0.070076,0.08284,0.095165,0.10621,0.11106,0.11651,0.12286,0.