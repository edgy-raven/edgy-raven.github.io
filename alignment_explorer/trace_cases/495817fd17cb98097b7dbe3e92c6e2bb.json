":[0.034428,0.068394,0.08232,0.097028,0.097698,0.096063,0.10073,0.096382,0.092571,0.096024,0.078444,0.059923]},{"section":9,"text":"Multiple sclerosis (MS) comes to mind because it's a demyelinating disease that can cause lesions in the brain and spinal cord.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.029378,0.052872,0.06958,0.082182,0.094626,0.10116,0.11133,0.11246,0.1056,0.096674,0.080078,0.064056],"unified_progress":[0.029678,0.057475,0.079104,0.091916,0.1017,0.11528,0.10698,0.1043,0.097446,0.090421,0.070935,0.054756]},{"section":10,"text":"MS often presents with a variety of symptoms, including weakness, spasticity, and hyper-reflexia.","dimension":14,"group":5,"is_degenerate":false,"model_progress":[0.039459,0.069024,0.07339,0.075471,0.084878,0.089092,0.096402,0.10019,0.098743,0.089082,0.093856,0.090414],"unified_progress":[0.068637,0.097862,0.090998,0.089179,0.09095,0.094724,0.090923,0.092963,0.085774,0.079261,0.066568,0.05216]},{"section":11,"text":"The atrophy in the hands and forearms could be due to chronic demyelination affecting the corticospinal tracts, leading to muscle wasting.","dimension":13,"group":3,"is_degenerate":false,"model_progress":[0.034715,0.051874,0.067858,0.078939,0.090727,0.097147,0.10392,0.106,0.10527,0.097954,0.088648,0.076952],"unified_progress":[0.039259,0.065505,0.086642,0.091957,0.098896,0.10232,0.099598,0.096669,0.097254,0.086892,0.074662,0.060345]},{"section":12,"text":"The spasticity in the legs might be due to the upper motor neuron lesions causing increased muscle tone.","dimension":3,"group":3,"is_degenerate":false,"model_progress":[0.028719,0.047436,0.066289,0.078574,0.091889,0.099811,0.10654,0.10937,0.10936,0.10063,0.089258,0.07212],"unified_progress":[0.035645,0.062639,0.081222,0.091817,0.098663,0.10668,0.10311,0.1015,0.097601,0.091925,0.074441,0.054746]},{"section":13,"text":"Another possibility is amyotrophic lateral sclerosis (ALS), but that typically presents with both upper and lower motor neuron signs, and the progression is usually more rapid.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.028211,0.050514,0.065434,0.076264,0.088928,0.096499,0.10596,0.10971,0.10747,0.10161,0.090913,0.078489],"unified_progress":[0.035364,0.061523,0.078724,0.089874,0.095551,0.10598,0.10264,0.10163,0.096624,0.092277,0.077452,0.062363]},{"section":14,"text":"The MRI findings in ALS might not show the same kind of coico-spinal tract signal changes as in MS.","dimension":12,"group":4,"is_degenerate":false,"model_progress":[0.03439,0.050018,0.066521,0.078109,0.089023,0.095723,0.10231,0.10469,0.10568,0.10083,0.092808,0.0799],"unified_progress":[0.032014,0.055423,0.072422,0.083024,0.092419,0.098874,0.099652,0.10238,0.10217,0.10192,0.088404,0.0713]},{"section":15,"text":"Also, the hyper-reflexia and spasticity are more consistent with MS than ALS.","dimension":14,"group":5,"is_degenerate":false,"model_progress":[0.029651,0.050491,0.065461,0.074805,0.086122,0.092851,0.099167,0.10316,0.10483,0.10219,0.099233,0.092043],"unified_progress":[0.042147,0.066392,0.074802,0.081314,0.087467,0.09379,0.094363,0.097317,0.096368,0.095446,0.089668,0.080927]},{"section":16,"text":"I should also consider other demyelinating conditions like acute disseminated encephalomyelitis (ADEM), but that's usually an acute presentation with more severe symptoms and doesn't typically present with chronic atrophy.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.026845,0.048135,0.062555,0.073976,0.087666,0.095902,0.10772,0.11209,0.10927,0.10349,0.091916,0.080439],"unified_progress":[0.028763,0.054735,0.07819,0.087981,0.0954,0.10734,0.1043,0.10364,0.099825,0.094851,0.080128,0.064847]},{"section":17,"text":"Additionally, the MRI findings in ADEM are more widespread and might not specifically target the coico-spinal tracts as described.","dimension":12,"group":4,"is_degenerate":false,"model_progress":[0.029341,0.045452,0.061849,0.073701,0.086052,0.09404,0.10188,0.10607,0.10