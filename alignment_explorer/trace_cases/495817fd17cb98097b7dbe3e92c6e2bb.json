ified_progress":[0.048314,0.067703,0.080684,0.09171,0.093828,0.095917,0.096008,0.094263,0.091343,0.092774,0.079697,0.06776]},{"section":11,"text":"Primary lateral sclerosis is just upper motor, so probably not.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030245,0.065325,0.080574,0.090904,0.097137,0.09838,0.09978,0.096373,0.091549,0.092143,0.080877,0.076712],"unified_progress":[0.03464,0.059116,0.07675,0.086852,0.093387,0.1005,0.099408,0.0994,0.096699,0.095458,0.084255,0.073534]},{"section":12,"text":"Amyotrophic lateral sclerosis (ALS) is the classic combination of both upper and lower motor neuron signs.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.027942,0.061396,0.076802,0.090186,0.098943,0.1015,0.10357,0.098002,0.090776,0.095184,0.079003,0.076698],"unified_progress":[0.030794,0.053351,0.073138,0.086556,0.093372,0.10409,0.10286,0.10286,0.099218,0.096532,0.084069,0.07316]},{"section":13,"text":"The progressive nature fits with ALS.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.033231,0.072607,0.08993,0.09598,0.09503,0.091573,0.092011,0.089652,0.086853,0.091577,0.081141,0.080416],"unified_progress":[0.035473,0.061238,0.073195,0.085178,0.089878,0.092748,0.094661,0.09774,0.097102,0.1022,0.091459,0.079125]},{"section":14,"text":"The MRI finding of corticospinal tract hyperintensity on T2 also aligns with ALS, as it can show signs of neuronal loss or degeneration there.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.036111,0.076324,0.088851,0.095671,0.095944,0.096454,0.09546,0.090414,0.093111,0.083439,0.075575,0.072645],"unified_progress":[0.037389,0.065156,0.082664,0.09903,0.099953,0.10036,0.09873,0.094904,0.095531,0.084232,0.074883,0.067169]},{"section":15,"text":"Another possibility could be hereditary spastic paraplegia, but that mainly affects the legs, not the hands.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.030259,0.064199,0.077039,0.088217,0.096663,0.1003,0.10325,0.10048,0.094987,0.094262,0.081786,0.06855],"unified_progress":[0.034258,0.058963,0.076899,0.08878,0.0956,0.10917,0.10326,0.10258,0.098253,0.095646,0.077956,0.058641]},{"section":16,"text":"Maybe cervical spondylosis or a spinal cord compression, but the MRI mentions the corticospinal tracts specifically, which points more to a degenerative disease rather than compression.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.028668,0.069142,0.084179,0.092838,0.094914,0.098531,0.099269,0.0952,0.10228,0.087913,0.078827,0.068233],"unified_progress":[0.031854,0.067184,0.085696,0.097947,0.1045,0.10313,0.10162,0.097947,0.099719,0.08473,0.070398,0.055271]},{"section":17,"text":"So putting it all together: progressive weakness (lower motor), spasticity and hyper-reflexia (upper motor), MRI showing corticospinal tract issues.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.032648,0.065155,0.075173,0.082862,0.088292,0.092257,0.095288,0.094771,0.097391,0.094533,0.092598,0.089031],"unified_progress":[0.040539,0.059633,0.072988,0.082984,0.091056,0.096387,0.097599,0.097842,0.09867,0.094083,0.088967,0.079251]},{"section":18,"text":"ALS is the most likely diagnosis here.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.022508,0.048257,0.062249,0.069484,0.074094,0.076782,0.083292,0.087121,0.094502,0.10216,0.1122,0.16735],"unified_progress":[0.021105,0.036374,0.045738,0.056393,0.061288,0.072757,0.077509,0.090649,0.10177,0.11112,0.14262,0.18269]}]}}