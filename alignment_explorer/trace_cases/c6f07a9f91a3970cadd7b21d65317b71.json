7647,0.054619]},{"section":6,"text":"The salivary gland biopsy showing lymphocytic infiltration is another key point.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.045328,0.090499,0.10034,0.10234,0.098482,0.096056,0.092651,0.086425,0.08759,0.075238,0.06622,0.058836],"unified_progress":[0.043547,0.077549,0.092284,0.10209,0.10547,0.10206,0.10016,0.092117,0.090544,0.076437,0.064923,0.052811]},{"section":7,"text":"I think the diagnostic criteria for Sj\u00f6gren's include glandular lymphocytic infiltration along with symptoms of dryness and positive antibodies.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039881,0.077076,0.087536,0.0945,0.09781,0.097506,0.097035,0.092101,0.085896,0.08546,0.074475,0.070724],"unified_progress":[0.042799,0.065237,0.080701,0.090423,0.095219,0.10617,0.099832,0.096811,0.09211,0.08805,0.077028,0.065625]},{"section":8,"text":"Let me make sure there's nothing else.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.30857,0.051228,0.052487,0.061966,0.062974,0.064449,0.061792,0.070556,0.072045,0.067216,0.072,0.054716],"unified_progress":[0.19967,0.077778,0.063577,0.063816,0.073891,0.073787,0.099687,0.082865,0.080177,0.064991,0.060832,0.05893]},{"section":9,"text":"Other possibilities might be systemic lupus erythematosus, but Ro antibodies can be present there too.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.032382,0.073335,0.06252,0.1036,0.10804,0.10128,0.10283,0.097237,0.090563,0.085195,0.077524,0.065486],"unified_progress":[0.044703,0.080607,0.066765,0.093284,0.10099,0.097398,0.099062,0.10022,0.095674,0.089928,0.075884,0.055486]},{"section":10,"text":"However, the combination of dry eyes, dry mouth, enlarged glands, and the biopsy findings really point more towards Sj\u00f6gren's.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.03336,0.068613,0.080999,0.087299,0.09168,0.093084,0.094988,0.093892,0.092474,0.094073,0.08704,0.082498],"unified_progress":[0.038183,0.061345,0.074011,0.084021,0.090335,0.09613,0.097351,0.098334,0.097862,0.098576,0.08903,0.074822]},{"section":11,"text":"Also, Sj\u00f6gren's is a type of autoimmune exocrinopathy, so that fits.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037231,0.068515,0.078963,0.08783,0.092962,0.094476,0.095619,0.093307,0.089568,0.09281,0.082892,0.085826],"unified_progress":[0.048503,0.060715,0.072874,0.08174,0.087646,0.095026,0.095437,0.097091,0.09511,0.094758,0.088621,0.082479]},{"section":12,"text":"I don't think the biopsy would show the same in other conditions like mumps or sarcoidosis.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.029848,0.064552,0.077775,0.0858,0.090833,0.094449,0.09816,0.098432,0.09936,0.095636,0.088385,0.076769],"unified_progress":[0.032623,0.061061,0.076603,0.087367,0.094045,0.095933,0.098461,0.10006,0.10035,0.099299,0.085506,0.068692]},{"section":13,"text":"Mumps would cause more acute swelling and maybe fever, which isn't mentioned here.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.018422,0.047973,0.063445,0.07501,0.084746,0.092782,0.10505,0.11048,0.11157,0.11092,0.10527,0.074323],"unified_progress":[0.023419,0.050509,0.066375,0.075757,0.089954,0.094184,0.10144,0.11107,0.11208,0.12113,0.096235,0.057849]},{"section":14,"text":"Sarcoidosis might have granulomas, but the biopsy here mentions lymphocytes.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022714,0.054549,0.06857,0.079501,0.086792,0.094132,0.10213,0.10486,0.11036,0.10404,0.096737,0.075616],"unified_progress":[0.027721,0.054734,0.072291,0.084014,0.094253,0.099531,0.10238,0.10665,0.10986,0.10576,0.086925,0.055888]},{"section":15,"text":"So putting it all together, the most likely diagnosis is Sj\u00f6gren's syndrome.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.029184,0.051766,0.05923,0.066017,0.072009,0.076934,0.083573,0.088359,0.094625,0.10104,0.11046,0.16681],"unified_pr