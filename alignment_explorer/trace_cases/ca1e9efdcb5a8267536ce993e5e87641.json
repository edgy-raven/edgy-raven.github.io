0.079444,0.073969,0.062653,0.049275]},{"section":5,"text":"His vital signs show a slightly elevated pulse (107/min) and a slightly low blood pressure (90/68 mmHg), which could be due to blood loss or dehydration from vomiting.","dimension":7,"group":7,"is_degenerate":false,"model_progress":[0.039684,0.080131,0.11144,0.11671,0.12753,0.11789,0.10701,0.083489,0.069942,0.056842,0.049356,0.039972],"unified_progress":[0.051475,0.092536,0.10248,0.10409,0.10989,0.10054,0.097554,0.087021,0.079712,0.069441,0.060807,0.044438]},{"section":6,"text":"His physical exam is normal, so I can rule out more serious issues like head injuries or other injuries.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.029836,0.061699,0.081642,0.091451,0.096648,0.099954,0.1003,0.10343,0.09877,0.09622,0.085372,0.054676],"unified_progress":[0.032057,0.061276,0.075352,0.085421,0.097487,0.097382,0.10118,0.1048,0.10267,0.10595,0.083645,0.052777]},{"section":7,"text":"They started IV fluids, which is standard for dehydration or blood loss.","dimension":0,"group":5,"is_degenerate":false,"model_progress":[0.046532,0.072799,0.085246,0.092869,0.095701,0.097141,0.099405,0.093421,0.088902,0.088186,0.076786,0.063013],"unified_progress":[0.052232,0.076906,0.083552,0.089476,0.093677,0.094251,0.096964,0.09447,0.093301,0.088179,0.076799,0.060193]},{"section":8,"text":"The blood typing and cross-matching are probably to prepare for a possible transfusion if needed.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.039118,0.070385,0.08902,0.098209,0.10226,0.10309,0.10303,0.095626,0.087692,0.081108,0.07141,0.059053],"unified_progress":[0.05161,0.081867,0.088746,0.095027,0.097235,0.095932,0.094989,0.092774,0.091139,0.081126,0.07086,0.058695]},{"section":9,"text":"The upper GI endoscopy showed a longitudinal mucosal tear in the distal esophagus.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.023608,0.058607,0.087691,0.1122,0.12025,0.12421,0.12056,0.1084,0.086047,0.065546,0.052551,0.040337],"unified_progress":[0.030666,0.071679,0.09359,0.10938,0.11432,0.10641,0.10271,0.092851,0.10187,0.071574,0.056819,0.048129]},{"section":10,"text":"That's concerning for a tear or injury in the esophagus, maybe from vomiting.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.036453,0.057975,0.077333,0.094053,0.10117,0.10518,0.11202,0.10335,0.09452,0.087707,0.070649,0.059585],"unified_progress":[0.037092,0.064796,0.082955,0.096697,0.1009,0.10767,0.10561,0.099052,0.09401,0.085742,0.070204,0.055266]},{"section":11,"text":"So, this points towards a condition where the esophagus is damaged, like a linear esophageal tear or a Mallory-Weiss tear, which is common in people who vomit forcefully, like after heavy drinking.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.030797,0.049877,0.06923,0.083011,0.095986,0.10391,0.10971,0.11038,0.10586,0.096686,0.077729,0.066819],"unified_progress":[0.034831,0.060979,0.080588,0.092496,0.098409,0.10837,0.10622,0.10289,0.097019,0.089433,0.072923,0.055852]},{"section":12,"text":"Putting it all together, the most likely diagnosis is Mallory-Weiss tear because it's a common cause of upper GI bleeding after forceful vomiting, especially in young individuals who have been drinking heavily.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.027958,0.04277,0.053426,0.061374,0.067676,0.074121,0.081461,0.089701,0.097352,0.11065,0.12519,0.16833],"unified_progress":[0.028724,0.045456,0.055906,0.066577,0.071046,0.082753,0.084491,0.092848,0.096954,0.101,0.12366,0.15059]},{"section":13,"text":"The absence of other symptoms and normal physical exam findings support this diagnosis over more serious conditions like esophageal perforation or bleeding ulcers.","dimension":5,"group":4,"is_degenerate":false,"model_progress":[0.019813,0.037431,0.055198,0.06541,0.072994,0.082028,0.09104,0.10213,0.11063,0.12072,0.12611,0.11651],"unified_progress":[0.021354,0.041381,0.055529,0.065715,0.0