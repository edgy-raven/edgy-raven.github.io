,0.17103,0.12554,0.10545,0.091861,0.081507,0.071796,0.060316,0.049528,0.042687,0.03616,0.029907],"unified_progress":[0.08744,0.13236,0.083153,0.10292,0.1046,0.096191,0.086765,0.079978,0.070101,0.062419,0.053576,0.040499]},{"section":6,"text":"Subcutaneous means it's just under the skin, so it's not deep in the tissues.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.35773,0.16276,0.081976,0.053694,0.063657,0.058581,0.048766,0.050759,0.043735,0.030923,0.030408,0.01701],"unified_progress":[0.23303,0.097336,0.07075,0.065453,0.07854,0.073185,0.083794,0.075199,0.069644,0.055532,0.050498,0.04704]},{"section":7,"text":"The tumor is small, which might make me think it's something less concerning, but I shouldn't get complacent.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.14947,0.17362,0.11607,0.094984,0.081768,0.073127,0.06518,0.058281,0.053722,0.053274,0.046281,0.034221],"unified_progress":[0.060136,0.10452,0.075171,0.097199,0.10151,0.097121,0.090981,0.091299,0.085328,0.079333,0.068635,0.048769]},{"section":8,"text":"The biopsy result is a benign neoplasm.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.058841,0.096637,0.10888,0.13394,0.10528,0.097545,0.091888,0.07961,0.068254,0.061577,0.053137,0.044417],"unified_progress":[0.041132,0.077597,0.092964,0.11033,0.10385,0.099028,0.097068,0.089995,0.08797,0.077592,0.066068,0.056412]},{"section":9,"text":"Benign tumors are generally not cancerous and don't spread, but I need to think about what the most common soft tissue tumor is.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.05084,0.080877,0.091361,0.09958,0.098233,0.095931,0.096434,0.090331,0.085306,0.083884,0.070991,0.056231],"unified_progress":[0.038896,0.068802,0.08487,0.096002,0.098859,0.10106,0.10022,0.097008,0.09197,0.090627,0.07437,0.057316]},{"section":10,"text":"The patient was told she has the most common soft tissue tumor.","dimension":0,"group":5,"is_degenerate":false,"model_progr