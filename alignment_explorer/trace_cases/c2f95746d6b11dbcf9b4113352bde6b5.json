33,0.072241,0.0546]},{"section":12,"text":"Calcifications are common in some eye tumors, especially in children.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.037317,0.060654,0.076707,0.088647,0.097493,0.10116,0.10674,0.10566,0.099156,0.089687,0.075615,0.061165],"unified_progress":[0.035968,0.062964,0.082767,0.095659,0.10187,0.10889,0.10596,0.10213,0.096234,0.087602,0.069735,0.050221]},{"section":13,"text":"Now, considering the age of the child, two years old, and the presence of a subretinal mass with calcifications, I'm thinking of retinoblastoma.","dimension":6,"group":8,"is_degenerate":false,"model_progress":[0.037613,0.06492,0.075129,0.081033,0.087935,0.090625,0.092162,0.092794,0.091029,0.098338,0.092932,0.095489],"unified_progress":[0.03847,0.066636,0.077476,0.087648,0.090886,0.092918,0.092841,0.0936,0.092949,0.090595,0.08841,0.087572]},{"section":14,"text":"Retinoblastoma is a cancer that starts in the retina and is the most common primary intraocular tumor in children.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.03133,0.055748,0.070569,0.082484,0.094122,0.099554,0.10968,0.10993,0.10338,0.094204,0.080265,0.068727],"unified_progress":[0.030458,0.05873,0.081819,0.094652,0.10105,0.11348,0.10567,0.10192,0.097583,0.088025,0.070954,0.055662]},{"section":15,"text":"It often presents with leukocoria because the white tumor reflects light, making the pupil look white.","dimension":9,"group":1,"is_degenerate":false,"model_progress":[0.036922,0.061803,0.077212,0.088849,0.096803,0.099945,0.10477,0.10183,0.097556,0.086312,0.078869,0.069127],"unified_progress":[0.03857,0.069868,0.087115,0.098275,0.10495,0.10511,0.10178,0.097262,0.096156,0.080722,0.066606,0.053592]},{"section":16,"text":"Other possibilities could include a choroidal tumor, but retinoblastoma is more common in this age group.","dimension":15,"group":3,"is_degenerate":false,"model_progress":[0.028643,0.051206,0.067668,0.079668,0.092215,0.098905,0.10753,0.10932,0.1