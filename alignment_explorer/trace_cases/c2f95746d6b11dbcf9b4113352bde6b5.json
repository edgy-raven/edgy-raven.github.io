0.097361,0.099583,0.10182,0.10079,0.098154,0.092112,0.087064,0.070456,0.051927]},{"section":5,"text":"The patient also has a total retinal detachment.","dimension":9,"group":5,"is_degenerate":false,"model_progress":[0.053142,0.092544,0.094187,0.097895,0.092914,0.091566,0.092245,0.086763,0.081472,0.077852,0.07303,0.06639],"unified_progress":[0.05436,0.082613,0.087163,0.092403,0.094168,0.093827,0.091926,0.091802,0.088717,0.08196,0.074551,0.066508]},{"section":6,"text":"Retinal detachment is when the retina separates from the retinal pigment epithelium.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.031563,0.054426,0.073613,0.087433,0.10136,0.10777,0.10938,0.10923,0.10251,0.087671,0.071735,0.06331],"unified_progress":[0.031786,0.058975,0.086173,0.094879,0.1009,0.11493,0.10538,0.099908,0.095886,0.086278,0.069721,0.055175]},{"section":7,"text":"In children, this is uncommon, but it can happen due to various reasons like trauma, infections, or tumors.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.033939,0.054711,0.072091,0.084256,0.094108,0.10052,0.10656,0.10731,0.10414,0.098446,0.079859,0.06406],"unified_progress":[0.036795,0.062883,0.080737,0.093344,0.09847,0.10545,0.10496,0.10287,0.097067,0.091571,0.0729,0.052947]},{"section":8,"text":"The ultrasound B scan is key here.","dimension":11,"group":8,"is_degenerate":false,"model_progress":[0.046201,0.077882,0.081319,0.089828,0.090302,0.091278,0.095124,0.09067,0.08745,0.090238,0.084848,0.07486],"unified_progress":[0.036016,0.066716,0.080626,0.094854,0.097368,0.09609,0.097806,0.094835,0.094015,0.091133,0.080257,0.070284]},{"section":9,"text":"A heterogeneous subretinal mass with calcification suggests there's a solid lesion in the subretinal space.","dimension":1,"group":1,"is_degenerate":false,"model_progress":[0.036068,0.058638,0.077865,0.10261,0.1002,0.10392,0.10493,0.099501,0.089457,0.079952,0.074258,0.072611],"unified_progress":[0.035609,0.063755,0.081274,0.098973,0.099462,0.099814,0.098029,0.094165,0.09529,0.083267,0.07634,0.074023]},{"section":10,"text":"Calcification in such a mass is concerning because it's a sign of a more organized structure, possibly a tumor.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.043316,0.05361,0.070567,0.08325,0.093112,0.09869,0.10258,0.10198,0.098642,0.092762,0.083115,0.078371],"unified_progress":[0.039847,0.058696,0.075491,0.087009,0.093179,0.10404,0.10029,0.098735,0.096085,0.091992,0.082664,0.071973]},{"section":11,"text":"Putting this together, the presence of a subretinal mass with calcification and leukocoria points towards a retinal tumor.","dimension":4,"group":0,"is_degenerate":false,"model_progress":[0.024119,0.039574,0.047878,0.055209,0.059086,0.064754,0.071247,0.081241,0.091928,0.11143,0.14245,0.21108],"unified_progress":[0.022157,0.037446,0.046412,0.056719,0.06118,0.073242,0.076234,0.088269,0.098317,0.10551,0.14301,0.19151]},{"section":12,"text":"In children, the most common intraocular tumor is a retinal astrocytic hamartoma, also known as a retinal hamartoma.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.018258,0.035894,0.051932,0.064762,0.079704,0.090841,0.10068,0.11004,0.11579,0.11266,0.10491,0.11452],"unified_progress":[0.021943,0.044849,0.063398,0.075856,0.085638,0.097412,0.10082,0.10618,0.10743,0.10635,0.098711,0.091408]},{"section":13,"text":"This tumor can cause leukocoria and retinal detachment.","dimension":2,"group":3,"is_degenerate":false,"model_progress":[0.027682,0.039985,0.053649,0.065772,0.081183,0.092533,0.10169,0.1112,0.11452,0.10799,0.099868,0.10393],"unified_progress":[0.028948,0.048113,0.065502,0.080004,0.087754,0.099894,0.10217,0.10451,0.10316,0.10073,0.092402,0.086806]},{"section":14,"text":"Other possibilities might include other tumors like medulloepithelialomas, but the most likely is the astrocytic hamartoma.","dimension":3,"group":6,"is_degenerate":false,"model_progress":[0.022534,0.040964,0.058548,0.071352,0.082945,0.092216,0