56288,0.056821],"unified_progress":[0.09033,0.078105,0.086433,0.09568,0.095627,0.089756,0.091639,0.088156,0.080934,0.083994,0.065928,0.053416]},{"section":8,"text":"The most common things I can think of are retinoblastoma, cataract, Coats' disease, maybe retinopathy of prematurity, but this kid is 2 years old, so ROP is less likely unless they were very premature.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.04535,0.084632,0.095422,0.10239,0.10485,0.10352,0.09714,0.089331,0.079874,0.077942,0.063655,0.055894],"unified_progress":[0.054201,0.081349,0.094636,0.095338,0.097936,0.10293,0.096114,0.094932,0.086125,0.080444,0.064586,0.051413]},{"section":9,"text":"But the key here is the retinal detachment and the mass with calcification.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.040159,0.082934,0.09709,0.10119,0.097784,0.093967,0.091749,0.086316,0.088578,0.082017,0.072397,0.06582],"unified_progress":[0.042641,0.072341,0.086277,0.097669,0.10123,0.099405,0.097518,0.093668,0.093552,0.086095,0.072241,0.057365]},{"section":10,"text":"Retinoblastoma is a malignant tumor of the retina, usually in kids under 5.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.035172,0.070344,0.083775,0.096394,0.10399,0.10456,0.10338,0.095425,0.086404,0.085028,0.07061,0.064921],"unified_progress":[0.043408,0.063023,0.081661,0.091975,0.09746,0.11426,0.10295,0.099049,0.092124,0.08589,0.070598,0.057595]},{"section":11,"text":"It can present with leukocoria.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037167,0.072121,0.082015,0.092323,0.099669,0.10207,0.10265,0.096561,0.087987,0.090104,0.072662,0.064666],"unified_progress":[0.043708,0.062187,0.080466,0.091289,0.097053,0.10563,0.10322,0.10101,0.095344,0.090102,0.07308,0.056919]},{"section":12,"text":"The presence of a subretinal mass on ultrasound is a big clue.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.034963,0.078892,0.093085,0.099092,0.097602,0.097449,0.095996,0.089554,0.093728,0.08214,0.072017,0.065482],"unified_progress":[0.035138,0.070981,0.089407,0.10144,0.10618,0.10359,0.10034,0.094987,0.095596,0.080666,0.067031,0.054641]},{"section":13,"text":"Also, calcifications are often seen in retinoblastoma.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034741,0.073531,0.087502,0.096719,0.10007,0.099545,0.099004,0.092651,0.088471,0.085369,0.073043,0.069352],"unified_progress":[0.036823,0.063804,0.082254,0.095035,0.09937,0.11061,0.10209,0.097031,0.092908,0.085722,0.072716,0.061642]},{"section":14,"text":"I remember that on imaging, calcifications are a hallmark, sometimes called \"calcified spots\" or \"calcium deposits\" in the tumor.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.034784,0.072813,0.085992,0.094852,0.098812,0.099815,0.099686,0.094064,0.091726,0.085723,0.074232,0.067502],"unified_progress":[0.039148,0.066762,0.084679,0.097157,0.10159,0.10496,0.10136,0.096865,0.093372,0.084512,0.070902,0.058693]},{"section":15,"text":"Coats' disease is a vascular abnormality leading to retinal telangiectasia and exudates, which can cause retinal detachment, but it usually doesn't have a mass or calcifications.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029226,0.06529,0.080139,0.094206,0.10271,0.10591,0.10687,0.098871,0.092231,0.090026,0.072608,0.061912],"unified_progress":[0.032233,0.058701,0.081383,0.09533,0.1019,0.11597,0.10703,0.10261,0.097132,0.088208,0.0687,0.050801]},{"section":16,"text":"Cataract would cause leukocoria but wouldn't show a mass.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028664,0.064004,0.077403,0.087142,0.093507,0.098095,0.10253,0.10119,0.099481,0.095075,0.08527,0.067641],"unified_progress":[0.033556,0.061413,0.078113,0.088706,0.097667,0.10113,0.10174,0.103,0.10081,0.099898,0.078375,0.055589]},{"section":17,"text":"Another possibility could be a retinoma, but that's part of neurofibromatosis, but again, not typically with a mass and calcification.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.025319,0.058885,0.074233,0.08671,0.095777,0.10094,0.10487,0.10342,0.10023,0.097281,0.084731,0.067603],"unified_progress":[0.032718,0.061764,0.079596,0.090999,0.097789,0.10464,0.10353,0.10347,0.0998,0.095389,0.076611,0.053699]},{"section":18,"text":"The combination of retinal detachment, subretinal mass, and calcification points strongly to retinoblastoma.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030724,0.065524,0.078572,0.086893,0.090673,0.093306,0.0953,0.093156,0.096969,0.093225,0.087537,0.088119],"unified_progress":[0.036073,0.059111,0.074764,0.087001,0.093338,0.098626,0.098104,0.096984,0.098286,0.091756,0.086712,0.079245]},{"section":19,"text":"Wait, are there other tumors?","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.024884,0.05671,0.076048,0.085875,0.094404,0.097253,0.099226,0.1004,0.10129,0.097106,0.089958,0.076844],"unified_progress":[0.034819,0.070119,0.084131,0.097393,0.097661,0.094775,0.097811,0.095498,0.092407,0.0968,0.078871,0.059714]},{"section":20,"text":"Maybe retinal astrocytoma, but those are usually benign and might not present with detachment or calcifications as prominently.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021629,0.054098,0.070512,0.083561,0.093624,0.09958,0.10632,0.10561,0.10289,0.10042,0.090232,0.071523],"unified_progress":[0.027232,0.05683,0.076215,0.087477,0.097822,0.10415,0.10379,0.10563,0.10244,0.09968,0.080486,0.058257]},{"section":21,"text":"The calcification part is key here.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.02485,0.05832,0.07605,0.085419,0.091692,0.094564,0.098251,0.098636,0.099662,0.097784,0.091936,0.082836],"unified_progress":[0.042268,0.061004,0.074154,0.085508,0.091499,0.094464,0.099086,0.098147,0.097346,0.098338,0.087291,0.070895]},{"section":22,"text":"Retinoblastoma is known for having calcifications on imaging like ultrasound or CT.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.028259,0.060658,0.074265,0.085633,0.093485,0.097905,0.10076,0.098015,0.09692,0.094283,0.086367,0.083453],"unified_progress":[0.035759,0.057972,0.075734,0.087135,0.09345,0.10093,0.099348,0.098577,0.097318,0.09257,0.08458,0.076624]},{"section":23,"text":"So putting it all together: leukocoria, retinal detachment, subretinal mass with calcification in a 2-year-old.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.030569,0.058175,0.067717,0.07586,0.083417,0.089395,0.093999,0.09577,0.10115,0.10108,0.10332,0.099544],"unified_progress":[0.040659,0.052469,0.065138,0.075121,0.084734,0.094799,0.095387,0.098934,0.10264,0.10168,0.10025,0.088188]},{"section":24,"text":"The most likely diagnosis is retinoblastoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.021989,0.044223,0.054247,0.061901,0.06927,0.075697,0.083475,0.088686,0.098252,0.10399,0.11894,0.17933],"unified_progress":[0.021887,0.033344,0.042626,0.052007,0.057745,0.072813,0.076758,0.092444,0.10471,0.11105,0.14516,0.18945]},{"section":25,"text":"<answer> Retinoblastoma </answer>","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.028725,0.048724,0.051694,0.057354,0.065263,0.073626,0.081904,0.08922,0.099146,0.10515,0.11887,0.18032],"unified_progress":[0.028747,0.032654,0.038565,0.045881,0.052094,0.063432,0.068102,0.08489,0.098084,0.11058,0.1531,0.22388]}]}}