.046021,0.037709,0.029382]},{"section":4,"text":"Hmm.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.39395,0.067794,0.065066,0.070057,0.064666,0.05841,0.052278,0.053266,0.050724,0.044975,0.0448,0.034013],"unified_progress":[0.2511,0.10761,0.072894,0.065434,0.079288,0.071728,0.08062,0.069543,0.063638,0.049845,0.046012,0.042292]},{"section":5,"text":"First, the optic disc has a large cup.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.10297,0.20522,0.06646,0.10713,0.090081,0.093276,0.072892,0.064701,0.05795,0.052227,0.046405,0.040696],"unified_progress":[0.10413,0.12082,0.074165,0.10697,0.099492,0.10483,0.085088,0.078219,0.069484,0.062405,0.053734,0.040661]},{"section":6,"text":"That makes me think of glaucoma, since cupping of the optic disc is a classic sign.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.059723,0.10491,0.1192,0.11471,0.10695,0.09289,0.087046,0.076308,0.067507,0.067823,0.052994,0.049942],"unified_progress":[0.054953,0.07956,0.095885,0.10481,0.10259,0.1036,0.096565,0.088907,0.082108,0.078812,0.062475,0.049723]},{"section":7,"text":"But wait, the intraocular pressure is normal.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.049276,0.09557,0.1084,0.10822,0.10192,0.094638,0.091027,0.08457,0.077848,0.073294,0.063562,0.051679],"unified_progress":[0.052387,0.083098,0.094732,0.10037,0.10356,0.097838,0.096363,0.091108,0.085055,0.080323,0.066218,0.048942]},{"section":8,"text":"Open-angle glaucoma usually has elevated IOP, but there's also normal-tension glaucoma where IOP is within normal limits.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037573,0.078945,0.093247,0.10177,0.10469,0.10297,0.10061,0.092816,0.08337,0.081123,0.066918,0.055978],"unified_progress":[0.04281,0.072156,0.088904,0.096768,0.10138,0.10761,0.10212,0.096801,0.089353,0.083548,0.067748,0.050806]},{"section":9,"text":"So that's a possibility.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.03758,0.077945,0.097166,0.10281,0.10108,0.094781,0.092137,0.087871,0.083765,0.084081,0.072273,0.068509],"unified_progress":[0.046034,0.072447,0.083941,0.096789,0.09706,0.094699,0.095694,0.093204,0.088834,0.091062,0.076933,0.063303]},{"section":10,"text":"The pupillary reflex is sluggish.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.052945,0.096306,0.096328,0.09457,0.092747,0.092314,0.090255,0.088398,0.083959,0.078181,0.071325,0.062672],"unified_progress":[0.063165,0.086207,0.090455,0.095317,0.095393,0.09436,0.092321,0.090975,0.085937,0.079355,0.069566,0.056948]},{"section":11,"text":"In glaucoma, especially advanced cases, there can be papillomacular bundle damage, which might affect the pupillary response.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.0427,0.082218,0.090542,0.096754,0.099207,0.09932,0.098102,0.092075,0.087374,0.081116,0.069391,0.061202],"unified_progress":[0.047446,0.070604,0.088369,0.094816,0.099184,0.10493,0.099062,0.09523,0.09191,0.082967,0.069636,0.055844]},{"section":12,"text":"The paracentral scotomas are also typical in glaucoma, as the damage often affects the mid-peripheral retina first, leading to those scotomas.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.042814,0.083509,0.090482,0.095413,0.097124,0.098082,0.097111,0.091934,0.088996,0.081703,0.070476,0.062356],"unified_progress":[0.047591,0.072471,0.086595,0.095216,0.099835,0.10278,0.098787,0.095374,0.092636,0.082993,0.06969,0.056034]},{"section":13,"text":"Other possibilities?","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.035539,0.078485,0.10112,0.10556,0.10138,0.092341,0.090217,0.085994,0.082507,0.087882,0.072091,0.066887],"unified_progress":[0.035715,0.072593,0.085996,0.099383,0.099131,0.094982,0.097738,0.093941,0.089917,0.094543,0.076297,0.059762]},{"section":14,"text":"Maybe optic neuropathy from another cause, like compressive lesion or ischemic optic neuropathy.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.028698,0.067495,0.083902,0.093501,0.09943,0.10097,0.10136,0.098543,0.094757,0.089738,0.078572,0.063034],"unified_progress":[0.032002,0.065953,0.083978,0.097197,0.10039,0.10256,0.10253,0.099657,0.095982,0.08956,0.073948,0.056234]},{"section":15,"text":"But ischemic would usually come on suddenly, and the patient here has a gradual deterioration.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021318,0.054217,0.069798,0.080061,0.089009,0.09561,0.10508,0.10872,0.10727,0.10449,0.097305,0.067121],"unified_progress":[0.029238,0.057244,0.072546,0.080262,0.09369,0.095611,0.10095,0.10885,0.10696,0.11281,0.088735,0.05311]},{"section":16,"text":"Also, normal pressure would make ischemic less likely unless there's another vascular issue, but the key signs point more to glaucoma.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022244,0.054598,0.070399,0.080749,0.087786,0.093809,0.10211,0.10542,0.10556,0.10474,0.096575,0.076003],"unified_progress":[0.029856,0.057848,0.071725,0.080861,0.090241,0.09431,0.10069,0.10494,0.1051,0.10886,0.091732,0.063836]},{"section":17,"text":"Another thought: maybe a tumor or something compressing the optic nerve, but that would likely cause different patterns of visual field loss, maybe more sectoral.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.025087,0.060296,0.074365,0.084103,0.090161,0.095944,0.10169,0.10288,0.10741,0.098824,0.090024,0.069211],"unified_progress":[0.030403,0.060836,0.077932,0.089621,0.097597,0.0998,0.10231,0.10358,0.10499,0.09909,0.080498,0.053344]},{"section":18,"text":"The paracentral scotomas are more glaucomatous.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.032291,0.068078,0.078423,0.086569,0.091889,0.096034,0.098855,0.097269,0.098216,0.092299,0.084463,0.075614],"unified_progress":[0.039103,0.064585,0.079305,0.089959,0.096356,0.10174,0.10028,0.098826,0.097992,0.09017,0.078177,0.06351]},{"section":19,"text":"So putting it all together: normal IOP but large cup and paracentral scotomas.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.031482,0.06379,0.077011,0.083965,0.087883,0.089669,0.092757,0.092843,0.095873,0.097362,0.095398,0.091967],"unified_progress":[0.038098,0.057589,0.070565,0.080797,0.0887,0.094332,0.096509,0.097805,0.099534,0.099172,0.094511,0.082389]},{"section":20,"text":"That's pointing towards normal-tension glaucoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.029855,0.060707,0.07382,0.081631,0.086142,0.087653,0.091157,0.091245,0.092604,0.095783,0.094796,0.11461],"unified_progress":[0.032211,0.050044,0.062713,0.073,0.078416,0.087072,0.089307,0.095091,0.099166,0.10163,0.11016,0.12119]},{"section":21,"text":"The sluggish pupil could be due to the optic nerve damage affecting the afferent pathway for the light reflex.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.035187,0.069895,0.078428,0.085718,0.090552,0.094822,0.097484,0.095575,0.096095,0.090594,0.085288,0.080364],"unified_progress":[0.040709,0.058226,0.071279,0.081853,0.088784,0.094921,0.095577,0.097643,0.10037,0.097116,0.092521,0.081]},{"section":22,"text":"Wait, but could it be another type of optic neuropathy?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.025885,0.056951,0.072934,0.083602,0.093966,0.097246,0.10189,0.10493,0.10339,0.10028,0.091037,0.067891],"unified_progress":[0.034964,0.066017,0.084251,0.097806,0.098937,0.098177,0.10281,0.10004,0.096123,0.092147,0.075404,0.05333]},{"section":23,"text":"Like from nutritional deficiency or toxicity?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.021258,0.053126,0.070211,0.081898,0.094047,0.10054,0.10549,0.10809,0.10613,0.10154,0.091507,0.066172],"unified_progress":[0.047212,0.071079,0.085256,0.094258,0.097794,0.097985,0.10043,0.099463,0.093958,0.090644,0.072328,0.049594]},{"section":24,"text":"But the history doesn't mention any meds or alcohol use.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.024878,0.057714,0.071735,0.080719,0.08965,0.098262,0.10258,0.1057,0.10431,0.10163,0.093748,0.06908],"unified_progress":[0.055563,0.087827,0.087536,0.087762,0.092744,0.09214,0.092534,0.097392,0.091517,0.091213,0.074713,0.049061]},{"section":25,"text":"Without more info, the most likely is still glaucoma, specifically normal-tension since IOP is normal.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.023813,0.052186,0.065048,0.073303,0.079809,0.085474,0.091661,0.094324,0.097731,0.10022,0.10416,0.13227],"unified_progress":[0.031571,0.053113,0.062066,0.070137,0.075339,0.08062,0.085107,0.088943,0.092546,0.099374,0.11796,0.14322]},{"section":26,"text":"Yeah, I think that's it.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.28624,0.047076,0.048183,0.05769,0.059939,0.063796,0.062868,0.073465,0.077494,0.076966,0.083454,0.062832],"unified_progress":[0.18816,0.072249,0.061787,0.062056,0.071404,0.073467,0.09946,0.085694,0.085374,0.072669,0.067748,0.059929]},{"section":27,"text":"The classic triad here is the optic cupping, visual field defects (paracentral), and the pupillary issues.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.038671,0.08053,0.052995,0.085311,0.090876,0.092281,0.095847,0.093421,0.094072,0.09596,0.092746,0.087292],"unified_progress":[0.047513,0.067273,0.056047,0.079596,0.089388,0.092368,0.10415,0.096978,0.097078,0.097053,0.092777,0.079784]},{"section":28,"text":"So the diagnosis should be normal-tension glaucoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.019325,0.038856,0.048279,0.056642,0.06573,0.073615,0.082738,0.088868,0.09987,0.10499,0.12465,0.19644],"unified_progress":[0.018825,0.029109,0.037327,0.047007,0.052412,0.069595,0.073901,0.090233,0.10785,0.11254,0.1538,0.2074]}]}}