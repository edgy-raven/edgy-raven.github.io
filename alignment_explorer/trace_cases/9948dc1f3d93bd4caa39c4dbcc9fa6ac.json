15,0.0098476,0.0074723],"unified_progress":[0.21658,0.054031,0.5471,0.035558,0.029817,0.025962,0.021785,0.019858,0.016817,0.012647,0.010474,0.0093675]},{"section":2,"text":"The patient is a 45-year-old woman presenting with mononeuritis multiplex.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.19766,0.36432,0.07185,0.10284,0.053364,0.059163,0.036651,0.030205,0.025475,0.021822,0.018883,0.017769],"unified_progress":[0.24597,0.1613,0.080886,0.11052,0.075913,0.090628,0.056269,0.048903,0.042015,0.035745,0.029621,0.02223]},{"section":3,"text":"Mononeuritis multiplex typically refers to inflammation of multiple peripheral nerves, which can be due to various causes like vasculitis, diabetes, or infections.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.080117,0.13248,0.13298,0.1175,0.10677,0.091791,0.081998,0.070379,0.057698,0.052069,0.041588,0.034621],"unified_progress":[0.066532,0.094459,0.11845,0.11114,0.10366,0.10015,0.090615,0.082345,0.073007,0.066926,0.0527,0.040022]},{"section":4,"text":"But here, there are other clues.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.063814,0.10888,0.12155,0.11816,0.10419,0.089143,0.081329,0.073983,0.066283,0.068069,0.054087,0.050507],"unified_progress":[0.069148,0.083712,0.091149,0.10263,0.10011,0.093349,0.091765,0.087829,0.081009,0.082685,0.065955,0.050663]},{"section":5,"text":"She has a history of bronchial asthma and allergic rhinitis, both of which are allergic conditions.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.066213,0.11385,0.10506,0.097761,0.094368,0.098407,0.086716,0.08487,0.074497,0.070159,0.059415,0.048688],"unified_progress":[0.083735,0.11752,0.10346,0.094687,0.090145,0.090118,0.083217,0.08663,0.074923,0.068979,0.059227,0.047355]},{"section":6,"text":"The presence of cutaneous purpura is significant.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.063937,0.11411,0.10786,0.096924,0.090718,0.092008,0.084381,0.08653,0.078151,0.070907,0.061797,0.052676],"unified_progress":[0.068868,0.10195,0.099404,0.10065,0.095884,0.095256,0.088327,0.087628,0.081257,0.073233,0.06083,0.046714]},{"section":7,"text":"Purpura suggests a vascular issue, maybe immune complex deposition or vasculitis.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.037004,0.07726,0.092083,0.10056,0.10289,0.10036,0.099853,0.092154,0.086402,0.082177,0.069935,0.059326],"unified_progress":[0.040206,0.067751,0.087877,0.094478,0.099754,0.10414,0.10043,0.095646,0.092394,0.087017,0.073481,0.056832]},{"section":8,"text":"Also, the blood test shows eosinophilia, which is an increase in eosinophils.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.047231,0.092612,0.10434,0.10502,0.1008,0.095253,0.094246,0.088118,0.081022,0.074049,0.065848,0.05147],"unified_progress":[0.047576,0.085675,0.099862,0.10332,0.10777,0.10097,0.10058,0.08982,0.082992,0.073763,0.062508,0.045173]},{"section":9,"text":"Eosinophils are often involved in allergic reactions and parasitic infections, but they can also be part of certain autoimmune conditions.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.035906,0.075122,0.090576,0.10052,0.10452,0.10309,0.10203,0.094317,0.084893,0.083835,0.068836,0.056348],"unified_progress":[0.04604,0.07139,0.087911,0.09657,0.10104,0.10741,0.10257,0.096983,0.089059,0.083664,0.067971,0.049394]},{"section":10,"text":"Putting this together: eosinophilia, asthma, allergic rhinitis (allergic triad?), purpura, and mononeuritis multiplex.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.038844,0.075828,0.085875,0.091851,0.095013,0.095895,0.095733,0.092259,0.088723,0.088309,0.079638,0.072031],"unified_progress":[0.045662,0.067757,0.080796,0.089743,0.094983,0.10054,0.098016,0.09663,0.093651,0.089727,0.079043,0.063453]},{"section":11,"text":"The combination of asthma, rhinitis, and eosinophilia makes me think of eosinophilic disorders.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034597,0.07172,0.086568,0.095066,0.098386,0.097472,0.097439,0.092605,0.087872,0.089547,0.07773,0.070998],"unified_progress":[0.038631,0.064381,0.081297,0.091214,0.096677,0.10227,0.10074,0.098272,0.09446,0.091542,0.078034,0.062481]},{"section":12,"text":"The cutaneous purpura could be part of a systemic eosinophilic condition.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.0321,0.067974,0.081894,0.091407,0.096682,0.098549,0.10008,0.095752,0.092904,0.089869,0.080406,0.072386],"unified_progress":[0.037264,0.059369,0.075787,0.087173,0.094219,0.10084,0.099893,0.099083,0.098515,0.094358,0.084501,0.068995]},{"section":13,"text":"Hmm, Churg-Strauss syndrome comes to mind.","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.037549,0.069782,0.082225,0.090344,0.094968,0.094699,0.0954,0.093154,0.089844,0.090543,0.080503,0.080989],"unified_progress":[0.048156,0.061375,0.075346,0.086832,0.090625,0.095363,0.095892,0.096044,0.093457,0.093183,0.085522,0.078206]},{"section":14,"text":"Wait, Churg-Strauss is now called eosinophilic granulomatosis with polyangiitis (EGPA).","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031373,0.063453,0.07787,0.093095,0.10346,0.10596,0.10645,0.097991,0.088498,0.090927,0.072654,0.068271],"unified_progress":[0.035655,0.054985,0.078643,0.089919,0.097911,0.10879,0.10536,0.10302,0.097479,0.091691,0.074934,0.06161]},{"section":15,"text":"The criteria for EGPA include asthma, eosinophilia, and vasculitis affecting small to medium vessels.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029829,0.063665,0.077555,0.090803,0.10051,0.10428,0.10607,0.099069,0.090867,0.095219,0.075525,0.066608],"unified_progress":[0.033623,0.057556,0.078266,0.0921,0.098458,0.1071,0.10608,0.10371,0.098452,0.092336,0.074664,0.057651]},{"section":16,"text":"The vasculitis can involve the nerves (leading to mononeuritis multiplex) and the skin (causing purpura).","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.031488,0.066722,0.077292,0.087041,0.094757,0.10003,0.10275,0.098756,0.095575,0.091404,0.081218,0.072973],"unified_progress":[0.03667,0.058465,0.073602,0.084359,0.092798,0.103,0.10045,0.10062,0.10064,0.094551,0.085544,0.069305]},{"section":17,"text":"Let me check the key points again.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.31781,0.051531,0.052666,0.061523,0.06246,0.064299,0.061617,0.070212,0.070635,0.065547,0.068757,0.052942],"unified_progress":[0.20203,0.077291,0.064199,0.064673,0.073711,0.073803,0.092079,0.082164,0.079043,0.064508,0.060522,0.065975]},{"section":18,"text":"EGPA typically has three components: asthma, eosinophilia, and systemic vasculitis.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.039972,0.085443,0.05671,0.098965,0.10604,0.1038,0.1029,0.094232,0.086949,0.083209,0.075174,0.0666],"unified_progress":[0.044745,0.066582,0.059374,0.092229,0.099297,0.10057,0.10454,0.10129,0.097253,0.09258,0.078789,0.062753]},{"section":19,"text":"The patient has all three.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.029641,0.064524,0.079833,0.088926,0.09516,0.09718,0.099412,0.097144,0.095125,0.091522,0.086168,0.075366],"unified_progress":[0.087693,0.06972,0.073069,0.079423,0.085292,0.089424,0.089186,0.093059,0.089789,0.089649,0.082645,0.071052]},{"section":20,"text":"The purpura is a cutaneous manifestation of vasculitis.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027051,0.059812,0.072681,0.083094,0.091485,0.097263,0.10137,0.099552,0.098869,0.095689,0.090922,0.08221],"unified_progress":[0.038115,0.057394,0.071941,0.079586,0.088393,0.095603,0.096591,0.097932,0.1007,0.099717,0.094119,0.079908]},{"section":21,"text":"Mononeuritis multiplex is a neurological manifestation, which fits with EGPA's vasculitic involvement of nerves.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027209,0.058355,0.070684,0.081711,0.090608,0.096509,0.10125,0.099809,0.098841,0.09668,0.091274,0.087068],"unified_progress":[0.033793,0.050226,0.064744,0.074909,0.085201,0.09549,0.097497,0.10115,0.1041,0.10404,0.10019,0.088666]},{"section":22,"text":"Other possibilities?","dimension":12,"group":8,"is_degenerate":false,"model_progress":[0.024678,0.058386,0.078453,0.08762,0.093728,0.095015,0.097411,0.098292,0.098897,0.097743,0.089393,0.080385],"unified_progress":[0.031056,0.064136,0.077725,0.091193,0.093504,0.093675,0.096717,0.097199,0.09624,0.10109,0.087695,0.069771]},{"section":23,"text":"Maybe hypereosinophilic syndrome, but that usually doesn't present with vasculitis and purpura.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.024684,0.056947,0.072117,0.084223,0.093972,0.099138,0.10447,0.1033,0.099574,0.098609,0.089038,0.073929],"unified_progress":[0.030842,0.057237,0.074718,0.084124,0.094894,0.10241,0.10249,0.10425,0.10151,0.099903,0.083922,0.063707]},{"section":24,"text":"Allergic granulomatous angiitis is another term for EGPA.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.025641,0.057026,0.071985,0.086489,0.097672,0.10282,0.10608,0.10207,0.095585,0.097225,0.081968,0.075439],"unified_progress":[0.03146,0.054914,0.074944,0.088535,0.095334,0.10518,0.10425,0.10397,0.099369,0.094171,0.08073,0.067139]},{"section":25,"text":"Another thought: could it be another type of vasculitis like polyarteritis nodosa?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.022989,0.053837,0.069864,0.082319,0.09433,0.099848,0.10468,0.10679,0.10446,0.10113,0.090507,0.06925],"unified_progress":[0.031851,0.064018,0.083364,0.095739,0.099959,0.10087,0.10371,0.10233,0.097789,0.091564,0.074921,0.053889]},{"section":26,"text":"But PAN usually affects medium arteries and isn't associated with eosinophilia or asthma.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.019937,0.050739,0.067763,0.080408,0.091373,0.09797,0.10609,0.10774,0.10568,0.10388,0.095735,0.072679],"unified_progress":[0.032296,0.057026,0.074624,0.084535,0.095677,0.10031,0.10286,0.10678,0.10349,0.10372,0.083416,0.055273]},{"section":27,"text":"So, the most likely diagnosis here is EGPA (Churg-Strauss syndrome).","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.021872,0.041854,0.050661,0.059461,0.068805,0.077147,0.085151,0.091018,0.098574,0.10305,0.11709,0.18531],"unified_progress":[0.025019,0.032203,0.040711,0.051118,0.056411,0.069848,0.07333,0.086145,0.094856,0.10554,0.15054,0.21427]},{"section":28,"text":"The combination of her allergic history, eosinophilia, cutaneous purpura (vasculitis), and mononeuritis multiplex all point to this condition.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.018588,0.04172,0.054239,0.064487,0.07561,0.085155,0.093809,0.099424,0.10842,0.11462,0.12268,0.12125],"unified_progress":[0.024536,0.038395,0.049889,0.060146,0.071455,0.086552,0.090729,0.10146,0.11364,0.12339,0.128,0.11182]}]}}