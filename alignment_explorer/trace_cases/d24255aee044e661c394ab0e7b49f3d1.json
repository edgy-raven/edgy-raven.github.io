],"unified_progress":[0.067402,0.076287,0.087137,0.098029,0.096526,0.092088,0.093713,0.089685,0.083789,0.086825,0.070628,0.057891]},{"section":7,"text":"Craniopharyngioma comes to mind.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.041395,0.080439,0.096216,0.10543,0.10726,0.10154,0.096747,0.087609,0.079262,0.078154,0.064389,0.061557],"unified_progress":[0.041761,0.06394,0.085224,0.095124,0.099624,0.1063,0.10057,0.09663,0.091317,0.086954,0.071577,0.060983]},{"section":8,"text":"They often occur near the pituitary gland and optic chiasm.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.034204,0.07471,0.089218,0.099488,0.10362,0.10405,0.10172,0.093244,0.087829,0.083771,0.067957,0.060189],"unified_progress":[0.039258,0.064872,0.084716,0.098051,0.10245,0.10733,0.10299,0.098927,0.094465,0.084676,0.067917,0.05435]},{"section":9,"text":"These tumors can cause visual problems because they're near the optic nerves and chiasm.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033643,0.07379,0.086252,0.095032,0.099183,0.10139,0.10134,0.095262,0.09275,0.085294,0.07302,0.063039],"unified_progress":[0.049276,0.066317,0.081707,0.092771,0.098816,0.10375,0.10009,0.097398,0.09506,0.085621,0.071761,0.057433]},{"section":10,"text":"The calcification on CT is a big clue because craniopharyngiomas frequently have calcifications, which show up well on CT scans.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.039882,0.080135,0.091942,0.098257,0.098392,0.096889,0.095776,0.090083,0.08782,0.084001,0.070875,0.065947],"unified_progress":[0.043776,0.069472,0.086259,0.096752,0.10099,0.10312,0.09993,0.095161,0.092021,0.084192,0.070224,0.058103]},{"section":11,"text":"Another possibility could be a pituitary adenoma, but those are less common in kids.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.031948,0.069893,0.086627,0.09559,0.099221,0.098294,0.098867,0.095322,0.090409,0.091113,0.076965,0.065751],"unified_progress":[0.036137,0.067186,0.083498,0.094607,0.098536,0.1024,0.10101,0.098942,0.094263,0.091938,0.074555,0.056926]},{"section":12,"text":"Also, adenomas usually don't have calcifications as prominently as craniopharyngiomas.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.031161,0.067211,0.081282,0.091674,0.097504,0.099395,0.1013,0.097362,0.092732,0.091563,0.078848,0.069973],"unified_progress":[0.034166,0.060199,0.078496,0.090238,0.097257,0.1037,0.10221,0.10146,0.097959,0.094126,0.078363,0.061832]},{"section":13,"text":"Germ cell tumors might be another option, but they might present differently.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.021357,0.054092,0.071409,0.083419,0.091903,0.09754,0.10519,0.10664,0.10493,0.10275,0.093031,0.067727],"unified_progress":[0.026182,0.056103,0.073597,0.084116,0.094854,0.09876,0.1027,0.10751,0.10584,0.11114,0.085103,0.054101]},{"section":14,"text":"The location is suprasellar, so maybe a Rathke's cleft cyst?","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.031511,0.070777,0.084189,0.092511,0.094243,0.097394,0.097211,0.093942,0.10325,0.088001,0.078207,0.068761],"unified_progress":[0.037388,0.067501,0.085478,0.098769,0.10401,0.1036,0.10216,0.097294,0.10045,0.082132,0.068783,0.052442]},{"section":15,"text":"But those typically don't calcify.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.020614,0.053426,0.070438,0.082429,0.091201,0.096922,0.10521,0.1066,0.10661,0.10284,0.094346,0.06936],"unified_progress":[0.036732,0.058164,0.074595,0.084752,0.096087,0.098294,0.10148,0.10558,0.10339,0.1044,0.081574,0.054953]},{"section":16,"text":"Also, they might cause symptoms like headaches and endocrine issues, but visual disturbances could happen if they compress the optic chiasm.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.022892,0.055806,0.069856,0.081281,0.090249,0.097579,0.10469,0.10537,0.10509,0.10088,0.092797,0.073507],"unified_progress":[0.031722,0.054977,0.070531,0.081134,0.091466,0.09927,0.10131,0.10547,0.10647,0.10522,0.089817,0.062605]},{"section":17,"text":"However, the calcification is more characteristic of a craniopharyngioma.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.028707,0.061648,0.074598,0.083677,0.088991,0.092698,0.096467,0.096144,0.09804,0.096406,0.089942,0.092681],"unified_progress":[0.032955,0.054895,0.07013,0.081443,0.088282,0.094444,0.096552,0.098271,0.099823,0.097943,0.094592,0.090671]},{"section":18,"text":"Also, the age is 12, which is a time when craniopharyngiomas can present.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.03807,0.071389,0.079244,0.086079,0.092128,0.098789,0.096564,0.096248,0.092484,0.093948,0.082431,0.072626],"unified_progress":[0.071523,0.092136,0.086095,0.085095,0.08669,0.090295,0.088814,0.091776,0.086958,0.083894,0.074772,0.061953]},{"section":19,"text":"The progressive symptoms over time suggest a slow-growing mass, which fits with a benign tumor like this.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.033298,0.070634,0.084314,0.091065,0.093389,0.094873,0.095615,0.093363,0.092377,0.092145,0.082586,0.076341],"unified_progress":[0.046934,0.071787,0.080166,0.08807,0.091531,0.093654,0.093908,0.094033,0.093263,0.093679,0.082989,0.069987]},{"section":20,"text":"The visual disturbances are likely due to compression of the optic pathways.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.029913,0.06678,0.079386,0.087754,0.09262,0.096613,0.099019,0.096293,0.098307,0.090885,0.085083,0.077346],"unified_progress":[0.040987,0.060953,0.073991,0.084825,0.091547,0.095767,0.096589,0.09698,0.099688,0.095263,0.088146,0.075263]},{"section":21,"text":"So putting it all together: suprasellar mass with calcification in a child with headaches and visual issues.","dimension":4,"group":9,"is_degenerate":false,"model_progress":[0.031467,0.062038,0.073913,0.08129,0.0861,0.089012,0.092482,0.09324,0.097021,0.099896,0.098584,0.094958],"unified_progress":[0.038332,0.053036,0.064937,0.075269,0.084918,0.091613,0.095658,0.099352,0.10298,0.10515,0.10078,0.08798]},{"section":22,"text":"The most likely diagnosis is craniopharyngioma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.023114,0.047933,0.058928,0.066963,0.073676,0.079294,0.085698,0.089216,0.097332,0.1012,0.11251,0.16413],"unified_progress":[0.022274,0.036176,0.04681,0.056679,0.062597,0.076183,0.079708,0.092248,0.10395,0.10924,0.13826,0.17586]}]}}