":[0.046859,0.067858,0.087812,0.096906,0.10037,0.11365,0.10169,0.095248,0.088911,0.079806,0.066443,0.05444]},{"section":8,"text":"Calcification usually means there's some sort of deposit or abnormality there.","dimension":4,"group":6,"is_degenerate":false,"model_progress":[0.034552,0.060262,0.081289,0.098404,0.10636,0.10966,0.10844,0.10119,0.094399,0.090003,0.072223,0.04322],"unified_progress":[0.041193,0.068786,0.08722,0.098002,0.10183,0.10224,0.10173,0.097384,0.092735,0.084006,0.070443,0.05442]},{"section":9,"text":"Now, what conditions cause calcifications in the brain?","dimension":5,"group":8,"is_degenerate":false,"model_progress":[0.021071,0.052929,0.078949,0.096477,0.10515,0.11011,0.11025,0.10779,0.10525,0.10239,0.074453,0.035187],"unified_progress":[0.035595,0.066338,0.08341,0.099521,0.10015,0.1025,0.10292,0.097526,0.092162,0.09154,0.073242,0.055096]},{"section":10,"text":"Craniopharyngioma comes to mind.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.015282,0.034225,0.052764,0.072072,0.091661,0.10836,0.12222,0.1253,0.12967,0.13212,0.084728,0.031603],"unified_progress":[0.025558,0.053954,0.078335,0.093337,0.10288,0.11702,0.1095,0.10568,0.098058,0.091499,0.070019,0.054166]},{"section":11,"text":"It's a type of tumor that often has calcifications and can press on the optic chiasm, causing vision problems.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.019893,0.031849,0.045774,0.061872,0.08093,0.099158,0.11513,0.12217,0.13146,0.14049,0.10244,0.048836],"unified_progress":[0.029315,0.05266,0.074275,0.092106,0.099265,0.11106,0.10999,0.10685,0.10074,0.093963,0.074127,0.055639]},{"section":12,"text":"And since it's in the suprasellar region, it fits perfectly.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.025656,0.03821,0.049023,0.059996,0.071626,0.083406,0.09577,0.10405,0.1155,0.12941,0.13025,0.097109],"unified_progress":[0.035904,0.053757,0.0683,0.079723,0.088431,0.099324,0.09847,0.10102,0.10103,0.099731,0.093707,0.080602]},{"section":13,"text":"Let's consider other possibilities too.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.10065,0.080711,0.075788,0.068977,0.071466,0.075779,0.080642,0.092595,0.086196,0.061606,0.067255,0.13833],"unified_progress":[0.19507,0.074627,0.061975,0.063253,0.072425,0.073906,0.094423,0.08406,0.082024,0.067673,0.063558,0.067005]},{"section":14,"text":"Could it be a meningioma?","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028456,0.048076,0.06543,0.080506,0.089405,0.099074,0.10916,0.11482,0.11836,0.11752,0.084786,0.044401],"unified_progress":[0.038508,0.06722,0.06395,0.093175,0.10254,0.10087,0.10111,0.10598,0.10148,0.094561,0.077815,0.052807]},{"section":15,"text":"Well, those can also cause headaches and vision issues, but they're less common in kids.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.026605,0.037737,0.050575,0.063367,0.076811,0.09191,0.10689,0.11809,0.12847,0.13368,0.10756,0.0583],"unified_progress":[0.036138,0.055913,0.072637,0.083175,0.093477,0.10162,0.10219,0.10505,0.1028,0.10196,0.084754,0.060285]},{"section":16,"text":"And they don't always show up as calcified masses on scans like craniopharyngiomas do.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.024058,0.033043,0.046888,0.061811,0.077521,0.09429,0.11039,0.12077,0.13126,0.13869,0.10642,0.054854],"unified_progress":[0.033839,0.053066,0.072802,0.08514,0.093935,0.10345,0.10404,0.10556,0.10228,0.10014,0.083143,0.062593]},{"section":17,"text":"What about aneurysms?","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.015231,0.032618,0.049409,0.06499,0.079971,0.097277,0.11326,0.12783,0.13844,0.13796,0.099053,0.043955],"unified_progress":[0.026782,0.054702,0.07279,0.084673,0.094204,0.09904,0.10295,0.10679,0.10534,0.10942,0.08554,0.057774]},{"section":18,"text":"They can cause similar symptoms, but they're rare in children and wouldn't typically present with calcification.","d