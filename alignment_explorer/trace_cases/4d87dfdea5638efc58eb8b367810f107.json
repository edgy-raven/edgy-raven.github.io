0,0.0,0.0]},{"section":1,"text":", let's see.","dimension":-1,"group":-1,"is_degenerate":true,"model_progress":[0.33381,0.059624,0.46533,0.027417,0.022372,0.019258,0.015171,0.014782,0.013194,0.011416,0.010024,0.0076064],"unified_progress":[0.20783,0.054635,0.55321,0.035956,0.03015,0.026252,0.022028,0.02008,0.017005,0.012789,0.010592,0.0094722]},{"section":2,"text":"The patient is a 50-year-old chronic smoker presenting with hemoptysis.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.19418,0.37045,0.070989,0.10407,0.051977,0.060112,0.035771,0.029495,0.025003,0.021479,0.01866,0.017813],"unified_progress":[0.2482,0.15227,0.077414,0.1124,0.076013,0.095104,0.056933,0.049638,0.042765,0.036482,0.030172,0.02261]},{"section":3,"text":"Hmm, hemoptysis can be from several causes like pneumonia, bronchitis, lung cancer, or maybe something else.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.093144,0.14168,0.14948,0.12052,0.10295,0.082002,0.072326,0.063951,0.05166,0.049959,0.038404,0.033929],"unified_progress":[0.079874,0.10006,0.1051,0.11211,0.10369,0.09606,0.08796,0.082499,0.071223,0.068529,0.05283,0.040058]},{"section":4,"text":"But then there's more info: truncal obesity and hypertension.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.078083,0.12899,0.11933,0.10584,0.09467,0.090109,0.079188,0.076714,0.066316,0.062606,0.052599,0.045564],"unified_progress":[0.078883,0.10366,0.09877,0.098287,0.09476,0.091058,0.086697,0.087087,0.077256,0.073985,0.061481,0.048079]},{"section":5,"text":"Those make me think of Cushing's syndrome, which often presents with central obesity, hypertension, and other features like easy bruising or muscle weakness.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.046355,0.088235,0.097624,0.10244,0.10337,0.10128,0.09693,0.089711,0.079549,0.076683,0.063905,0.053916],"unified_progress":[0.045314,0.071909,0.091395,0.094285,0.098529,0.10531,0.099036,0.095831,0.089502,0.085576,0.070001,0.053311]},{"section":6,"text":"The lab results mention an elevated ACTH level that doesn't suppress with high-dose dexamethasone.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.054295,0.099562,0.10477,0.10236,0.097787,0.09436,0.091811,0.086937,0.079449,0.07223,0.064109,0.052332],"unified_progress":[0.053923,0.0886,0.098109,0.10077,0.10453,0.099376,0.096456,0.089806,0.083375,0.073744,0.063399,0.047916]},{"section":7,"text":"Wait, in Cushing's, if ACTH is high, that suggests either a pituitary adenoma (Cushing's disease) or an ectopic source.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.037113,0.075763,0.089961,0.10058,0.10481,0.10391,0.1021,0.09336,0.084818,0.083018,0.066709,0.057849],"unified_progress":[0.041063,0.069316,0.089121,0.098292,0.10209,0.11079,0.10301,0.097199,0.08988,0.081931,0.066223,0.05109]},{"section":8,"text":"But dexamethasone suppression test: normally, if you give dexamethasone, which is a glucocorticoid, it should suppress ACTH because of feedback inhibition.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.042908,0.081025,0.091183,0.097363,0.099882,0.098814,0.099293,0.093332,0.085501,0.08156,0.070392,0.058746],"unified_progress":[0.058349,0.074525,0.088703,0.09573,0.1012,0.10195,0.099904,0.094007,0.087207,0.079118,0.067201,0.052105]},{"section":9,"text":"If it's not suppressible, that points away from a pituitary cause because the pituitary should respond to the negative feedback.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.042048,0.080591,0.091478,0.097109,0.098513,0.097233,0.097027,0.091999,0.086848,0.082328,0.071854,0.062972],"unified_progress":[0.051718,0.073556,0.088017,0.096371,0.10066,0.10067,0.10071,0.093093,0.087962,0.080654,0.069725,0.056863]},{"section":10,"text":"So maybe it's ectopic ACTH production.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.044243,0.079172,0.088912,0.094877,0.096445,0.094525,0.09433,0.090818,0.086842,0.085278,0.074243,0.070315],"unified_progress":[0.053354,0.06848,0.083078,0.093739,0.096885,0.098003,0.097528,0.094103,0.090022,0.085176,0.075065,0.064566]},{"section":11,"text":"Ectopic ACTH is often from a tumor, like a lung cancer, since he's a smoker.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.038616,0.074168,0.084268,0.092426,0.09747,0.10226,0.098684,0.094675,0.090051,0.087551,0.074539,0.065286],"unified_progress":[0.063271,0.088003,0.090707,0.092358,0.093848,0.097088,0.092511,0.093088,0.086325,0.079218,0.067838,0.055744]},{"section":12,"text":"Lung cancer can produce ACTH as a paraneoplastic syndrome.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.029757,0.063658,0.078273,0.091512,0.10046,0.10448,0.10539,0.098464,0.091296,0.091462,0.076351,0.068889],"unified_progress":[0.041171,0.064728,0.086144,0.090873,0.095897,0.10687,0.10078,0.098018,0.093138,0.087433,0.074432,0.060517]},{"section":13,"text":"The hemoptysis could be a direct sign of lung cancer.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.026575,0.060057,0.073077,0.083974,0.092995,0.099679,0.10394,0.10129,0.099744,0.093847,0.087455,0.077369],"unified_progress":[0.033636,0.053507,0.067307,0.077191,0.087838,0.10002,0.09844,0.1005,0.10403,0.10147,0.096907,0.079157]},{"section":14,"text":"So putting it all together: chronic smoking (risk factor for lung cancer), hemoptysis (a symptom of lung cancer), and ectopic ACTH production leading to Cushing's syndrome.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.03156,0.063431,0.075035,0.083887,0.089847,0.093722,0.096742,0.095818,0.09485,0.096564,0.08938,0.089164],"unified_progress":[0.041391,0.056578,0.066228,0.075159,0.08335,0.091611,0.094432,0.098379,0.10068,0.10209,0.099266,0.090839]},{"section":15,"text":"The elevated and non-suppressible ACTH supports ectopic ACTH syndrome.","dimension":2,"group":7,"is_degenerate":false,"model_progress":[0.035499,0.070887,0.082054,0.087808,0.09