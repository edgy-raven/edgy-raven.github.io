1,0.041515,0.03301]},{"section":4,"text":"These symptoms lasted 20 minutes but improved after diphenhydramine.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.12391,0.20317,0.16093,0.098607,0.071498,0.075191,0.056134,0.066315,0.043955,0.039285,0.032077,0.028924],"unified_progress":[0.10927,0.13785,0.11296,0.10469,0.084139,0.087439,0.072463,0.083176,0.063584,0.056225,0.048626,0.039578]},{"section":5,"text":"Hmm, the key here is the timing and the symptoms.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.075076,0.11521,0.13084,0.12634,0.10441,0.081415,0.074926,0.067211,0.058634,0.070462,0.048298,0.047185],"unified_progress":[0.082773,0.080038,0.084679,0.099373,0.097717,0.091156,0.092153,0.086534,0.077603,0.091006,0.065484,0.051484]},{"section":6,"text":"Haloperidol is known to cause extrapyramidal side effects.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.062459,0.09646,0.099895,0.10342,0.1021,0.095133,0.090333,0.083703,0.074032,0.07299,0.061637,0.057839],"unified_progress":[0.073588,0.069951,0.082654,0.088376,0.093584,0.097358,0.094511,0.093929,0.086917,0.085173,0.072388,0.061569]},{"section":7,"text":"The symptoms mentioned\u2014like oculogyric crisis, tongue protrusion, stiffness\u2014are classic signs of acute dystonia.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.059899,0.10064,0.095349,0.093039,0.093083,0.093711,0.090245,0.08881,0.078815,0.077538,0.066626,0.062243],"unified_progress":[0.062417,0.078424,0.085783,0.088198,0.09152,0.096648,0.093295,0.095335,0.089052,0.084858,0.073426,0.061042]},{"section":8,"text":"That usually happens in the early stages of antipsychotic treatment, like within the first few days, which matches the 2 days here.","dimension":13,"group":2,"is_degenerate":false,"model_progress":[0.058919,0.096137,0.093984,0.092493,0.092299,0.093831,0.089609,0.088636,0.079796,0.080813,0.068813,0.06467],"unified_progress":[0.071334,0.075796,0.082109,0.086193,0.089118,0.093722,0.091587,0.093913,0.087829,0.086971,0.076039,0.065388]},{"section":9,"text":"Dystonic reactions can present with muscle spasms, often in the neck, face, or limbs.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.045013,0.080756,0.085548,0.091191,0.095908,0.097582,0.097971,0.094766,0.087345,0.084495,0.073405,0.06602],"unified_progress":[0.053227,0.067332,0.082887,0.087351,0.092606,0.099869,0.097083,0.09768,0.093545,0.088941,0.076521,0.06296]},{"section":10,"text":"Tongue protrusion and eye movements (oculogyric crisis) are specific to this.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.041267,0.078299,0.084163,0.090061,0.09466,0.097606,0.09813,0.094709,0.089568,0.087262,0.075361,0.068912],"unified_progress":[0.045799,0.06709,0.082357,0.089543,0.095051,0.10174,0.099243,0.098292,0.095144,0.088437,0.075505,0.061798]},{"section":11,"text":"The fact that diphenhydramine helped is also a clue because anticholinergics like diphenhydramine are typically used to treat these acute dystonic reactions.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.043043,0.077332,0.084643,0.0901,0.0933,0.094062,0.095364,0.092669,0.087197,0.087913,0.078133,0.076243],"unified_progress":[0.0493,0.064101,0.077044,0.085194,0.091142,0.097196,0.096307,0.096287,0.093501,0.091253,0.084232,0.074443]},{"section":12,"text":"Other possibilities might be neuroleptic malignant syndrome, but that's more severe, with fever, rigidity, altered mental status, and autonomic instability.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.028489,0.061716,0.074437,0.084991,0.093335,0.098154,0.10356,0.10235,0.09787,0.097301,0.087166,0.070634],"unified_progress":[0.030981,0.056243,0.073305,0.082222,0.092383,0.099789,0.10165,0.10473,0.10308,0.10522,0.087463,0.062937]},{"section":13,"text":"Here, the patient didn't lose consciousness, and it resolved quickly, which doesn't fit NMS.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.027537,0.059865,0.069794,0.076958,0.083615,0.090872,0.10007,0.10538,0.10554,0.10421,0.099488,0.076676],"unified_progress":[0.031174,0.056474,0.067701,0.075255,0.08675,0.091039,0.097494,0.10621,0.10731,0.11774,0.097034,0.065818]},{"section":14,"text":"Tardive dyskinesia is a longer-term issue, so not after just 2 days.","dimension":1,"group":4,"is_degenerate":false,"model_progress":[0.029741,0.061105,0.070939,0.079905,0.087607,0.0941,0.10031,0.10282,0.10061,0.10162,0.093249,0.077988],"unified_progress":[0.035043,0.056245,0.069922,0.079039,0.088081,0.09602,0.099591,0.10467,0.10411,0.1073,0.092396,0.067584]},{"section":15,"text":"So acute dystonia is the most likely.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.022945,0.050424,0.064754,0.072363,0.076667,0.079381,0.085491,0.088711,0.094579,0.10151,0.10766,0.15551],"unified_progress":[0.02087,0.038343,0.048451,0.059749,0.064946,0.074442,0.080317,0.0887,0.096791,0.10812,0.13843,0.18083]}]}}