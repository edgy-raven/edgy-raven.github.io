498,0.077372,0.080236,0.08979,0.082238,0.057311,0.060443,0.12124],"unified_progress":[0.20109,0.078649,0.061883,0.063482,0.073195,0.073799,0.091224,0.083575,0.08124,0.067038,0.062544,0.062285]},{"section":12,"text":"Well, the sudden onset and quick relief with diphenhydramine make me suspect an acute dystonic reaction.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.036156,0.052502,0.067349,0.078037,0.083229,0.088099,0.091787,0.091729,0.09398,0.10162,0.11004,0.10547],"unified_progress":[0.044774,0.069436,0.057373,0.083348,0.09056,0.092843,0.096864,0.095201,0.094194,0.093551,0.091416,0.09044]},{"section":13,"text":"This is a type of extrapyramidal symptom that can happen with antipsychotic medications.","dimension":7,"group":3,"is_degenerate":false,"model_progress":[0.029349,0.037966,0.051978,0.067033,0.081769,0.096055,0.10897,0.11374,0.12136,0.13118,0.10202,0.058591],"unified_progress":[0.035184,0.053065,0.074548,0.085051,0.093244,0.10451,0.10346,0.1033,0.09962,0.095308,0.082589,0.070119]},{"section":14,"text":"It's known for causing muscle spasms and rigidity, exactly like what's described here.","dimension":8,"group":9,"is_degenerate":false,"model_progress":[0.02924,0.036981,0.044451,0.053232,0.064036,0.075179,0.088424,0.097492,0.11126,0.13231,0.14707,0.12032],"unified_progress":[0.036934,0.050712,0.063404,0.07375,0.082825,0.096863,0.096099,0.10019,0.10269,0.10233,0.10217,0.092039]},{"section":15,"text":"Yeah, putting it all together, it looks like the patient is having an acute dystonic reaction due to the haloperidol.","dimension":3,"group":0,"is_degenerate":false,"model_progress":[0.019102,0.028796,0.035393,0.042568,0.048756,0.055394,0.062497,0.067513,0.078753,0.10401,0.1888,0.26842],"unified_progress":[0.017625,0.029539,0.037895,0.046947,0.052925,0.069992,0.073493,0.092068,0.10441,0.11245,0.15369,0.20897]},{"section":16,"text":"The timing and response to treatment fit perfectly with this condition.","dimension":3,"group":0,"is_degenerate":fa