20788,0.19226,0.091865,0.11356,0.080062,0.081555,0.056746,0.048873,0.041612,0.034983,0.029188,0.021415]},{"section":3,"text":"He was treated for TB 10 years ago.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.11911,0.19536,0.14735,0.090794,0.078488,0.093055,0.061407,0.065416,0.046723,0.041275,0.033819,0.0272],"unified_progress":[0.13034,0.16308,0.12673,0.10304,0.082985,0.08681,0.064989,0.075458,0.052401,0.045236,0.0382,0.030735]},{"section":4,"text":"Now he has ptosis and miosis on the left side.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.11301,0.18431,0.14496,0.096866,0.076198,0.080154,0.062899,0.075268,0.054368,0.043705,0.036615,0.031656],"unified_progress":[0.10987,0.14272,0.11682,0.10999,0.088913,0.089676,0.072383,0.078571,0.063391,0.051093,0.042836,0.03374]},{"section":5,"text":"Chest X-ray shows a round opacity in the left upper lobe.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.064471,0.12588,0.12548,0.11308,0.097408,0.091773,0.082531,0.074625,0.080645,0.055683,0.047757,0.040667],"unified_progress":[0.059775,0.10015,0.10827,0.11452,0.11233,0.099539,0.09128,0.081937,0.089185,0.057964,0.046706,0.038338]},{"section":6,"text":"First, the weight loss and respiratory symptoms make me think of possible lung issues.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.060494,0.10981,0.12788,0.12278,0.1052,0.084722,0.078011,0.069592,0.062091,0.075014,0.052041,0.052367],"unified_progress":[0.061134,0.083056,0.093006,0.1041,0.10067,0.09154,0.093716,0.087949,0.081215,0.086535,0.065149,0.051933]},{"section":7,"text":"The history of TB is important.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.045077,0.093638,0.11559,0.11712,0.10634,0.094104,0.085543,0.078431,0.072256,0.074984,0.061519,0.055403],"unified_progress":[0.069533,0.092251,0.093398,0.098027,0.094458,0.090336,0.08952,0.087961,0.080468,0.08203,0.067613,0.054405]},{"section":8,"text":"But the new symptoms like ptosis and miosis are concerning.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.046528,0.095169,0.11137,0.11181,0.10177,0.090336,0.085069,0.079868,0.07467,0.077176,0.065175,0.061054],"unified_progress":[0.046343,0.080178,0.088675,0.0996,0.097634,0.094228,0.094613,0.090936,0.086801,0.089935,0.073046,0.05801]},{"section":9,"text":"Ptosis is drooping of the eyelid, and miosis is a constricted pupil.","dimension":10,"group":5,"is_degenerate":false,"model_progress":[0.05337,0.096244,0.096758,0.097295,0.097211,0.096588,0.093101,0.088456,0.081496,0.075342,0.066148,0.057993],"unified_progress":[0.067732,0.082408,0.088849,0.094115,0.095522,0.098745,0.093722,0.092289,0.086037,0.078821,0.066809,0.054952]},{"section":10,"text":"Those are signs of Horner's syndrome.","dimension":3,"group":8,"is_degenerate":false,"model_progress":[0.038009,0.078844,0.092967,0.099683,0.10106,0.098005,0.097659,0.09149,0.085268,0.083727,0.070996,0.06229],"unified_progress":[0.061088,0.071558,0.085187,0.092663,0.095917,0.099253,0.096337,0.093976,0.088702,0.085899,0.071652,0.057769]},{"section":11,"text":"Horner's is due to a disruption in the sympathetic pathway.","dimension":6,"group":2,"is_degenerate":false,"model_progress":[0.029709,0.066968,0.083455,0.095011,0.1015,0.10199,0.10409,0.098119,0.092801,0.087151,0.07646,0.062744],"unified_progress":[0.095854,0.069134,0.080397,0.087976,0.092806,0.09514,0.093596,0.092995,0.08619,0.081535,0.068262,0.056114]},{"section":12,"text":"The sympathetic nerves to the eye come from the cervical spine region, so a lesion in the lung (like a Pancoast tumor) could compress those nerves, leading to Horner's syndrome.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.033983,0.076248,0.089677,0.097973,0.098934,0.10075,0.098989,0.092346,0.093042,0.083304,0.071009,0.063743],"unified_progress":[0.040656,0.073382,0.095769,0.10399,0.10678,0.10388,0.099404,0.092498,0.089523,0.076693,0.063278,0.054145]},{"section":13,"text":"The chest X-ray shows a round opacity in the left upper lobe.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.03593,0.080995,0.09343,0.10063,0.098351,0.099364,0.096043,0.08855,0.097476,0.078654,0.068576,0.062001],"unified_progress":[0.038887,0.074134,0.095219,0.10962,0.1137,0.10513,0.10215,0.092365,0.092078,0.071056,0.05702,0.048638]},{"section":14,"text":"That's a classic presentation for a Pancoast tumor, which is a type of lung cancer that occurs in the apex of the lung.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.038033,0.07677,0.088198,0.097502,0.09998,0.10051,0.09863,0.091474,0.090631,0.082561,0.069811,0.065897],"unified_progress":[0.046744,0.06922,0.086735,0.099207,0.10321,0.11115,0.10137,0.094161,0.090255,0.077887,0.064615,0.055444]},{"section":15,"text":"These tumors can invade the sympathetic chain, causing the Horner's symptoms.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.030624,0.068347,0.082574,0.093043,0.098394,0.10087,0.10179,0.09572,0.094263,0.08721,0.076774,0.070389],"unified_progress":[0.045958,0.062681,0.080209,0.091651,0.097755,0.10421,0.10005,0.096595,0.094616,0.085712,0.075542,0.065022]},{"section":16,"text":"The patient's history of TB might have left a scarred area, but the current symptoms suggest something new.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.032508,0.070083,0.081883,0.089602,0.095217,0.10289,0.099414,0.097413,0.0955,0.091026,0.079271,0.065191],"unified_progress":[0.076013,0.10312,0.093953,0.090388,0.091029,0.090016,0.087267,0.089092,0.083115,0.076384,0.066082,0.053538]},{"section":17,"text":"The weight loss and hemoptysis are also common in lung cancer.","dimension":9,"group":9,"is_degenerate":false,"model_progress":[0.027551,0.061622,0.07475,0.08443,0.092454,0.098104,0.10204,0.10002,0.097118,0.095337,0.089285,0.077289],"unified_progress":[0.040346,0.06176,0.073949,0.079695,0.090141,0.094264,0.097017,0.098132,0.098999,0.09901,0.091888,0.074798]},{"section":18,"text":"Wait, but could it be a recurrence of TB?","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.029431,0.063384,0.079135,0.088008,0.094247,0.095569,0.098235,0.09978,0.097632,0.098273,0.086825,0.06948],"unified_progress":[0.042428,0.072074,0.085046,0.097563,0.096808,0.095995,0.098424,0.096631,0.092793,0.090789,0.076005,0.055443]},{"section":19,"text":"TB can sometimes form cavities or have fibrotic changes, but the combination of Horner's syndrome and the location (apical) makes me lean more towards malignancy.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.028331,0.065289,0.080414,0.089705,0.094138,0.097448,0.099586,0.097338,0.098574,0.092878,0.083976,0.072321],"unified_progress":[0.037143,0.067786,0.083148,0.094487,0.099317,0.10027,0.099475,0.098034,0.096241,0.08936,0.075595,0.05914]},{"section":20,"text":"Pancoast tumors are known for their association with Horner's.","dimension":8,"group":3,"is_degenerate":false,"model_progress":[0.025005,0.057911,0.073946,0.087089,0.096275,0.10035,0.10341,0.099509,0.095454,0.095035,0.08495,0.081071],"unified_progress":[0.041161,0.057779,0.074535,0.085612,0.091725,0.10503,0.099917,0.099107,0.095889,0.09242,0.083243,0.073581]},{"section":21,"text":"Also, the time since his TB treatment was 10 years, so recurrence might be less likely unless there's drug resistance, but the symptoms here point more to a mass effect.","dimension":11,"group":5,"is_degenerate":false,"model_progress":[0.031945,0.066147,0.076632,0.084296,0.091866,0.10172,0.09956,0.1003,0.097173,0.095286,0.085317,0.069763],"unified_progress":[0.076317,0.10657,0.09228,0.085495,0.086036,0.087294,0.084358,0.089872,0.083353,0.080467,0.07086,0.0571]},{"section":22,"text":"Another possibility is a neuroblastoma or other tumor, but those are rarer.","dimension":0,"group":6,"is_degenerate":false,"model_progress":[0.022274,0.054906,0.07232,0.083811,0.093569,0.098261,0.10334,0.1038,0.10396,0.10157,0.091715,0.070475],"unified_progress":[0.036736,0.07239,0.089004,0.10062,0.099448,0.097767,0.099433,0.096322,0.093003,0.089344,0.073363,0.052565]},{"section":23,"text":"The apical lung mass with Horner's is a textbook case for Pancoast.","dimension":5,"group":1,"is_degenerate":false,"model_progress":[0.025586,0.060686,0.076008,0.085887,0.090929,0.095162,0.097525,0.095792,0.10048,0.094706,0.08917,0.088073],"unified_progress":[0.03305,0.062391,0.078948,0.091535,0.096498,0.099923,0.098171,0.095713,0.096422,0.088541,0.082687,0.076121]},{"section":24,"text":"So the most likely diagnosis is Pancoast tumor, which is a type of non-small cell lung cancer, usually squamous cell or adenocarcinoma.","dimension":7,"group":0,"is_degenerate":false,"model_progress":[0.026093,0.053642,0.064722,0.074915,0.08327,0.089125,0.093698,0.093909,0.09592,0.097341,0.098276,0.12909],"unified_progress":[0.030962,0.046772,0.059518,0.070197,0.075918,0.088508,0.088045,0.093909,0.097676,0.099044,0.11444,0.13501]}]}}